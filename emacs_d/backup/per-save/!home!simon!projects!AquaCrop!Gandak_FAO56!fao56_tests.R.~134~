## Production
## ##########
library(rasterVis)
library(viridis)
library(grid)

## irrigated rice, 2001
x = get_nc_var("Output/netcdf/Production_yearMax_output.nc")
x = x[,,1,1]
r1 = raster(template)
r1[] = t(x)
r1[r1 == 0] = NA

p = levelplot(r1,
              margin=FALSE,
              xlab=NULL,
              ylab=NULL,
              par.settings=list(axis.line=list(lwd=1),
                                axis.components=list(left=list(tck=0.5), right=list(tck=0.5), top=list(tck=0.5), bottom=list(tck=0.5)),
                                background=list(col="transparent"),
                                layout.widths=list(right.padding=2)),
              par.strip.text=list(cex=0.9),
              main=list("Irrigated kharif rice, 2001"),
              col.regions=viridis(91, direction=-1),
              colorkey=list(space="bottom",
                            width=1,
                            at=seq(0,30000,length.out=91),
                            labels=list(at=seq(0,30000,10000),
                                        labels=seq(0,30000,10000), cex=0.9), tck=0),
              panel=function(...) {
                  grid.rect(gp=gpar(col=NA, fill="white"))
                  panel.levelplot(...)
              })

p <- p + layer(sp.polygons(adm2, lwd=0.25)) + layer(sp.polygons(adm0, lwd=3))

pname <- file.path(file.path("doc/rice_irri_kharif_production_2001.png"))
trellis.device(device="png", width=3.5, height=3.75, units="in", res=320, file=pname, bg="transparent")
print(p)
pushViewport(viewport(0.52,0.035,0.5,0.07))  ## TODO
grid.text("Production (tonne)", gp=gpar(cex=0.9, font=1, col="black"))
dev.off()

