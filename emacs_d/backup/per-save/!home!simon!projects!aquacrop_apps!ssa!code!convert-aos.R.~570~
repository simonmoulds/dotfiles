library(RSQLite)
library(tidyverse)
library(magrittr)
library(raster)    
library(ncdf4)

source("convert-aos-funs.R")

file_path = "/home/simon/projects/aquacrop_apps/ssa/data/aquacrop_os"
if (dir.exists(file_path)) {
    unlink(file_path, recursive=TRUE)
}
file_path_in = file.path(file_path, "Input")
file_path_out = file.path(file_path, "Output")

dir.create(file_path)
dir.create(file_path_in)
dir.create(file_path_out)

## config file
config_fn = "maize_rainfed_pt_agmerra.ini"

## point for which data will be created
pts = SpatialPoints(
    coords=data.frame(x=-1.875, y=7.875),
    proj4string=CRS("+proj=longlat +ellps=WGS84 +datum=WGS84 +no_defs")
)

## ############# ##
## FileSetup.txt ##
## ############# ##

write_file_setup_input_file(prefix="output", file_path=file_path_in)

## ######### ##
## Clock.txt ##
## ######### ##

