end_time = get_config_option(config_fn, "endTime")

write_clock_input_file(
    start_time,
    end_time,
    file_path=file_path_in
)

## ########### ##
## CropMix.txt ##
## ########### ##

crop_id = get_config_option(config_fn, "cropID")
con = dbConnect(
    drv=SQLite(),
    dbname="~/dev/aquacrop/aquacrop/data/crop_parameter_database.sqlite3"
)
crop_type = dbGetQuery(
    con,
    paste0("SELECT name FROM crops WHERE id=", crop_id)
)
dbDisconnect(con)

crop_type = crop_type[1,1]
write_crop_mix_input_file(
    crop_type,
    file_path=file_path_in
)

## ######## ##
## Crop.txt ##
## ######## ##

con = dbConnect(
    drv=SQLite(),
    dbname="~/dev/aquacrop/aquacrop/data/crop_parameter_database.sqlite3"
)
query = paste0(
    "SELECT name,value FROM parameter_values WHERE crop_id=",
    crop_id
)

crop_params = dbGetQuery(con, query) %>%
    filter(!is.na(name)) %>%
    column_to_rownames(var="name") %>%
    t %>%
    as.data.frame %>%
    as.list
dbDisconnect(con)

## add crop parameters which AquaCrop-Python has in config file
crop_params["CalendarType"] = get_config_option(config_fn, "CalendarType")
crop_params["SwitchGDD"] = get_config_option(config_fn, "SwitchGDD")
crop_params["GDDmethod"] = get_config_option(config_fn, "GDDmethod")
    
## planting/harvest date from netCDF
in_path = get_config_option(config_fn, "PathIn")
crop_nc = get_config_option(config_fn, "cropParametersNC") %>%
    gsub("^\\$\\{FILE_PATHS:PathIn\\}", in_path, .)
pd_jd = get_crop_param_from_nc(crop_nc, "PlantingDate", pts)
hd_jd = get_crop_param_from_nc(crop_nc, "HarvestDate", pts)

## convert Julian Day to mm/dd
## arbitrary time series for non-leap year
ts = seq.POSIXt(
    as.POSIXct("2001-01-01", format="%Y-%m-%d"),
    length.out=365,
    by="1 day"
)

pd_ts = ts[pd_jd] %>% as.POSIXlt
hd_ts = ts[hd_jd] %>% as.POSIXlt

pd_str = paste0(
    formatC(pd_ts$mday, width=2, flag="0"), "/",
    formatC(pd_ts$mon + 1, width=2, flag="0")
)

hd_str = paste0(
    formatC(hd_ts$mday, width=2, flag="0"), "/",
    formatC(hd_ts$mon + 1, width=2, flag="0")
)

crop_params["PlantingDate"] = pd_str
crop_params["HarvestDate"] = hd_str

write_crop_param_input_file(crop_params, file_path=file_path_in)

## ###############
## FieldManagement
## ###############
            
nc = get_config_option(config_fn, "fieldManagementNC")
if (nc == "None") {
    field_mgmt_params = list(
        Mulches = 0,
        MulchPctGS = 0,
        MulchPctOS = 0,
        fMulch = 0.5,
        Bunds = 0,
        zBund = 0,
        BundWater = 0
    )
}

write_field_mgmt_params_file(field_mgmt_params, file_path=file_path_in)

## #################### ##
## IrrigationManagement ##
## #################### ##

nc = get_config_option(config_fn, "irrigationManagementNC")
if (nc == "None") {
    irri_mgmt_params = list(
        IrrMethod = 0,
        IrrInterval = 1,
        SMT1 = 100,
        SMT2 = 100,
        SMT3 = 100,
        SMT4 = 100,
        MaxIrr = 15,
        AppEff = 100,
        NetIrrSMT = 50,
        WetSurf = 100
    )
}

write_irri_params_file(irri_mgmt_params, file_path=file_path_in)

## ############################ ##
## Carbon Dioxide concentration ##
## ############################ ##

library(ncdf.tools)

co2_nc = get_config_option(config_fn, "carbonDioxideNC") %>%
    gsub("^\\$\\{FILE_PATHS:PathIn\\}", in_path, .)

co2_time = get_time_dim_from_nc(co2_nc) %>% as.POSIXlt %>% `$`(year) %>% `+`(1900)
co2_vals = get_time_varying_var_from_nc(co2_nc, "co2", pts)
co2_data = data.frame(time=co2_time, conc=co2_vals)

write_co2_file(
    co2_data,
    file_path=file_path_in,
    file_name="MaunaLoaCO2.txt"
)

## ############# ##
## SoilHydrology ##
## ############# ##

dz_layer = get_config_option(config_fn, "dzSoilLayer") %>% strsplit(",") %>% `[[`(1) %>% as.numeric
soil_nc = get_config_option(config_fn, "soilHydraulicParametersNC") %>%
    gsub("^\\$\\{FILE_PATHS:PathIn\\}", in_path, .)
    
th_sat = get_soil_param_from_nc(soil_nc, "th_sat", pts)
th_fc = get_soil_param_from_nc(soil_nc, "th_crit", pts)
th_wp = get_soil_param_from_nc(soil_nc, "th_wilt", pts)
k_sat = get_soil_param_from_nc(soil_nc, "k_sat", pts)

write_soil_hydrualic_input(
    dz_layer,
    th_sat,
    th_fc,
    th_wp,
    k_sat,
    file_path=file_path_in,
    file_name="SoilHydrology.txt"
)

## ########### ##
## SoilProfile ##
## ########### ##

dz_layer = get_config_option(config_fn, "dzSoilLayer") %>% strsplit(",") %>% `[[`(1) %>% as.numeric
dz_comp = get_config_option(config_fn, "dzSoilCompartment") %>% strsplit(",") %>% `[[`(1) %>% as.numeric

z_bot = cumsum(dz_comp)
z_top = z_bot - dz_comp
z_mid = (z_bot + z_top) / 2
z_lyr_bot = cumsum(dz_layer)
z_lyr_top = z_lyr_bot - dz_layer
z_lyr_mid = (z_lyr_bot + z_lyr_top) / 2
z_mid > z_lyr_top

layer_index = (matrix(data=rep(z_mid, 4), nrow=4, byrow=T) > z_lyr_top) %>% colSums

write_soil_profile_input(
    dz_comp,
    layer_index,
    file_path=file_path_in,
    file_name="SoilProfile.txt"
)

## ################### ##
## InitialWaterContent ##
## ################### ##

init_cond_type = get_config_option(config_fn, "initialConditionType")
if (init_cond_type == "percent") {
    init_cond_pct = get_config_option(config_fn, "initialConditionPercent")
    init_cond_vals = th_wp + (as.numeric(init_cond_pct) / 100) * (th_fc - th_wp)
    init_cond_depths = z_lyr_mid
}

write_init_water_content_input(
    type="Num",
    interp_method="Layer",
    num_points=length(init_cond_depths),
    depths=init_cond_depths,
    vals=init_cond_vals,
    file_path=file_path_in
)

## #### ##
## Soil ##
## #### ##

con = dbConnect(
    drv=SQLite(),
    dbname="~/dev/aquacrop/aquacrop/data/soil_parameter_database.sqlite3"
)

query = "SELECT name,value FROM parameter_values"
soil_params = dbGetQuery(con, query) %>%
    filter(!is.na(name)) %>%
    column_to_rownames(var="name") %>%
    t %>%
    as.data.frame %>%
    as.list
dbDisconnect(con)

soil_params[["AdjREW"]] = get_config_option(config_fn, "adjustReadilyAvailableWater") %>% as.numeric
soil_params[["AdjCN"]] = get_config_option(config_fn, "adjustCurveNumber") %>% as.numeric
soil_params[["CalcSHP"]] = 0
soil_params[["zSoil"]] = sum(dz_layer)
soil_params[["nLayer"]] = length(dz_layer)
soil_params[["nComp"]] = length(dz_comp)
th_dry = th_wp / 2
soil_params[["REW"]] = round(1000 * (th_fc[1] - th_dry[1]) * soil_params[["EvapZsurf"]])

write_soil_parameter_input(soil_params, file_path=file_path_in)

## ########## ##
## WaterTable ##
## ########## ##

water_table = get_config_option(config_fn, "WaterTable") %>% as.integer %>% as.logical

write_water_table_input(
    water_table,
    method="Constant",
    depth="",
    file_path=file_path_in,
    file_name="WaterTable.txt"
)

## ####### ##
## Weather ##
## ####### ##

years = seq.POSIXt(as.POSIXlt(start_time), as.POSIXlt(end_time), by="1 day") %>% as.POSIXlt %>% `$`(year) %>% unique %>% sort %>% `+`(1900)

## precipitation ##
prec_nc = get_config_option(config_fn, "precipitationNC") %>%
    gsub("^\\$\\{FILE_PATHS:PathIn\\}", in_path, .)

prec_fs = rep(prec_nc, length(years))
tm = c()
vals = c()
for (i in 1:length(years)) {
    year = years[i]
    prec_fs = gsub("\\{year:0>4\\}", year, prec_nc)
    tm = append(tm, get_time_dim_from_nc(prec_fs))
    vals = append(vals, get_time_varying_var_from_nc(prec_fs[1], "prate", pts))
}

## tm = as.Date(tm)
prec_data = data.frame(time=tm, prec=vals)

## min temp ##
tmin_nc = get_config_option(config_fn, "minDailyTemperatureNC") %>%
    gsub("^\\$\\{FILE_PATHS:PathIn\\}", in_path, .)

tmin_fs = rep(tmin_nc, length(years))
tm = c()
vals = c()
for (i in 1:length(years)) {
    year = years[i]
    tmin_fs = gsub("\\{year:0>4\\}", year, tmin_nc)
    tm = append(tm, get_time_dim_from_nc(tmin_fs))
    vals = append(vals, get_time_varying_var_from_nc(tmin_fs, "tmin", pts))
}

tm = as.Date(tm)
tmin_data = data.frame(time=tm, tmin=vals)

## max temp
tmax_nc = get_config_option(config_fn, "maxDailyTemperatureNC") %>%
    gsub("^\\$\\{FILE_PATHS:PathIn\\}", in_path, .)

tmax_fs = rep(tmax_nc, length(years))
tm = c()
vals = c()
for (i in 1:length(years)) {
    year = years[i]
    tmax_fs = gsub("\\{year:0>4\\}", year, tmax_nc)
    tm = append(tm, get_time_dim_from_nc(tmax_fs))
    vals = append(vals, get_time_varying_var_from_nc(tmax_fs, "tmax", pts))
}

tm = as.Date(tm)
tmax_data = data.frame(time=tm, tmax=vals)

## etref
etref_nc = get_config_option(config_fn, "refEvapotranspirationNC") %>%
    gsub("^\\$\\{FILE_PATHS:PathIn\\}", in_path, .)

tm = get_time_dim_from_nc(etref_nc) %>% as.POSIXlt %>% as.Date
vals = get_time_varying_var_from_nc(ncfile=etref_nc, param="reference_crop_evapotranspiration", pts) %>% round(digits=2)

etref_data = data.frame(time=tm, etref=vals)

met_data = prec_data %>% left_join(tmin_data) %>% left_join(tmax_data) %>% left_join(etref_data)

write_weather_input(
    times=met_data[["time"]],
    prec_vals=round(met_data[["prec"]], digits=2),
    tmin_vals=round(met_data[["tmin"]], digits=2),
    tmax_vals=round(met_data[["tmax"]], digits=2),
    etref_vals=round(met_data[["etref"]], digits=2),
    file_path=file_path_in,
    file_name="Weather.txt"
)

