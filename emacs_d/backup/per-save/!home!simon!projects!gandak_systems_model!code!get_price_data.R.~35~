## diesel = wb(country="IND",indicator="EP.PMP.DESL.CD")
diesel_price =
    read.table("data/sult_base_diesel_prices_long.txt", header=TRUE, sep="\t") %>%
    mutate_at(vars(year), funs(as.character)) %>%
    dplyr::filter(grepl("^[0-9]{4}-01-01", year))

diesel_price[["year"]] %<>% 
    as.Date %>%
    as.POSIXlt(format="%Y-%m-%d") %>%
    format("%Y") %>%
    as.numeric

diesel_price %<>% setNames(c("YEAR","DIESEL_PRICE"))
diesel_price$ID = "Gandak"

## join data, fill in missing values using LOCF
gandak_price_data =
    left_join(combined_crop_price, combined_fert_price, by=c("ID","YEAR")) %>%
    left_join(diesel_price, by=c("ID","YEAR")) %>%
    ungroup %>%
    mutate_at(vars(-ID, -YEAR), funs(zoo::na.locf(., na.rm=FALSE, rule=1))) %>%
    mutate_at(vars(-ID, -YEAR), funs(zoo::na.locf(., fromLast=TRUE, na.rm=FALSE, rule=1)))



