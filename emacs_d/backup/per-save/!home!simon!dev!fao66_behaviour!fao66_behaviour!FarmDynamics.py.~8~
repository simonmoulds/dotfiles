# AquaCrop crop growth model

import os
import time
import calendar
import numpy as np
from hydro_model_builder import VirtualOS as vos
from aquacrop.Messages import *
import logging
logger = logging.getLogger(__name__)

class FarmDynamics(object):

    def __init__(self, FarmDynamics_variable):
        self.var = FarmDynamics_variable
        self.var.StartOfYear = 305  # TODO: check this is right

    def initial(self):
        arr_zeros = np.zeros((self.var.nFarm, self.var.nCell))
        self.var.GwPumpingVol = arr_zeros.copy()
        self.var.SwPumpingVol = arr_zeros.copy()
        self.var.CurrentAccount = arr_zeros.copy()
        self.var.SavingsAccount = arr_zeros.copy()
        self.var.CropIncome = np.zeros((self.var.nFarm, self.var.nCrop, self.var.nCell))
        self.var.LabourIncome = arr_zeros.copy()
        self.var.FarmIncome = arr_zeros.copy()
        self.var.AnnualIncome = arr_zeros.copy()

    def update_first_day_of_year(self):
        isLeapYear = calendar.isleap(self.var._modelTime.year)
        day_of_year = self.var._modelTime.doy
        start_of_year = self.var.StartOfYear
        if (isLeapYear & (start_of_year >= 60)):
            start_of_year += 1
            
        self.var.IsFirstDayOfYear = False
        self.var.IsLastDayOfYear = False
        if day_of_year == start_of_year:
            self.var.IsFirstDayOfYear = True
        elif ((day_of_year + 1) == start_of_year):
            self.var.IsLastDayOfYear = True
            
    def farm_income(self):
        self.crop_income()
        self.labour_income()
        self.var.FarmIncome = (
            np.sum(self.var.CropIncome, axis=1)
            + self.var.LabourIncome)
        
    def crop_income(self):
        self.var.CropIncome = (
            self.var.Y
            * self.var.CropArea
            * self.var.CropPrice)
        
    def labour_income(self):
        pass
    
    def update_annual_income(self):
        self.var.AnnualIncome += self.var.FarmIncome

    def update_farm_accounts(self):
        positive_balance = self.var.CurrentAccount > 0
        if self.var.IsLastDayOfYear:
            self.var.SavingsAccount[positive_balance] += self.var.CurrentAccount[positive_balance]
            self.var.CurrentAccount[positive_balance] = 0.
            self.var.CurrentAccount += self.var.AnnualIncome
        
    def farm_expenditure(self):
        self.fertiliser_expenditure()
        self.irrigation_expenditure()

    def fertiliser_expenditure(self):
        nitrogen_cost = (self.var.NitrogenAppRate * self.var.NitrogenPrice * self.var.CropArea)   
        phosphorus_cost = (self.var.PhosphorusAppRate * self.var.PhosphorusPrice * self.var.CropArea)
        potassium_cost = (self.var.PotassiumAppRate * self.var.PotassiumPrice * self.var.CropArea)
        self.var.FertiliserCost = (nitrogen_cost + phosphorus_cost + potassium_cost)

    def irrigation_expenditure(self):
        self.diesel_pump_cost()
        self.electric_pump_cost()
        self.IrrigationCost = self.var.DieselPumpCost + self.var.ElectricPumpCost
        
    def diesel_pump_cost(self):
        fuel_efficiency = 1.
        unit_fuel_consumption = (0.1133 * self.var.zGW) + 0.7949
        unit_fuel_consumption = unit_fuel_consumption * fuel_efficiency / 102.87
        self.var.DieselPumpCost = (
            unit_fuel_consumption
            * self.var.GwPumpingVol
            * self.var.DieselPrice
            * 0.4)              # TODO: ask JoK the reason for multiplying by 0.4 (subsidy, efficiency?)
        
    def electric_pump_cost(self):
        self.var.ElectricPumpCost = 0.

    def surface_water_irrigation_cost(self):
        pass
    
    def farm_investment(self):
        if self.var.IsLastDayOfYear:
            self.install_additional_tubewell()

    def install_additional_tubewell(self):
        pass

    def irrigation_supply(self):

        # Irrigation demand, depth -> volume (farm, crop, cell)
        irrigation_demand = np.multiply(
            (self.var.Irr / 1000),
            self.var.CurrentCropArea,
            out=np.zeros_like(self.var.CurrentCropArea),
            where=self.var.CurrentCropArea > 0)
        
        # Sum along crop axis to get total irrigation demand (farm, cell)
        total_irrigation_demand = np.sum(irrigation_demand, axis=1)
        
        # Compute the relative irrigation demand of each crop grown
        # on a given farm (farm, crop, cell)
        relative_irrigation_demand = np.divide(
            irrigation_demand,
            total_irrigation_demand[:,None,:],
            out=np.zeros_like(irrigation_demand),
            where=total_irrigation_demand[:,None,:] > 0)

        # *** The following variables (up to total_irrigation_supply) have
        # dimensions (farm, cell) ***
        
        # TODO: in canal module, convert input data to array with
        # dims (farm, cell) using canal reliability input (this parameter
        # should reflect the likelihood of a farmer receiving canal water
        # if the main branch is running)        
        canal_supply = np.broadcast_to(
            self.var.CanalSupply,
            (self.var.nFarm, self.var.nCell)).copy()
        canal_demand = np.clip(canal_supply, 0, total_irrigation_demand)

        groundwater_demand = np.clip(total_irrigation_demand - canal_demand, 0, None)
        # TODO: multiply demand by maximum tubewell capacity
        groundwater_supply = groundwater_demand.copy()

        self.var.SwPumpingVol = np.copy(canal_demand)        # (farm, cell)
        self.var.GwPumpingVol = np.copy(groundwater_supply)  # (farm, cell)
        # TODO: adjust according to available account balance        
        total_irrigation_supply = (
            self.var.SwPumpingVol
            + self.var.GwPumpingVol)

        # Get irrigation supply as a volume, then divide by crop area
        # to get depth
        irrigation_supply_vol = np.multiply(
            total_irrigation_supply[:,None,:],
            relative_irrigation_demand)
            
        irrigation_supply = np.divide(
            irrigation_supply_vol,
            self.var.CurrentCropArea,
            out=np.zeros_like(self.var.CurrentCropArea),
            where=self.var.CurrentCropArea > 0)
        irrigation_supply *= 1000

        # Lastly, limit calculated irrigation demand to the maximum
        # available supply
        self.var.Irr = np.clip(self.var.Irr, None, irrigation_supply)
        
    def dynamic(self):
        self.update_first_day_of_year()
        self.farm_income()        
        self.irrigation_supply()
        self.farm_expenditure()
        self.farm_investment()
        self.update_farm_accounts()
