[url]
serverroot = http://wci.earth2observe.eu/thredds/dodsC/
wrrsetroot = ecmwf/met_forcing_v0/


[selection]
calculateEvap = True
#evapMethod = PenmanMonteith
evapMethod = PenmanMonteith
#evapMethod = Hargreaves
#evapMethod = PriestleyTaylor

latmin = 25
latmax = 28
lonmin = 83
lonmax = 86.5
startyear = 1979
endyear= 2014
startmonth = 1
endmonth = 12
startday = 1
endday = 31

[downscaling]
highResDEM=/home/simon/projects/gandak_systems_model/data/hydrosheds_gandak_5m.map
radiationcordir=/home/simon/projects/gandak_systems_model/data/output_rad/
# The following only works for wrr2
# useVarLapseRate = True

resampling  = True
downscaling = True
resamplingtype=linear

[output]
# Gdal output format string
# See: http://www.gdal.org/formats_list.html
# examples: AAIGrid, PCRaster, GTiff
#format=PCRaster
format=GTiff
directory=/home/simon/projects/gandak_systems_model/data/output_evap/
prefix=PM
# Also downscale and save the intermediate variables (T, Pressure etc)
saveall=1

