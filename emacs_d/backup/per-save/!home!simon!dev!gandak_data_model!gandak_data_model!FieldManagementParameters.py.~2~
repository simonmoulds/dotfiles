class FieldManagementParameters(object):
    def __init__(self, FieldManagementParameters_variable):
        self.var = FieldManagementParameters_variable
        self.var.FieldManagementParameterOutputFile = vos.getFullPath(
            self.var._configuration.fieldManagementParameterOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        
    def initial(self):
        pass

    def dynamic(self):
        mulches = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 0.)
        mulchpctgs = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 50.)
        mulchpctos = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 50.)
        fmulch = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 0.5.)
        bunds = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 0.)
        zbund = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 0.)
        bundwater = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 0.)

        field_mgmt_parameters = {
            'Mulches' : mulches,
            'MulchPctGS' : mulchpctgs,
            'MulchPctOS' : mulchpctos,
            'fMulch' : fmulch,
            'Bunds' : bunds,
            'zBund' : zbund,
            'BundWater' : bundwater}
        
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)
        netcdf.create_netCDF(self.var.FieldManagementParameterOutputFile, field_mgmt_parameters.keys())
        for key, value in field_mgmt_parameters.iteritems():
            netcdf.data2NetCDF(self.var.FieldManagementParameterOutputFile, key, value)
        
