import os
import numpy as np

from hm import file_handling

class FieldManagementParameters(object):

    def __init__(self, land_cover, configuration):
        """Initialise FieldManagementParameters object"""
        self.land_cover = land_cover
        self.configuration = configuration

    def initial(self):
        arr_zeros = np.zeros(
            (self.land_cover.nFarm,
             self.land_cover.nCrop,
             self.land_cover.model.nCell)
        )
        
        self.land_cover.Bunds = arr_zeros.astype(bool)
        self.land_cover.zBund = arr_zeros
        
    def read(self):
        pass
        
    def dynamic(self):
        pass

class FieldManagementParametersManagedLand(FieldManagementParameters):    
    def initial(self):
        bunds = np.bool(np.int(self.configuration['bunds']))
        zbund = np.float(self.configuration['zBund'])
        arr_ones = np.ones(
            (self.land_cover.nFarm,
             self.land_cover.nCrop,
             self.land_cover.model.nCell)
        )
        self.land_cover.Bunds = arr_ones * bunds
        self.land_cover.zBund = arr_ones * zbund
