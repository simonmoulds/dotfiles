class SpecificHumidity(object):
    def __init__(self, SpecificHumidity_variable):
        self.var = SpecificHumidity_variable
        
    def initial(self):
        self.set_surface_specific_humidity_input_filenames()

    def set_surface_specific_humidity_input_filenames(self):
        (self.var.surfaceSpecificHumidityFileNC,
         self.var.surfaceSpecificHumidityVarName,
         self.var.surfaceSpecificHumidityTimeDimName) = (
            self.get_vals_from_meteo_options([
                'nearSurfaceSpecificHumidityNC',
                'nearSurfaceSpecificHumidityVarName',
                'nearSurfaceSpecificHumidityTimeDimName'
            ]))

    def read_surface_specific_humidity_data(self):
        day, month, year = (self.var._modelTime.currTime.day,
                            self.var._modelTime.currTime.month,
                            self.var._modelTime.currTime.year)
        self.var.specific_humidity = vos.netcdf2PCRobjClone(
            self.var.surfaceSpecificHumidityFileNC.format(day=day, month=month, year=year),
            self.var.surfaceSpecificHumidityVarName,
            str(self.var._modelTime.fulldate),
            useDoy = None,
            cloneMapAttributes = self.var.cloneMapAttributes,
            LatitudeLongitude = True)
        
    def dynamic(self):
        self.read_surface_specific_humidity_data()
