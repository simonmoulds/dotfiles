#!/bin/bash

# This script is run from
# 'run_grass_process_village_census.sh'

export GRASS_MESSAGE_FORMAT=plain

wd=/home/simon/dev/gandak_data_model/data-raw
datadir=/data/india_village_level_geospatial_socio_econ_data

# use region set in 'grass_make_grid.sh'
g.region region=india_30s

declare -a suffixes=("BR" "UP")
    # "AP" "AR" "AS" "BR" "CG" "GA" "GJ" "HR" "HP"
    # "JK" "JH" "KA" "KL" "MP" "MH" "MN" "ML" "MZ"
    # "NL" "OR" "PB" "RJ" "SK" "TN" "TR" "UP" "UK"
    # "WB" "UTerr")

declare -a columns=(
    "a_LAND_FORES"
    "a_CANAL_GOVT"
    "a_WELL_WO_EL"
    "a_WELL_W_EL"
    "a_TW_WO_EL"
    "a_TW_W_EL"
    "a_TANK_IRR"
    "a_RIVER_IRR"
    "a_W_FALL"
    "a_OTH_IRR"
    "a_TOT_IRR"
    "a_UN_IRR"
    "a_CULT_WASTE"
    "a_AREA_NA_CU"
)

for state in "${suffixes[@]}"
do
    v.proj \
        location=utm44n \
        mapset=PERMANENT \
        input="${state}"_grid_30s \
        output="${state}"_grid_30s_stats \
        --overwrite
    
    db.columns table="${state}"_grid_30s_stats | grep '^a_.*_sum' > tmp

    g.region \
        vector="${state}"_grid_30s \
        align=template
    g.region -p

    while read column
    do
        input="${state}"_grid_30s_stats
        output="${state}"_"${column}"_30s_rast
        echo $input
        echo $output
        v.to.rast \
            input="${input}" \
            output="${output}" \
            use=attr \
            attribute_column="${column}" \
            --verbose \
            --overwrite        
        # r.univar map="${output}"        
        outnm=$(echo "${state}" | tr "[:upper:]" "[:lower:]")_$(echo "${column}" | sed 's/a_\(.*\)/\1/g' | tr "[:upper:]" "[:lower:]").tif
        # echo $outnm
        r.out.gdal \
            input=data/"${output}" \
            output=$outnm \
            format=GTiff \
            --overwrite
    done < tmp
    
    # for column in "${columns[@]}"
    #     v.to.rast \
    #         input="${state}"_grid_30s_stats \
    #         output="${state}"_"${column}"_30s_rast \
    #         use=attr \
    #         attribute_column="${column}"_sum --overwrite    
    # outnm=$(echo "${state}" | tr "[:upper:]" "[:lower:]")_$(echo "${column}" | sed 's/a_\(.*\)/\1/g' | tr "[:upper:]" "[:lower:]").tif
    # echo $outnm
    # r.out.gdal \
    #     input="${state}"_"{column}"_30s_rast \
    #     output=$outnm \
    #     format=GTiff \
    #     type=Float64 --overwrite
done
