## Parameter file for Sultanpur district

## region characteristics
## ######################

farm_area = 10000
region_area = 20 * farm_area
surface_elev_masl = 103   ## Actual elevation above sea level

## hydrological parameters
## #######################

## aquifer specific yield
Sy = 0.3

## surface elevation (volume)
surface_elev = (surface_elev_masl * region_area) * Sy

## initial head
H_init = (surface_elev_masl - 7) * region_area * Sy 

root_zone_depletion_init = 0
field_capacity = 0.3
wilting_point = 0.12

## coefficients to control runoff and bare soil evaporation
runoff_coef = 0.95
evaporation_loss_coef = 0.8
return_flow_coef = 0.5

## canal volume and 
canal_volume = 1 * 5 * 4000
canal_leakage_coef = 0.4

## crop parameters
## ###############

## factor to change crop max yield by as values used are averages from Gov stats
wheat_yield_coeff = 1.8 
rice_yield_coeff = 1.7

## water stress coefficient max/min value
Ks_max = 1
Ks_min = 0

## yield response factor
Ky_wheat = 0.6
Ky_rice = 1.3

## crop factor (growth stages 1-4); values from Choudhury et al (2013)

## wheat
Kc1w = c(320,350,0.8) 
Kc2w = c(351,16,1.12)
Kc3w = c(17,47,1.25)
Kc4w = c(48,106,0.46)

## rice
Kc1r = c(148,185,0.61)
Kc2r = c(186,223,0.8)
Kc3r = c(224,261,1.23)
Kc4r = c(262,296,0.74)

## et depletion factor
et_depletion_factor_wheat = c(320,106,0.55)
et_depletion_factor_rice  = c(148,296,0.20)

## rooting depth
rooting_depth_wheat = c(320,106,1.25)
rooting_depth_rice  = c(148,296,0.65)

## irrigation parameters
## #####################

## harvest day
harvest_day = 305

## months in which crops are grown
wheat_months = c(11,12,1,2,3,4)
rice_months = c(5,6,7,8,9,10)

## irrigation efficiency
irrigation_eff = 0.4         

## Pump efficiency multiplier 100=1.0 90=1.11 80=1.25 70=1.43 50=2.0 30=3.33
fuel_eff = 2.00 

## crop min/max irrigation depth
wheat_min = 0.11
wheat_max = 0.15
rice_min = 0.15 
rice_max = 0.20

## well depths associated with categories 1-3
well_depth1 = (surface_elev_masl - 20) * region_area * Sy
well_depth2 = (surface_elev_masl - 40) * region_area * Sy
well_depth3 = (surface_elev_masl - 80) * region_area * Sy
well_depth = c(well_depth1, well_depth2, well_depth3)    
max_well_depth = min(well_depth)                         

## irrigation scheduling parameters
## ################################

## mu is mean irrigation day, sd is standard deviation
wheat_irr_schedule_mu = c(3,46,319)
wheat_irr_schedule_sd = c(3,3,3)   
wheat_can_irr_schedule_mu = c(3,46)
wheat_can_irr_schedule_sd = c(1,1) 
rice_irr_schedule_mu = c(148,168,208,218,268,288)
rice_irr_schedule_sd = c(3,3,3,3,3,3)            
rice_can_irr_schedule_mu = c(148,168,208,268,288)
rice_can_irr_schedule_sd = c(1,1,1,1,1)          

## farmer parameters
## #################

## initial savings upper and lower bounds
saving_lower = 50
saving_upper = 50

## Amount savings are reduced per year when farmers income is zero
savings_reduction = 0.8

## Percentage of income retained as savings
saving_percentage = 0.1 
