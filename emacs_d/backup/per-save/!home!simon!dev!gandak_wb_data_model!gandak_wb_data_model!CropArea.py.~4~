class CropArea(object):
    def __init__(self, CropArea_variable):
        self.var = CropArea_variable
        crop_types = self.var._configuration.irrNonPaddy['cropTypes']
        self.var.CropTypes = [x.strip() for x in crop_types.split(',')]
        self.var.nCrop = len(self.var.CropTypes)
        print(self.var.nCrop)
        self.var.CropAreaInputDir = str(self.var._configuration.irrNonPaddy['cropAreaPathIn'])
        self.var.CropAreaOutputFile = str(self.var._configuration.irrNonPaddy['cropAreaOutputFile'])
        self.bbox = get_clone_map_extent(self.var._configuration.cloneMap)
            
    def initial(self):
        pass

    def dynamic(self):
        crop_area = []
        for index,name in enumerate(self.var.CropTypes):
            arr = read_gdal_raster_image(
                os.path.join(self.var.CropAreaInputDir,'INDIA_' + name.upper() + '_2005.tif'),
                self.bbox,
                0.)
            crop_area.append(arr)

        self.var.crop_area = np.stack(crop_area, axis=0)
        self.var.crop_area *= 10000.
