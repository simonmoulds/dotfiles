import os
import numpy as np
from hydro_model_builder import VirtualOS as vos

import logging
logger = logging.getLogger(__name__)

class Tubewell(object):

    def __init__(self, Tubewell_variable):
        self.var = Tubewell_variable        
        
    def initial(self):
        initialTubewellCapacityNC = str(self.var._configuration.farmOptions['initialTubewellCapacityNC'])
        tubewell_capacity_varname = 'tubewell_capacity'
        try:
            tubewell_capacity = vos.netcdf2PCRobjCloneWithoutTime(
                initialTubewellCapacityNC,
                tubewell_capacity_varname,
                cloneMapFileName = self.var.cloneMap,
                LatitudeLongitude = True)
        except:
            tubewell_capacity = np.ones((self.var.nFarm, self.var.nLat, self.var.nLon))
        self.var.TubewellCapacity = tubewell_capacity.copy()
        
