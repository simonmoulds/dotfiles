import numpy as np
import pandas as pd
import netCDF4
import calendar
import datetime
import os

def get_times(year):
    dt = datetime.datetime(year,1,1)
    end = datetime.datetime(year+1,1,1)
    step = datetime.timedelta(days=1)
    times = []
    while dt < end:
        times.append(dt)
        dt += step
    return times

wd = '/home/simon/dev/gandak_data_model/data-raw'
datadir = '/data'
zipfile = 'GRIDDED RF DATA 0.25 X 0.25 (1901-2015)'

