## The first check I'm going to do is to make sure that each
## map in 'obs' has the non-NA cells. The way I do this is as
## follows:
## 1 - 'unstack' the ObsLulcRasterStack object, which
##     results in a list of Raster objects
## 2 - set all non-NA cells in each raster to the same value,
##     which means I can use raster::compareRaster() with
##     the 'value' argument set to TRUE
## 3 - compare each land use map to the 2001 map

maps = unstack(obs)
class(maps)
for (i in 1:length(maps)) {
    r = maps[[i]]
    r[!is.na(r)] = 1
    maps[[i]] = r
}

check = lapply(maps, FUN=function(x) compareRaster(maps[[1]], x, values=TRUE, stopiffalse = FALSE, showwarning = FALSE))

## If the check is passed then all elements of 'check' should
## be TRUE; the fact that they are not indicates that some maps
## have NA values where others have data (i.e. a value of 1, 2
## or 3). 

## explanatory variables
ef_001 <- ("Piura_elevation.tif") #elevation

## This elevation map is highly unusual - it has just nine
## unique values:
v = unique(getValues(raster(ef_001)))
v

## it looks to me as though you are using a map which was
## originally converted to a much coarser resolution - I would
## ask someone to give you a hand with preparing the elevation
## map from the original source (which is probably HydroSHEDS).

ef_002 <- ("Piura_rivers.tif") #distance to river
ef_003 <- ("Piura_roads.tif") #distance to road
ef_004 <- ("Piura_pop_density.tif") #population density
ef_set <- stack(ef_001,ef_002,ef_003,ef_004)
names(ef_set) = c("ef_001","ef_002","ef_003","ef_004")
ef <- ExpVarRasterList(x=ef_set, pattern="ef")

##resample ef
ef <-resample(ef,obs)

## fit statistical models
part <- partition(x=obs[[1]],size=0.5,spatial=TRUE)
train.data <- getPredictiveModelInputData(obs=obs,ef=ef,cells=part[["train"]])
forms <- list(Forest~ef_001+ef_004,
              Grassland~ef_001+ef_002,
              Crop~ef_002+ef_003)
glm.models <- glmModels(formula = forms,family = binomial,data = train.data,obs = obs)

## test availability of models to predict location of forest, urban and other lann uses in testing partition
test.data <- getPredictiveModelInputData(obs = obs,ef = ef, cells = part[["test"]])
glm.pred <- PredictionList(models = glm.models,newdata = test.data)
glm.perf <- PerformanceList(pred = glm.pred,measure = "rch")
p <- plot(list(glm=glm.perf))
p
dmd <- approxExtrapDemand(obs = obs, tout = 0:11) #change tout
ordered.model <- OrderedModel(obs = obs,
                              ef = ef,
                              models = glm.models,
                              time = 0:11, # the years I predict?
                              demand = dmd,
                              order = c(1,2,3))

## OK, setting stochastic=FALSE solves the main problem you've
## been having. This is a quick fix, but I will investigate
## the reason for the strange results when stochastic=TRUE.

ordered.model <- allocate(ordered.model,stochastic = FALSE)

## which year did I predict?
op <- slot(ordered.model,"output")
