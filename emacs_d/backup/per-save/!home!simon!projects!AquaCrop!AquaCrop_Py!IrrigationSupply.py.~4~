# AquaCrop crop growth model

import numpy as np

import logging
logger = logging.getLogger(__name__)

class IrrigationSupply(object):
    """Class to represent irrigation activities"""

    def __init__(self, IrrigationSupply_variable):
        self.var = IrrigationSupply_variable

    def initial(self):
        self.var.GwPumpingVol = np.zeros((self.var.nLat, self.var.nLon))
        self.var.SwPumpingVol = np.zeros((self.var.nLat, self.var.nLon))

    def reset_initial_conditions(self):
        pass

    def groundwater_pumping_cost(self):
        pass

    def canal_pumping_cost(self):
        pass
    
    def dynamic(self):

        # Get total irrigation demand by summing along crop axis
        irrigation_demand = np.multiply(self.var.Irr, self.var.CurrentCropArea)
        total_irrigation_demand = np.sum(irrigation_demand, axis=0)
        relative_irrigation_demand = np.divide(irrigation_demand, total_irrigation_demand)        

        # TODO: put behaviour in here (for now, assume supply = demand)
        
        # TODO: limit according to maximum allowable extraction
        canal_supply = self.var.CanalSupply

        groundwater_demand = np.clip(total_irrigation_demand - canal_supply, 0, None)
        groundwater_supply = np.copy(groundwater_demand)
        
        self.var.SwPumpingVol = np.copy(canal_supply)
        self.var.GwPumpingVol = np.copy(groundwater_supply)

        total_irrigation_supply = (canal_supply + groundwater_supply)
        irrigation_supply = np.divide(np.multiply(total_irrigation_supply, relative_irrigation_demand), self.var.CurrentCropArea)
        self.var.Irr = np.clip(self.var.Irr, None, irrigation_supply)
        
