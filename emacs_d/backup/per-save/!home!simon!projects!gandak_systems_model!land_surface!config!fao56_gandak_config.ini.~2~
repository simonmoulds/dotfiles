
[globalOptions]

# Set the input directory map in an absolute path. The input
# forcing and parameter directories will be relative to this
inputDir  = /home/simon/projects/AquaCrop/Input

# output directory (absolute)
outputDir = /home/simon/projects/AquaCrop/Output

# Map of clone (must be provided in PCRaster maps)
# (Spatial resolution and coverage are based on this map)
cloneMap = Gandak05min.clone.map

# The area/landmask of interest:
landmask = Gandak05min.landmask.map

# netcdf attributes for output files:
institution = Centre for Water Systems, University of Exeter
title       = AquaCrop v5.0 output
description = test version (by Simon Moulds) 

# Format: YYYY-MM-DD
startTime = 2001-01-01
endTime = 2001-12-31
# startTime = 2001-01-01
# endTime = 2001-01-10
# endTime = 1983-11-01
# endTime   = 2016-10-30

# Simulate off season
OffSeason = 1

# Initial conditions
initialConditionNC = Gandak_initial_water_content.nc
initialConditionType = Num
initialConditionInterpMethod = Layer

# If initialConditionInterpMethod = Depth, supply depths
initialConditionDepth = None

[meteoOptions]
precipitationNC = Gandak_prec_data_1979-2014.nc
temperatureNC = Gandak_temp_data_1979-2014.nc
refETPotFileNC = Gandak_etref_data_1979-2014.nc

precipitationVariableName = precipitation
tminVariableName = Tmin
tmaxVariableName = Tmax
refETPotVariableName = referencePotET

[carbonDioxideOptions]
carbonDioxideNC = Gandak_co2_concentration.nc

[groundwaterOptions]
WaterTable = 0
VariableWaterTable = 0
groundwaterNC = gwlevel_{day:d}_{month:d}_{year:d}.nc
groundwaterVariableName = level
DailyGroundwaterNC = 1
timeLag = 1
initialGroundwaterLevelNC = Gandak_initial_groundwater_level.nc
groundwaterInputDir = /var/data/chanse_model/gwlevel

[canalOptions]
Canal = 0
VariableCanalSupply = 0
canalNC = canalflow_{day:d}_{month:d}_{year:d}.nc
canalVariableName = flow
DailyCanalNC = 1
timeLag = 1
initialCanalSupplyNC = Gandak_initial_canal_supply.nc
canalInputDir = /var/data/chanse_model/GandakCanalModel/Output/NetCDF/Flows

[cropOptions]
nCrop = 8
cropParameterNC = Gandak_crop_params.nc
cropAreaNC = Gandak_crop_area.nc
cropAreaVariableName = crop_area_frac
croplandAreaNC = Gandak_crop_area.nc
croplandAreaVariableName = cropland_area
AnnualChangeInCropArea = 0

CalendarType = 2
SwitchGDD = 1
GDDmethod = 2

PotYieldNC = Gandak_potential_crop_yield_gaez.nc
PotYieldVariableName = Yx
AnnualChangeInPotYield = False

[farmOptions]
nFarm = 10
farmAreaNC = Gandak_crop_area.nc
farmAreaVariableName = farm_area

[irrMgmtOptions]
irrMgmtParameterNC = Gandak_irri_params.nc
irrScheduleNC = None

[fieldMgmtOptions]
fieldMgmtParameterNC = Gandak_mgmt_params.nc

AnnualChangeInFertiliserAppRate = 0
NitrogenApplicationRateNC = None
NitrogenApplicationRateVariableName = None
PhosphorusApplicationRateNC = None
PhosphorusApplicationRateVariableName = None
PotassiumApplicationRateNC = None
PotassiumApplicationRateVariableName = None

[priceOptions]
cropPriceNC = Gandak_price_data.nc
cropPriceVariableName = harvest_price
NitrogenPriceNC = Gandak_price_data.nc
NitrogenPriceVariableName = nitrogen_price
PhosphorusPriceNC = Gandak_price_data.nc
PhosphorusPriceVariableName = phosphorus_price
PotassiumPriceNC = Gandak_price_data.nc
PotassiumPriceVariableName = potassium_price
dieselPriceNC = Gandak_price_data.nc
dieselPriceVariableName = diesel_price

[soilOptions]
soilAndTopoNC = Gandak_soil_params.nc

[reportingOptions]
netcdf_y_orientation_follow_cf_convention = False
formatNetCDF = NETCDF4
zlib = True
outDailyTotNC = zGW
outMonthAvgNC = zGW
outYearMaxNC = Y,Production
outYearAvgNC = zGW
outYearTotNC = Recharge

