## groundnut
## #########

xx[["apy_groundnut-kharif"]] = xx[["mapspam_atot_groundnut"]][6]
xx[["irr_groundnut-kharif"]] = xx[["mapspam_xirr_groundnut"]][6]

## lentil
## ######

xx[["apy_lentil-rabi"]] = xx[["mapspam_atot_lentil"]]
xx[["irr_lentil-rabi"]] = xx[["mapspam_xirr_lentil"]]

## maize
## #####

## all ok

## other cereals
## #############

xx[["apy_other_cereals-kharif"]][c(7,11)] = xx[["apy_other_cereals-rabi"]][c(7,11)]
xx[["apy_other_cereals-rabi"]] = 0

## other fibre crops
## #################

xx[["apy_other_fibre_crops-rabi"]] = 0

## other oil crops
## #################

xx[["apy_other_oil_crops-kharif"]] = xx[["mapspam_atot_other_oil_crops"]]
xx[["irr_other_oil_crops-kharif"]] = xx[["mapspam_xirr_other_oil_crops"]]

## other pulses
## ############

xx[["apy_other_pulses-rabi"]] %<>% locf_interp(2, fromLast=TRUE)

## pigeonpea
## #########

xx[["apy_pigeonpea-kharif"]] %<>% linear_interp(7)

## potato
## ######

xx[["apy_potato-rabi"]] = xx[["apy_potato-rabi"]][7]
xx[["irr_potato-rabi"]] = xx[["irr_potato-rabi"]][7]

xx[["apy_sweet_potato-whole_year"]][7] = xx[["apy_sweet_potato-rabi"]][7]
xx[["apy_sweet_potato-whole_year"]][10:11] = xx[["apy_sweet_potato-kharif"]][10:11]
xx[["apy_sweet_potato-rabi"]] = 0
xx[["apy_sweet_potato-kharif"]] = 0

xx[["apy_sweet_potato-whole_year"]] %<>% linear_interp(8)

## rapeseed
## ########

if (dist_nm %in% c("East Garo Hills")) {
    xx[["irr_rapeseed-rabi"]] %<>% irr_frac_interp(xx[["apy_rapeseed-rabi"]], 6, c(5,7))
}

if (dist_nm %in% c("East Garo Hills","West Garo Hills")) {
    xx[["irr_rapeseed-rabi"]] %<>% irr_frac_interp(xx[["apy_rapeseed-rabi"]], 11, 10)
}

## rest of crops
## #############

xx[["apy_rest_of_crops-whole_year"]][7] = xx[["apy_rest_of_crops-rabi"]][7]
xx[["apy_rest_of_crops-rabi"]] = 0

xx[["apy_rest_of_crops-whole_year"]] %<>% linear_interp(8)
xx[["irr_rest_of_crops-whole_year"]] %<>% linear_interp(8)

## rice
## ####

xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 2:4, 1)
xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 11, 10)

xx[["apy_rice-summer"]] %<>% tot_frac_interp(xx[["irr_rice-summer"]], 6:8, 5)


