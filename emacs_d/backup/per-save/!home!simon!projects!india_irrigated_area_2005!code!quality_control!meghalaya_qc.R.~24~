## chickpea
## ######

## all ok

## coconut
## ######

xx[["apy_coconut-whole_year"]] = xx[["mapspam_atot_coconut"]][6]
xx[["irr_coconut-whole_year"]] = xx[["mapspam_xirr_coconut"]][6]

## cotton
## ######

xx[["apy_cotton-kharif"]][6] = xx[["apy_cotton-rabi"]][6]
