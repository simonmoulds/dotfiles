# Groundwater
# ===========

dataset = Dataset('groundwater_test.nc', 'w')
dataset.description = 'AquaCrop depth to groundwater table input data'
dataset.history = 'Created ' + time.ctime(time.time())

# dataset dimensions
lat = dataset.createDimension('lat', nlat)
lon = dataset.createDimension('lon', nlon)

# dataset variables
latitudes = dataset.createVariable('latitude', np.float64, ('lat',))
latitudes.units = "degrees_north"
latitudes[:] = lat_vals

longitudes = dataset.createVariable('longitude', np.float64, ('lon',))
longitudes.units = "degrees_east"
longitudes[:] = lon_vals

gw = dataset.createVariable('groundwater', np.float64, ('lat','lon'))
gw.setncattr('standard_name', 'groundwater')
gw.setncattr('long_name', 'depth to groundwater table')
gw.setncattr('units', 'm')
gw.setncattr('_FillValue', np.float64(1e+20))
gw.setncattr('missing_value', np.float64(1e+20))
gw[:] = 2
dataset.close()

