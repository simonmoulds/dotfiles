## List of tasks:
## 1  - downscale operational holdings to grid
## 1a - match polygons with ICRISAT data
## 1b - compute total cropland in district (from
##      iiasa-ifpri cropland map)
## 1c - compute fraction of cropland occurring in
##      each grid cell
## 1c - scale values in land_holdings to match
##      total cropland (preserve average size in
##      each class, such that the number in each
##      category increases)
## 1d - multiply the number of each holding in
##      land_holdings by the scale factor computed
##      in 1c to get the number of farms per
##      category on a grid cell basis
## 1e - NOTE: we need a time series of these maps
##      (but for now we could assume constant)

cropland = raster("data/iiasa-ifpri-cropland-map/Hybrid_10042015v9.img")
cropland = crop(cropland, extent(template))
cropland = aggregate(cropland, fact=10, fun=mean)
cropland = cropland / 100 * area(cropland)

x = land_holdings %>% filter(YEAR %in% 1980)

## First attempt - weight by cropland
v = getValues(adm2_1960_raster)

farm_area = list(
    marg=raster(template),
    small=raster(template),
    semim=raster(template),
    medium=raster(template),
    large=raster(template))

farm_nos = farm_area

cats = c("MARG","SMALL","SEMIM","MEDIUM","LARGE")

for (i in 1:nrow(x)) {
    gaul_id = x$GAUL_ID[i]
    cell_ix = which(v == gaul_id)
    area = cropland[cell_ix]
    weights = area / sum(area)
    total_cropland = sum(area) # km2
    sf = total_cropland / (x[["TOTAL_AR"]][i] * 10)
    for (j in 1:length(cats)) {
        area_col = paste0(cats[j], "_AR")
        no_col = paste0(cats[j], "_NO")
        size = x[[area_col]][i] / x[[no_col]][i]
        area = x[[area_col]][i] * sf * weights * 1000
        nos = area / size
        farm_area[[j]][cell_ix] = area
        farm_nos[[j]][cell_ix] = nos
    }    
}

