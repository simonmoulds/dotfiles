#!/bin/bash

Rscript process-hwsd.R

r.in.gdal \
    -a \
    input="hwsd.tif" \
    output=hwsd \
    --overwrite

g.region raster=hwsd

for lyr in t s
do
    for var in sand silt clay bulk_density cec_soil oc ph_h2o
    do       
	r.reclass \
	    input=hwsd \
	    output=${lyr}_${var} \
	    rules=${lyr}_${var}_rcl.txt \
	    --overwrite
	r.out.gdal \
	    input=${lyr}_${var} \
	    output=hwsd_${lyr}_${var}.tif \
	    --overwrite
    done
done

    
