## Quality control for Himachal Pradesh

## Crops not grown: Banana, Cassava, Coconut, Coffee, Finger Millet, ...

## barley
## ######

xx[["apy_barley-rabi"]] %<>% linear_interp(10)
xx[["irr_barley-rabi"]][10] = xx[["irr_barley-kharif"]][10]
xx[["irr_barley-rabi"]] %<>% irr_frac_interp(xx[["apy_barley-rabi"]], 11, 10)
xx[["irr_barley-kharif"]][10] = 0


## chickpea
## ########

xx[["apy_chickpea-rabi"]] %<>% linear_interp(4:5)
xx[["irr_chickpea-rabi"]] %<>% linear_interp(4:5)
xx[["apy_chickpea-rabi"]] %<>% linear_interp(10)
xx[["irr_chickpea-rabi"]] %<>% irr_frac_interp(xx[["apy_chickpea-rabi"]], 10:11, 9)

## cotton
## ######

if (dist_nm %in% c("Kangra","Solan")) {
    xx[["apy_cotton-kharif"]] = xx[["mapspam_atot_cotton"]][6]
    xx[["irr_cotton-kharif"]] = xx[["mapspam_xirr_cotton"]][6]
}

## groundnut
## #########

if (dist_nm %in% c("Bilaspur")) {
    xx[["apy_groundnut-kharif"]] = xx[["mapspam_atot_groundnut"]][6]
    xx[["irr_groundnut-kharif"]] = xx[["mapspam_xirr_groundnut"]][6]
}

if (dist_nm %in% c("Kullu","Shimla","Sirmaur")) {
    xx[["apy_groundnut-kharif"]] %<>% linear_interp(c(4:5,10))
    xx[["irr_groundnut-kharif"]] %<>% linear_interp(c(4:5,10))

    if (dist_nm %in% "Sirmaur") {
        xx[["irr_groundnut-kharif"]] %<>% irr_frac_interp(xx[["apy_groundnut-kharif"]], 10:11, 9)
    }
}

if (dist_nm %in% "Solan") {
    xx[["apy_groundnut-kharif"]] %<>% locf_interp(4:5, fromLast=TRUE)
    xx[["irr_groundnut-kharif"]] %<>% locf_interp(4:5, fromLast=TRUE)
    xx[["apy_groundnut-kharif"]] %<>% locf_interp(9:11)
    xx[["irr_groundnut-kharif"]] %<>% locf_interp(9:11)
}

## lentil
## ######

xx[["apy_lentil-rabi"]][c(1:3,8)] = xx[["apy_lentil-kharif"]][c(1:3,8)]
xx[["apy_lentil-kharif"]] = 0

xx[["apy_lentil-rabi"]] %<>% linear_interp(c(4:5,10))
xx[["irr_lentil-rabi"]] %<>% linear_interp(c(4:5,10))

if (dist_nm %in% c("Bilaspur")) {
    xx[["apy_lentil-rabi"]] %<>% locf_interp(9:11)
    xx[["irr_lentil-rabi"]] %<>% locf_interp(9:11)
}

if (dist_nm %in% c("Solan","Una")) {
    xx[["apy_lentil-rabi"]] %<>% locf_interp(10:11)
    xx[["irr_lentil-rabi"]] %<>% locf_interp(10:11)
}

## maize
## #####

xx[["apy_maize-kharif"]] %<>% linear_interp(10)
xx[["irr_maize-kharif"]] %<>% irr_frac_interp(xx[["apy_maize-kharif"]], 10:11, 9)

## other cereals
## #############

if (dist_nm %in% c("Chamba","Kinnaur")) {
    xx[["apy_other_cereals-kharif"]] %<>% tot_frac_interp(xx[["irr_other_cereals-kharif"]], 4:5, c(3,6))
    xx[["apy_other_cereals-kharif"]] %<>% linear_interp(10)
    xx[["irr_other_cereals-kharif"]] %<>% irr_frac_interp(xx[["apy_other_cereals-kharif"]], 11, 9)
    xx[["irr_other_cereals-rabi"]] = 0

    if (dist_nm %in% "Chamba") {
        xx[["irr_other_cereals-kharif"]] %<>% irr_frac_interp(xx[["apy_other_cereals-kharif"]], 7, 6)
    }
}

if (dist_nm %in% c("Kangra","Mandi","Shimla","Sirmaur")) {
    xx[["apy_other_cereals-kharif"]] %<>% linear_interp(c(4:5, 10))

    if (dist_nm %in% "Sirmaur") {
        xx[["irr_other_cereals-kharif"]] %<>% irr_frac_interp(xx[["apy_other_cereals-kharif"]], 11, 9)
    }
}

if (dist_nm %in% "Kullu") {
    xx[["apy_other_cereals-kharif"]] %<>% linear_interp(c(4:5, 8:10))
}

if (dist_nm %in% "Lahul & Spiti") {
    xx[["apy_other_cereals-kharif"]] %<>% tot_frac_interp(xx[["irr_other_cereals-kharif"]], 4:10, 3)
    xx[["apy_other_cereals-kharif"]] %<>% locf_interp(11)
    xx[["irr_other_cereals-kharif"]] %<>% locf_interp(11)
}

## other oil crops
## ###############

if (dist_nm %in% c("Chamba")) {
    xx[["apy_other_oil_crops-rabi"]] %<>% locf_interp(4:5, fromLast=TRUE)
    xx[["apy_other_oil_crops-rabi"]] %<>% linear_interp(9:10)
}

if (dist_nm %in% c("Kangra","Mandi")) {
    xx[["apy_other_oil_crops-rabi"]] %<>% linear_interp(4:5)
    xx[["apy_other_oil_crops-rabi"]] %<>% linear_interp(10)
}

## other pulses
## ############

if (dist_nm %in% c("Bilaspur","Chamba","Kangra","Shimla","Sirmaur","Solan","Una")) {
    xx[["apy_other_pulses-kharif"]] %<>% tot_frac_interp(xx[["irr_other_pulses-kharif"]], 4:5, 3)
    xx[["apy_other_pulses-kharif"]] %<>% tot_frac_interp(xx[["irr_other_pulses-kharif"]], 10, 9)
    xx[["irr_other_pulses-kharif"]] %<>% irr_frac_interp(xx[["apy_other_pulses-kharif"]], 11, 9)
}

if (dist_nm %in% c("Bilaspur")) {
    xx[["irr_other_pulses-rabi"]] %<>% linear_interp(6)
}

if (dist_nm %in% "Hamirpur") {
    xx[["apy_other_pulses-kharif"]] %<>% locf_interp(4:5, fromLast=TRUE)
    xx[["apy_other_pulses-kharif"]] %<>% linear_interp(10)
}

if (dist_nm %in% "Kinnaur") {
    xx[["apy_other_pulses-kharif"]] %<>% tot_frac_interp(xx[["irr_other_pulses-kharif"]], 4:10, 2)
    xx[["apy_other_pulses-rabi"]][c(3,8:10)] = xx[["irr_other_pulses-rabi"]][c(3,8:10)]
    xx[["apy_other_pulses-rabi"]] %<>% linear_interp(4:5)
    xx[["apy_other_pulses-rabi"]] %<>% locf_interp(1:2, fromLast=TRUE)
    xx[["irr_other_pulses-rabi"]] = xx[["apy_other_pulses-rabi"]]
}

if (dist_nm %in% "Kullu") {
    xx[["apy_other_pulses-kharif"]] %<>% locf_interp(c(4:5,10), fromLast=TRUE)
    xx[["irr_other_pulses-rabi"]] %<>% locf_interp(1:2, fromLast=TRUE)
    xx[["irr_other_pulses-rabi"]] %<>% linear_interp(c(8,10))
}

if (dist_nm %in% "Lahul & Spiti") {
    xx[["irr_other_pulses-kharif"]][11] = xx[["apy_other_pulses-kharif"]][11]
    xx[["apy_other_pulses-kharif"]][c(6:7,9,11)] = xx[["apy_other_pulses-rabi"]][c(6:7,9,11)]
    xx[["apy_other_pulses-rabi"]] = 0
    xx[["apy_other_pulses-kharif"]] %<>% tot_frac_interp(xx[["irr_other_pulses-kharif"]], 10, 11)
    xx[["apy_other_pulses-kharif"]] %<>% tot_frac_interp(xx[["irr_other_pulses-kharif"]], 4:5, 6)
    xx[["irr_other_pulses-kharif"]] %<>% irr_frac_interp(xx[["apy_other_pulses-kharif"]], 1:3, 6)
}

if (dist_nm %in% "Mandi") {
    xx[["apy_other_pulses-kharif"]] %<>% linear_interp(4:5)
    xx[["apy_other_pulses-kharif"]] %<>% locf_interp(10, fromLast=TRUE)
    xx[["apy_other_pulses-rabi"]] %<>% tot_frac_interp(xx[["irr_other_pulses-rabi"]], 8, 9)
    xx[["apy_other_pulses-rabi"]] %<>% tot_frac_interp(xx[["irr_other_pulses-rabi"]], 10, 9)
    xx[["irr_other_pulses-rabi"]] %<>% irr_frac_interp(xx[["apy_other_pulses-rabi"]], 7, 9)
    xx[["irr_other_pulses-rabi"]] %<>% irr_frac_interp(xx[["apy_other_pulses-rabi"]], 11, 9)
    xx[["apy_other_pulses-rabi"]] %<>% locf_interp(1:6, fromLast=TRUE)
    xx[["irr_other_pulses-rabi"]] %<>% locf_interp(1:6, fromLast=TRUE)
}

if (dist_nm %in% "Shimla") {
    xx[["apy_other_pulses-rabi"]] %<>% locf_interp(11)
}

if (dist_nm %in% c("Sirmaur","Solan")) {
    xx[["apy_other_pulses-rabi"]] %<>% tot_frac_interp(xx[["irr_other_pulses-rabi"]], 1:5, 6)
    xx[["apy_other_pulses-rabi"]] %<>% tot_frac_interp(xx[["irr_other_pulses-rabi"]], 8, 7)
    xx[["apy_other_pulses-rabi"]] %<>% tot_frac_interp(xx[["irr_other_pulses-rabi"]], 10, 9)
    xx[["irr_other_pulses-rabi"]] %<>% tot_frac_interp(xx[["apy_other_pulses-rabi"]], 11, 10)
}

## pearl millet
## ############

if (dist_nm %in% c("Bilaspur","Hamirpur","Mandi","Shimla","Sirmaur","Solan")) {
    xx[["apy_pearl_millet-summer"]] = xx[["mapspam_atot_pearl_millet"]][6]
    xx[["irr_pearl_millet-summer"]] = xx[["mapspam_xirr_pearl_millet"]][6]
}

if (dist_nm %in% c("Kangra")) {
    xx[["apy_pearl_millet-summer"]] %<>% linear_interp(c(8,10))
    xx[["irr_pearl_millet-summer"]] %<>% irr_frac_interp(xx[["apy_pearl_millet-summer"]], 10:11, 9)
}

## pigeonpea
## #########

if (dist_nm %in% c("Bilaspur","Chamba","Kangra","Kullu","Mandi","Shimla","Sirmaur","Solan","Una")) {
    xx[["apy_pigeonpea-kharif"]] = xx[["mapspam_atot_pigeonpea"]][6]
    xx[["irr_pigeonpea-kharif"]] = xx[["mapspam_xirr_pigeonpea"]][6]
}

## potato
## ######

xx[["apy_potato-kharif"]] = xx[["apy_potato-kharif"]][8]
xx[["irr_potato-kharif"]] = xx[["irr_potato-kharif"]][8]
xx[["apy_potato-rabi"]] = xx[["apy_potato-rabi"]][8]
xx[["irr_potato-rabi"]] = xx[["irr_potato-rabi"]][8]

if (dist_nm %in% "Bilaspur") {
    xx[["apy_sweet_potato-whole_year"]] = 0
}

## rapeseed
## ########

xx[["apy_rapeseed-rabi"]] %<>% locf_interp(c(4:5))
xx[["irr_rapeseed-rabi"]] %<>% locf_interp(c(4:5))

xx[["apy_rapeseed-rabi"]] %<>% locf_interp(10, fromLast=TRUE)
xx[["irr_rapeseed-rabi"]] %<>% locf_interp(10, fromLast=TRUE)

xx[["irr_rapeseed-rabi"]] %<>% irr_frac_interp(xx[["apy_rapeseed-rabi"]], 10:11, 9)

if (dist_nm %in% "Lahul & Spiti") {
    xx[["apy_rapeseed-rabi"]] %<>% linear_interp(7:8)
    xx[["irr_rapeseed-rabi"]] %<>% linear_interp(7:8)
}

## rest of crops
## #############

xx[["apy_rest_of_crops-rabi"]] = xx[["apy_rest_of_crops-rabi"]][11]
xx[["apy_rest_of_crops-summer"]] = xx[["irr_rest_of_crops-summer"]][11]

## rice
## ####

xx[["irr_rice-summer"]][1] = xx[["irr_rice-autumn"]][1]
xx[["irr_rice-autumn"]] = 0
xx[["irr_rice-winter"]] = xx[["irr_rice-summer"]]
xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 10, 9)
xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 11, 9)

if (dist_nm %in% "Kinnaur") {
    xx[["apy_rice-winter"]][10] = xx[["irr_rice-winter"]][10]
    f = xx[["mapspam_xirr_rice"]] / xx[["mapspam_atot_rice"]]
    xx[["irr_rice-winter"]] = xx[["apy_rice-winter"]] * f
}


## sesameseed
## ##########

xx[["apy_sesameseed-kharif"]] %<>% locf_interp(c(4:5))
xx[["irr_sesameseed-kharif"]] %<>% locf_interp(c(4:5))

xx[["apy_sesameseed-kharif"]] %<>% locf_interp(10, fromLast=TRUE)
xx[["irr_sesameseed-kharif"]] %<>% locf_interp(10, fromLast=TRUE)

## sorghum
## #######

if (dist_nm %in% "Kangra") {    
    xx[["apy_sorghum-kharif"]] = xx[["mapspam_atot_sorghum"]][6]
    xx[["irr_sorghum-kharif"]] = xx[["mapspam_xirr_sorghum"]][6]
}



