dist_long = ("Gandak")
dist_short = ("gandak")
elev = 61.3
scenario = c("bau","no_canal","no_irrig")
scenario2 = c("bau")

## income plots
## ############

data = list()
for (i in 1:length(dist_long)) {

    for (j in 1:length(scenario)) {

        income_min = read.table(file.path(ddir_output, paste0("income_min_", dist_short[i], "_", scenario[j], ".txt")), header=TRUE)[1:19,]
        income_max = read.table(file.path(ddir_output, paste0("income_max_", dist_short[i], "_", scenario[j], ".txt")), header=TRUE)[1:19,]
        income_med = read.table(file.path(ddir_output, paste0("income_med_", dist_short[i], "_", scenario[j], ".txt")), header=TRUE)[1:19,]

        income_base = data.frame(date=date_year, dist=dist_short[i], name=scenario[j], med=income_med, min=income_min, max=income_max)
        income = income_base
        n = length(data)
        data[[n+1]] = income
    }
}
## now join plots
df = do.call(rbind, data) %>% arrange(date, dist, name)
df = df[df$date %in% date,]
df[df$date >= as.Date("2018-01-01"),c("med","min","max")] = NA

df$name = factor(
    as.character(df$name),
    levels=c("bau","no_canal","no_irrig"),
    labels=c("Business As Usual","No Canal","No Irrigation"))

df$dist = factor(
    as.character(df$dist),
    levels=c("gandak"))

levels(df$dist) = c("Gandak")

p = ggplot(df, aes(x=date, y=med)) +
    geom_line(aes(colour=name), colour="black") +
    geom_ribbon(aes(ymax=min, ymin=max, fill=name), alpha = 0.4, fill="black") +
    facet_wrap(~name, ncol=3) +
