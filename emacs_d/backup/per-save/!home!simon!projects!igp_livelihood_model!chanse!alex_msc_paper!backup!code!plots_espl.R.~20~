## observed vs modelled groundwater
## ################################

data = list()

for (i in 1:length(dist_long)) {

    for (j in 1:length(scenario)) {
        gw_med = read.table(file.path(ddir_output, paste0("gw_med_", dist_short[i], "_", scenario[j], ".txt")))[,1]
        gw_min = read.table(file.path(ddir_output, paste0("gw_min_", dist_short[i], "_", scenario[j], ".txt")))[,1]
        gw_max = read.table(file.path(ddir_output, paste0("gw_max_", dist_short[i], "_", scenario[j], ".txt")))[,1]

        gw_mod = data.frame(date=date2, dist=dist_short[i], name=scenario[j], type="mod", med=gw_med, min=gw_min, max=gw_max)

        gw_obs =
            read.table(file.path(ddir_input, "sult_obs_gw2.txt"), header=TRUE) %>%
            dplyr::select(c("date","wl")) %>%
            `[`(complete.cases(.),)
        gw_obs[["date"]] = as.Date(gw_obs[["date"]])
        gw_obs %<>% dplyr::right_join(data.frame(date=date3)) 
        gw_obs[,c("wl")] = zoo::na.approx(gw_obs[,c("wl")], na.rm=FALSE)

        gw_obs2 = data.frame(date=date3, dist=dist_short[i], name=scenario[j], type="obs", med=gw_obs[["wl"]], min=gw_obs[["wl"]], max=gw_obs[["wl"]])

        ## df = rbind(gw_mod, gw_obs2) %>% arrange(date, dist, name)
        df = full_join(gw_mod, gw_obs2)
        df$med = df$med - elev[i]
        df$min = df$min - elev[i]
        df$max = df$max - elev[i]

        n = length(data)
        data[[n+1]] = df
    }    
}

## now join plots
df = do.call(rbind, data) %>% arrange(date, dist, name)
df$name = factor(
    as.character(df$name),
    levels=c("bau","no_canal","no_irrig"),
    labels=c("Business As Usual","No Canal","No Irrigation"))

df$dist = factor(
    as.character(df$dist),
    levels=c("gandak"),
    labels=c("gandak"))
df$type = factor(
    as.character(df$type),
    levels=c("obs","mod"),
    labels=c("obs","mod"))                 
df = df[df$date %in% date,]
df[df$date >= as.Date("2018-01-01"),c("med","min","max")] = NA

labs = c("Observed","Modelled")
p = ggplot(df, aes(x=date, y=med)) +
    geom_line(aes(colour=type)) +
    geom_ribbon(aes(ymax=min, ymin=max, fill=type), alpha=0.3) +
    scale_colour_manual(name="", values=c("red","black"), labels=labs) +
    scale_fill_manual(name="", values=c("transparent","black"), labels=labs) +
    theme_bw() +
    facet_wrap(~name, ncol=3) +
    theme(panel.grid.major = element_blank(),
          panel.grid.minor = element_blank(),
          strip.background = element_blank(),
          strip.text = element_text(size=12),
          plot.title = element_text(size=12),
          aspect.ratio=1,
          plot.margin = unit(c(0.25,0.25,0.25,0.25), "cm"),
          legend.direction="vertical",
          legend.position="bottom") +
    labs(x="Year", y="mBGL")
p

