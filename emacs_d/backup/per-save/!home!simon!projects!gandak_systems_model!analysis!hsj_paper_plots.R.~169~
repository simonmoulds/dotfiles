## ########################
## Irrigated area over time
## ########################

options(stringsAsFactors = FALSE)
dist_names = c("Maharajganj","Gorakhpur","Deoria","Pashchim Champaran","Purba Champaran","Gopalganj","Siwan","Saran","Muzaffarpur","Vaishali","Samastipur")
nia = read.csv("data/indiastat_nia_districtwise.csv") %>%
    filter(District %in% toupper(dist_names)) %>%
    separate(date, into=c("date","deleteme"), sep="_") %>%
    select(-deleteme) %>%
    mutate(date=as.numeric(gsub("X","",date))) %>%
    mutate(obs=total_nia) %>%
    select(-ends_with("_nia"))

## dims: lat/lon/farm/time
## TODO: I *think* this output needs to be multiplied by the
## total number of farms belonging to the super-individual
fn = file.path(output_dir, "area_with_irrigation_irrNonPaddy_yearEnd_output.nc")
x = get_nc_var(fn)
maps = get_maps_aggr_farm(x, model_region)
maps[maps==0] = NA

## overlay raster time series with district polygons and
## compute zonal statistics (sum)
years = 1980:2010
out = vector(mode="list", length=length(adm2_1990))
for (i in 1:length(adm2_1990)) {
    poly = adm2_1990[i,]
    state = toupper(poly$ADM1_NAME)
    dist = toupper(poly$ADM2_NAME)
    ts = raster::extract(maps, poly, fun=sum, na.rm=TRUE, df=FALSE) %>% as.numeric %>% `/`(1000) %>% `/`(1000)
    df = data.frame(
        State=toupper(poly$ADM1_NAME[1]),
        District=toupper(poly$ADM2_NAME[1]),
        date=years,
        mod=ts)
    out[[i]] = df
}
df = do.call(rbind, out)

data =
    left_join(df, nia, by=c("State","District","date")) %>%
    group_by(State,District,date) %>%
    gather(key=origin, value=nia, mod:obs) %>%
    arrange(State, District, date)

p = ggplot(data=data, aes(x=date, y=nia, color=origin)) +
    ## geom_point() +
    geom_line() + 
    scale_color_manual(values=c("cyan","magenta"), labels=c("Modelled","Observed")) +
    facet_wrap(~District) +
    theme(legend.position="bottom",
          legend.title=element_blank(),
          legend.spacing.x=unit(5, units="mm"),
          legend.text=element_text(margin=margin(r=10)))
p

pname <- file.path(file.path("~/Dropbox/documents/papers/super_individual_paper/net_irrigated_area_1980-2010.png"))
png(pname, width=6, height=6, units="in", res=320, bg="transparent")
print(p)
dev.off()

