library(zoo)
library(xts)
library(sp)
library(ncdf4)
library(magrittr)

read_yield = function(rootdir, subdir, crop) {
    yield_list = list()
    dirs = list.files(file.path(rootdir, subdir), full.names=TRUE)
    for (i in 1:length(dirs)) {
        dir=dirs[i]
        stn=basename(dir)

        ## get lat/long
        stn_ix = which(tahmo_metadata$Code %in% stn)
        
        ## find out if crop is grown here
        
        era5_nc = file.path(dir, 'output', crop, 'prec_era5/netcdf/Y_cropland_yearMax_output.nc')
        tahmo_nc = file.path(dir, 'output', crop, 'prec_tahmo/netcdf/Y_cropland_yearMax_output.nc')
        tamsat_nc = file.path(dir, 'output', crop, 'prec_tamsat/netcdf/Y_cropland_yearMax_output.nc')
        
        if (file.exists(era5_nc) && file.exists(tahmo_nc) && file.exists(tamsat_nc)) {
            nc = nc_open(era5_nc)
            era5_yield = ncvar_get(nc, 'crop_yield')
            nc_close(nc)

            nc = nc_open(tahmo_nc)
            tahmo_yield = ncvar_get(nc, 'crop_yield')
            nc_close(nc)

            nc = nc_open(tamsat_nc)
            tamsat_yield = ncvar_get(nc, 'crop_yield')
            nc_close(nc)
            
            x = data.frame(year=2016:2018, id=stn, era5=era5_yield, tahmo=tahmo_yield, tamsat=tamsat_yield)
            yield_list[[stn]] = x
        }
    }    
    yield_list
}

yield =
    read_yield(datadir, country, crop) %>%
    do.call(rbind, .) %>%
    dplyr::filter(year %in% year)

max_yield = ceiling(max(c(yield$tahmo, yield$era5, yield$tamsat)))

yield = yield %>% gather(key, yield, -year, -id, -tahmo)
yield$key = factor(yield$key, levels=c("era5","tamsat"))
levels(yield$key) = c("ERA5","TAMSAT")

key_labs = c("ERA5","TAMSAT")
names(key_labs) = c("ERA5","TAMSAT")

p = ggplot(yield, aes(x=tahmo, y=yield)) +
    geom_point(aes(color=key), shape=1, size=3) +
    scale_color_manual(values=c("magenta","blue")) +
    facet_grid(.~key, labeller=labeller(key=key_labs)) +
    coord_fixed() + 
    geom_abline(intercept=0, slope=1, size=0.25) + 
    xlim(0,max_yield) +
    ylim(0,max_yield) +
    xlab(expression("AquaCrop_TAHMO"~(t~ha^-1))) + 
    ylab(expression("AquaCrop_Grid"~(t~ha^-1))) +
    theme(
        panel.spacing = unit(2, "lines"),
        legend.position = "none")
    ## theme(legend.title = element_blank(),
    ##       legend.key = element_blank())
p
