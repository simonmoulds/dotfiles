#!/usr/bin/env python
# coding: utf-8

import os
import glob
run_dir = "../data/aquacrop_runs"
run_dirs = glob.glob(run_dir + '/' + 'TA*')
stns = [os.path.basename(dir) for dir in run_dirs]

def main():
    for dir in run_dirs:
        for config_file in glob.glob(dir + '/config/*.ini'):
            cmd = 'python -m aquacrop.run ' + config_file
            os.system(cmd)

if __name__ == '__main__':
    main()
