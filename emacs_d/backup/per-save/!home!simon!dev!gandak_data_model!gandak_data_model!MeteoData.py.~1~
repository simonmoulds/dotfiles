import numpy as np
import datetime
import os
import gdal
import netCDF4
import re

ds = gdal.Open('../data/output_prec/Rainfall/EX200000.001')
a = ds.ReadAsArray()
nlat,nlon = np.shape(a)
xres = 1./12
yres = 1./12

b = ds.GetGeoTransform() #bbox, interval
minx = b[0]
maxx = b[0] + nlon * xres
maxy = b[3] 
miny = b[3] + nlat * -yres

lon = np.arange(0,nlon) * xres + (minx + xres/2)
lat = np.arange(0,nlat) * yres + (miny + yres/2)
lat = lat[::-1]

dt = datetime.datetime(1979,1,1)
end = datetime.datetime(2014,1,1)
step = datetime.timedelta(days=1)
times = []
while dt < end:
    times.append(dt)
    dt += step

# Precipitation
# #############

# create NetCDF file
nco = netCDF4.Dataset('../data/Gandak_prec_data_1979-2014.nc','w',clobber=True)

# create dimensions, variables and attributes:
nco.createDimension('lon',nlon)
nco.createDimension('lat',nlat)
nco.createDimension('time',None)

timeo = nco.createVariable('time','f4',('time'))
timeo.units = 'days since 1901-01-01 00:00:00'
timeo.calendar = 'standard'
timeo.standard_name = 'time'
timeo[:] = netCDF4.date2num(times, units=timeo.units, calendar=timeo.calendar)

lono = nco.createVariable('lon',np.float64,('lon'),zlib=True,least_significant_digit=16)
lono.units = 'degrees_east'
lono.standard_name = 'longitude'
lono[:]=lon

lato = nco.createVariable('lat',np.float64,('lat'),zlib=True,least_significant_digit=16)
lato.units = 'degrees_north'
lato.standard_name = 'latitude'
lato[:]=lat

# create container variable for CRS: lon/lat WGS84 datum
crso = nco.createVariable('crs','i4')
crso.long_name = 'Lon/Lat Coords in WGS84'
crso.grid_mapping_name='latitude_longitude'
crso.longitude_of_prime_meridian = 0.0
crso.semi_major_axis = 6378137.0
crso.inverse_flattening = 298.257223563

prco = nco.createVariable('precipitation', np.float64, ('time', 'lat', 'lon'), zlib=False,fill_value=np.float64(1e+20))
prco.setncattr('standard_name', 'precipitation')
prco.setncattr('long_name', 'precipitation')
prco.setncattr('units','1e3 m.day-1')  # =mm
prco.setncattr('_FillValue', np.float64(1e+20))
prco.setncattr('missing_value', np.float64(1e+20))

nco.Conventions='CF-1.6'

pattern = re.compile('EX2[0-9]{5}\.[0-9]{3}')
itime=0

#step through data, writing time and data to NetCDF
for root, dirs, files in os.walk('../data/output_prec/Rainfall'):
    dirs.sort()
    files.sort()
    for f in files:
        if re.match(pattern,f):
            prc_path = os.path.join(root,f)
            print(prc_path)
            prc=gdal.Open(prc_path)
            a=prc.ReadAsArray()
            prco[itime,:,:]=a
            itime=itime+1

# close netCDF
nco.close()

