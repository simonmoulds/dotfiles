#!/bin/bash

wd=$HOME/projects/india_lulcc_1960-2010

echo 'export GRASS_MESSAGE_FORMAT=plain
g.region region=india_rgn
for map in data/output_maps/LULC_DIST*.tif
do
    nm=$(basename $map .tif)
    echo $nm
    r.in.gdal input=$map output=$nm --overwrite
done

for year in `seq 1960 2010`
do 
    maps=`g.list type=raster separator=, pattern="LULC_DIST_*_$year"`
    r.patch in=$maps out=lu"${year}"_mod --overwrite
    g.remove -f type=raster name=$maps
    r.out.gdal input=lu"${year}"_mod output=maps/INDIA_LULC_MOD_$year.tif createopt="COMPRESS=DEFLATE" --overwrite
    g.remove -f type=raster name=lu"${year}"_mod
done
' > mygrassjob_pt1.sh

chmod u+x mygrassjob_pt1.sh
export GRASS_BATCH_JOB=$wd/mygrassjob_pt1.sh
grass $HOME/grassdata/lcc/PERMANENT
unset GRASS_BATCH_JOB
rm mygrassjob_pt1.sh
