get_nc_var = function(fn) {
    nc = nc_open(fn)
    nm = attributes(nc$var)$names[1]
    var = ncvar_get(nc, nm)
    nc_close(nc)
    var
}

get_nc_var_dims = function(fn, var) {
    nc = nc_open(fn)
    ## nm = attributes(nc$var)$names[1]
    ## var = ncvar_get(nc, nm)
    dims = sapply(nc$var[[var]]$dim, FUN=function(x) x$name)
    nc_close(nc)
    dims
}

get_maps = function(x, template) {
    dims = dim(x)
    nt = dims[5]
    nfarm = dims[4]
    ncrop = dims[3]
    maps = list()
    for (i in 1:nt) {
        maps[[i]] = list()
        for (j in 1:ncrop) {
            maps[[i]][[j]] = list()
            for (k in 1:nfarm) {
                map = raster(template)
                map[] = t(x[,,j,k,i])
                maps[[i]][[j]][[k]] = map
            }
        }
    }
    maps
}

