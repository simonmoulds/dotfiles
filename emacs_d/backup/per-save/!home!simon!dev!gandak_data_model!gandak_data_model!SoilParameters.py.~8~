class SoilParameters(object):
    def __init__(self, SoilParameters_variable):
        self.var = SoilParameters_variable
        self.var.SoilParameterOutputFile = vos.getFullPath(
            self.var._configuration.soilParameterOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)
    def initial(self):
        pass

    def read_raster_data(self, filename):
        vos.gdal_warp(
            filename,
            'tmp.tif',
            self.bbox[0],
            self.bbox[1],
            self.bbox[2],
            self.bbox[3])
        r = rasterio.open('tmp.tif')
        arr = r.read(masked=True)[0,...]
        # mask = np.ma.getmask(arr)
        # arr[mask] = 0.
        # crop_area.append(arr)
        os.remove('tmp.tif')
        return arr
        
    def dynamic(self):
        thfc0_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcpf2_topsoil_gapfilled_5m.tif',
            as_string=False)
        
        thfc1_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcpf2_subsoil_gapfilled_5m.tif',
            as_string=False)
        thfc0 = self.read_raster_data(thfc0_filename)
        thfc1 = self.read_raster_data(thfc1_filename)
        thfc = np.stack([thfc0, thfc1], axis=0)

        thwp0_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcpf4.2_topsoil_gapfilled_5m.tif',
            as_string=False)
        
        thwp1_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcpf4.2_subsoil_gapfilled_5m.tif',
            as_string=False)
        thwp0 = self.read_raster_data(thwp0_filename)
        thwp1 = self.read_raster_data(thwp1_filename)
        thwp = np.stack([thwp0, thwp1], axis=0)
    
        thsat0_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcsat_topsoil_gapfilled_5m.tif',
            as_string=False)
        
        thsat1_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcsat_subsoil_gapfilled_5m.tif',
            as_string=False)
        thsat0 = self.read_raster_data(thsat0_filename)
        thsat1 = self.read_raster_data(thsat1_filename)
        thsat = np.stack([thsat0, thsat1], axis=0)

        thres0_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcres_topsoil_gapfilled_5m.tif',
            as_string=False)
        
        thres1_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcres_subsoil_gapfilled_5m.tif',
            as_string=False)
        thres0 = self.read_raster_data(thres0_filename)
        thres1 = self.read_raster_data(thres1_filename)
        thres = np.stack([thres0, thres1], axis=0)

        ksat0_filename = get_data_smart(
            'gandak_data_model',
            '../data/ksat_topsoil_gapfilled_5m.tif',
            as_string=False)
        
        ksat1_filename = get_data_smart(
            'gandak_data_model',
            '../data/ksat_subsoil_gapfilled_5m.tif',
            as_string=False)
        ksat0 = self.read_raster_data(ksat0_filename)
        ksat1 = self.read_raster_data(ksat1_filename)
        ksat = np.stack([ksat0, ksat1], axis=0)

        cn = np.full((self.var.nLat, self.var.nLon), 50)                      # TEMPORARY
        calcshp = np.full((self.var.nLat, self.var.nLon), 0)
        evapzsurf = np.full((self.var.nLat, self.var.nLon), 0.04)
        evapzmin = np.full((self.var.nLat, self.var.nLon), 0.15)
        evapzmax = np.full((self.var.nLat, self.var.nLon), 0.30)
        kex = np.full((self.var.nLat, self.var.nLon), 1.1)
        fevap = np.full((self.var.nLat, self.var.nLon), 4)
        fwrelexp = np.full((self.var.nLat, self.var.nLon), 0.4)
        fwcc = np.full((self.var.nLat, self.var.nLon), 50)
        adjrew = np.full((self.var.nLat, self.var.nLon), 0)
        rew = np.full((self.var.nLat, self.var.nLon), 9)
        adjcn = np.full((self.var.nLat, self.var.nLon), 1)
        zcn = np.full((self.var.nLat, self.var.nLon), 0.3)
        zgerm = np.full((self.var.nLat, self.var.nLon), 0.3)
        zres = np.full((self.var.nLat, self.var.nLon), -999)
        fshape_cr = np.full((self.var.nLat, self.var.nLon), 16)
        
        soil_parameters = {
            'th_fc' : thfc,
            'th_wp' : thwp,
            'th_s' : thsat,
            'th_dry' : thres,
            'ksat' : ksat,
            'CN' : cn,
            'CalcSHP' : calcshp,
            'EvapZsurf' : evapzsurf,
            'EvapZmin' : evapzmin,
            'EvapZmax' : evapzmax,
            'Kex' : kex,
            'fevap' : fevap,
            'fWrelExp' : fwrelexp,
            'fwcc' : fwcc,
            'AdjREW' : adjrew,
            'REW' : rew,
            'AdjCN' : adjcn,
            'zCN' : zcn,
            'zGerm' : zgerm,
            'zRes' : zres,
            'fshape_cr' : fshape_cr
        }
        
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(self.var.SoilParameterOutputFile, soil_parameters.keys())
        for key, value in soil_parameters.iteritems():        
            netcdf.data2NetCDF(self.var.SoilParameterOutputFile, key, value)



        

        







        
