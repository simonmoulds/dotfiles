# The purpose of this file is to parse the configuration file

import ConfigParser
import os
import sys
import string
import pandas

from HydroModelBuilder import Configuration
from HydroModelBuilder import VirtualOS as vos
# import HydroModelBuilder as hm
import time
import datetime
import shutil
import glob
import warnings
import logging
logger = logging.getLogger(__name__)


class RefETConfiguration(Configuration):

    filename_dict = pandas.DataFrame({
        'filename' :    ['temperatureNC',
                         'subDailyTemperatureNC',
                         'minDailyTemperatureNC',
                         'maxDailyTemperatureNC',
                         'downwellingLongwaveRadiationNC',
                         'surfaceAtmosphericPressureNC',
                         'nearSurfaceSpecificHumidityNC',
                         'downwellingShortwaveRadiationNC'],
        'varname'  :    ['temperatureVarName',
                         'subDailyTemperatureVarName',
                         'minDailyTemperatureVarName',
                         'maxDailyTemperatureVarName',
                         'downwellingLongwaveRadiationVarName',
                         'surfaceAtmosphericPressureVarName',
                         'nearSurfaceSpecificHumidityVarName',
                         'downwellingShortwaveRadiationVarName'],
        'timedimname' : ['temperatureVarName',
                         'subDailyTemperatureVarName',
                         'minDailyTemperatureVarName',
                         'maxDailyTemperatureVarName',
                         'downwellingLongwaveRadiationVarName',
                         'surfaceAtmosphericPressureVarName',
                         'nearSurfaceSpecificHumidityVarName',
                         'downwellingShortwaveRadiationVarName']})

    def set_global_options(self):
        self.set_temporal_resolution()
        self.set_reference_ET_estimation_method()

    def set_temporal_resolution(self):
        self.check_temporal_resolution()
        self.timeStep = 1.0
        self.timeStepUnit = "day"
        
    def check_temporal_resolution(self):
        if 'timeStep' in self.globalOptions.keys() and 'timeStepUnit'in self.globalOptions.keys():
            if float(self.globalOptions['timeStep']) != 1.0 or self.globalOptions['timeStepUnit'] != "day":
                logger.error('The model runs only on daily time step. Please check your ini/configuration file')
                self.timeStep     = None
                self.timeStepUnit = None
    
    def set_reference_ET_estimation_method(self):
        self.check_reference_ET_estimation_method()
        self.RefETMethodSelection = self.globalOptions['method'].split(",")

    def check_reference_ET_estimation_method(self):
        if 'method' not in self.globalOptions.keys():
            logger.error('method not provided')
        elif self.globalOptions['method'] == "None":
            logger.error('method cannot be None')
        else:
            method_selection = self.globalOptions['method'].split(",")
            allowable_methods = ['PenmanMonteith','PriestleyTaylor','Hargreaves']
            methods_ok = all([method in allowable_methods for method in method_selection])
            if not methods_ok:
                logger.error('method must be one or more of PenmanMonteith, PriestleyTaylor, Hargreaves')

    def set_input_files(self):
        self.set_clone_map()
        self.set_meteo_files()

    def set_clone_map(self):
        self.cloneMap = vos.getFullPath(self.globalOptions['cloneMap'], self.globalOptions['inputDir'])

    def set_meteo_files(self):
        self.check_meteo_input_filenames_are_provided()
        self.check_meteo_variable_names()
        for item in self.meteo_input_files:
            self.meteoOptions[item] = vos.getFullPath(self.meteoOptions[item], self.globalOptions['inputDir'])
    
    def check_meteo_input_filenames_are_provided(self):
        self.get_required_meteo_input_filenames()        
        input_files_not_provided = [key not in self.meteoOptions.keys() for key in self.meteo_input_files]
        input_files_none = [self.meteoOptions[item] == "None" for item in self.meteo_input_files]
        msg = ''
        sep = ', '
        if any(input_files_not_provided):
            missing_files = sep.join([key for (key, index) in zip(self.meteo_input_files, input_files_not_provided) if index])
            msg += 'The following required input files are not provided: ' + missing_files + '\n'
        if any(input_files_none):
            none_files = sep.join([key for (key, index) in zip(self.meteo_input_files, input_files_none) if index])
            msg += ('The ' if msg == '' else 'Additionally, the') + 'following input files cannot be None: ' + none_files + '\n'
        if any(input_files_not_provided) or any(input_files_none):
            logger.error(msg)

    def get_required_meteo_input_filenames(self):
        """Function returning a list of meteorological input file keys 
        required by the selected ET estimation methods
        """
        # All methods require mean, minimum and maximum temperature
        self.meteo_input_files = ['temperatureNC']
        # Tmin, Tmax can either be provided in daily files, or computed
        # from subdaily temperature data
        self.repair_subdaily_temperature_option()
        if self.meteoOptions['compute_daily_min_max_temperature_from_subdaily_data']:
            self.meteo_input_files.append('subDailyTemperatureNC')
        else:
            self.meteo_input_files += ['minDailyTemperatureNC','maxDailyTemperatureNC']

        # PriestleyTaylor and PenmanMonteith additionally require
        # data about radiation, pressure and humidity
        if any([method in self.RefETMethodSelection for method in ['PriestleyTaylor','PenmanMonteith']]):
            self.meteo_input_files += [
                'downwellingLongwaveRadiationNC',
                'surfaceAtmosphericPressureNC',
                'nearSurfaceSpecificHumidityNC',
                'downwellingShortwaveRadiationNC']

        # Further, PenmanMonteith requires wind speed
        if 'PenmanMonteith' in self.RefETMethodSelection:
            self.meteo_input_files.append('nearSurfaceWindSpeedNC')

    def check_meteo_variable_names(self):
        """Function which checks that for each input file key, there 
        is a corresponding key specifying the variable name in the 
        netCDF file
        """
        msg = ''
        missing_varname = False
        for filename, varname in zip(self.filename_dict.filename, self.filename_dict.varname):
            if filename in self.meteo_input_files:
                if not varname in self.meteoOptions.keys():
                    missing_varname = True
                    msg += 'Configuration does not specify ' + varname + ' \n'
        if missing_varname:
            logger.error(msg)

    def check_meteo_time_dimension_names(self):
        for filename, timedimname in zip(self.filename_dict.filename, self.filename_dict.timedimename):
            if filename in self.meteo_input_files:
                if not timedimname in self.meteoOptions.keys():
                    self.meteoOptions[varname] = 'time'
            
    def repair_subdaily_temperature_option(self):
        if 'compute_daily_min_max_temperature_from_subdaily_data' not in self.meteoOptions.keys():
            self.meteoOptions['compute_daily_min_max_temperature_from_subdaily_data'] = "False"
        
    def backup_configuration(self):
        """Function to copy ini file to log directory"""
        shutil.copy(
            self.iniFileName,
            self.logFileDir + os.path.basename(self.iniFileName) + '_'
            + str(self._timestamp.isoformat()).replace(":",".") + '.ini')
