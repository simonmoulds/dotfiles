[FILE_PATHS]
PathIn = /home/simon/dev/wbm/data-raw/data
PathOut = /home/simon/dev/wbm/data-raw/data

[MODEL_GRID]
# cloneMap = ${FILE_PATHS:PathIn}/africa_etref_clone_0pt25degree.tif
# landmask = ${FILE_PATHS:PathIn}/africa_etref_landmask_0pt25degree.tif
mask = ${FILE_PATHS:PathIn}/africa_etref_landmask_0pt25degree.tif

[CLOCK]
startTime = 2000-01-01
endTime = 2000-12-31
timeDelta = 1 day

[NETCDF_ATTRIBUTES]
institution = Department of Civil and Environmental Engineering, Imperial College London
title       = etref model output
description = 
netcdf_y_orientation_follow_cf_convention = True
formatNetCDF = NETCDF4
zlib = True

[ET_METHOD]
method = PenmanMonteith

[WEATHER]
compute_daily_min_max_temperature_from_subdaily_data = False
compute_daily_mean_temperature_from_subdaily_data = False

meanDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA_{year:0>4}_tavg.nc4
meanDailyTemperatureVarName = tavg

minDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA_{year:0>4}_tmin.nc4
minDailyTemperatureVarName = tmin

maxDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA_{year:0>4}_tmax.nc4
maxDailyTemperatureVarName = tmax

subDailyTemperatureNC = None
subDailyTemperatureVarName = None

downwellingLongwaveRadiationNC = None
downwellingLongwaveRadiationVarName = None

surfaceAtmosphericPressureNC = ${FILE_PATHS:PathIn}/PSurf_daily_WFDEI/PSurf_daily_WFDEI_{year:0>4}{month:0>2}.nc
surfaceAtmosphericPressureVarName = PSurf

specificHumidityNC = None
specificHumidityVarName = None

maxRelativeHumidityNC = ${FILE_PATHS:PathIn}/AgMERRA_{year:0>4}_rhstmax.nc4
maxRelativeHumidityVarName = rhstmax

minRelativeHumidityNC = None
minRelativeHumidityVarName = None

meanRelativeHumidityNC = None
meanRelativeHumidityVarName = None

downwellingShortwaveRadiationNC = ${FILE_PATHS:PathIn}/AgMERRA_{year:0>4}_srad.nc4
downwellingShortwaveRadiationVarName = srad

windSpeedNC = ${FILE_PATHS:PathIn}/AgMERRA_{year:0>4}_wndspd.nc4
windSpeedVarName = wndspd

[REPORTING]
report = True
daily_total = ETref
