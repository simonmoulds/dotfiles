#!/usr/bin/env python
# -*- coding: utf-8 -*-

import netCDF4 as nc
import numpy as np
import shutil
import os
import rasterio

def run():

    datadir = '../data'

    # currently the only spatially-explicit variables
    # we consider are planting/harvest date.

    # read geotiffs containing planting/harvest day
    pd_map = rasterio.open(
        os.path.join(
            datadir,
            'maize_planting_julian_day_sachs2010.tif',
        )
    )
    pd_vals = pd_map.read(1, masked=True)
    pd_vals = np.floor(pd_vals)
    pd_vals = pd_vals.astype(np.int32)
    
    hd_map = rasterio.open(
        os.path.join(
            datadir,
            'maize_harvest_julian_day_sachs2010.tif'
        )
    )
    hd_vals = hd_map.read(1, masked=True)
    hd_vals = np.floor(hd_vals)
    hd_vals = hd_vals.astype(np.int32)

    # plant pop
    pp_vals = np.zeros_like(hd_vals) + 50000

    ccx_vals = np.zeros_like(hd_vals).astype(np.float64) + 0.7
    ccx_vals.fill_value = nc.default_fillvals['f8']
    
    # get coordinate characteristics
    bbox = pd_map.bounds
    xmin,ymin,xmax,ymax = bbox[0],bbox[1],bbox[2],bbox[3]
    nlat = pd_map.height
    nlon = pd_map.width
    transform = pd_map.transform
    lon = np.arange(nlon) * transform[0] + transform[2]
    lat = np.arange(nlat) * transform[4] + transform[5]
    lon += transform[0] / 2         # mid-point
    lat += transform[4] / 2         # mid-point

    # create netCDF
    filename = 'crop_parameters.nc'
    filepath = os.path.join(datadir, filename)
    nco = nc.Dataset(filepath, 'w')

    nco.createDimension('lon', nlon)
    nco.createDimension('lat', nlat)
    nco.createDimension('crop', 1)

    lono = nco.createVariable('lon', 'f8', ('lon',))
    lono.units = 'degrees_east'
    lono.standard_name = 'longitude'
    lono[:] = lon

    lato = nco.createVariable('lat', 'f8', ('lat'))
    lato.units = 'degrees_north'
    lato.standard_name = 'latitude'
    lato[:] = lat

    crop = nco.createVariable('crop', 'i4', ('crop'))
    crop.units = '1'
    crop[:] = 1

    crso = nco.createVariable('crs','i4')
    crso.long_name = 'Lon/Lat Coords in WGS84'
    crso.grid_mapping_name = 'latitude_longitude'
    crso.longitude_of_prime_meridian = 0.0
    crso.semi_major_axis = 6378137.0
    crso.inverse_flattening = 298.257223563

    pd = nco.createVariable('PlantingDate', 'f8', ('crop','lat','lon'), fill_value=pd_vals.fill_value)
    pd.units = '1'
    pd.standard_name = 'PlantingDate'
    pd.long_name = 'Planting date'
    # pd[:] = pd_map.read(1, masked=True)
    pd[:] = pd_vals

    hd = nco.createVariable('HarvestDate', 'f8', ('crop','lat','lon'), fill_value=hd_vals.fill_value)
    hd.units = '1'
    hd.standard_name = 'HarvestDate'
    hd.long_name = 'Harvest date'
    # hd[:] = hd_map.read(1, masked=True)
    hd[:] = hd_vals

    pp = nco.createVariable('PlantPop', 'f8', ('crop','lat','lon'), fill_value=pp_vals.fill_value)
    pp.units = '1'
    pp.standard_name = 'PlantPop'
    pp.long_name = 'Plant population'
    pp[:] = pp_vals

    ccx = nco.createVariable('CCx', 'f8', ('crop','lat','lon'), fill_value=ccx_vals.fill_value)
    ccx.units = '1'
    ccx.standard_name = 'CCx'
    ccx.long_name = 'maximum canopy cover'
    ccx[:] = ccx_vals
    nco.close()

if __name__ == "__main__":
    run()
