        CWATMDIR, 'cwatm_input', 'landcover', lc, 'rootFraction1.nc'))
    rf1_data = rf1.variables['rootFraction1'][:]
    lat = rf1.variables['lat'][:]
    lon = rf1.variables['lon'][:]
    nlon = lon.size
    nlat = lat.size
    rf1.close()

    rf1_data = np.ma.array(
        data=rf1_data.data,
        mask=np.isnan(rf1_data.data),
        dtype=np.float32,
        fill_value=F4_FILLVAL
    )

    rf2 = netCDF4.Dataset(os.path.join(
        CWATMDIR, 'cwatm_input', 'landcover', lc, 'rootFraction2.nc')
