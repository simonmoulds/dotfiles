import os
import numpy as np
from hm import file_handling

from .LandCoverData import *

class LandSurfaceData(object):
    def __init__(self, model):
        self.model = model
        self.land_cover_modules = {
            'forest'      : Forest(model, 'forest'),
            'grassland'   : Grassland(model, 'grassland'),
            'irrPaddy'    : IrrPaddy(model, 'irrPaddy'),
            'irrNonPaddy' : IrrNonPaddy(model, 'irrNonPaddy'),
            'sealed'      : Sealed(model, 'sealed'),
            'water'       : Water(model, 'water')
            }
        self.land_cover_module_names = self.land_cover_modules.keys()
        
    def initial(self):
        for module in self.land_cover_modules.keys():
            print(module)
            self.land_cover_modules[module].initial()

    def dynamic(self):
        for module in self.land_cover_modules.keys():
            print(module)
            self.land_cover_modules[module].dynamic()
