#!/bin/bash

# This script is run from
# 'run_grass_process_village_census.sh'

export GRASS_MESSAGE_FORMAT=plain

# wd=/home/simon/projects/gandak_systems_model_data
datadir=/data/india_village_level_geospatial_socio_econ_data
outdir=/home/simon/projects/india_village_census/data

# bbox (set to India extent)
north=36
south=6
east=98
west=68

# region settings
g.region \
    n=$north \
    s=$south \
    e=$east \
    w=$west \
    res=0:00:30 \
    save=india_30s \
    --overwrite

r.mapcalc "template = 1" --overwrite

if [ -d /data/iiasa-ifpri-cropland-map ]
then
    rm -r /data/iiasa-ifpri-cropland-map
fi
unzip /data/cropland_hybrid_10042015v9.zip -d /data/iiasa-ifpri-cropland-map

gdal_translate \
    -of GTiff \
    /data/iiasa-ifpri-cropland-map/Hybrid_10042015v9.img \
    /data/iiasa-ifpri-cropland-map/Hybrid_10042015v9.tif

gdalwarp \
    -te $west $south $east $north \
    /data/iiasa-ifpri-cropland-map/Hybrid_10042015v9.tif \
    /data/iiasa-ifpri-cropland-map/Hybrid_10042015v9_cropped.tif

r.in.gdal \
    input=/data/iiasa-ifpri-cropland-map/Hybrid_10042015v9_cropped.tif \
    output=tmp \
    --overwrite

r.mapcalc \
    "iiasa_ifpri_crop_map = tmp / 100" \
    --overwrite

# all states in the IGP
declare -a suffixes=("RJ" "PB" "HP" "HR" "UK" "UP" "MP" "CH" "JH" "BH" "WB")
# # all states in dataset
# declare -a suffixes=(
#     "AP" "AR" "AS" "BR" "CG" "GA" "GJ" "HR" "HP"
#     "JK" "JH" "KA" "KL" "MP" "MH" "MN" "ML" "MZ"
#     "NL" "OR" "PB" "RJ" "SK" "TN" "TR" "UP" "UK"
#     "WB" "UTerr")

for state in "${suffixes[@]}"
do    
    # import the data
    infile=$datadir/india-village-census-2001-"${state}"_ll.gpkg
    v.in.ogr \
        input="${infile}" \
        output="${state}"_census_2001 \
        snap=1e-12 --overwrite

    # set the region to the state boundary, add a
    # buffer of 5 arcminute, align with template
    g.region vector="${state}"_census_2001
    g.region \
        n=n+0:05 \
        s=s-0:05 \
        e=e+0:05 \
        w=w-0:05
    g.region align=template res=0:00:30
    g.region -p

    # create a vector map representation of a
    # regular coordinate grid which corresponds
    # with the resolution and extent of the
    # intended raster map    
    v.mkgrid \
        map="${state}"_grid_30s \
        type=area --overwrite

    v.db.addcolumn \
        map="${state}"_grid_30s \
        columns="cropland_pct double precision"
    
    v.what.rast \
        map="${state}"_grid_30s \
        type=centroid \
        raster=iiasa_ifpri_crop_map \
        column=cropland_pct

    # v.out.ogr \
    # 	input="${state}"_grid_30s \
    # 	output="${outdir}"/"${state}"_grid_30s.gpkg \
    # 	--overwrite

    # # remove to save memory
    # g.remove \
    #     -f \
    #     type=vector \
    #     name="${state}"_census_2001
done

