def lookup_crop_id(crop_ref, column):
    row_ix = [i for i,s in enumerate(crop_names['ID']) if crop_ref.upper() in s]
    if len(row_ix) == 1:
        row_ix = row_ix[0]
    return crop_names[column][row_ix]
