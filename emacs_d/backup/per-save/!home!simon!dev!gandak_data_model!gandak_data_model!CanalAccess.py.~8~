#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import numpy as np
import rasterio

from hydro_model_builder.ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list
from utils import *

class CanalAccess(object):    
    def __init__(self, CanalAccess_variable):
        self.var = CanalAccess_variable
        self.var.CanalAccessOutputFile = vos.getFullPath(
            self.var._configuration.canalAccessOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)

    def initial(self):
        pass

    def dynamic(self):
        canal_access_filename = get_data_smart(
            'gandak_data_model',
            '../data/channel_network_IDs.asc',
            as_string = False)
        canal_access = read_gdal_raster_image(
            canal_access_filename,
            self.bbox,
            0)
        canal_access[canal_access > 0] = 1
        canal_access = np.broadcast_to(canal_access[None,:,:], (self.var.nFarm, self.var.nLat, self.var.nLon))
        netcdf = np2netCDF(self.var._configuration, self.var.dimensions, variable_list)        
        netcdf.create_netCDF(self.var.CanalAccessOutputFile, 'canal_access')        
        netcdf.data2NetCDF(
            self.var.CanalAccessOutputFile,
            'canal_access',
            canal_access)
