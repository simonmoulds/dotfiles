class FieldManagementParameters(object):
    def __init__(self, FieldManagementParameters_variable):
        self.var = FieldManagementParameters_variable
        self.var.FieldManagementParameterOutputFile = vos.getFullPath(
            self.var._configuration.fieldManagementParameterOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        
    def initial(self):
        self.var.field_mgmt_parameter_names = [
            'Mulches','MulchPctGS','MulchPctOS','fMulch','Bunds',
            'zBund','BundWater']
        arr_zeros = np.zeros((self.var.nCrop, self.var.nLat, self.var.nLon))
        for param in self.var.field_mgmt_parameter_names:
            vars(self.var)[param] = arr_zeros.copy()

    def dynamic(self):
        self.var.MulchPctGS[:] = 50.
        self.var.MulchPctOS[:] = 50.
        self.var.fMulch[:] = 0.5        
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)
        netcdf.create_netCDF(self.var.FieldManagementParameterOutputFile, self.var.field_mgmt_parameter_names)
        for param in self.var.field_mgmt_parameter_names:
            netcdf.data2NetCDF(self.var.FieldManagementParameterOutputFile, param, vars(self.var)[param])
        
