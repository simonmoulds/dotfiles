#!/usr/bin/env python
# coding: utf-8

import os
import shutil
import numpy as np
import datetime
import time
import glob
import configparser
import collections

datadir = "../data"
out_dir = "../data/aquacrop_grid"
if not os.path.exists(out_dir):    
    os.makedirs(out_dir)

starttime = datetime.datetime(1980, 1, 1)
endtime = datetime.datetime(2010, 12, 31)

crops = {
    'ghana' : ['maize','sorghum'],
    'kenya' : ['maize','wheat','sorghum']
    }

ids_dict = {'maize' : 2, 'wheat' : 10, 'sorghum' : 13}

def main():

    for country in ['ghana','kenya']:
        run_input_dir = os.path.join(out_dir, country, "input")
        run_output_dir = os.path.join(out_dir, country, "output")
        run_config_dir = os.path.join(out_dir, country, "config")
        if os.path.exists(run_input_dir):
            shutil.rmtree(run_input_dir)
        if os.path.exists(run_config_dir):
            shutil.rmtree(run_config_dir)
        os.makedirs(run_config_dir)
        os.makedirs(run_input_dir)
        if not os.path.exists(run_output_dir):
            os.makedirs(run_output_dir)

        for crop in crops.get(country):
        
            config = configparser.ConfigParser()
            config.optionxform = str
            config['FILE_PATHS'] = collections.OrderedDict([
                ('PathIn', os.path.abspath(run_input_dir)),
                ('PathOut', os.path.join(os.path.abspath(run_output_dir), crop))
            ])

            config['MODEL_GRID'] = collections.OrderedDict([
                ('cloneMap', '${FILE_PATHS:PathIn}/../../' + country + '_aquacrop_clone_0pt25degree.tif'),
                ('landmask', '${FILE_PATHS:PathIn}/../../' + country + '_aquacrop_landmask_0pt25degree.tif')
            ])

            config['CLOCK'] = collections.OrderedDict([
                ('startTime', str(starttime.year) + '-' + str(starttime.month) + '-' + str(starttime.day)),
                ('endTime', str(endtime.year) + '-' + str(endtime.month) + '-' + str(endtime.day)),
            ])

            config['INITIAL_WATER_CONTENT'] = collections.OrderedDict([
                ('initialConditionType', 'percent'),
                ('initialConditionPercent', str(25)),
                ('initialConditionInterpMethod', str(None))
            ])

            config['NETCDF_ATTRIBUTES'] = collections.OrderedDict([
                ('institution', 'Imperial College London, UK'),
                ('title', 'AquaCrop v5.0 output'),
                ('description', 'test version (by Simon Moulds)'),
                ('netcdf_y_orientation_follow_cf_convention', 'True'),
                ('formatNetCDF', 'NETCDF4'),
                ('zlib', 'True')
            ])            

            config['WEATHER'] = collections.OrderedDict([
                ('precipitationNC', '${FILE_PATHS:PathIn}/../../AgMERRA/AgMERRA_{year:0>4}_prate.nc4'),
                ('precipitationVarName', 'prate'),
                ('precipitationTimeDimName', 'time'),
                ('precipitationOffset', str(0)),
                ('precipitationFactor', str(1)),
                ('meanDailyTemperatureNC', '${FILE_PATHS:PathIn}/../../AgMERRA/AgMERRA_{year:0>4}_tavg.nc4'),
                ('meanDailyTemperatureVarName', 'tavg'),
                ('meanDailyTemperatureTimeDimName', 'time'),
                ('meanDailyTemperatureOffset', str(0)),
                ('meanDailyTemperatureFactor', str(1)),
                ('minDailyTemperatureNC', '${FILE_PATHS:PathIn}/../../AgMERRA/AgMERRA_{year:0>4}_tmin.nc4'),
                ('minDailyTemperatureVarName', 'tmin'),
                ('minDailyTemperatureTimeDimName', 'time'),
                ('minDailyTemperatureOffset', str(0)),
                ('minDailyTemperatureFactor', str(1)),
                ('maxDailyTemperatureNC', '${FILE_PATHS:PathIn}/../../AgMERRA/AgMERRA_{year:0>4}_tmax.nc4'),
                ('maxDailyTemperatureVarName', 'tmax'),
                ('maxDailyTemperatureTimeDimName', 'time'),
                ('maxDailyTemperatureOffset', str(0)),
                ('maxDailyTemperatureFactor', str(1)),
                ('refEvapotranspirationNC', '${FILE_PATHS:PathIn}/../../etref/' + country_+ '/output/netcdf/ETref_PenmanMonteith_dailyTot_output.nc'),
                ('refEvapotranspirationVarName', 'reference_crop_evapotranspiration'),
                ('refEvapotranspirationTimeDimName', 'time'),
                ('refEvapotranspirationOffset', str(0)),
                ('refEvapotranspirationFactor', str(1))
            ])

            config['CARBON_DIOXIDE'] = collections.OrderedDict([
                ('carbonDioxideNC', '${FILE_PATHS:PathIn}/../../co2_annual_mean_mlo_0pt25degree.nc')
            ])

            config['WATER_TABLE'] = collections.OrderedDict([
                ('WaterTable', str(0)),
                ('VariableWaterTable', str(0)),
                ('groundwaterVarName', str(None)),
                ('groundwaterInputDir', str(None)),
                ('DailyGroundwaterNC', str(0)),
                ('groundwaterInputFile', str(None))
            ])

            config['LAND_COVER'] = collections.OrderedDict([])

            config['CROP_PARAMETERS'] = collections.OrderedDict([
                ('nCrop', str(1)),
                ('cropParametersNC', '${FILE_PATHS:PathIn}/../../' + crop + '_crop_parameters.nc'),
                ('CalendarType', str(2)),
                ('SwitchGDD', str(1)),
                ('GDDmethod', str(1)),
                ('cropID', str(ids_dict.get(crop))),
                ('outDailyTotal', str(None)),
                ('outYearMaxNC', str('Y'))
            ])

            config['IRRIGATION_MANAGEMENT'] = collections.OrderedDict([
                ('irrigationManagementNC', str(None)),
                ('irrigationScheduleNC', str(None))
            ])

            config['FIELD_MANAGEMENT'] = collections.OrderedDict([
                ('fieldManagementNC', str(None))
            ])

            zlayer = [0.1,0.25,0.65,1.3]
            zcomp = [0.1,0.1,0.1,0.15,0.15,0.2,0.2,0.25,0.25,0.25,0.25,0.3]
            config['SOIL_HYDRAULIC_PARAMETERS'] = collections.OrderedDict([
                ('calculateSoilHydraulicParametersFromSoilTexture', '0'),
                ('soilHydraulicParametersNC', '${FILE_PATHS:PathIn}/../../soil_hydraulic_parameters.nc'),
                ('saturatedHydraulicConductivityVarName', 'k_sat'),
                ('saturatedVolumetricWaterContentVarName', 'th_sat'),
                ('fieldCapacityVolumetricWaterContentVarName', 'th_crit'),
                ('wiltingPointVolumetricWaterContentVarName', 'th_wilt'),
                ('dzSoilLayer',','.join(['%.5f' % num for num in zlayer])),
                ('dzSoilCompartment',','.join(['%.5f' % num for num in zcomp]))
            ])

            config['SOIL_PARAMETERS'] = collections.OrderedDict([
                ('soilParametersNC', str(None)),
                ('adjustReadilyAvailableWater', str(0)),
                ('adjustCurveNumber', str(1))
            ])        

            config['REPORTING'] = collections.OrderedDict([
                ('formatNetCDF', 'NETCDF4'),
                ('zlib', 'True')
            ])

            config_fn = os.path.join(run_config_dir, 'aquacrop_' + crop + '_rainfed_' + country + '_agmerra_config.ini')
            with open(config_fn, 'w') as f:
                config.write(f)

if __name__ == '__main__':
    main()
