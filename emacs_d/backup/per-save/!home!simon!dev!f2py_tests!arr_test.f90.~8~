    integer(int32), intent(in) :: nrow, ncol
    real(real64), dimension(nrow,ncol), intent(inout) :: a

    DO I=1,NROW
       DO J=1,NCOL
          A(I,J) = A(I,J) * 3.14
       END DO
    END DO
  
  END SUBROUTINE MULT0

