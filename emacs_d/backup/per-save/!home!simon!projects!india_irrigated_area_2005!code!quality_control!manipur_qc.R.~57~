## rice
## ####

xx[["irr_rice-winter"]] = xx[["irr_rice-autumn"]]
xx[["irr_rice-autumn"]] = 0

xx[["apy_rice-winter"]] %<>% locf_interp(9:11)

if (dist_nm %in% c("Bishnupur","Chandel","Churachandpur","East Imphal","Senapati","Tamenglong","Thoubal","Ukhrul")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 6:11, 5)
}

if (dist_nm %in% c("West Imphal")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 6:11, 4)
}

if (dist_nm %in% c("East Imphal","Chandel")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 2:4, c(1,5))
}

if (dist_nm %in% c("Churachandpur")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 2, c(1,3))
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 4, c(3,5))
}

