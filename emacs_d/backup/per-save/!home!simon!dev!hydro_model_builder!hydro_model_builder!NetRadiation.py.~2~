import os
import string
import numpy as np
from . import file_handling as vos
from . import Messages

alpha = 0.23 # albedo, 0.23 [-]
sigma = 4.903e-9 # stephan boltzmann [W m-2 K-4]

class NetRadiation(object):
    def __init__(self, NetRadiation_variable):
        self.var = NetRadiation_variable
        
    def initial(self):
        pass

    def compute_net_radiation(self):    
        Rso = np.maximum(0.1, ((0.75 + (2 * 0.00005)) * self.var.extraterrestrial_radiation)) # clear sky solar radiation MJ d-1
        Rsin_MJ = 0.086400 * self.var.shortwave_radiation
        Rlnet_MJ = (
            -sigma
            * ((self.var.tmax ** 4 + self.var.tmin ** 4) / 2)
            * (0.34 - 0.14 * np.sqrt(np.maximum(0, (self.var.ea_mean / 1000))))
            * (1.35 * np.minimum(1, (Rsin_MJ / Rso)) - 0.35))
        Rlnet_Watt = Rlnet_MJ / 0.086400
        self.var.net_radiation  = np.maximum(0, ((1 - alpha) * self.var.shortwave_radiation + Rlnet_Watt))
        
    def dynamic(self):
        self.compute_net_radiation()
