[FILE_PATHS]
PathIn = /home/simon/dev/hydro_model_builder/examples/WFDEI/input
PathOut = /home/simon/dev/hydro_model_builder/examples/WFDEI/output

[MODEL_GRID]
cloneMap = ${FILE_PATHS:PathIn}/Gandak30min.clone.tif
landmask = ${FILE_PATHS:PathIn}/Gandak30min.landmask.tif

[CLOCK]
startTime = 1982-05-01
endTime = 1983-10-30

[NETCDF_ATTRIBUTES]
institution = Centre for Water Systems, University of Exeter
title       = RefET model output
description = WFDEI example (by Simon Moulds) 
netcdf_y_orientation_follow_cf_convention = True
formatNetCDF = NETCDF4
zlib = True

[WEATHER]
compute_daily_min_max_temperature_from_subdaily_data = True

temperatureNC = ${FILE_PATHS:PathIn}/Tair_daily_WFDEI/Tair_daily_WFDEI_{year:0>4}{month:0>2}.nc
temperatureVarName = Tair
temperatureTimeDimName = timestp

subDailyTemperatureNC = ${FILE_PATHS:PathIn}/Tair_WFDEI/Tair_WFDEI_{year:0>4}{month:0>2}.nc
subDailyTemperatureVarName = Tair
subDailyTemperatureTimeDimName = timestp

downwellingLongwaveRadiationNC = ${FILE_PATHS:PathIn}/LWdown_daily_WFDEI/LWdown_daily_WFDEI_{year:0>4}{month:0>2}.nc
downwellingLongwaveRadiationVarName = LWdown
downwellingLongwaveRadiationTimeDimName = timestp

surfaceAtmosphericPressureNC = ${FILE_PATHS:PathIn}/PSurf_daily_WFDEI/PSurf_daily_WFDEI_{year:0>4}{month:0>2}.nc
surfaceAtmosphericPressureVarName = PSurf
surfaceAtmosphericPressureTimeDimName = timestp

nearSurfaceSpecificHumidityNC = ${FILE_PATHS:PathIn}/Qair_daily_WFDEI/Qair_daily_WFDEI_{year:0>4}{month:0>2}.nc
nearSurfaceSpecificHumidityVarName = Qair
nearSurfaceSpecificHumidityTimeDimName = timestp

downwellingShortwaveRadiationNC = ${FILE_PATHS:PathIn}/SWdown_daily_WFDEI/SWdown_daily_WFDEI_{year:0>4}{month:0>2}.nc
downwellingShortwaveRadiationVarName = SWdown
downwellingShortwaveRadiationTimeDimName = timestp

nearSurfaceWindSpeedNC = ${FILE_PATHS:PathIn}/Wind_daily_WFDEI/Wind_daily_WFDEI_{year:0>4}{month:0>2}.nc
nearSurfaceWindSpeedVarName = Wind
nearSurfaceWindSpeedTimeDimName = timestp

[REPORTING]
outDailyTotNC = ETref,tmin,tmax,tmean

