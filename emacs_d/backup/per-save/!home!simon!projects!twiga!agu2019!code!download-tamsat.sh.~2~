#!/bin/bash
#=======================================================#
# Download TAMSAT v3.0 rainfall estimates  (Jun 2018)   
#-------------------------------------------------------#
# Note: To download another timestep or anomaly files, 
# change the following line below accordingly:
# - filename=TAMSATv3.0_rfe_daily_$YYYY.zip 
#
# For pentadal, replace with:  
# - filename=TAMSATv3.0_rfe_pentadal_$YYYY.zip  
# For dekadal, replace with:  
# - filename=TAMSATv3.0_rfe_dekadal_$YYYY.zip
# For monthly, replace with:  
# - filename=TAMSATv3.0_rfe_monthly_$YYYY.zip 
# For seasonal, replace with:  
# - filename=TAMSATv3.0_rfe_seasonal_$YYYY.zip            
#=======================================================#

# Specify start and end years
start_year=2010
end_year=2019
out_dir=../data-raw

for YYYY in $(eval echo "{$start_year..$end_year}"); do
	filename=TAMSATv3.0_rfe_daily_$YYYY.zip
	echo $filename
	wget https://www.tamsat.org.uk/public_data/TAMSAT3/zip/$filename -d out_dir
done
