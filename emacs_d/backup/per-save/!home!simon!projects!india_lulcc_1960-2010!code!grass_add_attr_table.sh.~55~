7:Urban
8:Water bodies
9:Snow and ice" > categories.txt

echo 'export GRASS_MESSAGE_FORMAT=plain
r.mask -r
r.in.gdal input=maps/INDIA_LULC_MOD_2010.tif output=india
g.region rast=india
