library(magrittr)
library(dplyr)
library(raster)
library(sf)
library(sp)
library(rgdal)
library(xts)

source("code/helper-funs.R")

options(stringsAsFactors=FALSE)

## ============================= ##
## 1. precipitation and pet data ##
## ============================= ##

met_data_fn = file.path(
    "data-raw",
    "11_SWAT - Copy",
    "05_Meteo",
    "topmodel_hourly_met_data.csv"
)

met_data =
    read.csv(met_data_fn, header=TRUE) %>%
    mutate(time=as.POSIXct(
               time,
               tz="GMT",
               format="%Y-%m-%d %H:%M:%S")
           )
    
met_data = xts(
    data.frame(
        prec=met_data$prec,
        eto=met_data$eto
    ),
    order.by=met_data$time
)

rain = met_data$prec
eto = met_data$eto

## ==========================
## 2. digital elevation model
## ==========================

dem = raster(
    file.path(
        "data-raw",
        "11_SWAT - Copy",
        "02_DEM",
        "EU_DEM_v11.tif"
    )
)

## ============
## 3. landcover
## ============

## 3a. baseline scenario
lc_path = file.path("data-raw","11_SWAT - Copy","06_Landcover")
landcover_baseline = raster(
    file.path(
        lc_path,
        "01_Baseline",
        "Catchment_full_clip.tif"
    )) %>%
    raster::aggregate(fact=5, fun=modal) %>%
    setNames("landcover")

landcover_baseline_legend = read.csv(
    file.path(
        lc_path,
        "01_Baseline",
        "Landcover_codes.csv"
    ))

## 3b. peatland restoration
peatland_restoration = readOGR("data-raw/11_SWAT\ -\ Copy/06_Landcover/04_Peatland_restoration_scenario3/01_Location_of_peatland_restoration_units", layer="Peatland_restoration_units")
peatland_restoration = spTransform(
    peatland_restoration,
    crs(landcover_baseline)
)
peatland_restoration_raster = rasterize(
    peatland_restoration,
    landcover_baseline,
    field="Area"
)
peatland_restoration_raster[!is.na(peatland_restoration_raster)] = 1
names(peatland_restoration_raster) = "peatland_restoration_area"

x = add_peatland_area_to_landcover(landcover_baseline, landcover_baseline_legend, peatland_area=peatland_restoration_raster, peatland_legend_name="Restored peatland")
landcover_peatland = x$landcover
landcover_peatland_legend = x$landcover_legend

## 3c. woodland planting
landcover_woodland = raster(
    file.path(
        lc_path,
        "02_Woodland_scenario1",
        "Landcover_scenario_woodland_planting.tif"
    )) %>%
    raster::aggregate(fact=5, fun=modal) %>%
    setNames("landcover")

landcover_woodland_legend =
    rbind(
        landcover_baseline_legend,
        data.frame(
            Landcover_name=c(
                "Planted upland birch woodland",
                "Planted native broadleaf woodland1",
                "Planted native broadleaf woodland2",
                "Planted native broadleaf woodland3",
                "Planted native broadleaf woodland3",
                "Planted Scots pine"),
            ID=c(104,106,107,109,117,118)))

x = reorder_landcover_categories(landcover_woodland, landcover_woodland_legend)
landcover_woodland = x$landcover
landcover_woodland_legend = x$landcover_legend

## 3d. agroforestry
landcover_agroforestry = raster(
    file.path(
        lc_path,
        "03_Agroforest_scenario2",
        "Landcover_scenario_2_agroforestry.tif"
    )) %>%
    raster::aggregate(fact=5, fun=modal) %>%
    setNames("landcover")

landcover_agroforestry_legend =
    rbind(
        landcover_baseline_legend,
        data.frame(
            Landcover_name=c(
                "Planted upland birch woodland",
                "Planted native broadleaf woodland1",
                "Planted native broadleaf woodland2",
                "Planted native broadleaf woodland3",
                "Planted native broadleaf woodland3",
                "Planted Scots pine"),
            ID=c(104,106,107,109,117,118)))

x = reorder_landcover_categories(landcover_agroforestry, landcover_agroforestry_legend)
landcover_agroforestry = x$landcover
landcover_agroforestry_legend = x$landcover_legend

## ============================
## 4. crop coefficient (Kc) map
## ============================

## ID | Landcover name           | Kc
## 1  | Arable                   | 1.0
## 2  | Broadleaved forest       | 1.0
## 3  | Buildings                | 0.4
## 4  | Coniferous forest        | 1.0
## 5  | Felled woodland          | 0.5
## 6  | Heather                  | 0.5
## 7  | Heather matrix           | 0.5
## 8  | Mire                     | 1.05
## 9  | Mire matrix              | 1.05
## 10 | Mixed forest             | 1.0
## 11 | Moors and heathland      | 0.5
## 12 | Natural grassland        | 0.6
## 13 | Pastures                 | 0.6
## 14 | Sparsely vegetated areas | 0.4
## 15 | Water                    | 1.05

kc_baseline = landcover_baseline
kc_baseline[kc_baseline == 1] = 1.0   # Arable
kc_baseline[kc_baseline == 2] = 1.0   # Broadleaved forest
kc_baseline[kc_baseline == 3] = 0.4   # Buildings
kc_baseline[kc_baseline == 4] = 1.0   # Coniferous forest
kc_baseline[kc_baseline == 5] = 0.5   # Felled woodland
kc_baseline[kc_baseline == 6] = 0.5   # Heather
kc_baseline[kc_baseline == 7] = 0.5   # Heather matrix
kc_baseline[kc_baseline == 8] = 1.05  # Mire
kc_baseline[kc_baseline == 9] = 1.05  # Mire matrix
kc_baseline[kc_baseline == 10] = 1.0  # Mixed forest
kc_baseline[kc_baseline == 11] = 0.5  # Moors and heathland
kc_baseline[kc_baseline == 12] = 0.6  # Natural grassland
kc_baseline[kc_baseline == 13] = 0.6  # Pastures
kc_baseline[kc_baseline == 14] = 0.4  # Sparsely vegetated areas
kc_baseline[kc_baseline == 15] = 1.05 # Water
names(kc_baseline) = "kc"

## assume peatland is natural grassland
kc_peatland = landcover_peatland
kc_peatland[kc_peatland == 1] = 1.0   # Arable
kc_peatland[kc_peatland == 2] = 1.0   # Broadleaved forest
kc_peatland[kc_peatland == 3] = 0.4   # Buildings
kc_peatland[kc_peatland == 4] = 1.0   # Coniferous forest
kc_peatland[kc_peatland == 5] = 0.5   # Felled woodland
kc_peatland[kc_peatland == 6] = 0.5   # Heather
kc_peatland[kc_peatland == 7] = 0.5   # Heather matrix
kc_peatland[kc_peatland == 8] = 1.05  # Mire
kc_peatland[kc_peatland == 9] = 1.05  # Mire matrix
kc_peatland[kc_peatland == 10] = 1.0  # Mixed forest
kc_peatland[kc_peatland == 11] = 0.5  # Moors and heathland
kc_peatland[kc_peatland == 12] = 0.6  # Natural grassland
kc_peatland[kc_peatland == 13] = 0.6  # Pastures
kc_peatland[kc_peatland == 14] = 0.4  # Sparsely vegetated areas
kc_peatland[kc_peatland == 15] = 1.05 # Water
kc_peatland[kc_peatland == 16] = 0.6
names(kc_peatland) = "kc"

kc_woodland = landcover_woodland
kc_woodland[kc_woodland == 1] = 1.0   # Arable
kc_woodland[kc_woodland == 2] = 1.0   # Broadleaved forest
kc_woodland[kc_woodland == 3] = 0.4   # Buildings
kc_woodland[kc_woodland == 4] = 1.0   # Coniferous forest
kc_woodland[kc_woodland == 5] = 0.5   # Felled woodland
kc_woodland[kc_woodland == 6] = 0.5   # Heather
kc_woodland[kc_woodland == 7] = 0.5   # Heather matrix
kc_woodland[kc_woodland == 8] = 1.05  # Mire
kc_woodland[kc_woodland == 9] = 1.05  # Mire matrix
kc_woodland[kc_woodland == 10] = 1.0  # Mixed forest
kc_woodland[kc_woodland == 11] = 0.5  # Moors and heathland
kc_woodland[kc_woodland == 12] = 0.6  # Natural grassland
kc_woodland[kc_woodland == 13] = 0.6  # Pastures
kc_woodland[kc_woodland == 14] = 0.4  # Sparsely vegetated areas
kc_woodland[kc_woodland == 15] = 1.05 # Water
kc_woodland[kc_woodland == 16] = 1.0
kc_woodland[kc_woodland == 17] = 1.0
kc_woodland[kc_woodland == 18] = 1.0
kc_woodland[kc_woodland == 19] = 1.0
kc_woodland[kc_woodland == 20] = 1.0
kc_woodland[kc_woodland == 21] = 1.0
names(kc_woodland) = "kc"

## from the supplied legend:
## "400 stems per ha. Equivalent to 36% cover of closed woodland"
## so assume kc = kc_grass + 0.36 * (kc_woodland - kc_grass)
## = 0.6 + (0.36 * (1 - 0.6)) = 0.744
kc_agroforestry = kc_baseline
kc_agroforestry = landcover_agroforestry
kc_agroforestry[kc_agroforestry == 1] = 1.0   # Arable
kc_agroforestry[kc_agroforestry == 2] = 1.0   # Broadleaved forest
kc_agroforestry[kc_agroforestry == 3] = 0.4   # Buildings
kc_agroforestry[kc_agroforestry == 4] = 1.0   # Coniferous forest
kc_agroforestry[kc_agroforestry == 5] = 0.5   # Felled agroforestry
kc_agroforestry[kc_agroforestry == 6] = 0.5   # Heather
kc_agroforestry[kc_agroforestry == 7] = 0.5   # Heather matrix
kc_agroforestry[kc_agroforestry == 8] = 1.05  # Mire
kc_agroforestry[kc_agroforestry == 9] = 1.05  # Mire matrix
kc_agroforestry[kc_agroforestry == 10] = 1.0  # Mixed forest
kc_agroforestry[kc_agroforestry == 11] = 0.5  # Moors and heathland
kc_agroforestry[kc_agroforestry == 12] = 0.6  # Natural grassland
kc_agroforestry[kc_agroforestry == 13] = 0.6  # Pastures
kc_agroforestry[kc_agroforestry == 14] = 0.4  # Sparsely vegetated areas
kc_agroforestry[kc_agroforestry == 15] = 1.05 # Water
kc_agroforestry[kc_agroforestry == 104] = 0.744
kc_agroforestry[kc_agroforestry == 106] = 0.744
kc_agroforestry[kc_agroforestry == 107] = 0.744
kc_agroforestry[kc_agroforestry == 109] = 0.744
kc_agroforestry[kc_agroforestry == 117] = 0.744
kc_agroforestry[kc_agroforestry == 118] = 0.744
names(kc_agroforestry) = "kc"

writeRaster(kc_baseline, "kc_baseline.tif", format="GTiff", overwrite=TRUE)
writeRaster(kc_agroforestry, "kc_agroforestry.tif", format="GTiff", overwrite=TRUE)
writeRaster(kc_woodland, "kc_woodland.tif", format="GTiff", overwrite=TRUE)
    
## ===========================================
## 5. save the data in lists for each scenario
## ===========================================
baseline_scenario_data = list(
    rain=rain,
    eto=eto,
    dem=dem,
    landcover=landcover_baseline,
    landcover_legend=landcover_baseline_legend,
    kc=kc_baseline)

peatland_scenario_data = list(
    rain=rain,
    eto=eto,
    dem=dem,
    landcover=landcover_peatland,
    landcover_legend=landcover_peatland_legend,
    kc=kc_peatland)

woodland_scenario_data = list(
    rain=rain,
    eto=eto,
    dem=dem,
    landcover=landcover_woodland,
    landcover_legend=landcover_woodland_legend,
    kc=kc_woodland)

agroforestry_scenario_data = list(
    rain=rain,
    eto=eto,
    dem=dem,
    landcover=landcover_agroforestry,
    landcover_legend=landcover_agroforestry_legend,
    kc=kc_agroforestry)

saveRDS(baseline_scenario_data, "data/baseline_scenario_data.rds")
saveRDS(peatland_scenario_data, "data/peatland_scenario_data.rds")
saveRDS(woodland_scenario_data, "data/woodland_scenario_data.rds")
saveRDS(agroforestry_scenario_data, "data/agroforestry_scenario_data.rds")
