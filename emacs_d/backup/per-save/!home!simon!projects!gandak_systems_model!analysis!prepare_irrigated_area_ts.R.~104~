library(readxl)
bihar_nia = read_excel("data/ICRISAT/Bihar/dt_nca_gca_nia_gia_a_web.xlsx", skip=9)
up_nia = read_excel("data/ICRISAT/UttarPradesh/dt_nca_gca_nia_gia_a_web.xlsx", skip=9)
icrisat_nia = rbind(bihar_nia, up_nia)
icrisat_ids = c(901,902,903,904,906,907,911,220,221,222,224)
icrisat_nia %<>%
    filter(DIST %in% icrisat_ids) %>%
    filter(YEAR %in% 1980:2010)

years = icrisat_nia$YEAR
years = paste0(years, "-", substr(years + 1, 3, 4))
icrisat_nia$YEAR = years

lut = data.frame(
    DIST=icrisat_ids,
    GAUL_ID=c(17618,17613,17598,730,17628,17619,644,17894,17914,72651,17892)
)

icrisat_nia %<>%
    left_join(lut, ., by="DIST") %>%
    select("STNAME","DISTNAME","GAUL_ID","YEAR","NCA","GCA","NIA","GIA") %>%
    setNames(c("State","District","GAUL_ID","date","nca","gca","nia","gia")) %>%
    mutate(State = toupper(State)) %>%
    mutate(District = toupper(District)) %>%
    mutate(date = paste0("X", gsub("-","_",date))) %>%
    arrange(State,District) %>%
    group_by(State,District)

write.csv(icrisat_nia, "data/icrisat_nia_districtwise.csv", row.names=FALSE)

