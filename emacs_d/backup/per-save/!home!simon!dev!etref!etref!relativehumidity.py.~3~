class MaxRelativeHumidity(object):
    def __init__(self, model):
        self.model = model
        
    def initial(self):
        self.set_relative_humidity_input_filenames()
        # self.model.max_relative_humidity = np.zeros((self.model.nCell))

    def set_relative_humidity_input_filenames(self):
        keys = [
            'maxRelativeHumidityNC',
            'maxRelativeHumidityVarName',
            'maxRelativeHumidityTimeDimName'
        ]
        vals = [self.mode.config.WEATHER[key] for key in keys]
        self.model.max_relative_humidity_filename = vals[0]
        self.model.max_relative_humidity_variable_name = vals[1]
        self.model.max_relative_humidity_time_dim_name = vals[2]
        
    def read_relative_humidity_data(self):        
        if self.model.config.has_max_relative_humidity:  # This will probably break
            self.model.max_relative_humidity = open_hmdataarray(
                self.model.max_relative_humidity_filename,
                self.model.max_relative_humidity_variable_name,
                self.model.domain
            )
    def dynamic(self):
        self.read_relative_humidity_data()

