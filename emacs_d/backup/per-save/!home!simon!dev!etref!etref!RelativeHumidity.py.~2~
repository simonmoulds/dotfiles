#!/usr/bin/env python
# -*- coding: utf-8 -*-

import numpy as np

from hm import file_handling

class SpecificHumidity(object):
    def __init__(self, SpecificHumidity_variable):
        self.var = SpecificHumidity_variable
        
    def initial(self):
        self.set_surface_specific_humidity_input_filenames()

    def set_relative_humidity_input_filenames(self):
        keys = ['minRelativeHumidityNC',
                'minRelativeHumidityVarName',
                'minRelativeHumidityTimeDimName',
                'maxRelativeHumidityNC',
                'maxRelativeHumidityVarName',
                'maxRelativeHumidityTimeDimName',
                'meanRelativeHumidityNC',
                'meanRelativeHumidityVarName',
                'meanRRelativeHumidityTimeDimName',
        ]
        for key in keys:
            try:
                vars(self.var)[key] = self.var._configuration.WEATHER[key]
            except:
                vars(self.var)[key] = None
                
    def read_min_relative_humidity_data(self):
        if self.var.minRelativeHumidityNC is not None:            
            self.var.min_relative_humidity = file_handling.netcdf_to_array(
                self.var.minRelativeHumidityFileNC.format(
                    day=self.var._modelTime.currTime.day,
                    month=self.var._modelTime.currTime.month,
                    year=self.var._modelTime.currTime.year
                ),
                self.var.minRelativeHumidityVarName,
                str(self.var._modelTime.fulldate),
                useDoy = None,
                cloneMapFileName = self.var.cloneMapFileName,
                LatitudeLongitude = True)[self.var.landmask]
            self.var.has_min_relative_humidity = True
        else:
            self.var.has_min_relative_humidity = False

    def read_max_relative_humidity_data(self):
        if self.var.maxRelativeHumidityNC is not None:            
            self.var.max_relative_humidity = file_handling.netcdf_to_array(
                self.var.maxRelativeHumidityFileNC.format(
                    day=self.var._modelTime.currTime.day,
                    month=self.var._modelTime.currTime.month,
                    year=self.var._modelTime.currTime.year
                ),
                self.var.maxRelativeHumidityVarName,
                str(self.var._modelTime.fulldate),
                useDoy = None,
                cloneMapFileName = self.var.cloneMapFileName,
                LatitudeLongitude = True)[self.var.landmask]
            self.var.has_max_relative_humidity = True
        else:
            self.var.has_max_relative_humidity = False
            
    def read_mean_relative_humidity_data(self):
        if self.var.meanRelativeHumidityNC is not None:            
            self.var.mean_relative_humidity = file_handling.netcdf_to_array(
                self.var.meanRelativeHumidityFileNC.format(
                    day=self.var._modelTime.currTime.day,
                    month=self.var._modelTime.currTime.month,
                    year=self.var._modelTime.currTime.year
                ),
                self.var.meanRelativeHumidityVarName,
                str(self.var._modelTime.fulldate),
                useDoy = None,
                cloneMapFileName = self.var.cloneMapFileName,
                LatitudeLongitude = True)[self.var.landmask]
            self.var.has_mean_relative_humidity = True
        else:
            self.var.has_mean_relative_humidity = False
            
    def dynamic(self):
        self.read_min_relative_humidity_data()
        self.read_max_relative_humidity_data()
        self.read_mean_relative_humidity_data()
