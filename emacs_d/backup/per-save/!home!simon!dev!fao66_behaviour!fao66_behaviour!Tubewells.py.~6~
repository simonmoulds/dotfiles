        self.var.TubewellMaintenanceCost = np.full((self.var.nFarm, self.var.nCell), 10000)  # Rs
        self.var.TubewellInstallationCost = np.full((self.var.nFarm, self.var.nCell), 10000)  # Rs
        self.var.PumpCost = np.full((self.var.nFarm, self.var.nCell), 10000)  # Rs
        self.var.PumpLifespan = np.full((self.var.nFarm, self.var.nCell), 20) 
        self.var.PumpHorsePower = np.full((self.var.nFarm, self.var.nCell), 7.5)  # HP
        self.var.TubewellLifespan = np.full((self.var.nFarm, self.var.nCell), 20)  # years
        self.var.TubewellAge = np.zeros((self.var.nFarm, self.var.nCell))  # counter

