    def set_temperature_scale_factor(self):
        self.meanDailyTempFactor = \
            self.model.config.WEATHER['meanDailyTemperatureFactor']
        self.minDailyTempFactor = \
            self.model.config.WEATHER['minDailyTemperatureFactor']
        self.maxDailyTempFactor = \
            self.model.config.WEATHER['maxDailyTemperatureFactor']

    def read_temperature_data(self):        
        day = self.model._modelTime.currTime.day
        month = self.model._modelTime.currTime.month
        year = self.model._modelTime.currTime.year
        if self.model.compute_tmean_from_subdaily_data or self.model.compute_tmin_tmax_from_subdaily_data:
            self.read_subdaily_temperature_data(day, month, year)
            
        if self.model.compute_tmean_from_subdaily_data:
            self.compute_tmean_from_subdaily_data()
        else:
            self.read_daily_mean_temperature(day, month, year)
            
        if self.model.compute_tmin_tmax_from_subdaily_data:
            self.compute_tmin_from_subdaily_data()
            self.compute_tmax_from_subdaily_data()
        else:
            self.read_daily_min_temperature(day, month, year)
            self.read_daily_max_temperature(day, month, year)

    def update_temperature_data(self):
        self.model.tmin.update(time=self.model.time.curr_time)
        self.model.tmax.update(time=self.model.time.curr_time)
        self.model.tmean.update(time=self.model.time.curr_time)
