class Temperature(object):
    def __init__(self, model):
        self.model = model

    def initial(self):
        self.set_temperature_input_filenames()
        self.set_temperature_offset()
        self.set_temperature_scale_factor()
        self.read_temperature_data()
        
    def set_temperature_input_filenames(self):
        self.model.compute_tmin_tmax_from_subdaily_data = \
            self.model.config.WEATHER['compute_daily_min_max_temperature_from_subdaily_data']
        if self.model.compute_tmin_tmax_from_subdaily_data == 'True':
            self.model.compute_tmin_tmax_from_subdaily_data = True
        else:
            self.model.compute_tmin_tmax_from_subdaily_data = False

        self.model.compute_tmean_from_subdaily_data = \
            self.model.config.WEATHER['compute_daily_mean_temperature_from_subdaily_data']
        if self.model.compute_tmean_from_subdaily_data == 'True':
            self.model.compute_tmean_from_subdaily_data = True
        else:
            self.model.compute_tmean_from_subdaily_data = False
            
        if self.model.compute_tmean_from_subdaily_data or self.model.compute_tmin_tmax_from_subdaily_data:
            self.get_subdaily_temperature_netcdf_file()

        if not self.model.compute_tmean_from_subdaily_data:
            self.get_daily_average_temperature_netcdf_file()

        if not self.model.compute_tmin_tmax_from_subdaily_data:
            self.get_daily_min_temperature_netcdf_file()
            self.get_daily_max_temperature_netcdf_file()
                            
    def get_subdaily_temperature_netcdf_file(self):
        self.model.subDailyTempFileNC = \
            self.model.config.WEATHER['subDailyTemperatureNC']
        self.model.subDailyTempVarName = \
            self.model.config.WEATHER['subDailyTemperatureVarName']
        self.model.subDailyTimeDimName = \
            self.model.config.WEATHER['subDailyTemperatureTimeDimName']

