    def set_temperature_offset(self):
        self.meanDailyTempOffset = \
            self.model.config.WEATHER['meanDailyTemperatureOffset']
        self.minDailyTempOffset = \
            self.model.config.WEATHER['minDailyTemperatureOffset']
        self.maxDailyTempOffset = \
