    def apply_temperature_scale_factor(self):
        self.model.tmean *= self.meanDailyTempFactor
        self.model.tmin *= self.minDailyTempFactor
        self.model.tmax *= self.maxDailyTempFactor
                      
    def apply_temperature_offset(self):
        self.model.tmean -= self.meanDailyTempOffset
        self.model.tmin -= self.minDailyTempOffset
        self.model.tmax -= self.maxDailyTempOffset
        
