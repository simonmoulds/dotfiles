            self.model.config.WEATHER['meanDailyTemperatureVarName']
        self.model.meanDailyTempTimeDimName = \
            self.model.config.WEATHER['meanDailyTemperatureTimeDimName']

    def get_daily_min_temperature_netcdf_file(self):
