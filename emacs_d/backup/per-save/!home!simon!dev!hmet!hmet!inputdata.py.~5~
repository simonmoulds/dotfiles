from hm.input import HmInputData, HmSpaceInputData


class Wind(HmInputData):
    def __init__(self, model):
        self.model = model
        self.filename = \
            model.config.WEATHER['windSpeedNC']
        self.nc_varname = \
            model.config.WEATHER['windSpeedVarName']
        self.model_varname = 'wind'

        
