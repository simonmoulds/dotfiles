## The purpose of this script is to prepare a
## district-level time series of tubewell
## installation between 1982/83 - 2006/07

library(readxl)
library(raster)
library(rgdal)
library(magrittr)
library(dplyr)
library(tidyr)
library(xts)

options(stringsAsFactors = FALSE)

model_mask = raster("data/modelMask.tif")
template = raster(xmn=80, xmx=90, ymn=20, ymx=30, res=0.0833333333)

## Minor Irrigation Census data
## ############################

devtools::load_all("/home/simon/dev/r_indagridat/indagridat")

adm2_2010 = readOGR(dsn="pkg/india_adm2_2001/data", layer="g2008_2_India", stringsAsFactors=FALSE)
adm2_2010$ADM2_CODE %<>% as.numeric
adm2_2010_raster = rasterize(adm2_2010, template, "ADM2_CODE")

ids = c(70272,17914,70274,17894,70097,17619,17595,17626,17632,17613,17628,17620,70103,17630,17631,17604,17618,70271,17904)
## ids = c(17595,17604,17613,17618,17619,17620,17626,17628,17631,17632,17894,17914,70272,70274,72604,72651)

index = as.numeric(adm2_2010$ADM2_CODE) %in% ids
dist =
    adm2_2010$ADM2_NAME %>%
    as.character %>%
    `[`(index)
state =
    adm2_2010$ADM1_NAME %>%
    as.character %>%
    `[`(index)
gaul_id =
    adm2_2010$ADM2_CODE %>%
    as.numeric %>%
    `[`(index)

x = data.frame(state=state, dist=dist, gaul_id=gaul_id) %>% arrange(state)
    
