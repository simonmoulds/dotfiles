mi1993 =
    read.csv("data/minor_irrigation_census_1993-94_no_tubewells_installed.csv") %>%
    filter(State %in% c("BIHAR","UTTAR PRADESH")) %>%
    dplyr::select(-Upto.1986.87, -Total) %>%
    setNames(c("State","District","X1987_88","X1988_89","X1989_90","X1990_91","X1991_92","X1992_93","X1993_94")) %>%
    mutate(District = replace(District, District == "KUSHI NAGAR", "KUSHINAGAR")) %>%
    mutate(District = replace(District, District == "MAHRAJGANJ", "MAHARAJGANJ")) %>%
    mutate(District = replace(District, District == "CHAMPARAN WEST", "PASHCHIM CHAMPARAN")) %>%
    mutate(District = replace(District, District == "CHAMPARAN EAST", "PURBA CHAMPARAN")) %>%
    filter(District %in% toupper(x$dist)) %>%
    mutate(District = replace(District, District == "SHEOHAR", "SITAMARHI")) %>%
    mutate(District = replace(District, District == "KUSHINAGAR", "DEORIA")) %>%
    group_by(State, District) %>%
    summarise_all(funs(sum))    

mi2000 =
    read.csv("data/minor_irrigation_census_2000-01_no_tubewells_installed.csv") %>%
    filter(State %in% c("BIHAR","UTTAR PRADESH")) %>%
    dplyr::select(-starts_with("Upto"), -starts_with("Total")) %>%
    setNames(c("State","District","X1994_95","X1995_96","X1996_97","X1997_98","X1998_99","X1999_00","X2000_01")) %>%
    mutate(District = replace(District, District == "GOPAALGANJ", "GOPALGANJ")) %>%
    mutate(District = replace(District, District == "MAHARAJ GANJ", "MAHARAJGANJ")) %>%
    mutate(District = replace(District, District == "WEST CHAMPARAN", "PASHCHIM CHAMPARAN")) %>%
    mutate(District = replace(District, District == "EAST CHAMPARAN", "PURBA CHAMPARAN")) %>%
    filter(District %in% toupper(x$dist)) %>%
    mutate(District = replace(District, District == "SHEOHAR", "SITAMARHI")) %>%
    mutate(District = replace(District, District == "KUSHINAGAR", "DEORIA")) %>%
    group_by(State, District) %>%
    summarise_all(funs(sum))    

mi2006 =
    read.csv("data/minor_irrigation_census_2006-07_no_tubewells_installed.csv") %>%
    filter(STATE %in% c("BIHAR","UTTAR PRADESH")) %>%
    dplyr::select(-starts_with("UPTO"), -ends_with("COST"), -starts_with("TOTAL")) %>%
    setNames(c("State","District","X2001_02","X2002_03","X2003_04","X2004_05","X2005_06","X2006_07")) %>%
    mutate(District = replace(District, District == "GOPAALGANJ", "GOPALGANJ")) %>%
    mutate(District = replace(District, District == "MAHARAJ GANJ", "MAHARAJGANJ")) %>%
    mutate(District = replace(District, District == "WEST CHAMPARAN", "PASHCHIM CHAMPARAN")) %>%
    mutate(District = replace(District, District == "EAST CHAMPARAN", "PURBA CHAMPARAN")) %>%
    mutate(District = replace(District, District == "SHEOHAR", "SITAMARHI")) %>%
    mutate(District = replace(District, District == "KUSHINAGAR", "DEORIA")) %>%
    filter(District %in% toupper(x$dist)) %>%
    group_by(State, District) %>%
    summarise_all(funs(sum))

mi =
    mi1993 %>%
    left_join(mi2000) %>%
    left_join(mi2006) %>%
    gather(key=date, value=value, -State, -District) %>%
    arrange(State, District, date) %>%
    group_by(State, District) %>%
    mutate(value_cs=cumsum(value))

## mi = mi %>% dplyr::filter(District %in% "PASHCHIM CHAMPARAN")
## plot(mi$value_cs)

tubewell_gandak =
    mi %>%
    ungroup() %>%
    mutate(basin="Gandak") %>%
    group_by(basin, date) %>%
    summarise_at(vars(value_cs), funs(sum), na.rm=TRUE)
plot(tubewell_gandak$value_cs)

## write output
write.csv(tubewell_gandak, "data/minor_irrigation_census_no_tubewells_installed_gandak.csv", row.names=FALSE)

