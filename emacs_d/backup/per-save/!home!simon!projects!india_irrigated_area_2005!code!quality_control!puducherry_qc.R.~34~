## other pulses
## ############

if (dist_nm %in% c("Karaikal")) {
    xx[["apy_other_pulses-rabi"]][8:11] = xx[["apy_other_pulses-summer"]]
    xx[["irr_other_pulses-rabi"]][8:11] = xx[["irr_other_pulses-summer"]]
    xx[["apy_other_pulses-rabi"]] %<>% locf_interp(7)
    xx[["irr_other_pulses-rabi"]] %<>% locf_interp(7)
}

if (dist_nm %in% c("Puducherry")) {
    xx[["apy_other_pulses-rabi"]] %<>% linear_interp(7)
    xx[["irr_other_pulses-rabi"]][9:11] = xx[["irr_other_pulses-summer"]][9:11]
    xx[["irr_other_pulses-rabi"]] %<>% irr_frac_interp(xx[["apy_other_pulses-rabi"]], 7:8, c(6,9))
    xx[["apy_other_pulses-summer"]] = 0
    xx[["irr_other_pulses-summer"]] = 0
    xx[["apy_other_pulses-kharif"]] %<>% tot_frac_interp(xx[["irr_other_pulses-kharif"]], 1:4, 5)
    xx[["apy_other_pulses-kharif"]] %<>% tot_frac_interp(xx[["irr_other_pulses-kharif"]], 7, 6)
}

