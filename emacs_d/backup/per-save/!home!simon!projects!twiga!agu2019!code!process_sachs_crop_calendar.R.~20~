library(raster)
library(ncdf4)
library(magrittr)

ext = extent(c(-20, 55, -35, 38))

fs = list.files("../data-raw/sachs_crop_calendar", pattern="[a-z]+.crop.calendar.fill.nc", full.names=TRUE)
for (fn in fs) {
    crop =
        basename(fn) %>%
        gsub("([a-z]+).(crop.calendar.fill.nc)", "\\1", .) %>%
        tolower %>% gsub("\\.", "_", .)

    for (varname in c("plant","harvest")) {
        date =
            raster(fn, varname=varname) %>%
            crop(ext) %>%
            raster::aggregate(fact=3, fun=modal)
        ## date_start = raster(fn, varname="plant.start") %>% crop(ext)
        ## date_end = raster(fn, varname="plant.end") %>% crop(ext)
        outfn = file.path("../data", paste0(crop, "_", varname, "_julian_day_sachs2010.tif"))
        writeRaster(date, outfn, format="GTiff", overwrite=TRUE)
    }
}
