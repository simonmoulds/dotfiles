      "cell_type": "code",
      "source": "# Function to retrieve a pandas timeseries object for a specific station and variable through the TWIGA/HydroNET API.\n# INPUT:\n#   - station (string): Location identifier in HydroNET which can be retrieved from the location endpoint. E.g. \"TA00429\"\n#   - variable (string): The variable code for request variable which can be retrieved from the dataSourceVariables endpoint. E.g. \"TAHMO.Connectors.Stations.SoilMoisture\"\n#   - startDate (string): The HydroNET timestamp notation (YYYYmmddhhmmss). E.g. \"20181201000000\" for 2018-12-01 00:00:00 UTC.\n#   - endtDate (string): The HydroNET timestamp notation (YYYYmmddhhmmss). E.g. \"20181231000000\" for 2018-12-31 00:00:00 UTC.\n# OUTPUT:\n#   Pandas timeseries object (docs: https://pandas.pydata.org/pandas-docs/stable/timeseries.html)\n\ndef getTimeseries(station, variable, startDate, endDate, timeserieIndex=0):\n    requestBody = {\n        \"Readers\": [\n            {\n                \"DataSourceCode\": \"TAHMO.Connectors.Stations\",\n                \"Settings\": {\n                    \"LocationCodes\": [\n                        station\n                    ],\n                    \"VariableCodes\": [\n                        variable\n                    ],\n                    \"StartDate\": startDate,\n                    \"EndDate\": endDate,\n                    \"StructureType\": \"TimeSeries\"\n                }\n            }\n        ]\n    }\n    response = requests.post('https://tahmotwiga.mybluemix.net/twiga/api/timeSeries/get',\n                        json=requestBody,\n                        auth=requests.auth.HTTPBasicAuth(\n                          API_USER,\n                          API_PASSWORD))\n    \n    responseJSON = response.json()\n    \n    if 'Data' in responseJSON.keys() and len(responseJSON['Data']) > timeserieIndex and 'Data' in responseJSON['Data'][timeserieIndex].keys():\n        # Get array of all the values within the timeseries.\n        values = list(map(lambda timeserieElement: timeserieElement['Value'], responseJSON['Data'][timeserieIndex]['Data']))\n        \n        # Get array of all the dates in the timeseries in a supported date format (\"YYYY-mm-dd HH:ii:ss\").\n        dates = list(map(lambda timeserieElement: pd.Timestamp(\"%s-%s-%s %s:%s:%s\" % (timeserieElement['DateTime'][0:4], timeserieElement['DateTime'][4:6], timeserieElement['DateTime'][6:8], timeserieElement['DateTime'][8:10], timeserieElement['DateTime'][10:12], timeserieElement['DateTime'][12:14])), responseJSON['Data'][timeserieIndex]['Data']))\n    else:\n        values = []\n        dates = []\n        \n    return pd.Series(values, index=dates)",
      "execution_count": 10,
      "outputs": []
    },
