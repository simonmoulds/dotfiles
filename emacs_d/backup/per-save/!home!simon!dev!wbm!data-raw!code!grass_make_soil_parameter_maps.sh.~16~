#!/bin/bash

# grass script to spatially aggregate HiHydroSoil
# soil data

DATADIR=/data

if [ ! -d $DATADIR/HiHydroSoil ]
then
    mkdir $DATADIR/HiHydroSoil
fi

# ######################################################### #
# 1-Extract HiHydroSoil data                                #
# ######################################################### #

# main directory
if [ ! -f $DATADIR/HiHydroSoil/WCsat.7z ]
then
    7z x $DATADIR/HiHydroSoil.7z -o$DATADIR/HiHydroSoil
fi

# WCsat (saturated water content)
if [ ! -f $DATADIR/HiHydroSoil/wcsat_subsoil_gapfilled.txt ]
then
    7z x -aoa $DATADIR/HiHydroSoil/WCsat.7z -o$DATADIR/HiHydroSoil
fi

# WCpF2 (field capacity)
if [ ! -f $DATADIR/HiHydroSoil/wcpf2_subsoil_gapfilled.txt ]
then
    7z x -aoa $DATADIR/HiHydroSoil/WCpF2.7z -o$DATADIR/HiHydroSoil
fi

# WCpF4.2 (permanent wilting point)
if [ ! -f $DATADIR/HiHydroSoil/wcpf4.2_subsoil_gapfilled.txt ]
then
    7z x -aoa $DATADIR/HiHydroSoil/WCpF4.2.7z -o$DATADIR/HiHydroSoil
fi

# WCres (residual water content)
if [ ! -f $DATADIR/HiHydroSoil/wcres_subsoil_gapfilled.txt ]
then
    7z x -aoa $DATADIR/HiHydroSoil/WCres.7z -o$DATADIR/HiHydroSoil
fi

# Ksat (saturated hydraulic conductivity)
if [ ! -f $DATADIR/HiHydroSoil/ksat_subsoil_gapfilled.txt ]
then
    7z x -aoa $DATADIR/HiHydroSoil/KSAT.7z -o$DATADIR/HiHydroSoil
fi

# convert model mask file to geotiff w/ proper georeferencing

# gdal_translate \
#     -of GTiff \
#     -a_srs EPSG:4326\
#     $WD/data-raw/modelMask.asc \
#     $WD/data/modelMask.tif

g.region region=${DOMAIN}_0.083333Deg
eval `g.region -g`
gdalwarp \
    -t_srs EPSG:4326 \
    -te $w $s $e $n \
    -tr 0.08333333333333 0.08333333333333 \
    -r near \
    $WD/data/modelMask.tif \
    $WD/data/modelMask_resamp.tif \
    -overwrite

g.region region=gandak_0.083333Deg
g.region -p

for var in wcsat wcres ksat wcpf4.2 wcpf2
do
    for layer in topsoil subsoil
    do
        r.in.gdal \
	    -o \
	    input=${DATADIR}/HiHydroSoil/${var}_${layer}_gapfilled.txt output=${var}_${layer}_gapfilled --overwrite
        r.resamp.stats input=${var}_${layer}_gapfilled output=tmp method=average --overwrite
        r.mapcalc "${var}_${layer}_gapfilled_aggr = tmp / 10000" --overwrite
        g.remove -f type=raster name=tmp
        r.out.gdal input=${var}_${layer}_gapfilled_aggr output=${WD}/data/${var}_${layer}_gapfilled_5m.tif format=GTiff --overwrite
    done
done
