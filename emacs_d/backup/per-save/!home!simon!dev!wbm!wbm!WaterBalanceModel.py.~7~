#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import numpy as np

from hm import file_handling
from hm.Model import Model

from .Weather import Weather
from .Groundwater import Groundwater
from .LandSurface import LandSurface

import logging
logger = logging.getLogger(__name__)

class WaterBalanceModel(Model):    
    def __init__(self, configuration, modelTime, initialState = None):
        super(WaterBalanceModel, self).__init__(
            configuration,
            modelTime,
            initialState)

        self.weather = Weather(self)
        self.groundwater = Groundwater(self)
        self.land_surface = LandSurface(self)

    def get_model_dimensions(self):
        """Function to set model dimensions"""
        super(WaterBalanceModel, self).get_model_dimensions()
        self.nLayer = 3
        self.dimensions['depth'] = np.arange(self.nLayer)
        
    def initial(self):
        self.weather.initial()
        self.groundwater.initial()
        self.land_surface.initial()
        
    def dynamic(self):
        self.weather.dynamic()
        self.groundwater.dynamic()
        self.land_surface.dynamic()        
