# -*- coding: utf-8 -*-

import os
import shutil
import datetime
import numpy as np
import rasterio

from ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list
from utils import *

class LandCoverFrac(object):    
    def __init__(self, LandCoverFrac_variable):
        self.var = LandCoverFrac_variable
        self.var.LandCoverFracOutputFile = str(
            self.var._configuration.LANDCOVER['landCoverPathOut'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)

    def initial(self):
        pass

    def dynamic(self):
        lc_types = [lc.strip() for lc in self.var._configuration.LANDCOVER['landCoverTypes'].split(',')]
        veg_types = ['forest','grassland','irrPaddy','irrNonPaddy']
        natural_veg_types = ['forest','grassland']
        
        for lc in lc_types:
            config_section = getattr(self.var._configuration, lc)
            
            # land cover fraction
            lc_filename = str(config_section['landCoverFractionInputFile'])
            lc_output_filename = str(config_section['landCoverFractionOutputFile'])
            print lc_filename
            print lc_output_filename
            lc_output_variable_name = str(config_section['landCoverFractionOutputVariableName'])
            lc_frac = read_gdal_raster_image(lc_filename, self.bbox, 0)  # write to netCDF
            netcdf = np2netCDF(
                self.var._configuration,
                self.var.dimensions,
                variable_list)        
            netcdf.create_netCDF(
                lc_output_filename,
                lc_output_variable_name)        
            netcdf.data2NetCDF(
                lc_output_filename,
                lc_output_variable_name,
                lc_frac,
                timeStamp=datetime.datetime(
                    2009,1,1,0,0,0
                ))

            lc_outpath = str(config_section['landCoverTypePathOut'])       
            if lc in veg_types:
                # crop coefficient
                shutil.copy(
                    str(config_section['cropCoefficientInputFile']),
                    lc_outpath)
                
                # root fraction
                shutil.copy(
                    str(config_section['rootFractionInputFile']),
                    lc_outpath)
            
                # interception capacity
                if lc in natural_veg_types:
                    shutil.copy(
                        str(config_section['interceptCapInputFile']),
                        lc_outpath)

                # root depth
                shutil.copy(
                    str(config_section['maxRootDepthInputFile']),
                    lc_outpath)

                # alpha
                shutil.copy(
                    str(config_section['alphaInputFile']),
                    lc_outpath)

                # lambda
                shutil.copy(
                    str(config_section['lambdaInputFile']),
                    lc_outpath)
                    

            # relative elevation
            shutil.copy(
                str(config_section['relativeElevationInputFile']),
                lc_outpath)

            # elevation sd
            shutil.copy(
                str(config_section['elevationStandardDeviationInputFile']),
                lc_outpath)

            # tanslope
            shutil.copy(
                str(config_section['tanSlopeInputFile']),
                lc_outpath)

            # slope length
            shutil.copy(
                str(config_section['slopeLengthInputFile']),
                lc_outpath)
                
