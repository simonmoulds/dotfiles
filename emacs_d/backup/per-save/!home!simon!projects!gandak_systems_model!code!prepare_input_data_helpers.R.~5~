get_gaez_suit_data = function(crop, path, suffix, type="class", ...) {

    if (type=="class") {
        type="sc"
    } else if (type=="value") {
        type="su"
    } else {
        stop("Argument 'type' must be 'class' or 'value'")
    }

    ## input levels (class)
    input_levels = paste0(c("h","i","h","i","l"), "_", type, c("hi","ii","hr","ir","lr"))
    out = list()
    count = 0
    for (i in 1:length(input_levels)) {
        level = input_levels[i]
        f = paste0("res03_crav6190", level, "_", crop, suffix, ".tif")
        if (file.exists(file.path(path, f))) {
            count = count + 1
            r = raster(file.path(path, f))
            out[[level]] = r
        }
    }
    if (count == 0) {
        stop("no files available for the supplied crop")
    }
    out
}

