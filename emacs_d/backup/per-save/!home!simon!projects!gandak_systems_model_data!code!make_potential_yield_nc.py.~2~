#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import shutil
import csv
import numpy as np
import pandas as pd
import netCDF4 as nc
import xarray as xr
import rasterio

from utils import *

datadir = os.path.join('/','home','simon','projects','gandak_systems_model_data','data')
outdir = os.path.join('/','home','simon','projects','gandak_systems_model','land_surface','gandak_05min','landcover','irrNonPaddy')

crop_types = ["irr_rice_kharif","irr_rice_rabi","irr_wheat_rabi","irr_sugarcane_whole_year"]
fn = os.path.join(datadir, 'Gandak05min.clone.tif')    
r = xr.open_rasterio(fn)
lat_vals = r.y.values
lon_vals = r.x.values
nlat = lat_vals.size
nlon = lon_vals.size
ncrop = len(crop_types)
bbox = rasterio.open(fn).bounds

potential_yield_maps = []
for crop in crop_types:
    gaez_crop = lookup_crop_id(crop, 'GAEZ')
    fn = os.path.join(datadir, 'potential_yield_' + gaez_crop.lower() + '_mixed_input.tif')
    arr = read_gdal_raster_image(fn, self.bbox, 0)
    potential_yield_maps.append(arr)

yx_arr = np.stack(potential_yield_maps, axis=0)

netcdf = nc.Dataset('tmp.nc', 'w')
netcdf.createDimension('lat', nlat)
netcdf.createDimension('lon', nlon)
netcdf.createDimension('pseudo2', ncrop)

lato = netcdf.createVariable('lat', np.float64, ('lat'), zlib=True, least_significant_digit=16)
lato.units = 'degrees_north'
lato.standard_name = 'latitude'
lato.long_name = 'latitude'
lato[:]=r.y.values 

lono = netcdf.createVariable('lon', np.float64, ('lon'), zlib=True, least_significant_digit=16)
lono.units = 'degrees_east'
lono.standard_name = 'longitude'
lono.long_name = 'longitude'
lono[:]=r.x.values

pseu = netcdf.createVariable('pseudo2', np.int32, ('pseudo2'), zlib=True)
pseu.units = '1'
pseu.standard_name = 'pseudo2'
pseu[:]=np.arange(ncrop)

var1 = netcdf.createVariable('crop_yield', np.float64, ('pseudo2','lat','lon'), zlib=True, least_significant_digit=16)
var1.units = '1e-1 kg.m-2'      # tonne/hectare
var1.standard_name = 'crop_yield'
var1[:] = yx_arr

netcdf.close()
