# Retrieve data from netCDF file
f = 'jules.Base.nc'
d = nc.Dataset(f, 'r')
lons = d['longitude'][:].squeeze()
lats = d['latitude'][:].squeeze()
data = d['runoff'][:]
units = d.variables['runoff'].units
long_name = d.variables['runoff'].long_name
times = nc.num2date(
    d.variables['time'][:],
    d.variables['time'].units
)
d.close()

ts = pd.Series(np.sum(data, axis=(1,2)), index=times)
