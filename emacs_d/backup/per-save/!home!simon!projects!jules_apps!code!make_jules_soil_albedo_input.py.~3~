import netCDF4 as nc
import rasterio
import numpy as np
import shutil

# download the original data file from CLM data
# repository
os.system('svn --force export https://svn-ccsm-inputdata.cgd.ucar.edu/trunk/inputdata/lnd/clm2/rawdata/mksrf_soilcol.081008.nc ..')

# modify the raw data file so that it can be
# understood by CDO
try:
    os.remove("../mksrf_soilcol.081008_copy.nc")
except FileNotFoundError:
    pass

shutil.copy(src='../mksrf_soilcol.081008.nc', dst='../mksrf_soilcol.081008_copy.nc')
nco = nc.Dataset('../mksrf_soilcol.081008_copy.nc', 'r+')
latv = nco['LAT'][:]
nlat = len(latv)
lonv = nco['LON'][:]
nlon = len(lonv)
landmaskv = nco['LANDMASK'][:]
soilcolorv = nco['SOIL_COLOR'][:]
nco.close()

nco = nc.Dataset('../mksrf_soilcol.081008_mod.nc', 'w')
nco.createDimension('lon', nlon)
nco.createDimension('lat', nlat)

lato = nco.createVariable('lat', 'f4', ('lat',))
lato.units = 'degrees_north'
lato.standard_name = 'latitude'
lato[:] = latv

lono = nco.createVariable('lon', 'f4', ('lon',))
lono.units = 'degrees_east'
lono.standard_name = 'longitude'
lono[:] = lonv

crso = nco.createVariable('crs','i4')
crso.long_name = 'Lon/Lat Coords in WGS84'
crso.grid_mapping_name='latitude_longitude'
crso.longitude_of_prime_meridian = 0.0
crso.semi_major_axis = 6378137.0
crso.inverse_flattening = 298.257223563

landmask = nco.createVariable('LANDMASK', 'i4', ('lat','lon'))
landmask.units = '1'
landmask.standard_name = 'LANDMASK'
landmask[:] = landmaskv

soilcolor = nco.createVariable('SOIL_COLOR', 'i4', ('lat','lon'))
soilcolor.units = '1'
soilcolor.standard_name = 'SOIL_COLOR'
soilcolor[:] = soilcolorv
nco.close()

# now resample to 0.25 degree
file = open("gridfile.txt", "w")
file.writelines([
    'gridtype  = lonlat\n'
    'xsize     = 1440\n'
    'ysize     = 720\n'
    'xname     = lon\n'
    'xlongname = "longitude"\n'
    'xunits    = "degrees_east"\n'
    'yname     = lat\n'
    'ylongname = "latitude"\n'
    'yunits    = "degrees_north"\n'
    'xfirst    = -179.875\n'
    'xinc      = 0.25\n'
    'yfirst    = -89.875\n'
    'yinc      = 0.25'
    ]
)
file.close()

# use cdo to perform regridding:
# https://code.mpimet.mpg.de/projects/cdo/
os.system("cdo remapcon,gridfile.txt ../mksrf_soilcol.081008_mod.nc ../mksrf_soilcol.081008_0.25x0.25.nc")


