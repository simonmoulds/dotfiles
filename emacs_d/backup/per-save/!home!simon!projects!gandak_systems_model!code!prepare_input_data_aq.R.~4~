## Precipitation
if (!file.exists("data/prec_ts.rds")) {
    prec_fs = list.files("data/output_prec/Rainfall", full.names=TRUE)
    prec = rep(NA, length(prec_fs))
    for (i in 1:length(prec_fs)) {
        if (i %% 100 == 0) print(i)
        d = system(paste0("gdallocationinfo -geoloc ", prec_fs[i], " 84.625 27.125"), intern=TRUE) %>% grep("Value:", ., value=TRUE) %>% gsub("\\s+", "", .) %>% gsub("Value:", "", .) %>% as.numeric
        prec[i] = d
    }
    saveRDS(prec, "data/prec_ts.rds")
} else {
    prec = readRDS("data/prec_ts.rds")
}

## Reference ET
if (!file.exists("data/et_ts.rds")) {
    et_fs = list.files("data/output_evap/", pattern="^PM", full.names=TRUE)
    et = rep(NA, length(et_fs))
    for (i in 1:length(et_fs)) {
        if (i %% 1000 == 0) print(i)
        d = system(paste0("gdallocationinfo -geoloc ", et_fs[i], " 84.625 27.125"), intern=TRUE) %>% grep("Value:", ., value=TRUE) %>% gsub("\\s+", "", .) %>% gsub("Value:", "", .) %>% as.numeric
        et[i] = d
    }
    saveRDS(et, "data/et_ts.rds")
} else {
    et = readRDS("data/et_ts.rds")
}

start = as.POSIXct("1979-01-01")
end = as.POSIXct("2014-12-31")
ts = seq.POSIXt(start, end, by="1 day")

ts1 = seq.POSIXt(as.POSIXct("1979-01-01"), as.POSIXct("2010-12-31"), by="1 day")
ix1 = ts %in% ts1

prec_data = data.frame(time=1:length(ts1), prec=prec[ix1])
et_data = data.frame(time=1:length(ts1), et=et[ix1])
write.csv(prec_data, "~/Simile/data/prec_data.csv", row.names=FALSE)
write.csv(et_data, "~/Simile/data/et_data.csv", row.names=FALSE)

