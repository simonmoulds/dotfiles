## Crop factor (growth stages 1-4) (Choudhury et al, 2013)
## #######################################################

kcw = rep(0, 366)
kcw[320:350] = 0.8
kcw[c(1:16,351:365)] = 1.12
kcw[17:47] = 1.25
kcw[48:106] = 0.46

kcr = rep(0,366)
kcr[148:185] = 0.61
kcr[186:223] = 0.80
kcr[224:261] = 1.23
kcr[262:296] = 0.74

kcw_tab = data.frame(day=1:366, crop=1, Kc=kcw)
kcr_tab = data.frame(day=1:366, crop=2, Kc=kcr)
kc_tab = rbind(kcw_tab, kcr_tab) %>% arrange(day)
write.csv(kc_tab, "~/Simile/data/kc_tab.csv", row.names=FALSE)

## rooting depth
## #############

rdw = rep(0, 366)
rdw[c(1:106,320:366)] = 1.25 * 1000

rdr = rep(0, 366)
rdr[148:296] = 0.65 * 1000

rdw_tab = data.frame(day=1:366, crop=1, rd=rdw)
rdr_tab = data.frame(day=1:366, crop=2, rd=rdr)
rd_tab = rbind(rdw_tab, rdr_tab) %>% arrange(day)
write.csv(rd_tab, "~/Simile/data/rd_tab.csv", row.names=FALSE)

## et depletion factor
## ###################

pw = rep(0, 366)
pw[c(1:106,320:366)] = 0.55

pr = rep(0, 366)
pr[148:296] = 0.2

pw_tab = data.frame(day=1:366, crop=1, p=pw)
pr_tab = data.frame(day=1:366, crop=2, p=pr)
p_tab = rbind(pw_tab, pr_tab) %>% arrange(day)
write.csv(p_tab, "~/Simile/data/p_tab.csv", row.names=FALSE)

## maximum yield
## #############

yld = read.table("data/sult_pol_ln_crop_yield_sultanpur.txt", header=TRUE)
yrs = yld[["Year"]]
index = yrs %in% 1979:2010
wheat_yld = yld[["wheat_th"]][index] * 2.4
rice_yld = yld[["rice_th"]][index] * 1.7

## create index showing the time step of 1 January of each
## year in the simulation
yrs = 1979:2010
leap_year = (((yrs %% 4) == 0) & ((yrs %% 100) != 0)) | ((yrs %% 400) == 0)
ndays = ifelse(leap_year, 366, 365)
ix = (cumsum(ndays) + 1) - ndays
ts1[ix]
wheat_yield = data.frame(day=ix, crop=1, yield=wheat_yld)
rice_yield = data.frame(day=ix, crop=2, yield=rice_yld)
yield_tab = rbind(wheat_yield, rice_yield) %>% arrange(day)
write.csv(yield_tab, "~/Simile/data/yx_tab.csv", row.names=FALSE)

