## rice
## ####

if (dist_nm %in% c("Barpeta","Darrang","Dhemaji","Dhuburi","Dibrugarh","Goalpara","Golaghat","Hailakandi","Jorhat","Kamrup","Karbi Anglong","Karimganj","Kokrajhar","Lakhimpur","Marigaon","Nagaon","Nalbari","North Cachar Hills","Sibsagar","Sonitpur","Tinsukia")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:7, 8)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 11, 10)

    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:7, 8)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 11, 10)

    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:7, 8)
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 11, 10)
}

if (dist_nm %in% c("Bongaigaon")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:7, 8)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 11, 10)

    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:7, 8)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 11, 10)

    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:8, 9)
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 10:11, 9)
}

if (dist_nm %in% c("Cachar")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:9, 10)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 11, 10)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:9, 10)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 11, 10)
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:9, 10)
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 11, 10)
}

if (dist_nm %in% c("Dibrugarh")) {
    xx[["irr_rice-winter"]] = xx[["irr_rice-autumn"]]
    xx[["irr_rice-autumn"]] = 0
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 6:11, 5)
    xx[["apy_rice-summer"]] %<>% locf_interp(6:11)
}

if (dist_nm %in% c("Dhuburi","Goalpara","Kamrup")) {
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 9, 8)
}

if (dist_nm %in% c("Karbi Anglong")) {
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 10:11, 9)
}

