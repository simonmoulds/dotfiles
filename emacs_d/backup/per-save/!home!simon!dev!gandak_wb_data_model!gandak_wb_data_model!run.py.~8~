from .GandakWBDataModel import GandakWBDataModel
from .Configuration import Configuration
from . import variable_list

import logging
logger = logging.getLogger(__name__)

class DeterministicRunner(object):    
    def __init__(self, model, configuration, modelTime, variable_list, initialState = None):
        self.modelTime = modelTime
        self.model = model(configuration, modelTime, initialState)
        self.model.initial()
    def initial(self):
        pass
    def dynamic(self):
        self.model.dynamic()

def main():
    iniFileName = os.path.abspath(sys.argv[1])
    configuration = Configuration(iniFileName = iniFileName, debug_mode=False)
    currTimeStep = ModelTime()
    initial_state = None
    currTimeStep.getStartEndTimeSteps(
        configuration.TIME_CONSTANTS['startDate'],
        configuration.TIME_CONSTANTS['endDate'])    
    deterministic_runner = DeterministicRunner(
        GandakWBDataModel,
        configuration,
        currTimeStep,
        variable_list,
        initial_state)
    deterministic_runner.dynamic()

if __name__ == '__main__':
    sys.exit(main())

