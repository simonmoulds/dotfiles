# class DeterministicRunner(DynamicModel):    
class DeterministicRunner(object):    
    def __init__(self, model, configuration, modelTime, variable_list, initialState = None):
        # DynamicModel.__init__(self)
        self.modelTime = modelTime
        self.model = model(configuration, modelTime, initialState)
        self.model.initial()

    def initial(self):
        pass

    def dynamic(self):
        self.model.dynamic()

def main():
    iniFileName = os.path.abspath(sys.argv[1])
    configuration = Configuration(iniFileName = iniFileName, debug_mode=False)
    currTimeStep = ModelTime()
    initial_state = None
    currTimeStep.getStartEndTimeSteps(
        configuration.TIME_CONSTANTS['startTime'],
        configuration.TIME_CONSTANTS['endTime'])
    # logger.info('Transient simulation run has started')
    deterministic_runner = DeterministicRunner(
        GandakWBDataModel,
        configuration,
        currTimeStep,
        variable_list,
        initial_state)
    deterministic_runner.dynamic()
