[FILE_PATHS]
PathIn = /home/simon/projects/aquacrop_apps/ssa/data
PathOut = /home/simon/projects/aquacrop_apps/ssa/data

[MODEL_GRID]
cloneMap = ${FILE_PATHS:PathIn}/africa_clone_0pt25degree.tif
landmask = ${FILE_PATHS:PathIn}/africa_landmask_0pt25degree.tif

[CLOCK]
startTime = 2000-01-01
endTime = 2000-01-31

[NETCDF_ATTRIBUTES]
institution = Department of Civil and Environmental Engineering, Imperial College London
title       = etref model output
description = 
netcdf_y_orientation_follow_cf_convention = True
formatNetCDF = NETCDF4
zlib = True

[ET_METHOD]
method = PenmanMonteith

[WEATHER]
compute_daily_min_max_temperature_from_subdaily_data = False
compute_daily_avg_temperature_from_subdaily_data = False

meanDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_tavg.nc4
meanDailyTemperatureVarName = tavg
meanDailyTemperatureTimeDimName = time

minDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_tmin.nc4
minDailyTemperatureVarName = tmin
minDailyTemperatureTimeDimName = time

maxDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_tmax.nc4
maxDailyTemperatureVarName = tmax
maxDailyTemperatureTimeDimName = time

subDailyTemperatureNC = None
subDailyTemperatureVarName = None
subDailyTemperatureTimeDimName = None

downwellingLongwaveRadiationNC = None
downwellingLongwaveRadiationVarName = None
downwellingLongwaveRadiationTimeDimName = None

surfaceAtmosphericPressureNC = None
surfaceAtmosphericPressureVarName = None
surfaceAtmosphericPressureTimeDimName = None

specificHumidityNC = None
specificHumidityVarName = None
specificHumidityTimeDimName = None

maxRelativeHumidity = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_rhstmax.nc4
maxRelativeHumidityVarName = rhstmax
maxRelativeHumidityTimeDimName = time

minRelativeHumidity = None
minRelativeHumidityVarName = None
minRelativeHumidityTimeDimName = None

meanRelativeHumidity = None
meanRelativeHumidityVarName = None
meanRelativeHumidityTimeDimName = None

downwellingShortwaveRadiationNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_srad.nc4
downwellingShortwaveRadiationVarName = srad
downwellingShortwaveRadiationTimeDimName = time

windSpeedNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_wndspd.nc4
windSpeedVarName = wndspd
windSpeedTimeDimName = time

[REPORTING]
outDailyTotal = ETref
