#!/bin/bash

# This script is run from
# 'run_grass_process_village_census.sh'

export GRASS_MESSAGE_FORMAT=plain

wd=/home/simon/dev/gandak_wb_data_model/data-raw
datadir=/data/india_village_level_geospatial_socio_econ_data
outdir=/home/simon/projects/india_village_census/data

# declare array of state suffixes...
# all states in the IGP
declare -a suffixes=("RJ" "PB" "HP" "HR" "UK" "UP" "MP" "CH" "JH" "BH" "WB")

# # all states in the  dataset
# declare -a suffixes=(
#     "AP" "AR" "AS" "BR" "CG" "GA" "GJ" "HR" "HP"
#     "JK" "JH" "KA" "KL" "MP" "MH" "MN" "ML" "MZ"
#     "NL" "OR" "PB" "RJ" "SK" "TN" "TR" "UP" "UK"
#     "WB" "UTerr")

# ...and array of columns
declare -a agri_columns=(
    "LAND_FORES"
    "CANAL_GOVT"
    "CANAL_PVT"
    "WELL_WO_EL"
    "WELL_W_EL"
    "TW_WO_EL"
    "TW_W_EL"
    "TANK_IRR"
    "RIVER_IRR"
    "W_FALL"
    "OTH_IRR"
    "TOT_IRR"
    "UN_IRR"
    "CULT_WASTE"
    "AREA_NA_CU"
)

declare -a land_use_columns=(
    "LAND_FORES"
    "TOT_IRR"
    "UN_IRR"
    "CULT_WASTE"
    "AREA_NA_CU"
)

declare -a irr_area_columns=(
    "CANAL_GOVT"
    "CANAL_PVT"
    "WELL_WO_EL"
    "WELL_W_EL"
    "TW_WO_EL"
    "TW_W_EL"
    "TANK_IRR"
    "RIVER_IRR"
    "W_FALL"
    "OTH_IRR"
)    

declare -a categorical_columns=(
    "SID" "DID" "TID" "VILL_CODE" "C_CODE01" "UID" "CENSUS_COD"
    "STATE" "DISTRICT" "SUB_DIST" "TOWN_VILL" "WARD" "EB" "LEVEL"
    "ST_CODE" "DIST_CODE" "THSIL_CODE" "BLOCK_CODE" "V_CT_CODE"
    "VILL_NAME" "AREA" "EDU_FAC" "RANG_P_SCH" "RANG_M_SCH","RANG_COLL"
    "MEDI_FAC" "RANG_ALL" "RANG_MCW" "RANG_PHC" "DRNK_WAT_F"
    "RANG_WAT_F" "TAP" "WELL" "TANK" "TUBEWELL" "HANDPUMP" "RIVER"
    "CANAL" "LAKE" "SPRING" "OTHER" "RANG_SS" "SS_CODE" "P_T_FAC"
    "RANG_PO" "RANG_PHONE" "COMM_FAC" "BS_FAC" "RANG_BS" "RS_FAC"
    "RANG_RS" "NW_FAC" "RANG_NW" "BANK_FAC" "RANG_COMM" "RANG_COOP"
    "CRSOC_FAC" "RANG_ACS" "RANG_NAC" "RANG_OTH" "RC_FAC" "RANG_CV"
    "RANG_SPCL" "RANG_STAU" "APP_PR" "APP_MR" "APP_FP" "APP_NAVRIV"
    "APP_NAVCAN" "APP_NW" "DIST_TOWN" "POWER_SUPL" "POWER_DOM"
    "POWER_AGR" "POWER_OTH" "POWER_ALL" "PAP_MAG" "A_INCEXP"
)

declare -a continuous_columns=(
    "No_HH" "TOT_P" "TOT_M" "TOT_F" "P_06" "M_06" "F_06" "P_SC"
    "M_SC" "F_SC" "P_ST" "M_ST" "F_ST" "P_LIT" "M_LIT" "F_LIT"
    "P_ILL" "M_ILL" "F_ILL" "TOT_WORK_P" "TOT_WORK_M" "TOT_WORK_F"
    "MAINWORK_P" "MAINWORK_M" "MAINWORK_F" "MAIN_CL_P" "MAIN_CL_M"
    "MAIN_CL_F" "MAIN_AL_P" "MAIN_AL_M" "MAIN_AL_F" "MAIN_HH_P"
    "MAIN_HH_M" "MAIN_HH_F" "MAIN_OT_P" "MAIN_OT_M" "MAIN_OT_F"
    "MARGWORK_P" "MARGWORK_M" "MARGWORK_F" "MARG_CL_P" "MARG_CL_M"
    "MARG_CL_F" "MARG_AL_P" "MARG_AL_M" "MARG_AL_F" "MARG_HH_P"
    "MARG_HH_M" "MARG_HH_F" "MARG_OT_P" "MARG_OT_M" "MARG_OT_F"
    "NON_WORK_P" "NON_WORK_M" "NON_WORK_F" "T_HH" "T_P" "T_M" "T_F"
    "SC_P" "SC_M" "SC_F" "ST_P" "ST_M" "ST_F" "P_SCH" "M_SCH"
    "S_SCH" "S_S_SCH"
    "COLLEGE" "IND_SCH" "TR_SCH" "ADLT_LT_CT" "OTH_SCH" "ALL_HOSP"
    "AYU_HOSP" "UN_HOSP" "HOM_HOSP" "ALL_DISP" "AYU_DISP" "UN_DISP"
    "HOM_DISP" "MCW_CNTR" "M_HOME" "CWC" "H_CNTR" "PH_CNTR"
    "PHS_CNT" "FWC_CNTR" "TB_CLN" "N_HOME" "RMP" "SMP" "CHW"
    "OTH_CNTR" "POST_OFF" "TELE_OFF" "POST_TELE" "PHONE" "COMM_BANK"
    "COOP_BANK" "AC_SOC" "NAC_SOC" "OTHER_SOC" "C_V_HALL" "SP_CL_FAC"
    "ST_AU_FAC" "TOT_INC" "TOT_EXP"
    # "LAND_FORES" "CANAL_GOVT"
    # "CANAL_PVT" "WELL_WO_EL" "WELL_W_EL" "TW_WO_EL" "TW_W_EL"
    # "TANK_IRR" "RIVER_IRR" "LAKE_IRR" "W_FALL" "OTH_IRR" "TOT_IRR"
    # "UN_IRR" "CULT_WASTE" "AREA_NA_CU"
)

for state in "${suffixes[@]}"
do    
    # import 30 arc-second grid from latlong, and
    # set the region to match its extent.
    if [ -f "${outdir}"/"${state}"_grid_30s_utm44n.gpkg ]
    then
	v.in.ogr \
	    input="${outdir}"/"${state}"_grid_30s_utm44n.gpkg \
	    output="${state}"_grid_30s \
	    --overwrite
    else	
	v.proj \
            location=latlong \
            mapset=PERMANENT \
            input="${state}"_grid_30s \
            --overwrite
	v.out.ogr \
	    input="${state}"_grid_30s \
	    output="${outdir}"/"${state}"_grid_30s_utm44n.gpkg \
	    --overwrite
    fi
    # set region according to the grid file
    g.region \
        vector="${state}"_grid_30s \
        align=template    
    g.region -p

    # import the village geospatial dataset for
    # the current state
    if [ -f "${outdir}"/"${state}"_census_2001_clean_utm44n.gpkg ]
    then
	v.in.ogr \
	    input="${outdir}"/"${state}"_census_2001_clean_utm44n.gpkg \
	    output="${state}"_census_2001 \
	    --overwrite
    else	
	infile=$datadir/india-village-census-2001-"${state}".gpkg
	v.in.ogr \
            input="${infile}" \
            output="${state}"_census_2001 \
            --overwrite
	
	v.clean \
            input="${state}"_census_2001 \
            output="${state}"_census_2001_clean \
            tool=rmdupl,rmdac \
            --overwrite

	v.out.ogr \
	    input="${state}"_census_2001 \
	    output="${outdir}"/"${state}"_census_2001_clean_utm44n.gpkg \
	    --overwrite
    
	g.copy \
            vector="${state}"_census_2001_clean,"${state}"_census_2001 \
            --overwrite
    fi    

    # ###################################################### #
    # compute the actual area of each polygon
    # ###################################################### #
    
    v.db.addcolumn \
        map="${state}"_census_2001 \
        columns="area_size double precision"

    # `v.to.db` populates attribute columns from vector features
    # (in this case area)
    v.to.db \
        map="${state}"_census_2001 \
        option=area \
        columns=area_size \
        units=meters

    # ###################################################### #
    # normalize continuous variables by village/town area
    # ###################################################### #
    
    # DO SOMETHING HERE : NORMALIZE CONTINUOUS VARIABLES BY VILLAGE/TOWN AREA BEFORE GRIDDING
    for column in "${continuous_columns[@]}"
    do
	v.db.addcolumn \
	    map="${state}"_census_2001 \
	    columns="${column}_norm double precision" \
	    
        v.db.update \
            map="${state}"_census_2001 \
            col="${column}"_norm \
            qcol="${column} / area_size * 1000"
    done
    
    # CONTINUOUS VARIABLES
    # CATEGORICAL VARIABLES
    
    # ###################################################### #
    # intersect the census map with grid map
    # ###################################################### #
    
    # this divides the areas in ainput
    # according to the area boundaries in
    # binput (see man page for more details)
    v.overlay \
        ainput="${state}"_census_2001 \
        binput="${state}"_grid_30s \
        operator=and \
        output="${state}"_census_2001_grid \
        snap=1e-8 \
        --overwrite

    # export/import - THIS IS A HACK!!!
    v.out.ogr \
        input="${state}"_census_2001_grid \
        output=tmp.gpkg \
        format=GPKG \
        --overwrite
    v.in.ogr \
        input=tmp.gpkg \
        output="${state}"_census_2001_grid \
        --overwrite
    rm tmp.gpkg             

    # ##################################################### #
    # aggregate continuous/cat vars to grid polygons
    # ##################################################### #

    # this is in preparation for conversion to raster
    for column in "${continuous_columns[@]}"
    do
        col=
        v.vect.stats \
            points="${state}"_census_2001_grid \
            type=centroid \
            areas="${state}"_grid_30s \
            points_column="${column}" \
            count_column=num_points \
            method=average \
            stats_column="${column}"_avg
    done    
    
    # ##################################################### #
    # compute the area of each new polygon
    # ##################################################### #
    
    v.db.addcolumn \
        map="${state}"_census_2001_grid \
        columns="new_area_size double precision"
    v.to.db \
        map="${state}"_census_2001_grid \
        option=area \
        columns=new_area_size \
        units=meters

    # # convert overlay result to points
    # v.extract \
    #     input="${state}"_census_2001_grid \
    #     output="${state}"_census_2001_grid_pts \
    #     type=centroid \
    #     --overwrite

    # ##################################################### #
    # compute cropland and non-cropland area 
    # ##################################################### #

    # multiply the cropland_pct by the area of each polygon
    # to get the cropland in m2
    v.db.addcolumn \
        map="${state}"_census_2001_grid \
        columns="cropland_area double precision,total_cropland_area double precision"    
    v.db.update \
        map="${state}"_census_2001_grid \
        col=cropland_area \
        qcol="b_cropland_pct * new_area_size"

    # add up cropland area within a village
    # (this adds `stats_column` to `areas`)
    v.vect.stats \
        points="${state}"_census_2001_grid \
        type=centroid \
        areas="${state}"_census_2001 \
        points_column=cropland_area \
        count_column=num_points \
        method=sum \
        stats_column=total_cropland_area    

    # add up non cropland area, by subtracting
    # total_cropland_area from area_size
    v.db.addcolumn \
        map="${state}"_census_2001 \
        columns="total_non_cropland_area double precision"    
    v.db.update \
        map="${state}"_census_2001 \
        col=total_non_cropland_area \
        qcol="area_size - total_cropland_area"

    # ##################################################### #
    # repair land use and irrigated areas
    # ##################################################### #
    
    v.db.addcolumn \
        map="${state}"_census_2001 \
        columns="calculated_cropland_area double precision,calculated_non_cropland_area double precision,calculated_irr_area double precision,cropland_scale_factor double precision,non_cropland_scale_factor double precision,irr_area_scale_factor double precision"
    
    # compute cropland and non-cropland area from
    # the provided land use statistics (hectares)
    v.db.update \
        map="${state}"_census_2001 \
        col=calculated_cropland_area \
        qcol="TOT_IRR+UN_IRR"

    v.db.update \
        map="${state}"_census_2001 \
        col=calculated_non_cropland_area \
        qcol="LAND_FORES+CULT_WASTE+AREA_NA_CU"
    
    # compute scale factors for cropland and
    # non-cropland areas (divide by 10000 to
    # convert from hectares -> meters)
    v.db.update \
        map="${state}"_census_2001 \
        col=cropland_scale_factor \
        qcol="total_cropland_area / 10000 / calculated_cropland_area" \
        where="calculated_cropland_area > 0"

    v.db.update \
        map="${state}"_census_2001 \
        col=non_cropland_scale_factor \
        qcol="total_non_cropland_area / 10000 / calculated_non_cropland_area" \
        where="calculated_non_cropland_area > 0"
    
    # multiply cropland columns by cropland area
    # scale factor
    for crop in "TOT_IRR" "UN_IRR"
    do
        v.db.update \
            map="${state}"_census_2001 \
            col="${crop}" \
            qcol="${crop} * cropland_scale_factor"
    done    

    for noncrop in "LAND_FORES" "CULT_WASTE" "AREA_NA_CU"
    do
        v.db.update \
            map="${state}"_census_2001 \
            col="${noncrop}" \
            qcol="${noncrop} * non_cropland_scale_factor"
    done

    # now scale irrigation columns to match TOT_IRR.
    # We do it this way (rather than just
    # multiplying the irrigation column by
    # cropland_scale_factor) because sometimes
    # values are provided for irrigation columns
    # even when TOT_IRR equals zero. We assume
    # TOT_IRR is correct, and scale the irrigation
    # columns accordingly.

    # TODO: we could in fact take the irrigated fraction from a remote sensing image?
    
    v.db.update \
        map="${state}"_census_2001 \
        col=calculated_irr_area \
        qcol="CANAL_GOVT+CANAL_PVT+WELL_WO_EL+WELL_W_EL+TW_WO_EL+TW_W_EL+TANK_IRR+RIVER_IRR+LAKE_IRR+W_FALL+OTH_IRR"

    v.db.update \
        map="${state}"_census_2001 \
        col=irr_area_scale_factor \
        qcol="TOT_IRR / calculated_irr_area"
    
    for irr in "${irr_area_columns[@]}"
    do
        v.db.update \
            map="${state}"_census_2001 \
            col="${irr}" \
            qcol="${irr} * irr_area_scale_factor"
    done    

    # ##################################################### #
    # add village total_cropland_area to overlay map
    # ##################################################### #

    # join database tables
    v.db.join \
        map="${state}"_census_2001_grid \
        column=a_cat \
        other_table="${state}"_census_2001 \
        other_column=cat \
        subset_columns="total_cropland_area,LAND_FORES,CANAL_GOVT,CANAL_PVT,WELL_WO_EL,WELL_W_EL,TW_WO_EL,TW_W_EL,TANK_IRR,RIVER_IRR,LAKE_IRR,W_FALL,OTH_IRR,TOT_IRR,UN_IRR,CULT_WASTE,AREA_NA_CU"
    
    # compute the percentage of the total cropland
    # in a village in each of the new polygons
    v.db.addcolumn \
        map="${state}"_census_2001_grid \
        columns="area_weight double precision"

    v.db.update \
        map="${state}"_census_2001_grid \
        column=area_weight \
        qcol="cropland_area / total_cropland_area"

    # ##################################################### #
    # aggregate to grid polygons
    # ##################################################### #

    # this is in preparation for conversion to raster
    for column in "${agri_columns[@]}"
    do
        col="${column}"
        newcol="${column}"_wt        
        v.db.addcolumn \
            map="${state}"_census_2001_grid \
            columns="${newcol} double precision"
        v.db.update \
            map="${state}"_census_2001_grid \
            column="${newcol}" \
            qcol="${col}*area_weight"        
        v.vect.stats \
            points="${state}"_census_2001_grid \
            type=centroid \
            areas="${state}"_grid_30s \
            points_column="${newcol}" \
            count_column=num_points \
            method=sum \
            stats_column="${col}"_sum
    done

    # CHECK:
    v.vect.stats \
        points="${state}"_census_2001_grid \
        type=centroid \
        areas="${state}"_grid_30s \
        points_column=new_area_size \
        count_column=num_points \
        method=sum \
        stats_column=new_area_sum

    # ##################################################### #
    # compute grid area
    # ##################################################### #
    
    v.db.addcolumn \
        map="${state}"_grid_30s \
        columns="grid_cell_area double precision"
    
    v.to.db \
        map="${state}"_grid_30s \
        option=area \
        columns=grid_cell_area \
        units=meters    
done

