# Python
export PATH=$HOME/.local/pcraster-4.1.0_x86-64/bin:$HOME/.local/bin:$PATH
export PYTHONPATH=$HOME/.local/pcraster-4.1.0_x86-64/python:$PYTHONPATH

# zlib
export PATH=$HOME/local/zlib/bin:$PATH

# openmpi
export PATH=$HOME/local/openmpi/bin:$PATH

# hdf5/netcdf
export PATH=$HOME/local/netcdf/bin:$PATH

# cylc
export PATH=$HOME/local/cylc/bin:$PATH

# rose
export PATH=$HOME/local/rose/bin:$PATH

# fcm
export PATH=$HOME/local/fcm/bin:$PATH
