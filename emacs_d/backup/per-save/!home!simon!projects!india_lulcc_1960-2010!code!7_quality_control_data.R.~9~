## remote sensing stats (generate with grass_zonal_statistics.sh)
lulc_1985_stats = read.table(file="data/lulc_1985_dist_area.txt", header=FALSE, sep="\t") %>% mutate(year=1985)

lulc_1995_stats = read.table(file="data/lulc_1995_dist_area.txt", header=FALSE, sep="\t") %>% mutate(year=1995)

lulc_2005_stats = read.table(file="data/lulc_2005_dist_area.txt", header=FALSE, sep="\t") %>% mutate(year=2005)

lulc_stats =
    rbind(lulc_1985_stats, lulc_1995_stats, lulc_2005_stats) %>%
    `[`(,c(1,4,5,6)) %>%
    setNames(c("ID_2","lu","area","year")) %>%
    spread(lu, area) %>%
    arrange(ID_2, year)

lulc_stats_reclass =
    data.frame(ID_2=lulc_stats[["ID_2"]],
               year=lulc_stats[["year"]],
               cropland=rowSums(lulc_stats[,c(6,17)], na.rm=TRUE),
               fallow_land=lulc_stats[["fallow_land"]],
               urban=lulc_stats[["built_up_land"]],
               forest=rowSums(lulc_stats[,c(7:10,13:14)], na.rm=TRUE),
               grassland=lulc_stats[["grassland"]],
               shrubland=lulc_stats[["shrubland"]],
               wasteland=lulc_stats[["wasteland"]],
               barren=rowSums(lulc_stats[,c(4,18)], na.rm=TRUE),
               water=rowSums(lulc_stats[,c(3,22,16)], na.rm=TRUE),
               snow=lulc_stats[["snow_ice"]])

## lulc_stats_reclass = read.table("data/lulc_dist_area.txt", header=TRUE)

## state data (used for infilling some districts with very poor data availability)

rfdata = read.csv("data/300luc_formatted.csv", header=FALSE, skip=1)
rf_state_nms = rfdata[,2][which(rfdata[,1] == "INDIA")][-1]

## names of indiastat states corresponding with rf state names
states = list("Andaman and Nicobar",
              "Andhra Pradesh",
              "Arunachal Pradesh",
              "Assam",
              c("Bihar","Jharkhand"),
              "Delhi",
              c("Gujarat","Dadra and Nagar Haveli"),
              c("Haryana","Chandigarh"),
              "Himachal Pradesh",
              "Jammu and Kashmir",
              "Karnataka",
              "Kerala",
              "Lakshadweep",
              c("Madhya Pradesh","Chhattisgarh"),
              c("Maharashtra","Goa","Daman and Diu"),
              "Manipur",
              "Meghalaya",
              "Mizoram",
              "Nagaland",
              "Orissa",
              "Punjab",
              "Rajasthan",
              "Sikkim",
              c("Tamil Nadu","Puducherry"),
              "Tripura",
              c("Uttar Pradesh","Uttaranchal"),
              "West Bengal")

dfs = list()

for (i in 1:length(rf_state_nms)) {
    
    dists = sort(district1950$ID_2[district1950$NAME_1 %in% states[[i]]])

    ix = seq(which(rfdata[,2] %in% rf_state_nms[i]), length.out=15)
    rf = rfdata %>% `[`(ix,)

    rf_nca = as.numeric(rf[which(rf[,2] %in% "NET CULTIVATED AREA"),3:7]) * 1000 * 10000
    rf_forest = as.numeric(rf[which(rf[,2] %in% "TOTAL FOREST COVER"),3:7]) * 1000 * 10000
    rf_urban = as.numeric(rf[which(rf[,2] %in% "SETTLED/BUILT-UP"),3:7]) * 1000 * 10000
    rf_grassland = as.numeric(rf[which(rf[,2] %in% "GRASS/SHRUB COMPLEXES"),3:7]) * 1000 * 10000
    rf_barren = as.numeric(rf[which(rf[,2] %in% "BARREN/SPARSELY VEGETATED"),3:7]) * 1000 * 10000

    ## dfs = vector(mode="list", length=length(dists))
    for (j in 1:length(dists)) {
        dist = dists[j]
        rs = lulc_stats_reclass[lulc_stats_reclass$ID_2 %in% dist,]
        rs[is.na(rs)] = 0

        ## cultivated
        rs_nca = rowSums(matrix(c(rs$cropland, rs$fallow_land), ncol=2))
        rs_nca_1980 = predict(lm(nca~year, data.frame(year=c(1985,1995), nca=rs_nca[1:2])), newdata=data.frame(year=1980))
        ## rs_nca_1980 = spline(c(1985,1995,2005), rs_nca, xout=c(1980))$y
        if (rs_nca_1980 < 0) rs_nca_1980 = rs_nca[1]
        rf_nca_dist = rf_nca * (rs_nca_1980 / rf_nca[5])

        ## urban
        ## rs_urban_1980 = spline(c(1985,1995,2005), rs$urban, xout=c(1980))$y
        rs_urban_1980 = predict(lm(urban~year, data.frame(year=c(1985,1995), urban=rs$urban[1:2])), newdata=data.frame(year=1980))
        if (rs_urban_1980 < 0) rs_urban_1980 = rs$urban[1]
        rf_urban_dist = rf_urban * (rs_urban_1980 / rf_urban[5])

        ## forest
        ## rs_forest_1980 = spline(c(1985,1995,2005), rs$forest, xout=c(1980))$y
        rs_forest_1980 = predict(lm(forest~year, data.frame(year=c(1985,1995), forest=rs$forest[1:2])), newdata=data.frame(year=1980))
        if (rs_forest_1980 < 0) rs_forest_1980 = rs$forest[1]
        rf_forest_dist = rf_forest * (rs_forest_1980 / rf_forest[5])

        ## grassland/shrubland/wasteland
        ## rs_grassland_1980 = spline(c(1985,1995,2005), rs$grassland, xout=c(1980))$y
        rs_grassland_1980 = predict(lm(grassland~year, data.frame(year=c(1985,1995), grassland=rs$grassland[1:2])), newdata=data.frame(year=1980))
        if (rs_grassland_1980 < 0) rs_grassland_1980 = rs$grassland[1]
        rf_grassland_dist = rf_grassland * (rs_grassland_1980 / rf_grassland[5])

        ## rs_shrubland_1980 = spline(c(1985,1995,2005), rs$shrubland, xout=c(1980))$y
        rs_shrubland_1980 = predict(lm(shrubland~year, data.frame(year=c(1985,1995), shrubland=rs$shrubland[1:2])), newdata=data.frame(year=1980))
        if (rs_shrubland_1980 < 0) rs_shrubland_1980 = rs$shrubland[1]
        rf_shrubland_dist = rf_grassland * (rs_shrubland_1980 / rf_grassland[5])

        ## rs_wasteland_1980 = spline(c(1985,1995,2005), rs$wasteland, xout=c(1980))$y
        rs_wasteland_1980 = predict(lm(wasteland~year, data.frame(year=c(1985,1995), wasteland=rs$wasteland[1:2])), newdata=data.frame(year=1980))
        if (rs_wasteland_1980 < 0) rs_wasteland_1980 = rs$wasteland[1]
        rf_wasteland_dist = rf_grassland * (rs_wasteland_1980 / rf_grassland[5])

        ## barren
        ## rs_barren_1980 = spline(c(1985,1995,2005), rs$barren, xout=c(1980))$y
        rs_barren_1980 = predict(lm(barren~year, data.frame(year=c(1985,1995), barren=rs$barren[1:2])), newdata=data.frame(year=1980))
        if (rs_barren_1980 < 0) rs_barren_1980 = rs$barren[1]
        rf_barren_dist = rf_barren * (rs_barren_1980 / rf_barren[5])

        out = data.frame(ID_2=dist,
                         year=c(1880,1920,1950,1970,1980,1985,1995,2005),
                         cropland=c(NA, NA, NA, NA, NA, rs$cropland),
                         fallow_land=c(NA, NA, NA, NA, NA, rs$fallow_land),
                         cultivated=c(rf_nca_dist, rs_nca),
                         urban=c(rf_urban_dist, rs$urban),
                         forest=c(rf_forest_dist, rs$forest),
                         grassland=c(rf_grassland_dist, rs$grassland),
                         shrubland=c(rf_shrubland_dist, rs$shrubland),
                         wasteland=c(rf_wasteland_dist, rs$wasteland),
                         barren=c(rf_barren_dist, rs$barren),
                         water=c(NA, NA, NA, NA, NA, rs$water),
                         snow=c(NA, NA, NA, NA, NA, rs$snow))
        
        n = length(dfs)
        dfs[[(n+1)]] = out
    }
}

