is.leapyear=function(year){
    ## http://en.wikipedia.org/wiki/Leap_year
    return(((year %% 4 == 0) & (year %% 100 != 0)) | (year %% 400 == 0))
}

myfun = function(ts,planting_day,harvest_day) {
    ts = as.POSIXlt(ts)
    jd = ts$yday + 1
    yr = ts$year + 1900
    ix=rep(FALSE,length(ts))
    for (i in 1:length(ts)) {
        leap_year = is.leapyear(yr[i])
        if (leap_year) {
            if (planting_day > 59) planting_day0 = planting_day + 1
            if (harvest_day > 59) harvest_day0 = harvest_day + 1

        } else {
            harvest_day0 = harvest_day
            planting_day0 = planting_day
        }

        if (harvest_day0 < planting_day0) {
            if (jd[i] <= harvest_day0) {
                ix[i] = TRUE
            } else if (jd[i] >= planting_day0) {
                ix[i] = TRUE
            }
        } else {
            if (jd[i] >= planting_day0 && jd[i] <= harvest_day0) {
                ix[i] = TRUE
            }
        }        
    }
    ix
}

get_growing_stage = function(ts, planting_day, harvest_day, relative_stage_duration, ...) {
    
    ## convert time series to POSIXlt, so we can get Julian day
    tslt = as.POSIXlt(ts, format="%Y-%m-%d %H:%M:%S")
    tslt0 = seq(tslt[1], by="-1 day", length.out=2)[2]
    tslt1 = seq(tslt[length(tslt)], by="1 day", length.out=2)[2]
    tslt2 = as.POSIXlt(seq(tslt0, tslt1, by="1 day"))

    ## get preliminary index of crop growing season, then
    ## identify start and end days based on difference
    ix = myfun(tslt2, planting_day, harvest_day)
    dff = diff(ix)
    if (planting_day == 1 & harvest_day == 365) {
        start_ix = which(tslt$yday == 0)
        end_ix = which(tslt$mon == 11 & tslt$mday == 31)
    } else {
        start_ix = which((dff == 1)[-length(dff)]) # CHECK
        end_ix = which((dff == -1)[-1])            # CHECK
    }    
    frac = rep(0, length(ts))
    
    for (i in 1:length(start_ix)) {
        ix0 = start_ix[i]
        ix1 = end_ix[i]
        if (ix1 < ix0 & i < length(start_ix)) {
            ix1 = end_ix[i+1]
        }

        if (ix1 > ix0) {
            nd = ix1 - ix0 + 1
            frac[ix0:ix1] = cumsum(rep(1, length.out=nd) / nd)
        }    
    }

    l_accum = cumsum(relative_stage_duration)
    ix1 = frac > 0 & frac <= l_accum[1]
    ix2 = frac > l_accum[1] & frac <= l_accum[2]
    ix3 = frac > l_accum[2] & frac <= l_accum[3]
    ix4 = frac > l_accum[3] & frac <= l_accum[4]
    growing_stage = rep(0,length(frac))
    growing_stage[ix1] = 1
    growing_stage[ix2] = 2
    growing_stage[ix3] = 3
    growing_stage[ix4] = 4
    growing_stage
}

