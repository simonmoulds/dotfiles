library(lulcc)

library(magrittr)
xmin=500000
ymin=1150000
crop_ext = raster::extent(xmin, xmin+10000, ymin, ymin+10000)

##1. 

#Where is the land cover data store?

#lulcc package requires the observed land cover maps to be of class "ObsLulcRasterStack"
#To do this, we first need to create a variable to hold the location of our observed land cover maps

ag_obs_stack <- stack("ag_Stack_obs.tif") %>% crop(crop_ext) %>% stack

ag_olrc <- ObsLulcRasterStack(
    x=ag_obs_stack,
    categories=c(1,2,3,4,5,6,7,8),
    labels=c("Water", "BuiltUp", "Rice", "Crops", "Grassland", "Orchards", "BareLand", "Forest"),
    t=c(0,10)
)

#After reading the land cover maps in, let's check to ensure that they are there
ag_olrc

## 2. 
#Where is all of our explanatory data stored

#lulcc package requires the explanatory variables to be of class "ExpVarRasterList"
#To do this, we create a variable that holds the covariates
ag_evrl <- ExpVarRasterList(
    x=".", pattern = "ef"
)

ag_evrl@maps = lapply(ag_evrl@maps, FUN=function(x) crop(x, crop_ext))

#Note that the six layers of ag_evrl are: elev, slope, soil_af, soil_dr, soil_mr, nd soil_nm


## 3. 

#Now we are going to explore how our efs explain our obs
#To do this we are going to use a logistic regression

#To overcome issues of spatial autocorrelation, we are first going to randomly select out a portion of the dataset
part <- partition(
    x=ag_olrc[[1]],
    size=0.1,
    spatial=TRUE
)

#This selection will then be used a training data for our logistic regresson
train.data<- getPredictiveModelInputData(
    obs=ag_olrc,
    ef=ag_evrl,
    cells=part[["train"]],
    t=0
)

#This is the formula used for the GLM
forms <- list(
  Water~ ag_Stack_ef.1 + ag_Stack_ef.2 + ag_Stack_ef.3 + ag_Stack_ef.4 + ag_Stack_ef.5 + ag_Stack_ef.6,
  BuiltUp~ ag_Stack_ef.1 + ag_Stack_ef.2 + ag_Stack_ef.3 + ag_Stack_ef.4 + ag_Stack_ef.5 + ag_Stack_ef.6,
  Rice~ ag_Stack_ef.1 + ag_Stack_ef.2 + ag_Stack_ef.3 + ag_Stack_ef.4 + ag_Stack_ef.5 + ag_Stack_ef.6,
  Crops~ ag_Stack_ef.1 + ag_Stack_ef.2 + ag_Stack_ef.3 + ag_Stack_ef.4 + ag_Stack_ef.5 + ag_Stack_ef.6,
  Grassland~ ag_Stack_ef.1 + ag_Stack_ef.2 + ag_Stack_ef.3 + ag_Stack_ef.4 + ag_Stack_ef.5 + ag_Stack_ef.6,
  Orchards~ ag_Stack_ef.1 + ag_Stack_ef.2 + ag_Stack_ef.3 + ag_Stack_ef.4 + ag_Stack_ef.5 + ag_Stack_ef.6,
  BareLand~ ag_Stack_ef.1 + ag_Stack_ef.2 + ag_Stack_ef.3 + ag_Stack_ef.4 + ag_Stack_ef.5 + ag_Stack_ef.6,
  Forest~ ag_Stack_ef.1 + ag_Stack_ef.2 + ag_Stack_ef.3 + ag_Stack_ef.4 + ag_Stack_ef.5 + ag_Stack_ef.6)

#Let's run the logistic regresson
glm.models <- glmModels(formula=forms, family=binomial, data=train.data, obs=ag_olrc)


