get_crop_param_from_nc = function(crop_nc, param, pts) {
    nc = nc_open(crop_nc)
    lat = ncvar_get(nc, "lat")
    lon = ncvar_get(nc, "lon")
    vars = names(nc$var)
    if (param %in% vars) {
        param_arr = ncvar_get(nc, param)
    } else {
        stop("nc does not contain param")
    }
    nc_close(nc)
    lat_ix = which.min(abs(lat - pts$y))[1]
    lon_ix = which.min(abs(lon - pts$x))[1]
    param_val = param_arr[lon_ix, lat_ix]    
    param_val
}

