write_co2_file = function(co2_data,  file_path=".", file_name="CarbonDioxide.txt") {
    x = c(
        "%% ---------- CO2 concentration at Mauna Loa for AquaCrop ---------- %%",
        "%% Year      CO2 conc (ppm) %%"
    )
    for (i in 1:nrow(co2_data)) {
        yr = co2_data[i,1]
        val = formatC(co2_data[i,2], digits=2, flag="0", format="f")
        ln = paste0(yr, "    ", val)
        x = append(x, ln)
    }
    con = file(file.path(file_path, file_name))
    writeLines(x, con)
    close(con)    
}

