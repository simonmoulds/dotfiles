write_soil_hydrualic_input = function(dz_layer, th_sat, th_fc, th_wp, k_sat, file_path=".", file_name="SoilHydrology.txt") {
    x = c(
        "%% ---------- Soil hydraulic properties for AquaCropOS ---------- %%",
        "%% LayerNo  LayerThickness(m)  thS(m3/m3)    thFC(m3/m3)  thWP(m3/m3)   Ksat(mm/day) %%"
    )
    dz_layer = formatC(dz_layer, digits=2, format="f")
    th_sat = formatC(th_sat, digits=2, format="f")
    th_fc = formatC(th_fc, digits=2, format="f")
    th_wp = formatC(th_wp, digits=2, format="f")
    k_sat = formatC(k_sat, digits=2, format="f")
    for (i in 1:length(dz_layer)) {        
        ln = paste0(c(i, dz_layer[i], th_sat[i], th_fc[i], th_wp[i], k_sat[i]), collapse="\t")
        x = append(x, ln)
    }
    con = file(file.path(file_path, file_name))
    writeLines(x, con)
    close(con)    
}

