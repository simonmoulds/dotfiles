get_time_dim_from_nc = function(ncfile) {
    nc = nc_open(ncfile)
    time_vals = ncvar_get(nc, "time")
    time_unit = strsplit(nc$dim$time$units, split="since")[[1]][1] %>%
        trimws %>% tolower
    time_origin = strsplit(nc$dim$time$units, split="since")[[1]][2] %>%
        trimws %>%
        as.POSIXct
    time = convertDateNcdf2R(
        time.source=time_vals,
        units=time_unit,
        origin=time_origin
    )
    nc_close(nc)
    time
}

get_longitude_dim = function(nc) {
    if ("lon" %in% names(nc$dim)) {
        lon = ncvar_get(nc, "lon")
    } else if ("longitude" %in% names(nc$dim)) {
        lon = ncvar_get(nc, "longitude")
    } else {
        stop("longitude dimension not found")
    }
    lon
}

get_latitude_dim = function(nc) {
    if ("lat" %in% names(nc$dim)) {
        lat = ncvar_get(nc, "lat")
    } else if ("latitude" %in% names(nc$dim)) {
        lat = ncvar_get(nc, "latitude")
    } else {
        stop("latitude dimension not found")
    }
    lat
}

