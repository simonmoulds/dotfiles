write_weather_input = function(times, prec_vals, tmin_vals, tmax_vals, etref_vals, file_path=".", file_name="Weather.txt") {
    x = c(
        "%% ---------- Weather input time-series for AquaCropOS ---------- %%",
        "%% Day	Month	Year	MinTemp	MaxTemp	Precipitation	ReferenceET %%")
    times = as.POSIXlt(times)
    tmin_vals = formatC(tmin_vals, digits=2, format="f")
    data = data.frame(day=times$mday, month=times$mon + 1, year=times$year + 1900, tmin=tmin_vals, tmax=tmax_vals, prec=prec_vals, etref=etref_vals)
    for (i in 1:nrow(data)) {
        ln = paste0(data[i,], collapse="\t")
        x = append(x, ln)        
    }
    con = file(file.path(file_path, file_name))
    writeLines(x, con)
    close(con)    
}

write_file_locations_input = function(file_path_in, file_path_out, file_path_aos, file_name="FileLocations.txt") {
