## AquaCrop-OS input files

get_config_option = function(config_fn, option) {
    val = readLines(config_fn) %>%
        `[`(grepl(paste0("^", option), .)) %>%
        strsplit("=") %>%
        `[[`(1) %>%
        `[`(2) %>%
        trimws
    val
}

