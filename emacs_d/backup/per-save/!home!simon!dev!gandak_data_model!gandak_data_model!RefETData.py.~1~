import os
import numpy as np
import datetime
import scipy.interpolate as interpolate
import pandas
import rasterio
import re

from hydro_model_builder.ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list

class PrecipitationData(object):
    def __init__(self, PrecipitationData_variable):
        self.var = PrecipitationData_variable
        self.var.PrecipitationInputPath = (
            self.var._configuration.globalOptions['inputDir'] 
            + '/' + self.var._configuration.precipitationDataOptions['dataDir'])
        sd = str(self.var._configuration.precipitationDataOptions['startDate'])
        ed = str(self.var._configuration.precipitationDataOptions['endDate'])
        self.var.PrecipitationStartDate = datetime.datetime.strptime(sd, '%Y-%m-%d')
        self.var.PrecipitationEndDate = datetime.datetime.strptime(ed, '%Y-%m-%d')
        self.var.PrecipitationDataOutputFile = vos.getFullPath(
            self.var._configuration.precipitationDataOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)
        
    def initial(self):
        pass

    def dynamic(self):
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)
        netcdf.create_netCDF(self.var.PrecipitationDataOutputFile, 'precipitation')
        pattern = re.compile('EX2[0-9]{5}\.[0-9]{3}')
        itime=0
        dt = self.var.PrecipitationStartDate
        step = datetime.timedelta(days=1)

        # Step through data, writing time and data to NetCDF
        for root, dirs, files in os.walk(self.var.PrecipitationInputPath):
            dirs.sort()
            files.sort()
            for f in files:
                if re.match(pattern,f):
                    prc_path = os.path.join(root,f)
                    print prc_path
                    vos.gdal_warp(
                        prc_path,
                        'tmp_prec_data.tif',
                        self.bbox[0],
                        self.bbox[1],
                        self.bbox[2],
                        self.bbox[3])
                    r = rasterio.open('tmp_prec_data.tif')
                    arr = r.read(masked=True)[0,...]
                    # TODO: deal with nodata values properly
                    # mask = np.ma.getmask(arr)
                    # arr[mask] = 0.
                    netcdf.data2NetCDF(self.var.PrecipitationDataOutputFile, 'precipitation', arr, dt)
                    os.remove('tmp_prec_data.tif')
                    dt += step
