import os
import numpy as np
import pcraster as pcr
from hydro_model_builder import VirtualOS as vos
import netCDF4 as nc
import datetime as datetime
import calendar as calendar

class CropPrice(object):

    def __init__(self, CropPrice_variable):
        self.var = CropPrice_variable
        self.var.CropPriceFileNC = str(self.var._configuration.priceOptions['cropPriceNC'])
        self.var.CropPriceVarName = str(self.var._configuration.priceOptions['cropPriceVariableName'])
        self.var.landmask_crop = np.broadcast_to(
            self.var.landmask[None,:,:],
            (self.var.nCrop, self.var.nLat, self.var.nLon))
        
    def initial(self):
        self.var.CropPrice = np.zeros((self.var.nFarm, self.var.nCrop, self.var.nCell))

    def set_crop_price(self):   # Consider separate class???
        """Function to read crop area"""
        if self.var._modelTime.timeStepPCR == 1 or self.var._modelTime.doy == 1:
            if not self.var.CropPriceFileNC == "None":
                date = '%04i-%02i-%02i' % (self.var._modelTime.year, 1, 1)
                crop_price = vos.netcdf2PCRobjClone(
                    self.var.CropPriceFileNC,
                    self.var.CropPriceVarName,
                    date,
                    useDoy = None,
                    cloneMapFileName = self.var.cloneMap,
                    LatitudeLongitude = True)
                crop_price = np.reshape(
                    crop_price[self.var.landmask_crop],
                    (self.var.nCrop, self.var.nCell))
                crop_price = np.broadcast_to(
                    crop_price[None,:,:],
                    (self.var.nFarm,
                     self.var.nCrop,
                     self.var.nCell)).copy()

                self.var.CropPrice = crop_price
                                            
    def dynamic(self):
        self.set_crop_price()
