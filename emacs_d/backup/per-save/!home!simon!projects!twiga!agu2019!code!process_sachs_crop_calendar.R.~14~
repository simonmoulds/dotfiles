library(raster)
library(ncdf4)
library(magrittr)

ext = extent(c(-20, 55, -35, 38))

fs = list.files("../data-raw/sachs_crop_calendar", pattern="[a-z]+.crop.calendar.fill.nc", full.names=TRUE)
for (fn in fs) {
    crop =
        basename(fn) %>%
        gsub("([a-z]+).(crop.calendar.fill.nc)", "\\1", .) %>%
        tolower %>% gsub("\\.", "_", .)
    
    plant_date =
        raster(fn, varname="plant") %>%
        crop(ext) %>%
        raster::aggregate(fact=3, fun=modal)
    ## plant_date_start = raster(fn, varname="plant.start") %>% crop(ext)
    ## plant_date_end = raster(fn, varname="plant.end") %>% crop(ext)

    harvest_date =
        raster(fn, varname="harvest") %>%
        crop(ext) %>%
        raster::aggregate(fact=3, fun=modal)
    ## harvest_date_start = raster(fn, varname="harvest.start") %>% crop(ext)
    ## harvest_date_end = raster(fn, varname="harvest.end") %>% crop(ext)

    writeRaster(
        plant_date,
        "../data/maize_planting_julian_day_sachs2010.tif",
        format="GTiff",
        overwrite=TRUE
    )
    
    writeRaster(
        harvest_date,
        "../data/maize_harvest_julian_day_sachs2010.tif",
        format="GTiff",
        overwrite=TRUE
)
