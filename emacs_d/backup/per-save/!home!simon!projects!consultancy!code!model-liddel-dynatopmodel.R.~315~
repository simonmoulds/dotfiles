peat_mask = raster(
    file.path(
        "data-raw",
        "11_SWAT - Copy",
        "01_Study_area",
        "Peatland combined",
        "pcomb_dem.tif"
    )
)
peat_mask[!is.na(peat_mask)] = 1

q_peatland = run_dynatopmodel(
    dem=peatland_scenario_data$dem,
    rain=peatland_scenario_data$rain[time_ix] / 1000,
    eto=peatland_scenario_data$eto[time_ix] / 1000,
    landcover=peatland_scenario_data$landcover,
    landcover_legend=peatland_scenario_data$landcover_legend,
    kc=peatland_scenario_data$kc,
    mask=peat_mask,
    area.thresh=2/100
)

Qsim_peatland = q_peatland$qsim * q_peatland$catch.area
names(Qsim_peatland) = "Qsim_peatland"

