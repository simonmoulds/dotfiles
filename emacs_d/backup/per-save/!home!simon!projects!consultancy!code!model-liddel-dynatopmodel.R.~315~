## ================================= ##
## 2. Liddel catchment               ## 
## ================================= ##
## ================================= ##

liddel_mask = raster(
    file.path(
        "data-raw",
        "11_SWAT - Copy",
        "02_DEM",
        "NewCastleton",
        "ncas_dem.tif"
    )
)
liddel_mask[!is.na(liddel_mask)] = 1

set.seed(100)
q_liddel_baseline = run_dynatopmodel(
    dem=baseline_scenario_data$dem,
    rain=baseline_scenario_data$rain[time_ix] / 1000,
    eto=baseline_scenario_data$eto[time_ix] / 1000,
    landcover=woodland_scenario_data$landcover,
    landcover_legend=woodland_scenario_data$landcover_legend,
    kc=baseline_scenario_data$kc,
    mask=liddel_mask,
    area.thresh=0.5/100
)

Qsim_liddel_baseline = q_liddel_baseline$qsim * q_liddel_baseline$catch.area
names(Qsim_liddel_baseline) = "Qsim_liddel_baseline"

set.seed(100)
q_liddel_woodland = run_dynatopmodel(
    dem=woodland_scenario_data$dem,
    rain=woodland_scenario_data$rain[time_ix] / 1000,
    eto=woodland_scenario_data$eto[time_ix] / 1000,
    landcover=woodland_scenario_data$landcover,
    landcover_legend=woodland_scenario_data$landcover_legend,
    kc=woodland_scenario_data$kc,
    mask=liddel_mask,
    ## area.thresh=0.5/100
)
Qsim_liddel_woodland = q_liddel_woodland$qsim * q_liddel_woodland$catch.area
names(Qsim_liddel_woodland) = "Qsim_liddel_woodland"

set.seed(100)
q_liddel_agroforestry = run_dynatopmodel(
    dem=agroforestry_scenario_data$dem,
    rain=agroforestry_scenario_data$rain[time_ix] / 1000,
    eto=woodland_scenario_data$eto[time_ix] / 1000,
    landcover=woodland_scenario_data$landcover,
    landcover_legend=woodland_scenario_data$landcover_legend,
    kc=agroforestry_scenario_data$kc,
    mask=liddel_mask,
    area.thresh=0.5/100
)
Qsim_liddel_agroforestry = q_liddel_agroforestry$qsim * q_liddel_agroforestry$catch.area
names(Qsim_liddel_agroforestry) = "Qsim_liddel_agroforestry"

## percent decrease for peak
ix=which.max(Qsim_liddel_baseline)

liddel_woodland_pct_decrease = (as.numeric(q_liddel_baseline$qsim[ix]) - as.numeric(q_liddel_woodland$qsim[ix])) / as.numeric(q_liddel_baseline$qsim[ix]) * 100

liddel_agroforestry_pct_decrease = (as.numeric(q_liddel_baseline$qsim[ix]) - as.numeric(q_liddel_agroforestry$qsim[ix])) / as.numeric(q_liddel_baseline$qsim[ix]) * 100

liddel_woodland_pct_decrease
liddel_agroforestry_pct_decrease

stop()

p = ggplot() + 
    geom_line(data=Qsim_liddel_baseline, aes(x=Index, y=Qsim_liddel_baseline), color="blue") +
    geom_line(data=Qsim_liddel_woodland, aes(x=Index, y=Qsim_liddel_woodland), color="magenta") +
    ## geom_line(data=Qsim_peat, aes(x=Index, y=Qsim_peat), color="green") +    
    ## geom_line(data=Qsim_netherby, aes(x=Index, y=Qsim_netherby), color="black") +    
    xlab("") +
    ylab(expression(paste("Discharge (m"^"3"," / hour)")))
print(p)
ggsave("data/liddel_woodland_vs_baseline_2016.png", width=6, height=5, units="in")

