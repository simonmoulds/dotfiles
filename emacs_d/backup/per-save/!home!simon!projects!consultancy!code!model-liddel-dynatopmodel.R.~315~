options(stringsAsFactors=FALSE)

## read data, doing the necessary data processing if not
## already done
if (length(list.files("data","[a-z]*_scenario_data.rds")) != 4) {
    source("code/load-data.R")
}

baseline_scenario_data = readRDS("data/baseline_scenario_data.rds")
peatland_scenario_data = readRDS("data/peatland_scenario_data.rds")
woodland_scenario_data = readRDS("data/woodland_scenario_data.rds")
agroforestry_scenario_data = readRDS("data/agroforestry_scenario_data.rds")

## prepare index of time period to be studied
start_time = as.POSIXct(
    "2016-01-01 00:00:00",
    tz="GMT",
    format="%Y-%m-%d %H:%M:%S"
)
end_time = as.POSIXct(
    "2016-04-01 00:00:00",
    tz="GMT",
    format="%Y-%m-%d %H:%M:%S"
)
time_ix = (
    (index(baseline_scenario_data$rain) >= start_time) &
    (index(baseline_scenario_data$rain) <= end_time)
)
## rain = topmodel_met_data$prec[time_ix] / 1000
