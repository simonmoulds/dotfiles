myfun = function(x, fs, cols, ...) {

    for (i in 1:length(fs)) {
        y = fs[[i]]
        for (j in 1:length(cols)) {
            if (cols[j] %in% colnames(x) && cols[j] %in% colnames(y)) {
                ix1 = which(colnames(x) %in% cols[j])
                ix2 = which(colnames(y) %in% cols[j])
                ix3 = match(y[["year"]], x[["year"]])
                a = rep(NA, nrow(x))
                b = rep(NA, nrow(x))
                a = x[[ix1]]
                b[ix3] = y[[ix2]]
                x[[ix1]] = rowSums(matrix(c(a,b), ncol=2), na.rm=TRUE)
            }
        }
    }
    x
}

