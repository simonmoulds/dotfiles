def read_params(fn):
    with open(fn) as f:
        content = f.read().splitlines()

    # remove commented lines, then add parameters to a dictionary
    import re
    content = filter(lambda x: re.search('^(?!%%).*', x), content)
    content = [re.split('\s+:\s+', x) for x in content]
    params = {}
    for x in content:
        if len(x) > 1:
            nm = x[0]
            val = x[1]
            params[nm] = val
    return params

