#!/usr/bin/env python

import os
import cdsapi

c = cdsapi.Client()

# Get variable names by filling in example request here:
# https://cds.climate.copernicus.eu/cdsapp#!/dataset/reanalysis-era5-single-levels?tab=form

# Standard variables required for hydrological modelling
# (precipitation + variables for computing ref et using
# Penman Monteith equation)
VARIABLES = [
    'mean_surface_net_long_wave_radiation_flux',
    'mean_surface_net_short_wave_radiation_flux',
    'surface_pressure',
    '2m_temperature',
    '2m_dewpoint_temperature',
    '10m_u_component_of_wind',
    '10m_v_component_of_wind',
    'total_precipitation'
]
YEARS = [str(num) for num in range(2010, 2020)]
MONTHS = [str(num).zfill(2) for num in range(1, 13)]
DAYS = [str(num).zfill(2) for num in range(1, 32)]
TIME = [(str(num).zfill(2) + ":00") for num in range(24)]
AREA = [38, -20, -35, 55]

OUTDIR = '../data-raw/ERA5'
try:
    os.makedirs(OUTDIR)
except:
    pass
    
def main():
    for variable in VARIABLES:
        for year in YEARS:
            for month in MONTHS:
                fn = "era5_reanalysis_" + variable + "_" + year + month + ".nc"
                c.retrieve(
                    'reanalysis-era5-single-levels',
                    {
                        'product_type' : 'reanalysis',
                        'format' : 'netcdf',
                        'area' : AREA,
                        'variable' : variable,
                        'year' : [year],
                        'month' : [month],
                        'day' : DAYS,
                        'time' : TIME
                    },
                    fn
                )

if __name__ == "__main__":
    main()
