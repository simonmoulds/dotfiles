#!/bin/bash

aosdir='/home/simon/projects/AquaCrop/AquaCrop_Matlab/AquaCropOS_v50a'
testdir='/home/simon/projects/AquaCrop/AquaCrop_tests/aquacrop_matlab_test_data'

function run_matlab_tests {
    arr="$1"
    years="$2"
    for elem in "${arr[@]}"
    do
        for year in "${years[@]}"
        do        
            echo '%% Enter Location of Input files %%' > ${aosdir}/FileLocations.txt
            echo ${testdir}/Input_"${elem}"_"${year}" >> ${aosdir}/FileLocations.txt
            echo '%% Enter Location of Output files %%' >> ${aosdir}/FileLocations.txt
            echo ${testdir}/Output_"${elem}" >> ${aosdir}/FileLocations.txt
            chmod 755 ${aosdir}/FileLocations.txt
            cwd=`pwd`
            cd ${aosdir}
            for i in 1 2 3
            do
                echo Running test $elem for year $year, attempt $i
                octave --eval AquaCropOS_RUN && break
            done        
            cd ${cwd}
        done    
    done
}

