library(raster)
library(ncdf4)
library(magrittr)

xmin = -20
xmax = 55
ymin = -35
ymax = 38
template = raster(xmn=xmin, xmx=xmax, ymn=ymin, ymx=ymax, crs="+proj=longlat +ellps=WGS84 +datum=WGS84 +no_defs", resolution=0.25)
fn = "../data/sachs_crop_calendar/Maize.crop.calendar.fill.nc"

## planting date
pd = raster("../data/maize_planting_julian_day_sachs2010.tif") %>% crop(template)

## soil
ksat = raster("../data/soil/k_sat_cosby_sl1_filled_globe_0.250000Deg.tif") %>% crop(template)

landmask = (pd > 0) & (ksat > 0)
