## observed maps
And0<- raster('LU2001x.tif')
And8<- raster('LU2009x.tif')
And15<- raster('LU2016x.tif')

And<-stack(And0,And8,And15)
plot(And)

obs <- ObsLulcRasterStack(x=And,
                          pattern="lu", 
                          categories=c(1,2,3,4), 
                          labels=c("Forest","Shrub","Grass","Others"), 
                          t=c(0,8,15))

crossTabulate(obs, times=c(0,15))

#             Forest Shrub/Forest Grass Others
#Forest         9951          344   112      1
#Shrub/Forest     43          661   147     41
#Grass            87          216  5191     20
#Others            0           49    40   1353

## explanatory variables

ef_001  <- raster("ef_001.tif")    #HGT
ef_002  <- raster("ef_002.tif")    #distance to river
ef_003  <- raster("ef_003.tif")    #distance to road
ef_004  <- raster("ef_004.tif")    #population
ef_004 <- resample(ef_004, obs)
ef_001[is.na(ef_001)] = 0
ef_002[is.na(ef_002)] = 0
ef_003[is.na(ef_003)] = 0
ef_004[is.na(ef_004)] = 0

ef_set <- stack(ef_001,ef_002,ef_003,ef_004)

ef <- ExpVarRasterList(x=ef_set)
ef

## fit statistical models
part <- partition(x=obs[[1]], size=0.5, spatial=TRUE)
train.data <- getPredictiveModelInputData(obs=obs, ef=ef, cells=part[["train"]])

forms <- list(Forest ~ ef_001+ef_002+ef_003+ef_004,
              Shrub ~ ef_001+ef_002+ef_003+ef_004,
              Grass ~ ef_001+ef_002+ef_003+ef_004,
              Others ~ ef_001+ef_002+ef_003+ef_004)

glm.models <- glmModels(formula=forms, family=binomial, data=train.data, obs=obs)


## create suitability maps
all.data <- as.data.frame(x=ef, cells=part[['all']])
probmaps <- predict(object=glm.models, newdata=all.data, data.frame=TRUE)
points <- rasterToPoints(obs[[1]], spatial=TRUE)
probmaps <- SpatialPointsDataFrame(points, probmaps)

