class CarbonDioxide(object):
    def __init__(self, CarbonDioxide_variable):
        self.var = CarbonDioxide_variable
        self.var.CarbonDioxideOutputFile = vos.getFullPath(
            self.var._configuration.carbonDioxideOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        
    def initial(self):
        pass

    def read_input_data(self):
        carbon_dioxide_filename = get_data_smart(
            'gandak_data_model',
            '../data/carbon_dioxide_concentration.txt',
            as_string=False)
        d = pandas.read_csv(
            carbon_dioxide_filename,
            delimiter="\s+",
            header=None,
            skiprows=[0],
            names=['Year','CO2'])
        print d
        return d
            
    def dynamic(self):
        d = self.read_input_data()
        years = d['Year'].values
        data = d['CO2'].values
        f = interpolate.interp1d(years, data, kind="linear")
        newyears = np.arange(years.min(), years.max() + 1)
        dates = []
        for i in range(len(newyears)):
            dates.append(datetime.datetime(newyears[i],1,1))            
        newdata = f(newyears)
        newdata = np.broadcast_to(
            newdata[:,None,None],
            (newdata.size, self.var.nLat, self.var.nLon))        
        netcdf = np2netCDF(self.var._configuration, self.var.dimensions, variable_list)        
        netcdf.create_netCDF(self.var.CarbonDioxideOutputFile, 'co2')        
        for index,date in enumerate(dates):
            netcdf.data2NetCDF(
                self.var.CarbonDioxideOutputFile,
                'co2',
                newdata[index,...],
                date)
        
