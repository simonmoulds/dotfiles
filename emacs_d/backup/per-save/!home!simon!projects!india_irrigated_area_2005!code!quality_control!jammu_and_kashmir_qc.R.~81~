## barley
## ######

if (dist_nm %in% c("Doda","Jammu","Kathua","Leh (Ladakh)","Udhampur")) {
    xx[["irr_barley-rabi"]] = xx[["irr_barley-rabi"]] + xx[["irr_barley-kharif"]]
    xx[["irr_barley-kharif"]] = 0
    xx[["apy_barley-rabi"]] %<>% tot_frac_interp(xx[["irr_barley-rabi"]], 7, 8)
    xx[["apy_barley-rabi"]] %<>% tot_frac_interp(xx[["irr_barley-rabi"]], 10:11, 9)
    xx[["apy_barley-rabi"]] %<>% locf_interp(6)
    xx[["irr_barley-rabi"]] %<>% locf_interp(6)
}

if (dist_nm %in% c("Kargil","Rajouri","Srinagar")) {
    xx[["apy_barley-rabi"]] = xx[["mapspam_atot_barley"]][6]
    xx[["irr_barley-rabi"]] = xx[["mapspam_xirr_barley"]][6]
    xx[["apy_barley-kharif"]] = 0
    xx[["irr_barley-kharif"]] = 0
}

