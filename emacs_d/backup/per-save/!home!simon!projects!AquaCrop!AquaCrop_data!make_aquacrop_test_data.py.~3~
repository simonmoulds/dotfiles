# Python script to make NetCDF input data for AquaCrop_Py

import numpy as np
import datetime
import time
import ConfigParser
import gdal
from netCDF4 import Dataset, date2num

config = ConfigParser.ConfigParser()
config.optionxform = str
config.read('aquacrop_maize_crop_parameters.ini')
crop_nms = config.get('cropParameters','CropName').split(',')

ncrop = len(crop_nms)
nlayer = 1
ncompartment = 12
nrotation = 1

lat_vals = np.array([27.75, 27.25, 26.75, 26.25, 25.75, 25.25], dtype='f4')
