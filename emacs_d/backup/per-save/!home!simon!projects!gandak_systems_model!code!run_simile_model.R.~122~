## Script to run the Simile system dynamics model

library(Simile)
use.simile.at("/usr/lib/simile-6.9")

## load Simile model
model.handle = load.model("/home/simon/Simile/models/gandak_model_v2.so")
objs = list.objects(model.handle)
for (obj in objs) {
    print(c(obj, get.model.property(model.handle, obj, "Dims")))
}

## create model instance, and load file parameters
instance.handle = create.model(model.handle)
set.model.step(instance.handle, 1, 1)
param.file = "/home/simon/Simile/models/gandak_model_v2.spf"
consult.parameter.metafile(instance.handle, param.file)
reset.model(instance.handle, -2)
get.model.time(instance.handle)
ts = 0:1000

## ====================
## set fixed parameters
## ====================

## canal distribution factor
param.handle <- create.param.array(instance.handle, "/canal_network/distribution_factor")
set.model.parameter(param.handle, 0.1)

## baseflow index
param.handle <- create.param.array(instance.handle, "/baseflow_index")
set.model.parameter(param.handle, 0.7)

## current account initial value
param.handle <- create.param.array(instance.handle, "/farm_income/current_account_initial")
set.model.parameter(param.handle, 10000)

## savings account initial value
param.handle <- create.param.array(instance.handle, "/farm_income/savings_account_initial")
set.model.parameter(param.handle, 0)

reset.model(instance.handle, -1)

## ==========================
## Pre-allocate output arrays
## ==========================

groundwater_depth = rep(0, length(ts))
recharge = rep(0, length(ts))
abstraction = rep(0, length(ts))
prec = rep(0, length(ts))
