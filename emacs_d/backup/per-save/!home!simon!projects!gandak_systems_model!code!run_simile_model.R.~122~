## TODO
prec_data = readRDS("data/prec_ts.rds")
prec.handle <- create.param.array(instance.handle, "/Prec")

get.model.property(model.handle, "/crops/crop_area", "Dims")
crop_area.handle <- create.param.array(instance.handle, "/crops/crop_area")

for (count in ts) {

    ## set dynamic parameters
    set.model.parameter(prec.handle, prec_data[count+1])
    set.model.parameter(crop_area.handle, array(c(2,2),c(2,1)))

    ## execute model
    execute.model(instance.handle, count+1, "Euler", count)

    ## retrieve output (TODO: put this in a function)
    groundwater_depth[count] = get.value.list(instance.handle, "/aquifer/groundwater_depth")
    recharge[count+1] = get.value.list(instance.handle, "/aquifer/recharge")
    abstraction[count+1] = get.value.list(instance.handle, "/aquifer/abstraction")    
    prec[count+1] = get.value.list(instance.handle, "/Prec")
    ## etref[count+1] = get.value.list(instance.handle, "/ETref")
