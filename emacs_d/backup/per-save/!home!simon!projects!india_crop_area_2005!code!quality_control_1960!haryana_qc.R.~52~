## Quality control for Haryana

## Barley
## ######

xx[["apy_barley"]] %<>% tot_frac_interp(xx[["irr_barley"]], 61:63, 60)

## Chickpea
## ########

xx[["irr_chickpea"]] %<>% linear_interp(61)
xx[["apy_chickpea"]] %<>% tot_frac_interp(xx[["irr_chickpea"]], 61:63, 60)
xx[["irr_chickpea"]] %<>% irr_frac_interp(xx[["apy_chickpea"]], 44:50, 43)

## Cotton
## ######

xx[["apy_cotton"]] %<>% locf_interp(61:63)
xx[["irr_cotton"]] %<>% locf_interp(61:63)

if (dist_nm %in% c("Ambala")) {
    xx[["irr_cotton"]] %<>% linear_interp(58)
}

if (dist_nm %in% c("Gurgaon")) {
    xx[["irr_cotton"]] %<>% pmin(xx[["apy_cotton"]])
}

if (dist_nm %in% c("Hisar.Mahendragarh","Jind","Karnal","Rohtak")) {
    xx[["irr_cotton"]] %<>% irr_frac_interp(xx[["apy_cotton"]], 48, 47)
    xx[["irr_cotton"]] %<>% irr_frac_interp(xx[["apy_cotton"]], 58, 57)
}

## Finger millet
## #############

xx[["apy_finger_millet"]] = 0
xx[["irr_finger_millet"]] = 0

## Groundnut
## #########

if (dist_nm %in% c("Ambala")) {
    xx[["apy_groundnut"]] %<>% locf_interp(61:63)
}

xx[["irr_groundnut"]] %<>% irr_frac_interp(xx[["apy_groundnut"]], 44:48, 43)
xx[["apy_groundnut"]] %<>% irr_frac_interp(xx[["irr_groundnut"]], 61:63, 60)

if (dist_nm %in% c("Jind")) {
    xx[["apy_groundnut"]] = 0
    xx[["irr_groundnut"]] = 0
}

## Maize
## #####

xx[["apy_maize"]] %<>% irr_frac_interp(xx[["irr_maize"]], 61:63, 60)

if (dist_nm %in% c("Gurgaon")) {
    xx[["irr_maize"]] %<>% irr_frac_interp(xx[["apy_maize"]], 48, 44)
    xx[["apy_maize"]] %<>% tot_frac_interp(xx[["irr_maize"]], 49, 50)
}

if (dist_nm %in% c("Jind")) {
    xx[["apy_maize"]] %<>% tot_frac_interp(xx[["irr_maize"]], 36, 35)
}

if (dist_nm %in% c("Karnal")) {
    xx[["irr_maize"]] %<>% irr_frac_interp(xx[["apy_maize"]], 46:48, 45)
}

if (dist_nm %in% c("Rohtak")) {
    xx[["irr_maize"]] %<>% irr_frac_interp(xx[["apy_maize"]], 45:48, 44)
    xx[["apy_maize"]] %<>% tot_frac_interp(xx[["irr_maize"]], 49, 50)
}

## Pearl millet
## ############

xx[["apy_pearl_millet"]] %<>% irr_frac_interp(xx[["irr_pearl_millet"]], 61:63, 60)

xx[["irr_pearl_millet"]] %<>% irr_frac_interp(xx[["apy_pearl_millet"]], 44:50, 43)

## Pigeonpea
## #########

xx[["apy_pigeonpea"]] %<>% tot_frac_interp(xx[["irr_pigeonpea"]], 61:63, 60)

xx[["apy_pigeonpea"]] %<>% locf_interp(46:47)

xx[["irr_pigeonpea"]] %<>% irr_frac_interp(xx[["apy_pigeonpea"]], 44:50, 43)

if (dist_nm %in% c("Gurgaon")) {
    xx[["irr_pigeonpea"]] %<>% irr_frac_interp(xx[["apy_pigeonpea"]], 32, 31)
    xx[["irr_pigeonpea"]] %<>% irr_frac_interp(xx[["apy_pigeonpea"]], 36, 35)
}

## Rapeseed
## ########

xx[["apy_rapeseed"]] %<>% tot_frac_interp(xx[["irr_rapeseed"]], 61:63, 60)
xx[["irr_rapeseed"]] %<>% irr_frac_interp(xx[["apy_rapeseed"]], 44:50, 43)

## Rice
## ####

xx[["irr_rice-autumn"]][60:62] = xx[["irr_rice-summer"]][60:62]
xx[["irr_rice-winter"]] = xx[["irr_rice-autumn"]]
xx[["irr_rice-autumn"]] = 0
xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice"]], 44:50, 43)
xx[["apy_rice"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 61:63, 60)

## Sesamum
## #######

xx[["apy_sesamum"]] %<>% tot_frac_interp(xx[["irr_sesamum"]], 61:63, 60)
xx[["irr_sesamum"]] %<>% irr_frac_interp(xx[["apy_sesamum"]], 44:48, 43)

if (dist_nm %in% c("Jind")) {
    xx[["apy_sesamum"]] %<>% tot_frac_interp(xx[["irr_sesamum"]], 49, 48)
    xx[["apy_sesamum"]] %<>% tot_frac_interp(xx[["irr_sesamum"]], 59, 58)
}

