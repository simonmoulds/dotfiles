def get_netcdf_files_covering_time_period(nc_filename, nc_varname, model_time):
    # assume that no more than one file per day is used - reasonable?
    datelist = pd.date_range(
        model_time.start_time.date(),
        model_time.end_time.date(),
        freq='D'
    ).to_pydatetime().tolist()
    filename_list= []
    for date in datelist:
        f = nc_filename.format(day=date.day, month=date.month, year=date.year)
        filename_list.append(f)
    # https://stackoverflow.com/a/44628266
    lookup = set()  # a temporary lookup set
    filename_list = [x for x in filename_list if x not in lookup and lookup.add(x) is None]
    return filename_list

def get_format_args(x):
    """Function to get format arguments from a string. This is
    useful to work out whether input data files are provided
    on a monthly or yearly basis
    """
    format_args = [tup[1] for tup in string.Formatter().parse(x) if tup[1] is not None]
    return format_args

def check_format_args_ok(format_args, allowable_args, allow_duplicates=True):
    """Function to check format arguments meet certain
    conditions.
    """
    format_args_ok = all([arg in allowable_args for arg in format_args])
    if format_args_ok and not allow_duplicates:
        format_args_ok = not any_duplicates(format_args)
    return format_args_ok

def has_format_args(x):
    format_args = [tup[1] for tup in string.Formatter().parse(x) if tup[1] is not None]
    return len(format_args) > 0

def open_dataset():
    if has_format_args(nc_filename):
        nc_filename_list = get_netcdf_files_covering_time_period()
        if len(nc_filename_list) > 1:
            dataset = open_nc_mfdataset(nc_filename_list)
        else:
            dataset = open_nc_dataset(nc_filename_list[0])
    else:
        dataset = open_nc_dataset(nc_filename)
    return dataset

def has_time(dims):
    return np.any([nm in allowed_t_dim_names for nm in dims])

def has_space(dims):
    has_x = np.any([nm in allowed_x_dim_names for nm in dims])
    has_y = np.any([nm in allowed_y_dim_names for nm in dims])
    return has_x & has_y

def open_hmdataset(
        nc_filename,
        nc_varname,
        model_domain,
        grid_is_1d,
        grid_dim_name
):
    """Open a dataset from a file or file-like object

    Parameters
    ----------
    nc_filename : str 
    nc_varname : str
    model_time : ModelTime 
    grid_is_1d : bool, optional
        If True, the space dimension is interpreted as one-dimensional
    grid_dim_name : str, optional
        Only used if grid_is_1d is True

    Returns
    -------
    dataset : Subclass of HmDataset
        The newly created dataset

    Notes
    -----
    TODO

    See also
    --------
    TODO
    """
    dataset = open_dataset(nc_filename, nc_varname, model_time)
    dims = dataset.variables[nc_varname].dimensions
    spatial = has_space(dims)
    temporal = has_space(dims)
    if spatial & temporal:
        if grid_is_1d:
            ds = Hm1dSpaceTimeDataset(dataset)
        else:
            ds = Hm2dSpaceTimeDataset(dataset)
    elif spatial:
        if grid_is_1d:
            ds = Hm1dSpaceDataset(dataset)
        else:
            ds = Hm2dSpaceDataset(dataset)
    elif temporal:
        ds = HmTimeDataset(dataset)
    return ds

def load_hmdataset(nc_filename, nc_varname, model_time, grid_is_1d, grid_dim_name):
    ds = open_hmdataset(nc_filename, nc_varname, model_time, grid_is_1d, grid_dim_name)
    ds.load()
    return ds
