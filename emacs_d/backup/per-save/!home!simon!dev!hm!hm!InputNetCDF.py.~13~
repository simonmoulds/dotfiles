class Hm2dSpaceDataset(Hm1dSpaceDataset):
    def __init__(self, dataset, model_domain, **kwargs):
        super().__init__(
            dataset,
            model_domain,
            **kwargs
        )
        self.check_regular_grid()
        
    def get_spatial_resolution(self):
        self.res = Resolution(
            x = float(abs(self.coordinates.x[0] - self.coordinates.x[1])),
            y = float(abs(self.coordinates.y[0] - self.coordinates.y[1]))
        )
        
    def compare_region(self):
        self.compare_resolution()
        self.compare_extent()
        self.identical_region = self.identical_extent & self.identical_resolution
    
    def enforce_y_orientation(self):
        # netcdf_y_orientation_follow_cf_convention = True
        if len(self.coordinates.y) > 1:
            netcdf_y_orientation_follow_cf_convention = (self.coordinates.y[0] - self.coordinates.y[1]) > 0
            if not netcdf_y_orientation_follow_cf_convention:
                # self.coordinates.y = self.coordinates.y[::-1]
                self.flipud = True
            else:
                self.flipud = False                
        
    def check_regular_grid(self):
        uniform_x = len(set(np.diff(self.coordinates.x))) == 1
        uniform_y = len(set(np.diff(self.coordinates.y))) == 1
        uniform_xy = uniform_x & uniform_y
        if not uniform_xy:
            msg = "Dataset " + self.nc_filename + " does not have a regular grid"
            raise ValueError(msg)
        
    def compare_resolution(self):
        self.identical_resolution = True
        if (self.res['x'] != self.region.xres) | (self.res['y'] != self.region.yres):
            self.identical_resolution = False
            
    def compare_extent(self):
        self.identical_extent = True
        if self.bounds.left != self.region.bounds.left:
            self.identical_extent = False
        if self.bounds.top != self.region.bounds.top:
            self.identical_extent = False
        if self.bounds.right != self.region.bounds.right:
            self.identical_extent = False
        if self.bounds.bottom != self.region.bounds.bottom:
            self.identical_extent = False

    def load(self):
        if self._values is None:
            self._values = self.select()
            
    def select(self):
        values = self.dataset.variables[self.nc_varname][self.index]
        if self.flipud:
            return np.flip(values, axis=self.axis.y)
        else:
            return values
        
    def get_index(self):
        index = [slice(None)] * len(self.dims)
        if not self.identical_region:
            index[self.x_axis] = self.get_x_slice()
            index[self.y_axis] = self.get_y_slice()
        self.index = index
        
    def get_x_slice(self):
        # longitudes are ascending (i.e. W -> E), hence we *add* half
        # the input cellsize to the clone map western boundary
        min_x = min(abs(self.coordinates.x - (self.bounds.left + 0.5 * self.res.x)))
        x_index_start = int(np.where(abs(self.coordinates.x - (self.region.bounds.left + 0.5 * self.res.x)) == min_x)[0])
        x_index_end = int(math.ceil(x_index_start + self.region.ncol / (self.res.x / self.region.res.x)))
        x_step = int((x_index_end - x_index_start) / abs(x_index_end - x_index_start))
        self.x_slice = self.disaggregate(x_index_start, x_index_stop, x_step, self.res.x, self.region.res.x)

    def get_y_slice(self):
        if self.flipud:
            min_y = min(abs(self.coordinates.y - (self.bounds.bottom + 0.5 * self.res.y)))
            y_index_start = int(np.where(abs(self.coordinates.y - (self.bounds.bottom + 0.5 * self.res.y)) == min_y)[0])
            y_index_end = int(math.ceil(y_index_start + self.region.ncol / (self.res.y / self.region.res.y)))
            # y_step = int((y_index_end - y_index_start) / abs(y_index_end - y_index_start))
        else:
            # latitudes are descending (i.e. N -> S), hence we *subtract*
            # half the input cellsize from the clone map northern boundary        
            min_y = min(abs(self.coordinates.y - (self.bounds.top - 0.5 * self.res.y)))
            y_index_start = int(np.where(abs(self.coordinates.y - (self.bounds.top - 0.5 * self.res.y)) == min_y)[0])
            y_index_end = int(math.ceil(y_index_start + self.region.nrow / (self.res.y / self.region.res.y)))
            # y_step = int((y_index_end - y_index_start) / abs(y_index_end - y_index_start))
            # self.y_slice = self.disaggregate(y_index_start, y_index_stop, y_step, self.res.y, self.region.res.y)
        y_step = int((y_index_end - y_index_start) / abs(y_index_end - y_index_start))
        self.y_slice = self.disaggregate(y_index_start, y_index_stop, y_step, self.res.y, self.region.res.y)
            
    def disaggregate(self, start, end, step, res, model_res):
        if res == model_res:
            slc = slice(start, end, stop)
        else:
            if float(res) % float(model_res) == 0:
                factor = int(float(res) / float(model_res))
                slc = np.arange(start, end, step).repeat(factor)
            else:
                msg = "Spatial resolution of dataset " + self.nc_filename + " is not a multiple of the model resolution"
                raise ValueError(msg)
    @property 
    def xmin(self):
        return np.min(self.coordinates.x) - self.res.x * 0.5
    @property
    def xmax(self):
        return np.max(self.coordinates.x) + self.res.x * 0.5
    @property
    def ymin(self):
        return np.min(self.coordinates.y) - self.res.y * 0.5
    @property
    def ymax(self):
        return np.max(self.coordinates.y) + self.res.y * 0.5                
    @property
    def xres(self):
        return self.res.x
    @property
    def yres(self):
        return self.res.y
    @property
    def ncol(self):
        return self.coordinates.x.size
    @property
    def nrow(self):
        return self.coordinates.y.size

class HmTimeDataset(HmDataset):    

    def __init__(self, dataset, model_domain, **kwargs):
        super(HmTimeDataset, self).__init__(
            dataset,
            model_domain,
            **kwargs
        )
        self.model_time = model_time
        self.get_time_units()
        self.get_time_calendar()
        self.get_index()
            
    def get_time_dimension_names(self):
        t_name = [dim for dim in allowed_t_dim_names if dim in self.dims]
        if len(t_name) == 1:
            self.has_time_dim = True
            self.dims.time = t_name
        else:
            self.has_time_dim = False
            
    def get_time_dimension_axes(self):
        if self.has_time_dim:
            t_axis = [position for position,value in enumerate(self.dims) if value == self.t_name]
            self.axes.time = t_axis
    
    def get_time_coordinates(self):
        if has_time_dim:
            self.coordinates.time = self.dataset.variables[self.dims.time][:]

    def get_time_units(self):
        self.time_units = repair_time_string(self.dataset[self.t_name].units)

    def get_time_calendar(self):
        self.time_calendar = self.dataset[self.t_name].calendar

    def load(self):
        if self._values is None:
            # TODO: model_time class does not currently include times attribute
            self._values = self.select(self.model_time.times)

    def select(self, time):
        index = [slice(None)] * len(self.dims)
        time_slice = self.get_time_slice(time)
        index[self.t_axis] = time_slice
        if self._values is not None:
            return self._values[index]
        else:
            return self.dataset.variables[self.nc_varname][index]

    def get_index(self):
        pass
    
    def get_time_slice(self, time, before=True):
        datenum = nc.date2num(time, units=self.time_units, calendar=self.time_calendar)
        inexact = np.logical_not(np.isin(datenum, self.coordinates.time))
        time_slice = np.searchsorted(self.coordinates.time, datenum)
        if inexact.any():
            if before:
                time_slice[inexact] = (np.searchsorted(self.coordinates.time, datenum) - 1)[inexact]
            else:
                time_slice[inexact] = np.searchsorted(self.coordinates.time, datenum)[inexact]
        return time_slice
    
    @property
    def values(self):
        return self._values

class HmSpaceTimeDataset(object):
    def select(self, time):
        self.index[self.t_axis] = self.get_time_slice(time)
        if self._values is not None:
            return self._values[self.index]
        else:
            return self.dataset.variables[self.nc_varname][self.index]
                
class Hm1dSpaceTimeDataset(HmSpaceTimeDataset, HmTimeDataset, Hm1dSpaceDataset):
    pass

class Hm2dSpaceTimeDataset(HmSpaceTimeDataset, HmTimeDataset, Hm2dSpaceDataset):
