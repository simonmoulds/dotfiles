class HmDomain(object):
    def __init__(self, model_region, model_time, region_varname=None):
        try:
            ds = xr.open_dataset(model_region)
            # if region_varname not supplied, use the first variable which isn't also a dimension
            if region_varname is None:
                # raise Warning()
                try:
                    region_varname = [value for key, value in enumerate(ds.variables) if value not in ds.dims.keys()][0]
                except IndexError:
                    msg = 'Provided region file ' + model_region + ' does not contain any (non-dimension) variables'
                    raise OSError(msg)
                
            rgn = ds.to_array(region_varname)
            dimnames = get_dimension_names(ds, region_varname)
            coords = get_coordinates(ds, dimnames)
            self.x = coords.x
            self.y = coords.y
            self.z = coords.z
            mask = model_region.variables[region_varname][:]
            self.mask = mask > 0
        except:
            try:
                ds = xr.open_rasterio(model_region)
                self.x = ds.x.values
                self.y = ds.y.values
                self.z = None
                mask = ds.values
            except:
                msg = 'File containing model region cannot be opened: ' + model_region
                raise OSError(msg)
        self.time = model_time.times

class HmDataset(ABC):
    def __init__(self, dataset, model_domain, **kwargs):
        self.dataset = dataset
        self.domain = model_domain
        self.dims = Dimnames()
        self.axes = Axes()
        self.coordinates = Coordinates()
        self._values = None
        
    @abstractmethod
    def get_space_dimension_names(self):
        pass
    @abstractmethod
    def get_time_dimension_names(self):
        pass
    @abstractmethod
    def get_space_dimension_axes(self):
        pass
    @abstractmethod
    def get_time_dimension_axes(self):
        pass    
    @abstractmethod
    def get_space_coordinates(self):
        pass
    @abstractmethod
    def get_time_coordinates(self):
        pass
    
class HmSpaceDataset(HmDataset):
    
    def __init__(self, dataset, model_domain, **kwargs):
        super().__init__(
            dataset,
            model_domain,
            **kwargs
        )
        self.get_space_dimension_names()
        self.get_space_dimension_axes()
        self.get_space_coordinates()
        self.get_bounds()
        self.get_spatial_resolution()
        self.compare_region()
        self.get_index()
        
    def get_space_dimension_names(self):
        y_name = [dim for dim in allowed_y_dim_names if dim in self.dims]
        x_name = [dim for dim in allowed_x_dim_names if dim in self.dims]
        if (len(y_name) == 1) & (len(x_name) == 1):
            self.dims.y = y_name[0]
            self.dims.x = x_name[0]
        else:
            msg='Dataset dimensions are not understood: x dimension must be one of ' + ', '.join('"{0}"'.format(w) for w in allowed_x_dim_names) + '; y dimension must be one of ' + ', '.join('"{0}"'.format(w) for w in allowed_y_dim_names)
            raise ValueError(msg)
        
        z_name = [dim for dim in allowed_z_dim_names if dim in self.dims]
        if len(z_name) == 1:
            self.has_z_dim = True
            self.dims.z = z_name
        else:
            self.has_z_dim = False            
            
    def get_space_dimension_axes(self):
        y_axis = [position for position,value in enumerate(self.dims) if value == self.y_name]
        x_axis = [position for position,value in enumerate(self.dims) if value == self.x_name]
        self.axes.y = y_axis
        self.axes.x = x_axis
        if self.has_z_dim:
            z_axis = [position for position,value in enumerate(self.dims) if value == self.dims.z]
            self.axes.z = z_axis
    
    def get_space_coordinates(self):
        self.coordinates = Coordinates(
            x = self.dataset.variables[self.dims.x][:],
            y = self.dataset.variables[self.dims.y][:]
        )        
        if has_z_dim:
            self.coordinates.z = self.dataset.variables[self.dims.z][:]            

    # @abstractmethod
    def get_spatial_resolution(self):
        pass
    # @abstractmethod
    def get_bounds(self):
        pass
    # @abstractmethod
    def compare_region(self):
        pass
    # @abstractmethod
    def get_index(self):
        pass
    
class Hm1dSpaceDataset(HmSpaceDataset):
    
    def get_spatial_resolution(self):
        pass
    
    def get_bounds(self):
        self.bounds = BoundingBox(
            left = self.xmin,
            bottom = self.ymin,
            right = self.xmax,
            top = self.ymax
        )
    
    def compare_region(self):
        identical_y_coordinates = np.array_equal(self.coordinates.y, self.region.coordinates.y)
        identical_x_coordinates = np.array_equal(self.coordinates.x, self.region.coordinates.x)
        self.identical_region = identical_y_coordinates & identical_x_coordinates        

    def load(self):
        if self._values is None:
            self._values = self.select()

    def select(self):
        return self.dataset.variables[self.nc_varname][self.index]
    
    def get_index(self):
        index = [slice(None)] * len(self.dims)
        if not self.identical_region:
            index[self.x_axis] = self.get_x_slice()
            index[self.y_axis] = self.get_y_slice()
        self.index = index
        
    def get_x_slice(self):
        ds = xr.open_dataset(self.nc_filename)
        x_match = ds[self.x_name].sel({self.x_name : self.region.coordinates.x}).values
        x = ds[self.x_name]
        ds.close()
        # this could be too time consuming - use f2py?
        self.x_slice = tuple([np.argwhere(xx == x).item() for xx in x_match])        

    def get_y_slice(self):
        ds = xr.open_dataset(self.nc_filename)
        y_match = ds[self.y_name].sel({self.y_name : self.region.coordinates.y}).values
        y = ds[self.y_name]
        ds.close()
        # this could be too time consuming - use f2py?
        self.y_slice = tuple([np.argwhere(yy == y).item() for yy in y_match])

