        self.potential_yield_module.initial()
        self.price_module.initial()
        self.soil_parameters_module.initial()
        self.canal_access_module.initial()
        
        self.get_model_dimensions()
        
    def get_model_dimensions(self):
        latitudes = np.unique(pcr.pcr2numpy(pcr.ycoordinate(self.cloneMap), vos.MV))[::-1]
        longitudes = np.unique(pcr.pcr2numpy(pcr.xcoordinate(self.cloneMap), vos.MV))
        zLayer = np.array([0.3,2.])
        zLayerBot = np.cumsum(zLayer)
        zLayerTop = zLayerBot - zLayer
        zLayerMid = (zLayerTop + zLayerBot) / 2
        nLayer = zLayer.size

        zComp = np.array([0.1,0.1,0.1,0.15,0.15,0.2,0.2,0.25,0.25,0.25,0.25,0.3])
        zCompBot = np.cumsum(zComp)
        zCompTop = zCompBot - zComp
        zCompMid = (zCompBot + zCompTop) / 2
        nComp = zComp.size
        
        self.dimensions = {
            'lat' : latitudes,
            'lon' : longitudes,
            'time': None,
            'layer' : zLayerMid,
            'compartment' : zCompMid,
            'crop' : np.arange(self.nCrop),
            'farm' : np.arange(self.nFarm),
            'category' : np.arange(self.nFarmSizeCategory)
        }

    def dynamic(self):
        self.carbon_dioxide_module.dynamic()
        self.cropland_area_module.dynamic()
        self.crop_area_module.dynamic()
        self.farm_area_module.dynamic()
