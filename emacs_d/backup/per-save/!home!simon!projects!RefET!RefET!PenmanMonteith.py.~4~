        #     method_for_time_index = self.var._configuration.meteoOptions['time_index_method_for_temperature_netcdf']

        method_for_time_index = None        
        day, month, year = (self.var._modelTime.currTime.day,
                            self.var._modelTime.currTime.month,
                            self.var._modelTime.currTime.year)
        self.var.temperature = vos.netcdf2PCRobjClone(
            self.var.tempFileNC.format(day=day, month=month, year=year),
            self.var.tempVarName,
            str(self.var._modelTime.fulldate),
            useDoy = method_for_time_index,
            cloneMapAttributes = self.var.cloneMapAttributes,
            LatitudeLongitude = True)

        if self.var.compute_tmin_tmax_from_subdaily_data:
            self.compute_tmin_tmax_from_subdaily_data()
        else:
            self.var.tmin = vos.netcdf2PCRobjClone(
                self.var.tminFileNC.format(day=day, month=month, year=year),
                self.var.tminVarName,
                str(self.var._modelTime.fulldate),
                useDoy = method_for_time_index,
                cloneMapAttributes = self.var.cloneMapAttributes,
                LatitudeLongitude = True)

            self.var.tmax = vos.netcdf2PCRobjClone(
                self.var.tmaxFileNC.format(day=day, month=month, year=year),
                self.var.tmaxVarName,
                str(self.var._modelTime.fulldate),
                useDoy = method_for_time_index,
                cloneMapAttributes = self.var.cloneMapAttributes,
                LatitudeLongitude = True)
            
        self.adjust_temperature_data()

