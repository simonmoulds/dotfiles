class PenmanMonteith(object):

    def __init__(self, PenmanMonteith_variable):
        self.var = PenmanMonteith_variable

    def initial(self):
        self.set_input_filenames()
        self.set_meteo_conversion_factors()
        
    def set_input_filenames(self):        
        self.set_temperature_input_filenames()
        self.set_longwave_radiation_input_filenames()
        self.set_surface_pressure_input_filenames()
        self.set_surface_specific_humidity_input_filenames()
        self.set_shortwave_radiation_input_filenames()
        self.set_wind_input_filenames()
        self.check_input_filenames()
        self.check_nc_variable_names()            
        
    def get_vals_from_meteo_options(self, keys):
        return [self.var._configuration.meteoOptions[key] for key in keys]
    
    def set_longwave_radiation_input_filenames(self):
        self.var.longwaveRadiationDownFileNC, self.var.longwaveRadiationDownFileVarName = (
            self.get_vals_from_meteo_options([
                'downwellingLongwaveRadiationNC',
                'downwellingLongwaveRadiationVarName'
            ]))

    def set_surface_pressure_input_filenames(self):
        self.var.surfacePressureFileNC, self.var.surfacePressureVarName = (
            self.get_vals_from_meteo_options([
                'surfaceAtmosphericPressureNC',
                'surfaceAtmosphericPressureVarName']))

    def set_surface_specific_humidity_input_filenames(self):
        self.var.surfaceSpecificHumidityFileNC, self.var.surfaceSpecificHumidityVarName = (
            self.get_vals_from_meteo_options([
                'nearSurfaceSpecificHumidityNC',
                'nearSurfaceSpecificHumidityVarName']))
        
    def set_shortwave_radiation_input_filenames(self):
        self.var.shortwaveRadiationDownFileNC, self.var.shortwaveRadiationDownVarName = (
            self.get_vals_from_meteo_options([
                'downwellingShortwaveRadiationNC',
                'downwellingShortwaveRadiationVarName']))

    def set_wind_input_filenames(self):
        self.var.windFileNC, self.var.windVarName = (
            self.get_vals_from_meteo_options([
                'nearSurfaceWindSpeedNC',
                'nearSurfaceWindSpeedVarName']))
        
    def set_temperature_input_filenames(self):
        self.var.tempFileNC, self.var.tempVarName = (
            self.get_vals_from_meteo_options([
                'temperatureNC',
                'temperatureVarName'
            ]))
        
        self.var.compute_tmin_tmax_from_subdaily_data = (
            bool(self.get_vals_from_meteo_options(['compute_daily_min_max_temperature_from_subdaily_data'])))
        
        if self.var.compute_tmin_tmax_from_subdaily_data:
            self.var.subDailyTempFileNC, self.var.subDailyTempVarName = (
                self.get_vals_from_meteo_options([
                    'subDailyTemperatureNC',
                    'subDailyTemperatureVarName']))
            self.var.tminFileNC, self.var.tminVarName = None, None
            self.var.tmaxFileNC, self.var.tmaxVarName = None, None
        else:
            self.var.subDailyTempFileNC, self.var.subDailyTempVarName = None, None
            self.var.tminFileNC, self.var.tminVarName = (
                self.get_vals_from_meteo_options([
                    'minDailyTemperatureNC',
                    'minDailyTemperatureVarName']))
            self.var.tmaxFileNC, self.var.tmaxVarName = (
                self.get_vals_from_meteo_options([
                    'maxDailyTemperatureNC',
                    'maxDailyTemperatureVarName']))
                
    def check_input_filenames(self):
        self.check_format_args([
            self.var.tempFileNC,
            self.var.subDailyTempFileNC,
            self.var.tminFileNC,
            self.var.tmaxFileNC,
            self.var.longwaveRadiationDownFileNC,
            self.var.surfacePressureFileNC,
            self.var.surfaceSpecificHumidityFileNC,
            self.var.shortwaveRadiationDownFileNC,
            self.var.windFileNC])
        
    def check_format_args(self, filenames):
        msg = ''
        format_args_not_ok = False
        for filename in filenames:
            if filename is not None:
                format_args = vos.get_format_args(filename)                
                if len(format_args) > 0:
                    format_args_ok = vos.check_format_args_ok(format_args, ['day','month','year'])
                    if not format_args_ok:
                        format_args_not_ok = True
                        msg += 'Filename ' + filename + ' contains invalid format arguments: only day, month and year are allowable\n'
        if format_args_not_ok:
            raise Messages.ModelError(msg)
                
