library(magrittr)
library(lubridate)
library(dplyr)

datadir = "../data/pt_met_data/"

options(stringsAsFactors = FALSE)
x = read.csv(
    file.path(
        datadir,
        "tahmo_era5_stn_TA00339_met_2016-2019.csv"
    )
)
x$DATE %<>% as.POSIXlt(format="%Y-%m-%d")

x %<>%
    group_by(yr=year(date), mon=month(date)) %>%
    summarise(mn_amt = mean(P_TAHMO))
month(x$DATE)

