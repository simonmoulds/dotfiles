            ('downwellingShortwaveRadiationVarName', 'srad'),
            ('downwellingShortwaveRadiationTimeDimName', 'time'),
            ('downwellingShortwaveRadiationOffset', str(0)),
            ('downwellingShortwaveRadiationFactor', str(1)),
            ('windSpeedNC', '${FILE_PATHS:PathIn}/../../AgMERRA/AgMERRA_{year:0>4}_wndspd.nc4'),
            ('windSpeedVarName', 'wndspd'),
            ('windSpeedTimeDimName', 'time'),
            ('windSpeedOffset', str(0)),
            ('windSpeedFactor', str(1))
        ])

        config['REPORTING'] = collections.OrderedDict([
            ('outDailyTotal', 'ETref'),
            ('formatNetCDF', 'NETCDF4'),
            ('zlib', 'True')
        ])

        config_fn = os.path.join(run_config_dir, 'etref_' + country + '_agmerra_config.ini')
        with open(config_fn, 'w') as f:
            config.write(f)

if __name__ == '__main__':
    main()

