class Model(object):
    
    def __init__(self, configuration, modelTime, initialState = None):                
        self._configuration = configuration
        self._modelTime = modelTime
        self.set_clone_map()
        self.set_landmask()
        self.set_grid_cell_area()
        self.get_model_dimensions()
        
    def set_clone_map(self):
        self.cloneMapFileName = str(self._configuration.cloneMap)
        self.cloneMap = vos.read_GDAL(self.cloneMapFileName)

    def set_landmask(self):
        self.landmask = vos.gdal_to_array(self._configuration.landmask, cloneMapFileName=self.cloneMapFileName)
        print((self.landmask.shape))
        # self.landmask = vos.read_map_clone(self.configuration.landmask, self.cloneMap)
        self.landmask = self.landmask > 0

    def set_grid_cell_area(self):
        # grid_cell_area = vos.netcdf_to_arrayWithoutTime(
        #     str(self._configuration.MASK_OUTLET['gridCellAreaInputFile']),
        #     str(self._configuration.MASK_OUTLET['gridCellAreaVariableName']),
        #     cloneMapFileName = self.cloneMapFileName)
        # grid_cell_area = np.float64(grid_cell_area)
        # self.grid_cell_area = grid_cell_area[self.landmask]
        self.grid_cell_area = np.ones_like(self.landmask)  # TEMP

    def get_model_dimensions(self):
        """Function to set model dimensions"""
        # self.nLat = int(self.cloneMapAttributes['rows'])
        # ds = xr.open_rasterio(self.cloneMap)        
        self.latitudes = self.cloneMap.y
        self.nLat = self.cloneMap.y.size
        self.longitudes = self.cloneMap.x
        self.nLon = self.cloneMap.x.size
        self.nCell = int(np.sum(self.landmask))
        self.nLayer = int(self._configuration.SOIL_PARAMETERS['nLayer'])
        self.nComp = int(self._configuration.SOIL_PARAMETERS['nComp'])
        self.dimensions = {
            'time'     : None,
            # 'depth'    : np.arange(self.nLayer), # TODO - put nComp in config section [SOIL_PARAMETERS]
            'depth'    : np.arange(self.nComp), # TODO - put nComp in config section [SOIL_PARAMETERS]
            'lat'      : self.latitudes,
            'lon'      : self.longitudes,
        }
        
    @property
    def configuration(self):
        return self._configuration
