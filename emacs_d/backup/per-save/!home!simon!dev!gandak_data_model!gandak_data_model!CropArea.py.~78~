import os
import numpy as np
import rasterio

from hydro_model_builder.ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list
from utils import *

class CropArea(object):
    def __init__(self, CropArea_variable):
        self.var = CropArea_variable
        crop_types = self.var._configuration.cropAreaOptions['cropTypes']
        self.var.CropTypes = set([x.strip() for x in crop_types.split(',')])
        self.var.nCrop = len(self.var.CropTypes)
        # self.var.CropTypes = list(set(self.var._configuration.cropAreaOptions['cropTypes'].split(",")))
        self.var.CropAreaInputDir = self.var._configuration.cropAreaOptions['cropAreaInputDir']
        self.var.CropAreaOutputFile = vos.getFullPath(
            self.var._configuration.cropAreaOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)
            
    def initial(self):
        pass

    def dynamic(self):
        crop_area = []
        print self.var.CropTypes
        for index,name in enumerate(self.var.CropTypes):
            arr = read_gdal_raster_image(
                os.path.join(self.var.CropAreaInputDir,'INDIA_' + name.upper() + '_2005.tif'),
                self.bbox,
                0.)
            crop_area.append(arr)

        self.var.crop_area = np.stack(crop_area, axis=0)
        self.var.crop_area *= 10000.
        netcdf = np2netCDF(self.var._configuration, self.var.dimensions, variable_list)        
        netcdf.create_netCDF(self.var.CropAreaOutputFile, 'crop_area')        
        netcdf.data2NetCDF(
            self.var.CropAreaOutputFile,
            'crop_area',
            self.var.crop_area)

