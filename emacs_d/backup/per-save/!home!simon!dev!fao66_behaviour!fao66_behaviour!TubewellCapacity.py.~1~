# -*- coding: utf-8 -*-

import os
import time
import numpy as np
from hydro_model_builder import VirtualOS as vos
from aquacrop.Messages import *

import logging
logger = logging.getLogger(__name__)

class TubewellCapacity(object):

    def __init__(self, TubewellCapacity_variable):
        self.var = TubewellCapacity_variable

    def initial(self):
        initialTubewellCapacityNC = str(self.var._configuration.canalOptions['initialTubewellCapacityNC'])
        try:
            canal_access = vos.netcdf2PCRobjCloneWithoutTime(
                initialTubewellCapacityNC,
                canal_access_varname,
                cloneMapFileName = self.var.cloneMap,
                LatitudeLongitude = True)
        except:
            canal_access = np.ones((self.var.nFarm, self.var.nLat, self.var.nLon))

        self.var.TubewellCapacity = canal_access.copy()

    def dynamic(self):
        pass
