r1 = raster("up_canal_govt_sum.tif")
r2 = raster("br_canal_govt_sum.tif")
r = raster(xmn=77, xmx=89, ymn=22, ymx=30.5, res=0.008333333)
r[] = 0
r3 = r
r4 = r
r3[r1] = r3[r1] + r1[r1]
r4[r2] = r4[r2] + r2[r2]
r = stackApply(stack(r3,r4), indices=c(1,1), fun=max)


template = raster(xmn=83, ymn=25, xmx=86.5, ymx=28, ncols=42, nrows=36)

r = crop(r, extent(template))
plot(r)
area = area(r) * 1000 * 1000 / 10000

pts = as(r, "SpatialPoints")
idx = getValues(r) > getValues(area)
pts = pts[idx]
pts = SpatialPointsDataFrame(pts, data=data.frame(id=seq(1, length(pts))))

r[idx] = NA
plot(r)
points(pts)

writeRaster(r, "up_br_canal_govt_sum.tif", format="GTiff", overwrite=TRUE)
