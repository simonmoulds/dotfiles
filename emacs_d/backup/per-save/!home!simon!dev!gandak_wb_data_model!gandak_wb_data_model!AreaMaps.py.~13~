#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import shutil
import numpy as np
import rasterio

from hm import file_handling
from hm.OutputNetCDF import OutputNetCDF

import variable_list as variable_list
from utils import *

class AreaMaps(object):    
    def __init__(self, AreaMaps_variable):
        self.var = AreaMaps_variable
        self.var.AreaMapsOutputPath = str(
            self.var._configuration.MASK_OUTLET['areaMapsPathOut'])
        self.bbox = get_clone_map_extent(self.var._configuration.cloneMap)

    def initial(self):
        pass

    def dynamic(self):
        grid_cell_area_filename = str(
            self.var._configuration.MASK_OUTLET['gridCellAreaInputFile']
        )
        grid_cell_area_output_filename = str(
            self.var._configuration.MASK_OUTLET['gridCellAreaOutputFile']
        )
        grid_cell_area_output_varname = str(
            self.var._configuration.MASK_OUTLET['gridCellAreaOutputVariableName']
        )
        self.var.grid_cell_area = read_gdal_raster_image(
            grid_cell_area_filename,
            self.bbox,
            0)        
        self.var.grid_cell_area *= 1e6  # km2 -> m2

        netcdf = OutputNetCDF(
            self.var._configuration.NETCDF_ATTRIBUTES,
            self.var.dimensions,
            variable_list
            )        
        netcdf.create_netCDF(
            grid_cell_area_output_filename,
            grid_cell_area_output_varname)
        netcdf.add_data_to_netcdf(
            grid_cell_area_output_filename,
            grid_cell_area_output_varname,
            self.var.grid_cell_area)

        shutil.copy(
            str(self.var._configuration.MASK_OUTLET['cloneMap']),
            self.var.AreaMapsOutputPath)
        
        shutil.copy(
            str(self.var._configuration.MASK_OUTLET['landmask']),
            self.var.AreaMapsOutputPath)
