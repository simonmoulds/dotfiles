\subsubsection{Interception}
The vegetation canopy is modelled as a single reservoir with capacity $s_{c}$ ($\mathrm{M L^{-2}}$). Precipitation fills the reservoir to its maximum capacity, $s_{c,max}$, with excess water falling as net precipitation,

\begin{equation}
  P_{e}(t) =
  \begin{cases}
    P(t) - (S_{c,max} - S_{c}), & \text{if}\ P(t) + s_{c}(t-1) > s_{c,max}\\
    0, & \text{otherwise}.
\end{cases}
\end{equation}

\noindent The evaporative flux from the canopy store, $E_{c}(t)$ is either energy or water limited, as follows:

\begin{equation}
  E_{c}(t) =
  \begin{cases}
    ET_{o}(t)K_{c}, & \text{if}\ ET_{o}(t)K_{c} \leq s_{c}\\
    S_{c}, & \text{otherwise}.
  \end{cases}
\end{equation}

\subsubsection{Evapotranspiration}
Evapotranspiration is computed as

\begin{equation}
  ET_{c}(t) = K_{s}(t)K_{c}(t)ET_{0}(t)
\end{equation}

\noindent where $K_{c}$ and $ET_{0}$ ($\mathrm{M L^{-2}}$) is reference evapotranspiration. The water stress coefficient, $K_{s}(t)$, is calculated

\begin{equation}
  K_{s}(t) = \frac{TAW - D_{r}(t)}{(1 - p) TAW}
\end{equation}

