\subsubsection{Surface runoff}
Surface runoff is modelled using the Improved Arno scheme \citep{todini_arno_1996,hagemann_improving_2003}, in which the soil water storage of a catchment is represented as a distribution, such that for a given average soil water content $W(t)$ a proportion of the area will be at saturation and thus capable of producing runoff \citep{}. A derivation of the Improved Arno scheme is provided in Appendix A.\\

Surface runoff $q_{r}(t)$ is related to the average soil water content $W(t)$ according to the following scheme:

\begin{enumerate}
\item $P_{e}(t) < W_{min} - W(t)$,
  \begin{equation}
    q_{r}(t) = 0
  \end{equation}

\item $W_{min} - W(t) \leq P(t) < \left(b+1\right) \left(W_{max} - W_{min}\right) \left[\frac{W_{max} - W_{min}}{W_{max} - W_{min}}\right]^{\frac{1}{b+1}}$,
  \begin{multline}
    q_{r}(t) = P_{e}(t) - (W_{max} - W(t)) \\
    + (W_{max} - W_{min}) \left[ \left(\frac{W_{max} - W}{W_{max} - W_{min}} \right)^{\frac{1}{b+1}} - \frac{P_{e}(t)}{\left(b+1\right) \left(W_{max} - W_{min}\right)} \right]^{b+1}
  \end{multline}
  
\item $P(t) \geq \left(b+1\right) \left(W_{max} - W_{min}\right) \left[\frac{W_{max} - W_{min}}{W_{max} - W_{min}}\right]^{\frac{1}{b+1}}$,
  \begin{equation}
    q_{r}(t) = P_{e}(t) - (W_{max} - W(t))
  \end{equation}
\end{enumerate}

\noindent where $W_{max}$ and $W_{min}$ are the maximum and minimum average storage, respectively, and $b$ is a dimensionless shape parameter which defines the distribution of soil water storage.\\

\subsubsection{Infiltration}
% refer to surface runoff equation
Following Equation~\ref{}, infiltration is computed as

\begin{equation}
  I(t) = P_{e}(t) - q_{t}(t).
\end{equation}

\noindent We model the root zone as three compartments: an upper compartment which has a depth of 50mm, and two additional compartments of varying depths. Referring to each compartment with an index variable $i$, such that for the uppermost compartment $i=1$, we set the downward flux $q_{i}$ ($\mathrm{L T^{-1}}$) equal to the unsaturated hydraulic conductivity:

\begin{equation}
  q_{i}(t) = k_{i}(s_{i}(t)), \quad \text{for} \quad 1 \leq i \leq n
\end{equation}

\noindent where $k$ is the unsaturated hydraulic conductivity ($\mathrm{L T^{-1}}$), and $s(t)$ is the degree of saturation of compartment ($\mathrm{M L^{-3}}$), such that

\begin{equation}
  s_{i}(t) = \frac{\theta_{i}(t) - \theta_{i,r}}{\theta_{i,s} - \theta_{i,r}}
\end{equation}

\noindent where $\theta_{i}(t)$ is the actual water content of compartment $i$ and $\theta_{i,r}$ and $\theta_{i,s}$ are the residual and saturated volumetric water contents of compartment $i$, respectively ($\mathrm{M L^{-3}}$). \\

\subsubsection{Recharge}
Recharge is computed as the sum of the downward flux from the bottom soil layer, $q_{n}$, and preferential flow, $q_{pref}$,

\begin{equation}
  R(t) = q{n}(t) + q_{pref}(t).
\end{equation}

Preferential flow is modelled separately from the infiltration... Eq.~\ref{}. 

