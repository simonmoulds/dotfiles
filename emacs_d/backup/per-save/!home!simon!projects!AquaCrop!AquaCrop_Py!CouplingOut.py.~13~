    def create_coupling_directory(self, dirname):
        """Function to create directory in which to write files for 
        model coupling. If the directory already exists the function 
        removes any netCDF files, because the models have no way of 
        distinguishing between current and previous model runs
        """
        if not os.path.exists(dirname):
            try:
                os.makedirs(dirname)
            except:
                msg = ''
                raise AQError(msg)
                
        else:
            for fl in os.listdir(dirname):
                if re.search('nc$|nc4$', fl):
                    print fl
                    os.remove(os.path.join(dirname, fl))
        
    def initiate_reporting(self):
        """Function to create netCDF files for each output variable"""

        # object for reporting
        self.netcdfObj = np2netCDF(self.configuration, self._model)

        # coupling variables (currently only recharge and irrigation are considered)
        self.coupling_output_variables = []
        if 'recharge' in self.configuration.couplingOptions.keys():
            if self.configuration.couplingOptions['recharge'] == "1":
                self.coupling_output_variables.append('recharge')
                rechargeOutputDir = self.configuration.couplingOptions['rechargeOutputDir']
                self.create_coupling_directory(rechargeOutputDir)
                self.rechargeNC = os.path.join(
                    self.configuration.couplingOptions['rechargeOutputDir'],
                    self.configuration.couplingOptions['rechargeOutputNC'])

        if 'gwpumping' in self.configuration.couplingOptions.keys():
            if self.configuration.couplingOptions['gwpumping'] == "1":
                self.coupling_output_variables.append('gwpumping')
                gwpumpingOutputDir = self.configuration.couplingOptions['gwpumpingOutputDir']
                self.create_coupling_directory(gwpumpingOutputDir)
                self.gwpumpingNC = os.path.join(
                    self.configuration.couplingOptions['gwpumpingOutputDir'],
                    self.configuration.couplingOptions['gwpumpingOutputNC'])

        if 'swpumping' in self.configuration.couplingOptions.keys():
            if self.configuration.couplingOptions['swpumping'] == "1":
                self.coupling_output_variables.append('swpumping')
                swpumpingOutputDir = self.configuration.couplingOptions['swpumpingOutputDir']
                self.create_coupling_directory(swpumpingOutputDir)
                self.swpumpingNC = os.path.join(
                    self.configuration.couplingOptions['swpumpingOutputDir'],
                    self.configuration.couplingOptions['swpumpingOutputNC'])

    def post_processing(self):
        """Function to process model variables to output variables. In 
        most cases this simply involves copying model attributes
        """
        if not len(self.coupling_output_variables) == 0:            
            if 'recharge' in self.coupling_output_variables:
                # multiply by current crop area to get volume

                # TODO: this isn't right because we also model recharge from current fallow land

                
                self.RechargeVol = np.sum(np.multiply((vars(self._model)['DeepPerc'] / 1000),
                                                      vars(self._model)['CurrentCropArea']), axis=0)

            if 'gwpumping' in self.coupling_output_variables:
                self.GwPumpingVol = vars(self._model)['GwPumpingVol']                

            if 'swpumping' in self.coupling_output_variables:
                self.SwPumpingVol = vars(self._model)['SwPumpingVol']

            # print self._model.DeepPerc[:,10]
