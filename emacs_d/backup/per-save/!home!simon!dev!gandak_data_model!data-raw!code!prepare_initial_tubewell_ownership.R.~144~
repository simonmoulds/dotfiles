## The purpose of this script is to prepare a
## map showing the rate of tubewell ownership
## in each farm size category

## Farm size categories:
## 
## Marginal    : 0-1 Ha
## Small       : 1-2 Ha
## Semi-medium : 2-4 Ha
## Medium      : 4-6 Ha
## Large       : > 6 Ha

## Strategy is to downscale data from Minor
## Irrigation Census (1986-87)

library(readxl)
library(raster)
library(rgdal)
library(magrittr)
library(dplyr)
library(tidyr)
library(xts)

options(stringsAsFactors = FALSE)

model_mask = raster("data/modelMask.tif")
template = raster(xmn=80, xmx=90, ymn=20, ymx=30, res=0.0833333333)

## Minor Irrigation Census data
## ############################

devtools::load_all("/home/simon/dev/r_indagridat/indagridat")
## adm2_1960 = readOGR(dsn=system.file("shapes", package="indagridat"), layer="g1960_2_India", stringsAsFactors=TRUE)
## adm2_1960_raster = rasterize(adm2_1960, template, "ADM2_CODE")

adm2_2010 = readOGR(dsn="pkg/india_adm2_1990/data", layer="g1990_2_India", stringsAsFactors=FALSE)
adm2_2010$ADM2_CODE %<>% as.numeric
adm2_2010_raster = rasterize(adm2_2010, template, "ADM2_CODE")

## adm2_2010_raster[is.na(template)] = NA
## ids =
##     adm2_2010_raster %>%
##     getValues %>%
##     unique %>%
##     `[`(!is.na(.)) %>%
##     sort
ids = c(17595,17604,17613,17618,17619,17620,17626,17628,17631,17632,17894,17914,70272,70274,72604,72651)

index = as.numeric(adm2_2010$ADM2_CODE) %in% ids
dist =
    adm2_2010$ADM2_NAME %>%
    as.character %>%
    `[`(index)
state =
    adm2_2010$ADM1_NAME %>%
    as.character %>%
    `[`(index)
gaul_id =
    adm2_2010$ADM2_CODE %>%
    as.numeric %>%
    `[`(index)

x = data.frame(state=state, dist=dist, gaul_id=gaul_id)

## District-wise number of tubewells
micensus = read_excel("data/micensus/micensus_1986-87_shallowtubewell.xls") %>%
    setNames(paste0("X", seq(1, ncol(.)))) %>%
    filter(X1 %in% c("Bihar","Uttar Pradesh")) %>%
    setNames(c("state","id","dist", names(.)[4:38])) %>%
    dplyr::select(-(id))

nms = names(micensus)
nms[15:20] = c("MARG_NO_TW","SMALL_NO_TW","SEMIM_NO_TW","MEDIUM_NO_TW","LARGE_NO_TW","TOTAL_NO_TW")
names(micensus) = nms

## http://censusindia.gov.in/2011census/maps/administrative_maps/Final%20Atlas%20India%202011.pdf

dists = x$dist
dists[dists == "Purba Champaran"] = "East Champaran"
dists[dists == "Pashchim Champaran"] = "West Champaran"
dists[dists == "Samastipur"] = "Samistipur"
x$dist = dists
dists[dists == "Maharajganj"] = "Gorakhpur"
dists[dists == "Mau"] = "Azamgarh"
x$dist = dists

micensus_gandak =
    left_join(x, micensus, by=c("state","dist")) %>%
    group_by(state, dist, gaul_id) %>%
    summarise_all(funs(mean(., na.rm=TRUE)))

## downscale to 5 arcminute grid

tubewell_frac = raster("data/igp_tw_irr.tif")
tubewell_frac = crop(tubewell_frac, extent(template))
tubewell_frac = aggregate(tubewell_frac, fact=10, fun=sum)

v = getValues(adm2_2010_raster)

cats = c("MARG","SMALL","SEMIM","MEDIUM","LARGE")

tw_ownership = list(
    marg=raster(template),
    small=raster(template),
    semim=raster(template),
    medium=raster(template),
    large=raster(template))

for (i in 1:length(cats)) {
    farm_nos = raster(file.path("data", paste0(tolower(cats[i]), "_no_1980.tif")))
    for (j in 1:nrow(micensus_gandak)) {
        gaul_id = micensus_gandak$gaul_id[j]
        cell_ix = which(v == gaul_id)
        total_farms = sum(farm_nos[cell_ix])
        if (is.na(total_farms)) stop()
        col_nm = paste0(cats[i], "_NO_TW")
        total_tubewells = micensus_gandak[[col_nm]][j]
        area = tubewell_frac[cell_ix]
        weight = area / sum(area)
        tubewell_nos = total_tubewells * weight
        tw_ownership[[i]][cell_ix] = tubewell_nos / farm_nos[cell_ix]
    }
}

for (i in 1:length(tw_ownership)) {
    r = tw_ownership[[i]]
    r = crop(r, extent(model_mask))
    tw_ownership[[i]] = r
}

plot(tw_ownership[[1]])
plot(tw_ownership[[2]])
plot(tw_ownership[[3]])
plot(tw_ownership[[4]])
plot(tw_ownership[[5]])

## canal access

canal_area = raster("data/igp_canal_irr.tif")
canal_area = crop(canal_area, extent(template))
canal_area = aggregate(canal_area, fact=10, fun=sum)

cropland = raster("data/iiasa-ifpri-cropland-map/Hybrid_10042015v9.img")
cropland = crop(cropland, extent(template))
cropland = aggregate(cropland, fact=10, fun=mean)
cropland = cropland / 100 * area(cropland) * 1000 * 1000 / 10000
plot(cropland)

canal_frac = canal_area / cropland

## assume access to canal water is even across
## all farm size categories
canal_access = list(
    marg=canal_frac,
    small=canal_frac,
    semim=canal_frac,
    medium=canal_frac,
    large=canal_frac)

