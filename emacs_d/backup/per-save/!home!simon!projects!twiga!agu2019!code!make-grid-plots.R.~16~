get_faostat_yield_data = function(fn, country, crop, years) {
    data =
        read.csv(fn) %>%
        filter(Area %in% country) %>%
        filter(Element %in% "Yield") %>%
        filter(Item %in% crop) %>%
        dplyr::select(-matches("Y[0-9]{4}F")) %>%
        gather(key="Year", value="Yield", -(Area.Code:Unit)) %>%
        mutate(Year=gsub("(Y)([0-9]{4})", replacement="\\2", Year)) %>%
        mutate(Year=as.numeric(Year)) %>%
        filter(Year %in% years)
    data
}

get_mapspam_phys_area = function(path, crop, region) {
    fs = list.files(path, pattern=paste0("SPAM2005V3r2_global_[A-Z]{1}_[A-Z]{2}_", crop, "_[A-Z]{1}.tif$"), full.names=TRUE)
    crop_area = raster(fs[5]) %>% crop(extent(region)) %>% raster::aggregate(fact=3, fun=sum)
    crop_area
}

get_aquacrop_yield_output = function(path, country, crop, years) {
    fn = file.path(path, tolower(country), "output", tolower(crop), "netcdf", "Y_cropland_yearMax_output.nc")
    nc = nc_open(fn)
    yield = ncvar_get(nc, "crop_yield") # nlon, nlat, time
    latitude = ncvar_get(nc, "lat")
    longitude = ncvar_get(nc, "lon")
    time = ncvar_get(nc, "time")
    rlist = vector(mode="list", length=length(time))
    for (i in 1:length(time)) {
        r = raster(region)
        r[] = t(yield[,,i])
        rlist[[i]] = r
    }
    nc_close(nc)
    rlist
}

get_mean_country_yield = function(yield_maps, crop_area, total_crop_area, years) {
    tot = rep(NA, length(years))
    for (i in 1:length(years)) {
        r = yield_maps[[i]]
        prod = r * crop_area
        total_prod = sum(getValues(prod), na.rm=T)
        yield = total_prod / total_crop_area
        tot[i] = yield
    }
    tot
}

