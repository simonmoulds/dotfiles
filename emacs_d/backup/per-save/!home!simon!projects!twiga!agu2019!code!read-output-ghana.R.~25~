library(ncdf4)
library(raster)
library(rasterVis)
library(grid)
library(gridExtra)
library(rworldmap)
library(magrittr)
library(dplyr)
library(tidyr)

datadir="../data/aquacrop_ghana/output"
region=raster("../data/ghana_aquacrop_landmask_0pt25degree.tif")
nlat=nrow(region)
nlon=ncol(region)

## ###################### ##
## get FAOSTAT yield data ##
## ###################### ##

system("unzip ../data-raw/Production_Crops_E_All_Data.zip -d ../data")

options(stringsAsFactors = FALSE)
data =
    read.csv("../data/Production_Crops_E_All_Data.csv") %>%
    filter(Area %in% "Ghana") %>%
    filter(Element %in% "Yield") %>%
    filter(Item %in% "Maize") %>%
    dplyr::select(-matches("Y[0-9]{4}F")) %>%
    gather(key="Year", value="Yield", -(Area.Code:Unit)) %>%
    mutate(Year=gsub("(Y)([0-9]{4})", replacement="\\2", Year)) %>%
    mutate(Year=as.numeric(Year))

fs = list.files("../data/mapspam/geotiff_global_phys_area", pattern="SPAM2005V3r2_global_[A-Z]{1}_[A-Z]{2}_MAIZ_[A-Z]{1}.tif$", full.names=TRUE)
maize_area = raster(fs[5]) %>% crop(extent(region)) %>% raster::aggregate(fact=3, fun=sum)
total_area = sum(getValues(maize_area), na.rm=TRUE) # hectares

nc = nc_open(file.path(datadir, "netcdf", "Y_cropland_yearMax_output.nc"))
yield = ncvar_get(nc, "crop_yield") # nlon, nlat, time
latitude = ncvar_get(nc, "lat")
longitude = ncvar_get(nc, "lon")
time = ncvar_get(nc, "time")
rlist = vector(mode="list", length=length(time))
for (i in 1:length(time)) {
    r = raster(region)
    r[] = t(yield[,,i])
    rlist[[i]] = r
}
nc_close(nc)

years = 1980:2010
tot = rep(NA, length(years))
for (i in 1:length(years)) {
    r = rlist[[i]]
    prod = r * maize_area
    total_prod = sum(getValues(prod), na.rm=T)
    yield = total_prod / total_area
    tot[i] = yield
}
plot(tot, ylim=c(0,5000))

## plot years 1984, 2004
st = stack(rlist[c(5,25)])
min_val = floor(min(cellStats(st, "min")))
max_val = ceiling(max(cellStats(st, "max")))
nlev = 100
my_breaks = seq(min_val, max_val, length.out=nlev+1)

p = levelplot(st,
              at=my_breaks,
              margin=FALSE,
              xlab=NULL,
              ylab=NULL,
              xlim=c(-4,2),
              ylim=c(4,12),
              par.settings=list(axis.line=list(lwd=1), strip.background=list(col="transparent"), strip.border=list(col="transparent")),
              par.strip.text=list(cex=0.6),
              names.attr=c("1984","2004"),
              col.regions=rev(terrain.colors(nlev)), #terrain.colors,#colorRampPalette(brewer.pal(n=9, "YlGn"))(1000),
              layout=c(2,1),
              scales=list(draw=TRUE, cex=0.6),
              colorkey=list(
                  space="bottom",
                  width=0.75,
                  at=seq(min_val,max_val,length.out=nlev),
                  labels=list(
                      at=seq(min_val, max_val,by=2),
                      labels=seq(min_val, max_val,by=2),
                      cex=0.6
                  ),
                  tck=0.5
              ))
p

data(countriesCoarse)
p = p + layer(sp.polygons(countriesCoarse, lwd=1, fill="transparent"))

pname = "ghana_maize_yield_1984_2004.png"
trellis.device(device="png", width=4, height=3.5, res=320, units="in", file=pname)
print(p)
pushViewport(viewport(0.52,0.04,0.5,0.07))
grid.text(expression("Maize yield"~(t~h^-1)), gp=gpar(cex=0.6))
dev.off()
