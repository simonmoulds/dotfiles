library(Reanalysis)
WATCHcreateHourlyWFDEIobs(
    nc.location="$HOME",
    startyear=1979,
    endyear=2016,
    lon=-2.51,
    lat=55.35,
    sunTimeOffset = 2,
    solarMethod="simpleMaxSolar",
    interpolationMethod="linear",
    obsFileName="swdown_wfdei_carterhouse.obs",
    timezone="GMT")

glat <- function(x){
    ## gets integer location corresponding to half-degree
    ## of latitude
    ## 1 = -89.75
    ## 360 = 89.75
    y <- round((x + 89.75) / 0.5)
    y <- y + 1
    return(y)
}

glon <- function(x) {
    ## gets integer location corresponding to half-degree
    ## of longitude
    ## 1 = -179.75
    ## 720 = 179.75
    y <- round((x + 179.75) / 0.5)
    y <- y + 1
    return(y)
}

lon=-2.51
lat=55.35
lon.glon=glon(lon)
lat.glat=glat(lat)
WATCHgetWFDEIvalues()
