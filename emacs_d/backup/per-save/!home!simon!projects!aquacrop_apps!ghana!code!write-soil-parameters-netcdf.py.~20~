    #     ),
    #     bbox,
    #     masked=masked
    # )
    # soil_varnames = [
    #     'b', 'hcap', 'hcon', 'k_sat', 'psi_m',
    #     'theta_crit', 'theta_sat', 'theta_wilt'
    # ]
    soil_varnames = [
        'k_sat', 'theta_crit', 'theta_sat', 'theta_wilt'
    ]
    for varname in soil_varnames:
        arr = get_soil_data(
            varname,
            method,
            res,
            domain,
            bbox,
            masked
        )
        soil_data[varname] = arr
    return soil_data


