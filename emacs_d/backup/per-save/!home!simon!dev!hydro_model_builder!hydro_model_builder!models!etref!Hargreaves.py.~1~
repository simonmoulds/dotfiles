class Hargreaves(Model):

    def initial(self):
        self.temperature_module = Temperature(self)
        self.extraterrestrial_radiation_module = ExtraterrestrialRadiation(self)

        self.temperature_module.initial()
        self.extraterrestrial_radiation_module.initial()

        self.get_model_dimensions()
        
    def get_model_dimensions(self):
        latitudes = np.unique(pcr.pcr2numpy(pcr.ycoordinate(pcr.boolean(self.cloneMap)), vos.MV))[::-1]
        longitudes = np.unique(pcr.pcr2numpy(pcr.xcoordinate(pcr.boolean(self.cloneMap)), vos.MV))
        self.dimensions = {
            'lat' : latitudes,
            'lon' : longitudes,
            'time': None}
        
    def hargreaves(self):
        self.ETref = (
            0.0023
            * (self.extraterrestrial_radiation * 0.408)  # MJ m-2 d-1 -> mm d-1
            * ((np.maximum(0, (self.tmean - 273.0))) + 17.8)
            * np.sqrt(np.maximum(0,(self.tmax - self.tmin))))
    
    def dynamic(self):
        logger.info("Reading forcings for time %s", self._modelTime)
        self.temperature_module.dynamic()
        self.extraterrestrial_radiation_module.dynamic()
        self.hargreaves()
