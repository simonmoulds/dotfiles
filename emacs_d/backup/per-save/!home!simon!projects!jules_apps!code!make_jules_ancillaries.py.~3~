def get_raster_extent(ds):
    ulx, xres, xskew, uly, yskew, yres  = ds.GetGeoTransform()
    lrx = ulx + (ds.RasterXSize * xres)
    lry = uly + (ds.RasterYSize * yres)
    return (ulx,lrx,lry,uly)

def get_raster_resolution(ds):
