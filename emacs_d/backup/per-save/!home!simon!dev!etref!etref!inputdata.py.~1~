import numpy as np

class _InputData(object):
    def __init__(self, model, filename, nc_varname, model_varname):
        self.model = model
        self.filename = filename
        self.nc_varname = nc_varname
        self.model_varname = model_varname
        
    def initial(self):
        self.read()

    def read(self):
        vars(self.model)[self.model_varname] = open_hmdataarray(
            self.filename,
            self.nc_varname,
            self.model.domain
        )

    def update(self):
        vars(self.model)[self.model_varname].select(
            time=self.model.time.curr_time, method='nearest'
        )        
    def dynamic(self):
        self.update()    

class MaxRelativeHumidity(_InputData):
    def __init__(self, model):
