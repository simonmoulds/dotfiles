#!/bin/bash

WD=/home/simon/projects/accra_flood_ineq_analysis

# ##################################### #
# Prepare GAUD
# ##################################### #

# Raw data available from:

# Huang, Yinghuai (2020): High spatiotemporal resolution mapping of
# global urban change from 1985 to 2015. figshare. Dataset.
# https://doi.org/10.6084/m9.figshare.11513178.v1

# Extract raw data file:
unzip -o $WD/data-raw/11513178.zip -d $WD/data

# Ghana is covered by four grid boxes: 67, 68, 87, 88
unzip -o $WD/data/urban_grid_60-79.zip -d $WD/data
unzip -o $WD/data/urban_grid_80-99.zip -d $WD/data

# Use gdalwarp to build a map for Ghana
gdalwarp \
    $WD/data/urban_grid_67.tif \
    $WD/data/urban_grid_68.tif \
    $WD/data/urban_grid_87.tif \
    $WD/data/urban_grid_88.tif \
    $WD/data/urban_grid_ghana.tif 


# ##################################### #
# Prepare high-res pop density maps
# ##################################### #

# Raw data available from:

# https://data.humdata.org/dataset/highresolutionpopulationdensitymaps

# Extract raw data file:
unzip -o $WD/data-raw/population_gha_2018-10-01.zip -d $WD/data

# ##################################### #
# Prepare health sites dataset
# ##################################### #

# Raw data available from:

# https://data.humdata.org/dataset/ghana-healthsites

# *N.B. updated monthly*

ogr2ogr \
    -t_srs EPSG:4326 \
    $WD/data/ghana_healthsites.gdb \
    $WD/data-raw/ghana.geojson

# ##################################### #
# Prepare Ghana Settlements Extent
# ##################################### #

# Raw data available from:

# https://data.humdata.org/dataset/grid3-ghana-settlement-extents-version-01-alpha

# *N.B. updated regularly*

unzip $WD/data-raw/grid3_gha_settlement_extents_20200415_v02.zip -d $WD/data

ogr2ogr \
    -t_srs EPSG:4326 \
    $WD/data/AFRICA_GHANA_ACCRA_building.gpkg \
    /data/ecopia_africa/AFRICA_GHANA_building.gdb


# ##################################### #
# Prepare building footprint data
# ##################################### #

# TODO - I can't remember exactly what I did here
ogr2ogr \
    -t_srs EPSG:4326 \
    -clipdst -1 5 1 7 \
    -nlt POLYGON \
    $WD/data/AFRICA_GHANA_ACCRA_building.gpkg \
    /data/ecopia_africa/AFRICA_GHANA_building.gdb

