library(foreign)
library(magrittr)
library(rgdal)

datadir = "/home/simon/projects/pathways/glss_analysis/data"

## create the output destination directories
if (dir.exists(file.path(datadir, "g7spss_csv"))) {
    unlink(file.path(datadir, "g7spss_csv"), recursive = TRUE)
}
dir.create(file.path(datadir, "g7spss_csv"))
dir.create(file.path(datadir, "g7spss_csv", "PartA"))
dir.create(file.path(datadir, "g7spss_csv", "PartB"))

## Part A
options(stringsAsFactors = FALSE)

fs = list.files(file.path(datadir, "g7spss", "PartAB", "PartA"), pattern="^.*.sav$", full.names=TRUE)

for (f in fs) {
    newf = basename(f) %>%
        gsub("sav$","csv",.) %>%
        file.path(datadir, "g7spss_csv", "PartA", .)
    x = read.spss(f, to.data.frame=TRUE)
    write.csv(x, newf, row.names=FALSE)
}

## Part B
fs = list.files(file.path(datadir, "g7spss", "PartAB", "PartB"), pattern="^.*.sav$", full.names=TRUE)

for (f in fs) {
    newf = basename(f) %>%
        gsub("sav$","csv",.) %>%
        file.path(datadir, "g7spss_csv", "PartB", .)
    x = read.spss(f, to.data.frame=TRUE)
    write.csv(x, newf, row.names=FALSE)
}

