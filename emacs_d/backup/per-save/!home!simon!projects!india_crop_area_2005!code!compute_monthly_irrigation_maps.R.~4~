## script to calculate monthly irrigation maps for
## 2005

library(raster)

maps = vector(mode="list", length=12)
for (i in 1:12) {
    num = formatC(i, width=3, flag=0)
    maps = list.files("data/output_2005/monthly_maps", pattern=paste0("TOTAL_2005_", num, ".tif"), full.names=TRUE)
    st = stack(maps)
    sum = stackApply(st, indices=rep(1, length(maps)), fun=sum)
    


