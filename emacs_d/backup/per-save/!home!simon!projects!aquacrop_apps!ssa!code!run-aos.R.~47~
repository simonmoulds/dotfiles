get_aqpy_yield_at_point = function(ncfile, varname, pts) {
    nc = nc_open(ncfile)
    yield = ncvar_get(nc, varname)
    yield_dim_ix = nc$var[[varname]][["dimids"]]
    yield_dims = names(nc$dim)[ix + 1][1:length(dim(yield))]
    dims = c("farm","crop","time","lat","lon") # defined order of dims
    dims = c("lat","lon","time","crop","farm")
    perm = match(yield_dims, dims[dims %in% yield_dims])
    yield = aperm(yield, perm)
    lat = ncvar_get(nc, "lat")
    lon = ncvar_get(nc, "lon")
    lat_ix = which.min(abs(lat - pts$y))[1]
    lon_ix = which.min(abs(lon - pts$x))[1]
    yield_val = R.utils::extract(yield, indices=list("1"=lat_ix, "2"=lon_ix))
    nc_close(nc)
    yield_val
}

ncfile = file.path("../data", "netcdf", "Y_cropland_yearMax_output.nc")
