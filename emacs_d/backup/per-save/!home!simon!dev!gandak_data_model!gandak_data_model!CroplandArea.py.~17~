#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import numpy as np
import rasterio

from hydro_model_builder.ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list
from utils import *

class CroplandArea(object):    
    def __init__(self, CroplandArea_variable):
        self.var = CroplandArea_variable
        self.var.CroplandAreaOutputFile = vos.getFullPath(
            self.var._configuration.croplandAreaOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)

    def initial(self):
        pass

    def dynamic(self):
        cropland_area_filename = get_data_smart(
            'gandak_data_model',
            '../data/modelMaskCellArea.tif',
            as_string = False)
        self.var.cropland_area = read_gdal_raster_image(
            cropland_area_filename,
            self.bbox,
            0)
        netcdf = np2netCDF(self.var._configuration, self.var.dimensions, variable_list)        
        netcdf.create_netCDF(self.var.CroplandAreaOutputFile, 'cropland_area')        
        netcdf.data2NetCDF(
            self.var.CroplandAreaOutputFile,
            'cropland_area',
            self.var.cropland_area)
