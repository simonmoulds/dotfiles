## hydrological model is based on the Global Crop Water Model

update_actual_et = function(time, state_vars, met_data, farm_parms, crop_parms, soil_parms) {
    actual_et = ks * met_data$eto
}

update_ks = function(time, state_vars, met_data, farm_parms, crop_parms, soil_parms) {
    p = crop_parms$p_std + 0.04 * (5 - state_vars$etc[time])
    if (state_vars$S[time] < (1 - p) * soil_parms$S_max) {
        ks = state_vars$S[time] / ((1 - p) * crop_parms$S_max)
    } else {
        ks = 1
    }
    ks
}

update_irrigation = function() {
    state_vars$I[time + 1] = soil_parms$S_max - state_vars$S[time]
}

update_runoff = function() {
    state_vars$R[time + 1] = (met_data$P[time+1] + state_vars$I[time+1]) * (state_vars$S[time] / soil_parms$S_max) ** farm_parms$gamma_r
}

update_soil_water_balance = function() {
    state_vars$S[time + 1] = state_vars$S[time] + met_data$P[time+1] + state_vars$I[time+1] - state_vars$R[time+1] - state_vars$eta[time+1]
}

