## groundwater model
update_groundwater_depth = function(time, state_vars, met_data, farm_parms, crop_parms, soil_parms) {
    ## prec : precipitation (mm)
    ## reference_crop_ET : reference crop evapotranspiration (mm)
    ## et_depletion_factor : ET depletion factor (FAO56)
    ## rooting_depth : rooting depth (mm)
    ## H_init : groundwater head from previous time point
    ## root_zone_depletion_init : root zone depletion
    ## f1 : total irrigation [demand?]
    ## c1 : canal irrigation [demand?]
    ## well_depth : current well depth (m)
    ## max_well_depth : maximum well depth (m)
    ## farmer_canal_access : does the current farmer have access to canal water
    ## farm_area : farm area (m2)
    ## surface_elev : surface elevation
    ## return_flow_coef : return flow coefficient (-)
    ## irrigation_eff : irrigation efficiency (-)
    ## canal_volume : canal volume, depth * width * length (m3)
    ## canal_leakage_coef : canal leakage (-) 
    ## field_capacity : field capacity, (mm)
    ## wilting_point : wilting point (mm)
    ## runoff_coef : runoff coefficient (-)
    ## Ks_max : max water stress coefficient (-)
    ## Ks_min : min water stress coefficient (-)
    ## evaporation_loss_coef
    
    ## infiltration
    infiltration_volume = (prec / 1000) * runoff_coef * evaporation_loss_coef * farm_area

    ## irrigation
    if (farmer_canal_access | (H_init > well_depth)) {
        irrigation_volume = (farm_area * f1) * (1 + irrigation_eff)
    } else {
        irrigation_volume = 0
    }

    ## raw/taw
    taw = 1000 * (field_capacity - wilting_point) * rooting_depth # m -> mm
    taw = et_depletion_factor * taw

    ## crop stress, actual ET, root zone depletion
    if (root_zone_depletion_init < raw) {
        Ks = 1
    } else {
        Ks = (taw - root_zone_depletion_init) / ((1 - et_depletion_factor) * taw)
    }

    actual_ET = Ks * reference_crop_ET

    ## abstraction converted to depth (divide by farm area) and
    ## units changed to mm
    root_zone_depletion_new = root_zone_depletion_init + actual_ET - (((irrigation_volume * evaporation_loss_coef + infiltration_volume) / farm_area) * 1000)

    recharge_depth = 0
    if (root_zone_depletion_new < 0) {
        recharge_depth = (root_zone_depletion_new / 1000) * -1
        root_zone_depletion_new = 0
    }
    recharge_volume = recharge_depth * farm_area

    ## hydraulic head after removing drainage due to lateral flow
    k = 30
    z = 79 - 10
    L = 11500
    w = 100
    b = (79 - (H_init / 10000)) - (79 - 30)
    cond = ((k * w * b) / L) / 10000
    outflow = (cond * (H_init / 10000 - z)) * -1
    H_new_lat = (H_init - outflow)

    ## hydraulic head
    canal_leakage = 0
    if (farmer_canal_access) {
        canal_leakage = (canal_volume * canal_leakage_coef)
        H_new = H_new_lat + recharge_volume + canal_leakage
    } else {
        if (H_new_lat <= well_depth) {
            ## in this case the farmer's well is not deep enough to exploit the resource, so the new groundwater head is simply that for the previous day plus recharge
            H_new = H_new_lat + recharge_volume
        } else {
            ## otherwise the farmer's well is deep enough to extract groundwater
            H_new = H_new_lat + recharge_volume - irrigation_volume
        }
    }

    ## update recharge volume to include canal leakage
    recharge_volume = recharge_volume + canal_leakage

    ## groundwater level cannot be above the ground surface
    if (H_new > surface_elev) {
        H_new = surface_elev
    }

    ## nor, for the purposes of the model, can it be below the maximum well depth
    if (H_new <= max_well_depth) {
        H_new = max_well_depth
    }

    return(list(actual_ET=actual_ET, H=H_new, root_zone_depletion=root_zone_depletion_new, abstraction=irrigation_volume, outflow=outflow, recharge=recharge_volume))
}

model = function() {
    root_zone_depletion_init = initial_root_zone_depletion
    H_init = initial_H
    reference_crop_ET = reference_ET * Kc
    ## wheat_crop_cal
    ## rice_crop_cal
    ## fert_n_t_ha
    ## fert_p_t_ha
    ## fert_k_t_ha
    ## fert_n_price_per_kg
    ## fert_p_price_per_kg
    ## fert_k_price_per_kg    
    ## farmer_category; farmer_category[0] = init_farmer_category
    ## farmer_saving
    ## farmer_wheat_yield
    ## farmer_rice_yield
    ## farmer_wheat_irr_cost
    ## farmer_rice_irr_cost
    ## farmer_livelihood
    ## farmer_actual_ET
    ## farmer_gw_head
    ## farmer_root_zone_depletion
    ## farmer_abstraction
    ## farmer_outflow
    ## farmer_recharge
    ## farmer_irr_cost
    for (i in 1:n_day) {
        for (j in 1:n_farmer) {

            ## irrigation schedule
            wd = runif(1, wheat_min, wheat_max)
            rd = runif(1, rice_min, rice_max)
            
            ## the variable wheat/rice_irr_schedule is a matrix in which
            ## rows represent the days on which irrigation takes place and
            ## columns represent individual farmers
            wheat_irr_schedule_j = wheat_irr_schedule[,j]
            rice_irr_schedule_j = rice_irr_schedule[,j]

            ## wheat/rice_can_irr_schedule has the same structure as
            ## wheat/rice_irr_schedule but indicates the day on which
            ## canal water is available
            wheat_can_irr_schedule_j = wheat_can_irr_schedule[,j]
            rice_can_irr_schedule_j = rice_can_irr_schedule[,j]

            ## the purpose of this section is to find out whether irrigation
            ## takes place on the current day.
            if (day %in% wheat_irr_schedule_j) {
                irr_wh = wd
            }
            if (day %in% wheat_can_irr_schedule_j) {
                irr_wh_canal = 0
            }

            if (day %in% rice_irr_schedule_j) {
                irr_ri = rd
            }
            if (day %in% rice_can_irr_schedule_j) {
                irr_ri_canal = rd
            }
            
            f1 = c(irr_wh, irr_ri) # total irrigation
            c1 = c(irr_wh_canal, irr_ri_canal) # canal irrigation

            ## groundwater model
            ## #################
            gw_sim = groundwater_model()
            
            farmer_actual_ET[i,j] = gw_sim[["actual_ET"]]
            farmer_gw_head[i,j] = gw_sim[["H"]]
            farmer_root_zone_depletion[i,j] = gw_sim[["root_zone_depletion"]]
            farmer_abstraction[i,j] = gw_sim[["abstraction"]]
            farmer_outflow[i,j] = gw_sim[["outflow"]]
            farmer_recharge[i,j] = gw_sim[["recharge"]]

            ## irrigation cost model
            ## #####################
            
            ## TODO: option for electricity

            gw_depth = (surface_elev / region_area) - (farmer_gw_head[i,j] / region_area)
            if (c1 == 0) {
                fuel = (0.1133 * gw_depth) + 0.7949
            }

            fuel_m3 = fuel * fuel_eff / 102.87 # fuel consumed to pump 1m3 water
            fuel_ha = farmer_abstraction[i,j] * fuel_m3 # volume of fuel used
            farmer_irr_cost[i,j] = fuel_ha * diesel_price[i] * 0.4

            ## crop yield model
            ## ################
            
            if (day[i] == harvest_day) {

                ## TODO : include labour factor

                index = (((year == (year[i] - 1)) & (day >= harvest_day)) | ((year == year[i]) & (day < harvest_day)))
                wheat_index = index & wheat_crop_cal
                rice_index = index & rice_crop_cal

                farmer_actual_ET_j = farmer_actual_ET[,j]

                aet_wheat_daily = farmer_actual_ET_j[wheat_index]
                ref_et_wheat_daily = refernce_crop_ET[wheat_index]
                aet_wheat = sum(aet_wheat_daily)
                ref_et_wheat = sum(ref_et_wheat_daily)
                
                aet_rice_daily = farmer_actual_ET_j[rice_index]
                ref_et_rice_daily = refernce_crop_ET[rice_index]
                aet_rice = sum(aet_rice_daily)
                ref_et_rice = sum(ref_et_rice_daily)

                if (aet_wheat > 0) {
                    farmer_wheat_yield[count,j] = (1 - (Ky_wheat * (1 - (aet_wheat / ref_et_wheat)))) * wheat_yield[count] * wheat_yield_coeff
                } else {
                    farmer_wheat_yield[count,j] = 0
                }

                if (aet_rice > 0) {
                    farmer_rice_yield[count,j] = (1 - (Ky_rice * (1 - (aet_rice / ref_et_rice)))) * rice_yield[count] * rice_yield_coeff
                } else {
                    farmer_rice_yield[count,j] = 0
                }

                farmer_irr_cost_j = farmer_irr_cost[,j]
                wheat_irr_cost_daily = farmer_irr_cost_j[wheat_index]
                rice_irr_cost_daily = farmer_irr_cost_j[rice_index]
                farmer_wheat_irr_cost[count,j] = sum(wheat_irr_cost_daily)
                farmer_rice_irr_cost[count,j] = sum(rice_irr_cost_daily)

                ## get the price of rice and wheat at harvest time, assuming
                ## that harvest is the last day of the crop season

                ## NB JoK was taking the mean price over the season - check
                ## whether this is right
                v = seq(0, length(wheat_index) - 1)
                vv = v[wheat_index]
                wheat_index_last = tail(vv, 1)[0]

                v = seq(0, length(rice_index) - 1)
                vv = v[rice_index]
                rice_index_last = tail(vv, 1)[0]

                wheat_harvest_price_per_t = wheat_price_per_t[wheat_index_last]
                rice_harvest_price_per_t = rice_price_per_t[rice_index_last]

                n_app_rate = fert_n_t_ha[index]
                p_app_rate = fert_p_t_ha[index]
                k_app_rate = fert_k_t_ha[index]

                mean_fert_n_t_ha = mean(n_app_rate)
                mean_fert_p_t_ha = mean(p_app_rate)
                mean_fert_k_t_ha = mean(k_app_rate)

                n_price = fert_n_price_per_kg[index]
                p_price = fert_p_price_per_kg[index]
                k_price = fert_k_price_per_kg[index]

                mean_fert_n_price_per_kg = mean(n_price);
                mean_fert_p_price_per_kg = mean(p_price);
                mean_fert_k_price_per_kg = mean(k_price);

                total_fert_cost = (
                    mean_fert_n_t_ha * mean_fert_n_price_per_kg * farm_area / 10000 + 
                    mean_fert_p_t_ha * mean_fert_p_price_per_kg * farm_area / 10000 + 
                    mean_fert_k_t_ha * mean_fert_k_price_per_kg * farm_area / 10000
                )
                ## assume we double because of two growing seasons?
                total_fert_cost = total_fert_cost * 2

                total_irrigation_cost = farmer_wheat_irr_cost[count,j] + farmer_rice_irr_cost[count,j]
                total_income = farmer_wheat_yield[count,j] * wheat_harvest_price_per_t + farmer_rice_yield[count,j] * rice_harvest_price_per_t
                farmer_liveilhood[count,j] = total_income - total_irrigation_cost - total_fert_cost

                if (count == 0) {
                    rand = round(runif(1, saving_lower, saving_upper)[0])
                    farmer_saving[count,j] = farmer_livelihood[count,j] * saving_percentage + rand
                } else {
                    farmer_saving[count,j] = farmer_livelihood[count,j] * saving_percentage + farmer_saving[count-1,j]
                }

                ## check if:
                ## (i) farmer can afford new well;
                ## (ii) farmer can change category
                if ((farmer_saving[count,j] > well_cost[i]) & (farmer_category[count,j] < 3)) {
                    farmer_saving[count,j] = farmer_saving[count,j] - well_cost[i]
                    if ((count+1) < n_year) {
                        farmer_category[count+1,j] = farmer_category[count,j] + 1
                    } else {
                        farmer_category[count+1,j] = farmer_category[count,j]
                    }                    
                } else {
                    farmer_category[count+1,j] = farmer_category[count,j]
                }
            }                
            ## update groundwater head & rzd for next farmer
            H_init = farmer_gw_head[i,j]
            root_zone_depletion_init = farmer_root_zone_depletion[i,j]
        }
        ## update count at harvest day
        if ((day[i] == harvest_day) & ((count+1) < n_year)) {
            count = count + 1
        }
    }

    return(list(farmer_category=farmer_category, farmer_livelihood=farmer_livelihood, farmer_saving=farmer_saving, farmer_wheat_yield=farmer_wheat_yield, farmer_rice_yield=farmer_rice_yield, farmer_actual_ET=farmer_actual_ET, farmer_gw_head=farmer_gw_head, farmer_root_zone_depletion=farmer_root_zone_depletion, farmer_abstraction=farmer_abstraction, farmer_outflow=farmer_outflow, farmer_recharge=farmer_recharge))
}
    
