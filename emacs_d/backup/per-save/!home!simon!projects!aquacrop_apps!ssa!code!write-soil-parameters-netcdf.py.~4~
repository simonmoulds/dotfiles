#!/usr/bin/env python
# -*- coding: utf-8 -*-

import netCDF4 as nc
import numpy as np
import shutil
import os
import rasterio

def stack(input_file_list, output_file):
    # Read metadata of first file
    with rasterio.open(input_file_list[0]) as src0:
        meta = src0.meta

    # Update meta to reflect the number of layers
    meta.update(count = len(input_file_list))

    # Read each layer and write it to stack
    with rasterio.open(output_file, 'w', **meta) as dst:
        for id, layer in enumerate(input_file_list, start=1):
            with rasterio.open(layer) as src1:
                dst.write_band(id, src1.read(1))

def run():

    datadir = '../data-raw/soil'
    ksat_files = [
        'k_sat_cosby_ssa_layer1_0pt25degree.tif',
        'theta_wilt_cosby_ssa_layer2_0pt25degree.tif',
        'theta_sat_cosby_ssa_layer3_0pt25degree.tif',
        'theta_crit_cosby_ssa_layer4_0pt25degree.tif'
    ]    
    suffixes = ['ssa_layer' + str(num) + '_0pt25degree.tif' for num in range(1,5)]
    ksat_files = [os.path.join(datadir, 'k_sat_cosby_' + f) for f in suffixes]
    th_wilt_files = [os.path.join(datadir, 'theta_wilt_cosby_' + f) for f in suffixes]
    th_crit_files = [os.path.join(datadir, 'theta_crit_cosby_' + f) for f in suffixes]
    th_sat_files = [os.path.join(datadir, 'theta_sat_cosby_' + f) for f in suffixes]
    
    stack(ksat_files, '../data/k_sat_cosby_layer1-4_0pt25degree.tif')
    stack(th_wilt_files, '../data/theta_wilt_cosby_layer1-4_0pt25degree.tif')
    stack(th_crit_files, '../data/theta_crit_cosby_layer1-4_0pt25degree.tif')
    stack(th_sat_files, '../data/theta_sat_cosby_layer1-4_0pt25degree.tif')

    ksat_map = rasterio.open('../data/k_sat_cosby_layer1-4_0pt25degree.tif')
    th_wilt_map = rasterio.open('../data/theta_wilt_cosby_layer1-4_0pt25degree.tif')
    th_crit_map = rasterio.open('../data/theta_crit_cosby_layer1-4_0pt25degree.tif')
    th_sat_map = rasterio.open('../data/theta_sat_cosby_layer1-4_0pt25degree.tif')

    # get coordinate characteristics
    bbox = ksat_map.bounds
    xmin,ymin,xmax,ymax = bbox[0],bbox[1],bbox[2],bbox[3]
    nlat = ksat_map.height
    nlon = ksat_map.width
    transform = ksat_map.transform
    lon = np.arange(nlon) * transform[0] + transform[2]
    lat = np.arange(nlat) * transform[4] + transform[5]
    lon += transform[0] / 2         # mid-point
    lat += transform[4] / 2         # mid-point

    # create netCDF
    filename = 'soil_parameters.nc'
    filepath = os.path.join(datadir, filename)
    nco = nc.Dataset(filepath, 'w')

    nco.createDimension('lon', nlon)
    nco.createDimension('lat', nlat)
    nco.createDimension('depth', 4)

    lono = nco.createVariable('lon', 'f4', ('lon',))
    lono.units = 'degrees_east'
    lono.standard_name = 'longitude'
    lono[:] = lon

    lato = nco.createVariable('lat', 'f4', ('lat'))
    lato.units = 'degrees_north'
    lato.standard_name = 'latitude'
    lato[:] = lat

    dpth = nco.createVariable('depth', 'f4', ('depth'))
    dpth.units = 'm'
    dpth.standard_name = 'depth'
    dpth[:] = np.array([0.05,0.225,0.675,2.])

    crso = nco.createVariable('crs','i4')
    crso.long_name = 'Lon/Lat Coords in WGS84'
    crso.grid_mapping_name = 'latitude_longitude'
    crso.longitude_of_prime_meridian = 0.0
    crso.semi_major_axis = 6378137.0
    crso.inverse_flattening = 298.257223563

    ksat = nco.createVariable('k_sat', 'f4', ('depth','lat','lon'), fill_value=ksat_map.nodata)
    ksat.units = 'm s-1'
    ksat.standard_name = 'soil_hydraulic_conductivity_at_saturation'
    ksat.long_name = 'saturated hydraulic conductivity'
    ksat[:] = ksat_map.read(masked=True)

    thw = nco.createVariable('th_wilt', 'f4', ('depth','lat','lon'), fill_value=th_wilt_map.nodata)
    thw.units = '1'
    thw.standard_name = 'volume_fraction_of_condensed_water_in_soil_at_wilting_point'
    thw[:] = th_wilt_map.read(masked=True)

    thfc = nco.createVariable('th_crit', 'f4', ('depth','lat','lon'), fill_value=th_crit_map.nodata)
    thfc.units = '1'
    thfc.standard_name = 'volume_fraction_of_condensed_water_in_soil_at_critical_point'
    thfc[:] = th_crit_map.read(masked=True)

    # N.B. CF standard name table does not include an entry for volumetric
    ## water content at saturation, so use the generic form and add a
    ## descriptive long_name
    ths = nco.createVariable('th_sat', 'f4', ('depth','lat','lon'), fill_value=th_sat_map.nodata)
    ths.units = '1'
    ths.standard_name = 'volume_fraction_of_condensed_water_in_soil'
    ths.long_name = 'volume fraction of condensed water in soil at saturation'
    ths[:] = th_sat_map.read(masked=True)

    nco.close()

if __name__ == "__main__":
    run()
