from .api import set_domain

class Model(object):
    def __init__(
            self,
            config,
            time,
            init=None,
            **kwargs
    ):
        self.config = config
        self.time = time

        # TODO: create the model domain in run script
        self.domain = set_domain(
            self.config.MODEL_GRID['mask'],
            modeltime = self.time,
            mask_varname = self.config.MODEL_GRID['mask_varname'],
            area_varname = self.config.MODEL_GRID['area_varname'],
            is_1d = self.config.MODEL_GRID['is_1d'],
            xy_dimname = self.config.MODEL_GRID['xy_dimname'],            
            pseudo_coords = self.config.PSEUDO_COORDS,
            **kwargs
        )
