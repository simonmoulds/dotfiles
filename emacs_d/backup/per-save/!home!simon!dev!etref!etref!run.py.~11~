def run(method, config, modeltime, init):
    dynamic_model = HmDynamicModel(
        method,
        config,
        modeltime,
        init
    )
    dynamic_framework = DynamicFramework(dynamic_model, len(currTimeStep))
    dynamic_framework.setQuiet(True)
    dynamic_framework.run()

