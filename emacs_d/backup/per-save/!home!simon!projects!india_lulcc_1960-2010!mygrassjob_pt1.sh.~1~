export GRASS_MESSAGE_FORMAT=plain
r.mask -r
r.in.gdal input=maps/INDIA_LULC_MOD_2010.tif output=india
g.region rast=india
g.region -p

for year in {1960..2010}
do
    fn=INDIA_LULC_MOD_"${year}".tif
    out=lu"${year}"_mod
    r.in.gdal input=data/output_maps/"${fn}" output="${out}" --overwrite
    r.mapcalc "${out} = int(${out})" --overwrite
    r.category map="${out}" separator=: rules=categories.txt
    r.out.gdal -c -m  -t input="${out}" output=data/"${fn}" --overwrite
done

