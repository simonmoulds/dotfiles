#!/bin/bash

# grass script to spatially aggregate HiHydroSoil data

# check if HiHydroSoil data has been unpacked yet
if [ ! -f WCsat.7z ]
then
    7z e HiHydroSoil.7z
fi

# WCsat (saturated water content)
if [ ! -f wcsat_topsoil_gapfilled.txt ]
then
    7z e WCsat.7z
fi

# WCpF2 (field capacity)
if [ ! -f wcpf2_topsoil_gapfilled.txt ]
then
    7z e WCpF2.7z
fi

# WCpF4.2 (permanent wilting point)
if [ ! -f wcpf4.2_topsoil_gapfilled.txt ]
then
    7z e WCpF4.2.7z
fi

# Ksat (saturated hydraulic conductivity)
if [ ! -f ksat_topsoil_gapfilled.txt ]
then
    7z e KSAT.7z
fi

echo 'export GRASS_MESSAGE_FORMAT=plain
g.region n=28N s=25N e=86E w=83E nsres=0:05 ewres=0:05
# g.region n=90N s=90S e=180E w=180W nsres=0:05 ewres=0:05
for var in wcsat ksat wcpf4.2 wcpf2
do
    for layer in topsoil subsoil
    do
        r.in.gdal -o input=${var}_${layer}_gapfilled.txt output=${var}_${layer}_gapfilled --overwrite
        r.resamp.stats input=${var}_${layer}_gapfilled output=tmp method=average --overwrite
        r.mapcalc "${var}_${layer}_gapfilled_aggr = tmp / 10000" --overwrite
        g.remove -f type=raster name=tmp
    done
    r.mapcalc "${var}_gapfilled_aggr = (${var}_topsoil_gapfilled_aggr * 0.3 + ${var}_subsoil_gapfilled_aggr * 1) / 1.3" --overwrite
    r.out.gdal input=${var}_gapfilled_aggr output=${var}_gapfilled_5m.tif format=GTiff --overwrite
done
' > mygrassjob_pt1.sh

chmod u+x mygrassjob_pt1.sh
export GRASS_BATCH_JOB=./mygrassjob_pt1.sh
grass $HOME/grassdata/latlong/PERMANENT
unset GRASS_BATCH_JOB
rm mygrassjob_pt1.sh
