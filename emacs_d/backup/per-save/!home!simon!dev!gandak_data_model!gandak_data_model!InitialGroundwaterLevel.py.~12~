class InitialGroundwaterLevel(object):
    def __init__(self, InitialGroundwaterLevel_variable):
        self.var = InitialGroundwaterLevel_variable
        self.var.InitialGroundwaterLevelOutputFile = vos.getFullPath(
            self.var._configuration.initialGroundwaterLevelOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)

    def initial(self):
        pass

    def dynamic(self):
        gwlevel_filename = get_data_smart(
            'gandak_data_model',
            '../data/initial_groundwater_level.tif',
            as_string = False)
        gwlevel = read_gdal_raster_image(
            gwlevel_filename,
            self.bbox,
            0)
        print gwlevel
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(self.var.InitialGroundwaterLevelOutputFile, 'level')
        netcdf.data2NetCDF(
            self.var.InitialGroundwaterLevelOutputFile,
            'level',
            gwlevel)
