#!/usr/bin/env python

import os
import pickle
import numpy as np
import netCDF4
import xarray

DATADIR = '../data'

# Read data from Jan

with open(os.path.join(DATADIR, 'TA00136_data.pkl'), 'rb') as f:
    tid, lat, lon, z, tahmo_data_df_day = pickle.load(f)

with open(os.path.join(DATADIR, 'TA00136cluster_data.pkl'), 'rb') as f:
    cluster_data = pickle.load(f)

nlon = 1
nlat = 1
nxy = nlon

# #######################################
# Mask
# #######################################

ds = netCDF4.Dataset(
    os.path.join(
        DATADIR,
        'mask_pt.nc',
    ),
    'w'
)

ds.createDimension('space', nxy)
ds.createDimension('time', None)

pts = ds.createVariable('space', np.int32, ('space',))
pts.units = '1'
pts[:] = np.arange(nxy) + 1

lats = ds.createVariable('lat', np.float64, ('space',))
lats.units = "degrees_north"
lats[:] = lat

lons = ds.createVariable('lon', np.float64, ('space',))
lons.units = "degrees_east"
lons[:] = lon

mask = ds.createVariable('mask', np.int32, ('space',))
mask[:] = 1

ds.close()

# #######################################
# Meteorological data
# #######################################

ts = tahmo_data_df_day.index.to_pydatetime()

ds = netCDF4.Dataset(
    os.path.join(
        DATADIR,
        'meteo_pt.nc',
    ),
    'w'
)

ds.createDimension('space', nxy)
ds.createDimension('time', None)

pts = ds.createVariable('space', np.int32, ('space',))
pts.units = '1'
pts[:] = np.arange(nxy) + 1

lats = ds.createVariable('lat', np.float64, ('space',))
lats.units = "degrees_north"
lats[:] = lat

lons = ds.createVariable('lon', np.float64, ('space',))
lons.units = "degrees_east"
lons[:] = lon

times = ds.createVariable('time', np.int32, ('time',))
times.units = "days since 1901-01-01 00:00:00"
times.calendar = "standard"
times[:] = netCDF4.date2num(ts, units=times.units, calendar=times.calendar)

prec = ds.createVariable('prec', np.float64, ('time', 'space'))
prec[:] = tahmo_data_df_day['P'].values

tavg = ds.createVariable('tavg', np.float64, ('time', 'space'))
tavg[:] = tahmo_data_df_day['TMEAN'].values

tmin = ds.createVariable('tmin', np.float64, ('time', 'space'))
tmin[:] = tahmo_data_df_day['TMIN'].values

tmax = ds.createVariable('tmax', np.float64, ('time', 'space'))
tmax[:] = tahmo_data_df_day['TMAX'].values

eto = ds.createVariable('etref', np.float64, ('time', 'space'))
eto[:] = tahmo_data_df_day.interpolate()['ETo'].values

ds.close()

# #######################################
# Crop parameters
# #######################################

ds = xarray.open_dataset(
    os.path.join(
        DATADIR,
        'crop_parameters.nc'
    )
)
pd = ds.sel(lat=lat, lon=lon, method='nearest')['PlantingDate'].values[:]
hd = ds.sel(lat=lat, lon=lon, method='nearest')['HarvestDate'].values[:]
ds.close()

ds = netCDF4.Dataset(
    os.path.join(
        DATADIR,
        '../data/crop_parameters_pt.nc',
    ),
    'w'
)

ds.createDimension('space', nxy)
ds.createDimension('time', None)

pts = ds.createVariable('space', np.int32, ('space',))
pts.units = '1'
pts[:] = np.arange(nxy) + 1

lats = ds.createVariable('lat', np.float64, ('space',))
lats.units = "degrees_north"
lats[:] = lat

lons = ds.createVariable('lon', np.float64, ('space',))
lons.units = "degrees_east"
lons[:] = lon

pds = ds.createVariable('PlantingDate', np.int32, ('space'))
pds[:] = pd

hds = ds.createVariable('HarvestDate', np.int32, ('space'))
hds[:] = hd

ds.close()

# #######################################
# Carbon dioxide
# #######################################

ds = xarray.open_dataset(
    os.path.join(
        DATADIR,
        'co2_annual_mean_mlo_0pt25degree.nc'
    )
)
co2 = ds.sel(lat=lat, lon=lon, method='nearest')['co2'].values[:]
ts = ds['time'].values[:].astype('datetime64[s]').tolist()
ds.close()

ds = netCDF4.Dataset(
    os.path.join(
        DATADIR,
        'co2_annual_mean_mlo_pt.nc',
    ),
    'w'
)

ds.createDimension('space', nxy)
ds.createDimension('time', None)

pts = ds.createVariable('space', np.int32, ('space',))
pts.units = '1'
pts[:] = np.arange(nxy) + 1

lats = ds.createVariable('lat', np.float64, ('space',))
lats.units = "degrees_north"
lats[:] = lat

lons = ds.createVariable('lon', np.float64, ('space',))
lons.units = "degrees_east"
lons[:] = lon

times = ds.createVariable('time', np.int32, ('time',))
times.units = "days since 1901-01-01 00:00:00"
times.calendar = "standard"
times[:] = netCDF4.date2num(ts, units=times.units, calendar=times.calendar)

conc = ds.createVariable('co2', np.float64, ('time', 'space'))
conc[:] = co2

ds.close()

# #######################################
# Soil hydraulic parameters
# #######################################

ds = xarray.open_dataset(
    os.path.join(
        DATADIR,
        'soil_hydraulic_parameters.nc'
    )
)
ds_sel = ds.sel(lat=lat, lon=lon, method='nearest')
ksat = ds_sel['satcon'].values[:]
ths = ds_sel['sm_sat'].values[:]
thw = ds_sel['sm_wilt'].values[:]
thfc = ds_sel['sm_crit'].values[:]
ds.close()

ds = netCDF4.Dataset(
    os.path.join(
        DATADIR,
        'soil_hydraulic_parameters_pt.nc',
    ),
    'w'
)

ds.createDimension('space', nxy)
ds.createDimension('time', None)
ds.createDimension('layer', 4)

pts = ds.createVariable('space', np.int32, ('space',))
pts.units = '1'
pts[:] = np.arange(nxy) + 1

lats = ds.createVariable('lat', np.float64, ('space',))
lats.units = "degrees_north"
lats[:] = lat

lons = ds.createVariable('lon', np.float64, ('space',))
lons.units = "degrees_east"
lons[:] = lon

dpth = ds.createVariable('layer', 'f8', ('layer'))
dpth.units = 'm'
dpth.standard_name = 'layer'
dpth[:] = np.array([0.05, 0.225, 0.675, 2.])

satcon = ds.createVariable('k_sat', np.float64, ('layer', 'space'))
satcon[:] = ksat * 60 * 60 * 24

smsat = ds.createVariable('th_sat', np.float64, ('layer', 'space'))
smsat[:] = ths

smwlt = ds.createVariable('th_wilt', np.float64, ('layer', 'space'))
smwlt[:] = thw

smcrit = ds.createVariable('th_crit', np.float64, ('layer', 'space'))
smcrit[:] = thfc

ds.close()
