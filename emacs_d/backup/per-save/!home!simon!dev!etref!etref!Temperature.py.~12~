#!/usr/bin/env python
# -*- coding: utf-8 -*-

import numpy as np

from hm import file_handling

class Temperature(object):
    def __init__(self, Temperature_variable):
        self.var = Temperature_variable

    def initial(self):
        self.set_temperature_input_filenames()

    def set_temperature_input_filenames(self):
        self.var.compute_tmin_tmax_from_subdaily_data = \
            self.var._configuration.WEATHER['compute_daily_min_max_temperature_from_subdaily_data']
        if self.var.compute_tmin_tmax_from_subdaily_data == 'True':
            self.var.compute_tmin_tmax_from_subdaily_data = True
        else:
            self.var.compute_tmin_tmax_from_subdaily_data = False

        self.var.compute_tavg_from_subdaily_data = \
            self.var._configuration.WEATHER['compute_daily_avg_temperature_from_subdaily_data']
        if self.var.compute_tavg_from_subdaily_data == 'True':
            self.var.compute_tavg_from_subdaily_data = True
        else:
            self.var.compute_tavg_from_subdaily_data = False
            
        if self.var.compute_tmin_tmax_from_subdaily_data:
            keys = ['subDailyTemperatureNC',
                    'subDailyTemperatureVarName',
                    'subDailyTemperatureTimeDimName']            
            vals = [self.var._configuration.WEATHER[key] for key in keys]
            self.var.subDailyTempFileNC = vals[0]
            self.var.subDailyTempVarName = vals[1]
            self.var.subDailyTimeDimName = vals[2]
            
            self.var.tminFileNC, self.var.tminVarName = None, None
            self.var.tminVarName, self.var.tmaxVarName = None, None
        else:
            self.var.subDailyTempFileNC, self.var.subDailyTempVarName = None, None
            keys = ['avgDailyTemperatureNC',
                    'minDailyTemperatureNC',
                    'maxDailyTemperatureNC',
                    'avgDailyTemperatureNC',
                    'minDailyTemperatureVarName',
                    'maxDailyTemperatureVarName',
                    'avgDailyTemperatureNC',
                    'minDailyTemperatureTimeDimName',
                    'maxDailyTemperatureTimeDimName']            
                    
            vals = [self.var._configuration.WEATHER[key] for key in keys]
            self.var.tavgFileNC, self.var.tminFileNC, self.var.tmaxFileNC = vals[0], vals[1], vals[2]
            self.var.tavgVarName, self.var.tminVarName, self.var.tmaxVarName = vals[3], vals[4], vals[5]
            self.var.tavgTimeDimName, self.var.tminTimeDimName, self.var.tmaxTimeDimName = vals[6], vals[7], vals[8]

    def read_temperature_data(self):        
        day, month, year = (self.var._modelTime.currTime.day,
                            self.var._modelTime.currTime.month,
                            self.var._modelTime.currTime.year)
        
        self.var.tavg = file_handling.netcdf_to_array(
            self.var.tavgFileNC.format(day=day, month=month, year=year),
            self.var.tavgVarName,
            str(self.var._modelTime.fulldate),
            useDoy = None,
            cloneMapFileName = self.var.cloneMapFileName,
            LatitudeLongitude = True)[self.var.landmask]

        if self.var.compute_tmin_tmax_from_subdaily_data:
            self.compute_tmin_tmax_from_subdaily_data(day, month, year)
        else:
            self.var.tmin = file_handling.netcdf_to_array(
                self.var.tminFileNC.format(day=day, month=month, year=year),
                self.var.tminVarName,
                str(self.var._modelTime.fulldate),
                useDoy = None,
                cloneMapFileName = self.var.cloneMapFileName,
                LatitudeLongitude = True)[self.var.landmask]

            self.var.tmax = file_handling.netcdf_to_array(
                self.var.tmaxFileNC.format(day=day, month=month, year=year),
                self.var.tmaxVarName,
                str(self.var._modelTime.fulldate),
                useDoy = None,
                cloneMapFileName = self.var.cloneMapFileName,
                LatitudeLongitude = True)[self.var.landmask]
            
    def compute_tmin_tmax_from_subdaily_data(self, day, month, year):
        daily_temp_data = file_handling.netcdf_daily_time_slice_to_array(
            self.var.subDailyTempFileNC.format(day=day, month=month, year=year),
            self.var.subDailyTempVarName,
            str(self.var._modelTime.fulldate),
            useDoy = None,
            cloneMapFileName = self.var.cloneMapFileName,
            LatitudeLongitude = True)[...,self.var.landmask]
        ntime = daily_temp_data.shape[0]
        if not ntime > 1:
            raise ModelError('')
        else:
            self.var.tmin = np.amin(daily_temp_data, axis=0)
            self.var.tmax = np.amax(daily_temp_data, axis=0)            
        
    def dynamic(self):
        self.read_temperature_data()
