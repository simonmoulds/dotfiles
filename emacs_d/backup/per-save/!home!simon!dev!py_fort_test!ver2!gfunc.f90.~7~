module gfunc_module
implicit none
contains
  subroutine gfunc(x, a, b, c)
    double precision, intent(in) :: x
    double precision, dimension(:), intent(in) :: a
    double precision, dimension(:), intent(in) :: b
    double precision, dimension(:, :), intent(out) :: c
    integer :: i, j, n, m
    n = size(a)
    m = size(m)
    
    do j=1,m
        do i=1,n
             c(i,j) = exp(-x * (a(i)**2 + b(j)**2))
        end do
    end do
  end subroutine gfunc  
end module
