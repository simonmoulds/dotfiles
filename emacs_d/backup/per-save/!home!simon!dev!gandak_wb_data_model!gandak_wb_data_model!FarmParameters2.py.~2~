#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import numpy as np
import rasterio

from ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list
from utils import *

class FarmParameters(object):
    def __init__(self, FarmParameters_variable):
        self.var = FarmParameters_variable
        self.var.FarmParametersOutputFile = str(self.var._configuration.irrNonPaddy['farmParametersOutputFile'])
        self.var.nFarmSizeCategory = int(self.var._configuration.irrNonPaddy['nFarmSizeCategory'])
        farm_per_category = str(self.var._configuration.irrNonPaddy['nFarmPerCategory'])
        farm_per_category = [int(x) for x in farm_per_category.split(",")]
        if (len(farm_per_category) == 1) and (self.var.nFarmSizeCategory > 1):
            farm_per_category = [farm_per_category[0] for i in range(self.var.nFarmSizeCategory)]
        self.var.nFarmPerCategory = np.array(farm_per_category)
        self.var.nFarm = np.sum(self.var.nFarmPerCategory)
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)
            
    def initial(self):
        pass

    def dynamic(self):
        netcdf = np2netCDF(self.var._configuration, self.var.dimensions, variable_list)
        netcdf.create_netCDF(
            self.var.FarmParametersOutputFile,
            ['farm_category','farm_area','farm_category_area','tubewell_ownership','canal_access'])

        # Farm category
        farm_category = np.arange(1, self.var.nFarmSizeCategory + 1)
        farm_category = np.repeat(
            farm_category,
            np.array(self.var.nFarmPerCategory))
        farm_category = (
            farm_category[:,None,None]
            * np.ones((self.var.nLat, self.var.nLon)))        
        netcdf.data2NetCDF(
            self.var.FarmParametersOutputFile,
            'farm_category',
            farm_category)
        
        # Farm area
        farm_area_list = []
        for index,suffix in enumerate(['marg','small','semim','medium','large']):
            fn = get_data_smart(
                'gandak_wb_data_model',
                '../data/' + suffix + '_farm_area_1980.tif',
                as_string = False)
            ar = read_gdal_raster_image(fn, self.bbox, 0)
            farm_area_list.append(ar[None,:,:] * np.ones((self.var.nFarmPerCategory[index]))[:,None,None])

        farm_area = np.concatenate(farm_area_list, axis=0)
        farm_area *= 10000      # Ha -> m2
        netcdf.data2NetCDF(
            self.var.FarmParametersOutputFile,
            'farm_area',
            farm_area)
        
        farm_category_area = np.zeros((self.var.nFarmSizeCategory, self.var.nLat, self.var.nLon))
        for index,suffix in enumerate(['marg','small','semim','medium','large']):
            fn = get_data_smart(
                'gandak_wb_data_model',
                '../data/' + suffix + '_total_area_1980.tif',
                as_string = False)
            ar = read_gdal_raster_image(fn, self.bbox, 0)
            farm_category_area[index,:,:] = ar

        # TODO: change dimensions in variable_list to farm,lat,lon
        netcdf.data2NetCDF(
            self.var.FarmParametersOutputFile,
            'farm_category_area',
            farm_category_area)

        # initial tubewell ownership
        tw_ownership_list = []
        for index,suffix in enumerate(['marg','small','semim','medium','large']):
            fn = get_data_smart(
                'gandak_wb_data_model',
                '../data/' + suffix + '_tw_ownership_rate.tif',
                as_string = False)
            ar = read_gdal_raster_image(fn, self.bbox, 0)
            tw_ownership_list.append(ar[None,:,:] * np.ones((self.var.nFarmPerCategory[index]))[:,None,None])
        tw_ownership = np.concatenate(tw_ownership_list, axis=0)
        print tw_ownership.shape
        # tw_ownership_binary = (
        #     tw_ownership
        #     > np.random.random((self.var.nFarm, self.var.nLat, self.var.nLon))
        # )
        
        netcdf.data2NetCDF(
            self.var.FarmParametersOutputFile,
            'tubewell_ownership',
            tw_ownership)

        # canal access
        canal_access_list = []
        for index,suffix in enumerate(['marg','small','semim','medium','large']):
            fn = get_data_smart(
                'gandak_wb_data_model',
                '../data/' + suffix + '_canal_access_rate.tif',
                as_string = False)
            ar = read_gdal_raster_image(fn, self.bbox, 0)
            canal_access_list.append(ar[None,:,:] * np.ones((self.var.nFarmPerCategory[index]))[:,None,None])
        canal_access = np.concatenate(canal_access_list, axis=0)
        print canal_access.shape
        # canal_access_binary = (
        #     canal_access
        #     > np.random.random((self.var.nFarm, self.var.nLat, self.var.nLon))
        # )
        
        netcdf.data2NetCDF(
            self.var.FarmParametersOutputFile,
            'canal_access',
            canal_access)
