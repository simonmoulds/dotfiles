// [[Rcpp::export]]
NumericMatrix get_total_areaC(NumericMatrix x, int n_season, int n_input) {

  int nrow = x.nrow(), ncol = x.ncol();
  int n_cell = nrow / (n_season * n_input);
  int n_cell_input = n_cell * n_input;
  
  NumericMatrix out(n_season,ncol);
  for (int i = 0; i < n_season; i++) {
    NumericMatrix xx(n_cell_input,ncol);
    for (int j = 0; j < n_cell; j++) {
      for (int k = 0; k < n_input; k++) {
	int ix1 = j * n_input + k;
	int ix2 = j * n_season * n_input + (i * n_input) + k;
	xx(ix1,_) = x(ix2,_);
      }
    }
    out(i,_) = colSums(xx);
  }
  return out;
}

// [[Rcpp::export]]
NumericVector subcolumn(NumericMatrix x, int row1, int row2, int col) {
  if (col >= x.ncol()) {
    stop("stop");
  }

  if (row2 >= x.nrow()) {
    stop("stop");
  }

  if (row1 > row2) {
    stop("stop");
  }
  
  NumericVector xx = x(_,col);
  return xx[Range(row1, row2)];
}

// [[Rcpp::export]]
IntegerVector order_(NumericVector x, bool descending) {
  // if (is_true(any(duplicated(x)))) {
  //   Rf_warning("There are duplicates in 'x'; order not guaranteed to match that of R's base::order");
  // }
  NumericVector sorted = clone(x).sort(descending);
  return match(sorted, x);
}

// [[Rcpp::export]]
IntegerVector which_(LogicalVector x) {
  IntegerVector a = seq(0, x.size()-1);
  return a[x];
}

// [[Rcpp::export]]
NumericVector jitter_(NumericVector x, double factor = 1.0, double amount = NA_REAL) {

  if (x.size() == 0)
    return x;

  NumericVector r = range(x);
  double z = diff(r)[0];
  if (z == 0)
    z = std::abs(r[0]);

  if (z == 0)
    z = 1;

  if (NumericVector::is_na(amount)) {    
    int digits = 3 - Rcpp::floor(Rcpp::log10(NumericVector::create(z)))[0];
    NumericVector xx = Rcpp::unique(Rcpp::round(clone(x), digits)).sort();
    NumericVector d = diff(xx);
    double dd;

    if (d.size() > 0) {
      dd = min(d);
    } else if ((xx.size() == 1) && (xx[0] != 0)) {
      dd = xx[0] / 10;
    } else {
      dd = z / 10;
    }
    amount = factor / 5 * std::abs(dd);
  } else if (amount == 0) {
    amount = factor * (z / 50);
  }
  NumericVector out = clone(x) + Rcpp::runif(x.size(), -amount, amount);
  return out;
}
		      
// [[Rcpp::export]]
NumericMatrix contract(NumericMatrix area, NumericMatrix suit, NumericMatrix yield, NumericVector demand, int crop_ix, int n_cell, int n_season, int n_input, NumericVector cell_area, double fact, int no_chng_count_max, double tolerance) {
  
  double target_demand = std::abs(demand[crop_ix]);  

  NumericMatrix area1 = clone(area);
  NumericVector suit_v = jitter_(suit(_,crop_ix));
  IntegerVector ordr = order_(suit_v, false);

  int index = 0;
  double total_prod_chng = 0;
  int no_chng_count = 0;

  do {

    int ix = ordr[index];
    int cell_ix = ceil((ix + 1) / (n_season * n_input)) - 1;

    double ar = area1(ix,crop_ix);
    
    double prod_chng = 0.0;
    double area_chng = 0.0;

    if (ar > 0) {

      double area_chng0 = Rcpp::min(NumericVector::create(ar, (cell_area[cell_ix] * fact)));
      double prod_chng0 = area_chng0 * yield(ix,crop_ix);

      if (prod_chng0 < target_demand) {
	prod_chng = prod_chng0;
	area_chng = area_chng0;
      } else {
	prod_chng = target_demand;
	area_chng = prod_chng / yield(ix,crop_ix);
      }
    }

    area1(ix,crop_ix) -= area_chng;
    target_demand -= prod_chng;
    total_prod_chng += prod_chng;
    
    if (index == (n_cell * n_season * n_input)) {
      index = 0;
      if (total_prod_chng < tolerance) {
	no_chng_count++;
      }
      total_prod_chng = 0.0;
    } else {
      index++;
    }

  } while ((target_demand > tolerance) && (no_chng_count <= no_chng_count_max));

  return area1;

}
    
// [[Rcpp::export]]
NumericMatrix intensify(NumericMatrix area, NumericMatrix suit, NumericMatrix yield, NumericVector demand, double target_intensification, int crop_ix, int n_cell, int n_season, int n_input, NumericVector cell_area, double fact, int no_chng_count_max, double tolerance) {

  // function to intensify production
  double target_demand = demand[crop_ix] * target_intensification;
  NumericMatrix area1 = clone(area);

  // do we need to put this in the do { ... } loop?
  // what is a better way of doing this?
  NumericVector max_suit(n_cell);
  for (int i = 0; i < n_cell; i++) {
    int start_row_ix = i * n_season * n_input;
    int end_row_ix = start_row_ix + (n_season * n_input) - 1;
    NumericVector suit_v = subcolumn(suit, start_row_ix, end_row_ix, crop_ix);
    NumericVector area_v = subcolumn(area, start_row_ix, end_row_ix, crop_ix);
    double max_suit_v = Rcpp::max(suit_v);
    double max_area_v = Rcpp::max(area_v);
    if ((max_suit_v > 0) && (max_area_v > 0)) {
      NumericVector a = suit_v[suit_v > 0];
      max_suit[i] = a[0];
    } else {
      max_suit[i] = 0.0;
    }
  }

  // https://stackoverflow.com/questions/21609934/ordering-permutation-in-rcpp-i-e-baseorder
  IntegerVector ordr = order_(jitter_(max_suit), true);
  int index = 0;
  int no_chng_count = 0;
  double total_prod_chng = 0.0;

  do {

    int ix = ordr[index];
    int cell_ix = ceil((ix + 1) / (n_season * n_input)) - 1;
    
    for (int i = 0; i < n_season; i++) {

      int start_row_ix = ix * n_season * n_input + i * n_input;
      int end_row_ix = start_row_ix + (n_input - 1);

      for (int j = 0; j < (n_input - 1); j++) {

	int hi_ix = end_row_ix - (j+1);
	int lo_ix = hi_ix + 1;

	double higher_intensity_area = area1(hi_ix,crop_ix);
	double lower_intensity_area = area1(lo_ix,crop_ix);

	double prod_chng = 0.0;
	double area_chng = 0.0;
	
	if (lower_intensity_area > 0) {
	  
	  double area_chng0 = Rcpp::min(NumericVector::create(lower_intensity_area, (cell_area[cell_ix] * fact)));
	  double prod_chng0 = area_chng0 * (yield(hi_ix,crop_ix) - yield(lo_ix,crop_ix));

	  if (prod_chng0 > 0) {

	    if (prod_chng0 < target_demand) {
	      prod_chng = prod_chng0;
	      area_chng = area_chng0;
	    } else {
	      prod_chng = target_demand;
	      area_chng = prod_chng / (yield(hi_ix,crop_ix) - yield(lo_ix,crop_ix));
	    }
	  }
	}

	area1(hi_ix,crop_ix) += area_chng;
	area1(lo_ix,crop_ix) -= area_chng;
	target_demand -= prod_chng;	
	total_prod_chng += prod_chng;	
      }
    }

    if (index == (n_cell - 1)) {
      index = 0;
      if (total_prod_chng < tolerance) {
	no_chng_count++;
      }
      total_prod_chng = 0;
    } else {
      index++;
    }

  } while ((target_demand > tolerance) && (no_chng_count <= no_chng_count_max));
      
  return area1;

}

// [[Rcpp::export]]
NumericMatrix extensify(NumericMatrix area, NumericMatrix suit, NumericMatrix yield, NumericVector cropland_area, NumericVector demand, double target_extensification, int crop_ix, int n_cell, int n_season, int n_input, NumericVector cell_area, double fact, int no_chng_count_max, double tolerance) {

  // function to intensify production
  double target_demand = demand[crop_ix] * target_extensification;
  NumericMatrix area1 = clone(area);

  NumericVector suit_v = jitter_(suit(_,crop_ix));
  IntegerVector ordr = order_(suit_v, true);
  int index = 0;
  int no_chng_count = 0;
  double total_prod_chng = 0.0;
  
  do {

    int ix = ordr[index];

    // TODO: check these indexes
    int cell_ix = ceil((ix + 1) / (n_season * n_input)) - 1;
    int season_ix = ceil(((ix + 1) - (cell_ix * n_season * n_input)) / n_input) - 1; 
    int start_row_ix = (cell_ix * n_season * n_input) + (season_ix * n_input);
    int end_row_ix = start_row_ix + n_input - 1;
    NumericMatrix a = area1(Range(start_row_ix, end_row_ix),_);
    double alloc_area = sum(a);

    if ((season_ix == 0) && (n_season > 1)) {
      double max_alloc_area = 0.0;
      for (int i = 1; i < n_season; i++) { // start at 1 (i.e. season 2)
	int start_row_ix = (cell_ix * n_season * n_input) + (i * n_input);
	int end_row_ix = start_row_ix + n_input - 1;
	NumericMatrix a = area1(Range(start_row_ix, end_row_ix),_);
	double tmp_alloc_area = sum(a);
	if (tmp_alloc_area > max_alloc_area) {
	  max_alloc_area = tmp_alloc_area;
	}
      }
      alloc_area += max_alloc_area;
    }

    double unalloc_area = cropland_area[cell_ix] - alloc_area;
    double prod_chng = 0.0;
    double area_chng = 0.0;
    
    if (unalloc_area > 0.0) {

      double area_chng0 = Rcpp::min(NumericVector::create(unalloc_area, (cell_area[cell_ix] * fact)));
      double prod_chng0 = area_chng0 * yield(ix,crop_ix);

      if (prod_chng0 > 0.0) {
	
	if (prod_chng0 < target_demand) {
	  prod_chng = prod_chng0;
	  area_chng = area_chng0;
	} else {
	  prod_chng = target_demand;
	  area_chng = prod_chng / yield(ix,crop_ix);
	}
      }
    }

    area1(ix,crop_ix) += area_chng;
    target_demand -= prod_chng;
    total_prod_chng += prod_chng;
    
    if (index == (n_cell * n_season * n_input)) {
      index = 0;
      if (total_prod_chng < tolerance) {
	no_chng_count++;
      }
      total_prod_chng = 0.0;
    } else {
      index++;
    }

  } while ((target_demand > tolerance) && (no_chng_count <= no_chng_count_max));

  return area1;

}

// [[Rcpp::export]]
int find_crop(std::vector<std::string> crop_names, std::string crop) {
  int n_subcrops = crop_names.size();
  LogicalVector subcrop_ix_logical(n_subcrops);
  for (int k = 0; k < n_subcrops; k++) {
    subcrop_ix_logical[k] = (crop_names[k] == crop);
  }
  int subcrop_ix = which_(subcrop_ix_logical)[0];
  return subcrop_ix;
}

// [[Rcpp::export]]
NumericMatrix allocate(NumericMatrix area, NumericMatrix suit, NumericMatrix yield, NumericMatrix demand, double target_intensification, double target_extensification, std::vector<std::string> crop_names, std::vector<std::string> subcrop_names, std::vector<std::string> alloc_order, int n_cell, int n_season, int n_input, NumericVector cell_area, NumericVector cropland_area, double fact, int no_chng_count_max, double tolerance) {

  bool c1 = area.nrow() == suit.nrow() && area.nrow() == yield.nrow();
  bool c2 = area.ncol() == suit.ncol() && area.ncol() == yield.ncol();
  if (!c1 || !c2) stop("'area', 'suit' and 'yield' matrices must have the same dimensions");
 
  bool c3 = area.nrow() == n_cell * n_season * n_input;
  if (!c2) stop("Number of rows in 'area', 'suit' and 'yield' matrices must equal the number of cells multiplied by the number of input levels and the number of seasons");
    
  int n_subcrops = subcrop_names.size();
  bool c4 = area.ncol() == n_subcrops && suit.ncol() == n_subcrops && yield.ncol() == n_subcrops;
  if (!c4) stop("Number of columns of 'area', 'suit' and 'yield' matrices must equal the number of subcrops");

  bool c5 = demand.ncol() == n_subcrops;
  if (!c5) stop("Number of columns of demand matrix must equal the number of subcrops");

  bool c6 = crop_names.size() == n_subcrops;
  if (!c6) stop("'crop_names' must include a crop name for each subcrop");

  bool c7 = alloc_order.size() == n_subcrops;
  if (!c7) stop("All elements of 'alloc_order' must appear in argument 'subcrop_names'");
      
  NumericMatrix area1 = clone(area);
  NumericVector demand0 = demand(0,_);
  NumericVector demand1(n_subcrops);
  std::vector<std::string> decr_crops;
  std::vector<std::string> incr_crops;
  
  for (int j = 0; j < n_subcrops; j++) {
    double tmp = demand(1,j) - demand(0,j);
    if (tmp < 0) {
      decr_crops.push_back(subcrop_names[j]);
    } else {
      incr_crops.push_back(subcrop_names[j]);
    }
    demand1[j] = std::abs(tmp);
  }

  // first handle crops with decreasing demand
  // =========================================
  
  for (int j = 0; j < n_subcrops; j++) {
    std::string crop = alloc_order[j];
    bool test = std::find(decr_crops.begin(), decr_crops.end(), crop) != decr_crops.end();
    
    if (test) {

      int subcrop_ix = find_crop(subcrop_names, crop);
      double crop_prod0 = sum(area1(_,subcrop_ix) * yield(_,subcrop_ix));
      area1 = contract(area1, suit, yield, demand1, subcrop_ix, n_cell, n_season, n_input, cell_area, fact, no_chng_count_max, tolerance);
      double crop_prod1 = sum(area1(_,subcrop_ix) * yield(_,subcrop_ix));      
      demand1[subcrop_ix] -= std::abs(crop_prod0 - crop_prod1);

      // TODO exceptions
      
    }
  }

  // increasing demand
  double total_demand;
  double total_change;
  do {

    total_demand = sum(demand1);

    for (int j = 0; j < n_subcrops; j++) {
      std::string crop = alloc_order[j];
      bool test = std::find(incr_crops.begin(), incr_crops.end(), crop) != incr_crops.end();

      if (test) {

	int subcrop_ix = find_crop(subcrop_names, crop);
	double crop_prod0 = 0.0;
	double crop_prod1 = 0.0;

	// first round of intensification
	crop_prod0 = sum(area1(_,subcrop_ix) * yield(_,subcrop_ix));
	area1 = intensify(area1, suit, yield, demand1, target_intensification, subcrop_ix, n_cell, n_season, n_input, cell_area, fact, no_chng_count_max=2, tolerance);
	crop_prod1 = sum(area1(_,subcrop_ix) * yield(_,subcrop_ix));
	demand1[subcrop_ix] -= std::abs(crop_prod0 - crop_prod1);

	// extensification
	crop_prod0 = crop_prod1;
	area1 = extensify(area1, suit, yield, cropland_area, demand1, target_extensification, subcrop_ix, n_cell, n_season, n_input, cell_area, fact, no_chng_count_max, tolerance);
	crop_prod1 = sum(area1(_,subcrop_ix) * yield(_,subcrop_ix));
	demand1[subcrop_ix] -= std::abs(crop_prod0 - crop_prod1);

	// second round of intensification
	if (demand1[subcrop_ix] > 0.0) {
	  crop_prod0 = crop_prod1;
	  area1 = intensify(area1, suit, yield, demand1, 1, subcrop_ix, n_cell, n_season, n_input, cell_area, fact, no_chng_count_max=2, tolerance);
	  crop_prod1 = sum(area1(_,subcrop_ix) * yield(_,subcrop_ix));
	  demand1[subcrop_ix] -= std::abs(crop_prod0 - crop_prod1);
	}

	if (demand1[subcrop_ix] > 0.0) {

	  double outstanding_demand = demand1[subcrop_ix];
	  std::string crop_name = crop_names[subcrop_ix];
	  std::vector<int> tmp_id_locs; // Setup storage for found IDs
	  for (int i = 0; i < n_subcrops; i++) {
	    if ((crop_names[i] == crop_name) && (i != subcrop_ix)) {
	      tmp_id_locs.push_back(i);
	    }
	  }

	  IntegerVector id_locs = wrap(tmp_id_locs);
	  if (id_locs.size() > 0) {
	    NumericVector subcrop_dmd = demand0[id_locs];
	    double total_subcrop_dmd = sum(subcrop_dmd);
	    for (int i = 0; i < id_locs.size(); i++) {
	      int id = id_locs[i];
	      demand1[id] += outstanding_demand * (subcrop_dmd[i] / total_subcrop_dmd);
	    }
	  }
	}
      }
    }

    total_change = std::abs(total_demand - sum(demand1));
    Rprintf("%f\n", max(demand1));
    Rprintf("%f\n", total_change);

  } while((Rcpp::max(demand1) > tolerance) && (total_change > tolerance));
  
  return area1;
}
      
