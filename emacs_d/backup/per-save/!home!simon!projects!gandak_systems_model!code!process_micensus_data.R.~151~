    full_join(micensus_es_4, by=c("State","District","type")) %>%
    full_join(micensus_ic_4, by=c("State","District","type")) %>%
    full_join(micensus_mc_4, by=c("State","District","type")) %>%
    gather(varname, value, -State, -District, -type) %>%
    spread(type, value) %>%
    gather(type, value, -State, -District, -varname) %>%
    spread(varname, value) %>%
    arrange(State, District, type)
    
