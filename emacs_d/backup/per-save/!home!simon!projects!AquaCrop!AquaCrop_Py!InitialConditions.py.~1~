class InitialConditions(object):

    def __init__(self, configuration, currTimeStep, initialState = None):
        self._configuration = configuration
        self._modelTime = currTimeStep

        # clone map, land mask
        pcr.setclone(configuration.cloneMap)
        self.landmask = vos.readPCRmapClone(configuration.globalOptions['landmask'],\
                                            configuration.cloneMap,\
                                            configuration.tmpDir,\
                                            configuration.globalOptions['inputDir'],\
                                            True)

        # Soil parameters
        self.read_soil_parameters()
        self.soil.read()

        # Crop parameters
        self.read_crop_parameters()
        self.crop.read()
        self.crop.compute_variables()

        # Irrigation management parameters
        self.read_irrigation_mgmt_parameters()
        self.irrigation_mgmt.read()

        # Field management parameters
        self.read_field_mgmt_parameters()
        self.field_mgmt.read()
        
        # Prepare sub-models
        self.create_submodels(initialState)

        # Only compute capillary rise parameters if water table is modelled
        if groundwater.WaterTable:
            self.soil.compute_capillary_rise_parameters()

        # Set initial conditions
        self.set_initial_conditions()
        
    @property
    def configuration(self):
        return self._configuration

    def create_submodels(self, initialState):
        self.meteo = meteo.Meteo(
            self._configuration,
            self.landmask,
            initialState)

        self.groundwater = groundwater.Groundwater(
            self._configuration,
            self.landmask,
            initialState)

        self.soilwater = soilwater.SoilWater(
            self._configuration,
            self.landmask,
