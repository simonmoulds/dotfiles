import os
import numpy as np
import calendar
from hydro_model_builder import VirtualOS as vos

import logging
logger = logging.getLogger(__name__)

class Investment(object):

    def __init__(self, Investment_variable):
        self.var = Investment_variable        
        self.var.StartOfYear = 305  # TODO: check this is right
        
    def initial(self):
        pass

    def update_first_day_of_year(self):
        isLeapYear = calendar.isleap(self.var._modelTime.year)
        day_of_year = self.var._modelTime.doy
        start_of_year = self.var.StartOfYear
        if (isLeapYear & (start_of_year >= 60)):
            start_of_year += 1            
        self.var.IsFirstDayOfYear = False
        self.var.IsLastDayOfYear = False
        if day_of_year == start_of_year:
            self.var.IsFirstDayOfYear = True
        elif ((day_of_year + 1) == start_of_year):
            self.var.IsLastDayOfYear = True
    
    def farm_investment(self):
        if self.var.IsLastDayOfYear:
            self.install_additional_tubewell()

    def install_additional_tubewell(self):
        pass
    
    def dynamic(self):
        self.update_first_day_of_year()
        self.farm_investment()
        
