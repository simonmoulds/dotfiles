## Implementation of the socio-hydrological model developed by
## Viglione et al (2014), published in Journal of Hydrology

## Time parameters
maxtime = 50
dt = 0.001
t = seq(0, maxtime, dt)
nt = length(t)

## Compute inter-arrival time of flood events, plus flood magnitude
t_mean = 1/dt
H_mult = 1
w = rep(0, nt)
index = 0
t0 = 0
t1 = 0
theta=0.28

while (index < nt) {
    x = runif(1)
    t1 = t0 + (t_mean * log(1/(1-x)))
    index = which.min(abs(t/dt - t1))
    y = runif(1)
    w[index] = H_mult * ((theta + 1) / theta) * (1 - (1 - y) ** theta)
    t0 = t1
}

## Parameters
xi_H = c(0.5,0.5)
alpha_H = c(10,10)
rho_E = c(1,1)
gamma_E = c(0.005,0.005) # 0.005 -> inf
lambda_P = c(1,1)        # 0 -> 5
sigma_P = c(0.1,0.1)
epsilon_T = c(1.1,1.1)
keta_T = c(0.1,0.1)
alpha_S = c(0.5,0.5)     # 0 -> 1
mu_S = c(0.215,0.215)    # 0.01 -> 10

## State variables
F = data.frame(a=rep(0, nt), b=rep(0, nt))
R = data.frame(a=rep(0, nt), b=rep(0, nt))
S = data.frame(a=rep(0, nt), b=rep(0, nt))
G = data.frame(a=rep(0.01, nt), b=rep(0.01, nt))
D = data.frame(a=rep(1, nt), b=rep(1, nt))
H = data.frame(a=rep(0, nt), b=rep(0, nt))
M = data.frame(a=rep(0, nt), b=rep(0, nt))

nc = 2

for (i in 1:nt) {

    for (j in 1:nc) {
        
    ## proportion of settlement that is damaged
    if ((w[i] + xi_H * H[i]) > H[i]) {
        F[i] = 1 - exp(-(w[i] + xi_H * H[i]) / (alpha_H * D[i]))
    } else {
        F[i] = 0
    }
    
    ## raising of levees
    R[i] = 0
    if (F[i] > 0) {
        if ((F[i] * G[i]) > (gamma_E * R[i] * sqrt(G[i]))) {
            if ((G[i] - F[i] * G[i]) > (gamma_E * R[i] * sqrt(G[i]))) {
                R[i] = epsilon_T * (w[i] + xi_H * H[i] - H[i])
            }
        }
    }

    ## shock magnitude
    if (R[i] > 0) {
        S[i] = alpha_S * F[i]
    } else {
        S[i] = 0
    }
    
    ## value of Dirac comb
    if (w[i] > 0) {
        Delta = 1
    } else {
        Delta = 0
    }

    dG_dt = rho_E * (1 - D[i]) * G[i] - Delta * (F[i] * G[i] + gamma_E * R[i] * sqrt(G[i]))
    dD_dt = (M[i] - D[i] / lambda_P) * (sigma_P / sqrt(G[i]))
    dH_dt = Delta * R[i] - keta_T * H[i]
    dM_dt = Delta * S[i] - mu_S * M[i]

    G[i+1] = G[i] + dG_dt * dt
    D[i+1] = D[i] + dD_dt * dt
    H[i+1] = H[i] + dH_dt * dt
    M[i+1] = M[i] + dM_dt * dt
}

