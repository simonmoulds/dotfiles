#!/bin/bash

matlabdir='/home/simon/projects/AquaCrop/AquaCrop_tests/aquacrop_matlab_test_data'
pythondir='/home/simon/projects/AquaCrop/AquaCrop_tests/aquacrop_python_test_data'
aostestdir='/home/simon/projects/AquaCrop/AquaCrop_Py/test/release'

for dir in $pythondir/*/
do
    basedir=`basename $dir`
    newdir=test_"${basedir}"
    echo $dir
    echo $newdir
    if [ -d $aostestdir/$newdir ]
    then
        rm -r $aostestdir/$newdir
    fi    

    cp -r $pythondir/$basedir $aostestdir/$newdir
    for yrdir in $aostestdir/$newdir/*/; do
        yr=`basename $yrdir`
        outdir=$aostestdir/$newdir/$yr/Output
        if [ "(ls -A $outdir)" ]
        then
            rm outdir/*
        fi        
    done

    for yrdir in $matlabdir/$basedir/*/
    do
        yr=`basename $yrdir`
        cp -r $matlabdir/$basedir/$yr/Output $aostestdir/$newdir/$yr/Expected_Output
    done    
done
