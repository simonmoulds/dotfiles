    setNames(c("State","District","Year","Rice","Sorghum","Bajra","Maize","Ragi","Wheat","Barley","Other_Cereals","Gram","Tur","Other_Pulses","Sugarcane","Condiments","Fruits_and_Vegetables","Groundnut","Sesamum","Rape","Linseed","Cotton","Tobacco")) %>%
