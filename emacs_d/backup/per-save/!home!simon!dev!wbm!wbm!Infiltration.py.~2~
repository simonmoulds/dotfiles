#!/usr/bin/env python
# -*- coding: utf-8 -*-

import numpy as np

import logging
logger = logging.getLogger(__name__)

class Infiltration(object):
    """Class to infiltrate incoming water (rainfall and irrigation)"""
    
    def __init__(self, land_cover):
        self.land_cover = land_cover

    def initial(self):
        arr_zeros = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
        self.land_cover.potential_infiltration = arr_zeros.copy()
        self.land_cover.infiltration = arr_zeros.copy()
        self.land_cover.direct_runoff = arr_zeros.copy()
        self.land_cover.preferential_flow = arr_zeros.copy()

    def reset_initial_conditions(self):
        pass

    def compute_infiltration_capacity(self):
        # CWATM, soil.py, lines 267-287
        soil_water_storage = self.land_cover.wc[...,0,:] + self.land_cover.wc[...,1,:]
        soil_water_storage_capacity = self.land_cover.wc_sat[...,0,:] + self.land_cover.wc_sat[...,1,:]
        self.land_cover.relative_saturation = soil_water_storage / soil_water_storage_capacity

        # Equation 2 in Hagemann & Gates, 2003
        saturated_area_fraction = 1. - (1. - self.land_cover.relative_saturation) ** self.land_cover.arno_beta
        saturated_area_fraction = saturated_area_fraction.clip(0, 1)
        store = soil_water_storage_capacity / (self.land_cover.arno_beta + 1.)
        potential_beta = (self.land_cover.arno_beta + 1.) / self.land_cover.arno_beta
        self.land_cover.potential_infiltration = store - store * (1. - (1. - saturated_area_fraction) ** potential_beta)
        
        # additionally, limit by saturated hydraulic conductivity of top layer        
        self.land_cover.potential_infiltration = self.land_cover.potential_infiltration.clip(None, self.land_cover.ksat[...,0,:])

    def compute_preferential_flow(self):
        # CWATM, soil.py, lines 295-300

        self.include_preferential_flow = False
        # CALIBRATION - TODO
        self.land_cover.cPrefFlow = 0.        
        if self.include_preferential_flow:
            self.land_cover.preferential_flow = (
                self.land_cover.water_available_for_infiltration
                * self.land_cover.relative_saturation
                ** self.land_cover.cPrefFlow)            
            self.land_cover.preferential_flow[self.land_cover.frost_index > self.land_cover.frost_index_threshold] = 0.
            self.land_cover.water_available_for_infiltration -= self.land_cover.preferential_flow  # CHECK

    def dynamic(self):
        self.compute_infiltration_capacity()
        self.compute_preferential_flow()

        ToStore = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
        RunoffIni = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
        InflTot = (
            self.land_cover.water_available_for_infiltration
            + self.land_cover.SurfaceStorage)

        # Infiltration limited by saturated hydraulic conductivity of surface
        # soil layer; additional water ponds on surface
        ksat_top = self.land_cover.ksat[:,:,0,:]
        cond1 = (self.land_cover.Bunds == 1) & (self.land_cover.zBund > 0.001)
        cond11 = (cond1 & (InflTot > 0))
        cond111 = (cond11 & (InflTot > self.land_cover.potential_infiltration))
        ToStore[cond111] = self.land_cover.potential_infiltration[cond111]
        self.land_cover.SurfaceStorage[cond111] = (InflTot - self.land_cover.potential_infiltration)[cond111]

        # Otherwise all water infiltrates and surface storage becomes zero
        cond112 = (cond11 & np.logical_not(cond111))
        ToStore[cond112] = InflTot[cond112]
        self.land_cover.SurfaceStorage[cond112] = 0

        # Calculate additional RunoffIni if water overtops bunds
        cond113 = (cond11 & (self.land_cover.SurfaceStorage > self.land_cover.zBund))
        RunoffIni[cond113] = (self.land_cover.SurfaceStorage - (self.land_cover.zBund))[cond113]
        self.land_cover.SurfaceStorage[cond113] = (self.land_cover.zBund)[cond113]

        # Otherwise excess water does not overtop bunds and there is no RunoffIni
        cond114 = (cond11 & np.logical_not(cond113))
        RunoffIni[cond114] = 0.

        # If total infiltration is zero then there is no storage or RunoffIni
        cond12 = (cond1 & np.logical_not(cond11))
        ToStore[cond12] = 0.
        RunoffIni[cond12] = 0.
        
        # If there are no bunds then infiltration is divided between RunoffIni
        # and infiltration according to saturated conductivity of surface
        # layer
        cond2 = (self.land_cover.Bunds == 0)
        cond21 = (cond2 & (self.land_cover.water_available_for_infiltration > self.land_cover.potential_infiltration))

        ToStore[cond21] = self.land_cover.potential_infiltration[cond21]
        RunoffIni[cond21] = (self.land_cover.water_available_for_infiltration - self.land_cover.potential_infiltration)[cond21]
        cond22 = (cond2 & np.logical_not(cond21))
        ToStore[cond22] = self.land_cover.water_available_for_infiltration[cond22]
        RunoffIni[cond22] = 0

        self.land_cover.infiltration = ToStore.copy()
        self.land_cover.direct_runoff = RunoffIni.copy()

        # infiltration to top soil layer; if this is full then
        # infiltrate to second soil layer
        self.land_cover.wc[...,0,:] += ToStore
        saturation_excess = self.land_cover.wc[...,0,:] - self.land_cover.wc_sat[...,0,:]
        saturation_excess = saturation_excess.clip(0., None)
        self.land_cover.wc[...,1,:] += saturation_excess
        self.land_cover.wc[...,0,:] -= saturation_excess

        # print self.land_cover.wc[0,:,0,0] >= self.land_cover.wc_crit[0,:,0,0]
        # print self.land_cover.wc[0,:,1,0] >= self.land_cover.wc_crit[0,:,1,0]
        
        self.land_cover.th[...,0,:] = self.land_cover.wc[...,0,:] / self.land_cover.root_depth[...,0,:]
        self.land_cover.th[...,1,:] = self.land_cover.wc[...,1,:] / self.land_cover.root_depth[...,1,:]
        
class InfiltrationSealed(Infiltration):
    """Class to represent infiltration for sealed area

    N.B. We could eventually adapt this class to represent 
    drainage to a sewer network, e.g.
    """
    def dynamic(self):
        self.land_cover.direct_runoff = self.land_cover.water_available_for_infiltration - self.land_cover.EWact

class InfiltrationWater(InfiltrationSealed):
    """Class to represent infiltration for water body"""
