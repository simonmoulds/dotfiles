import numpy as np
import datetime
import os
import gdal
import netCDF4
import re

ds = gdal.Open('../data/output_prec/Rainfall/EX200000.001')
a = ds.ReadAsArray()
nlat,nlon = np.shape(a)
xres = 1./12
yres = 1./12

b = ds.GetGeoTransform() #bbox, interval
minx = b[0]
maxx = b[0] + nlon * xres
maxy = b[3] 
miny = b[3] + nlat * -yres

lon = np.linspace(minx + xres/2, maxx - xres/2, nlon)
lat = np.linspace(miny + yres/2, maxy - yres/2, nlat)

