#!/bin/sh

count=1
while read line; do
    if [[ $line == https* ]]; then
	#url=$line
	file=$(awk 'NR == nr' nr=$((count+1)) micensus_districtwise_urls.txt)
	url=$(curl $line | grep window.location.href | sed 's/.*= //' | sed 's/"//g') 									     
        echo $url > temp
	wget -O $file -i temp 
    fi
    count=$((count+1))
done < micensus_district_water_distn_system.txt

