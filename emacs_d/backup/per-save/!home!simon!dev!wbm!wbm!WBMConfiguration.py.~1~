    def repair_landcover_options(self):
        if 'dynamicLandCover' not in list(self.LAND_COVER.keys()):
            self.LAND_COVER['dynamicLandCover'] = 0
            self.LAND_COVER['staticLandCoverYear'] = 1
        # if 'dynamicLandCover' not in list(self.LAND_COVER.keys()):
        #     self.LAND_COVER['dynamicLandCover'] = 0

        # if 'staticLandCoverYear' not in list(self.LAND_COVER.keys()):
        #     if not bool(self.LAND_COVER['dynamicLandCover']):
        #         logger.error('If land cover is not dynamic the year for which land cover data is used must be supplied')

        lc_types = [lc.strip() for lc in self.LAND_COVER['landCoverTypes'].split(',')]
        for lc in lc_types:
            lc_config = getattr(self, lc)
            if 'interceptCapInputFile' not in list(lc_config.keys()):
                lc_config['interceptCapInputFile'] = "None"
                lc_config['interceptCapVariableName'] = "None"
            
