[FILE_PATHS]
PathIn = ../data
PathOut = ../data

[MODEL_GRID]
cloneMap = ${FILE_PATHS:PathIn}/africa_clone_0pt25degree.tif
landmask = ${FILE_PATHS:PathIn}/africa_landmask_0pt25degree.tif

[CLOCK]
startTime = 2000-01-01
endTime = 2010-12-31

[INITIAL_WATER_CONTENT]
initialConditionType = percent
initialConditionPercent = 50
initialConditionInterpMethod =

[NETCDF_ATTRIBUTES]
institution = University of Exeter, UK
title = AquaCrop v5.0 output
description = test version (by Simon Moulds)
netcdf_y_orientation_follow_cf_convention = True
formatNetCDF = NETCDF4
zlib = True

[WEATHER]
precipitationNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_prate.nc4
precipitationVarName = prate
precipitationTimeDimName = time
precipitationOffset = 0.
precipitationFactor = 1.

meanDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_tavg.nc4
meanDailyTemperatureVarName = tavg
meanDailyTemperatureTimeDimName = time
meanDailyTemperatureOffset = 0.
meanDailyTemperatureFactor = 1.

minDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_tmin.nc4
minDailyTemperatureVarName = tmin
minDailyTemperatureTimeDimName = time
minDailyTemperatureOffset = 0.
minDailyTemperatureFactor = 1.

maxDailyTemperatureNC = ${FILE_PATHS:PathIn}/AgMERRA/AgMERRA_{year:0>4}_tmax.nc4
maxDailyTemperatureVarName = tmax
maxDailyTemperatureTimeDimName = time
maxDailyTemperatureOffset = 0.
maxDailyTemperatureFactor = 1.

refEvapotranspirationNC = ${FILE_PATHS:PathIn}/etref_ssa/ETref_PenmanMonteith_dailyTot_output.nc
refEvapotranspirationVarName = reference_crop_evapotranspiration
refEvapotranspirationTimeDimName = time
refEvapotranspirationConstant = 0.
refEvapotranspirationFactor = 1.

[CARBON_DIOXIDE]
carbonDioxideNC = ${FILE_PATHS:PathIn}/co2_annual_mean_mlo_0pt25degree.nc

[WATER_TABLE]
WaterTable = 0
VariableWaterTable = 0
groundwaterVarName = None
groundwaterInputDir = None
DailyGroundwaterNC = 0
groundwaterNC = None

[LAND_COVER]

[CROP_PARAMETERS]
nCrop = 1
cropParametersNC = ${FILE_PATHS:PathIn}/crop_parameters.nc
CalendarType = 2
SwitchGDD = 1
GDDmethod = 3
cropID = 2
outDailyTotal = thRZ_Act, CC
outYearMaxNC = Y

[IRRIGATION_MANAGEMENT]
irrigationManagementNC = None
irrigationScheduleNC = None

[FIELD_MANAGEMENT]
fieldManagementNC = None

[SOIL_HYDRAULIC_PARAMETERS]
calculateSoilHydraulicParametersFromSoilTexture = 0
soilHydraulicParametersNC = ${FILE_PATHS:PathIn}/soil_hydraulic_parameters.nc
saturatedHydraulicConductivityVarName = k_sat
saturatedVolumetricWaterContentVarName = th_sat
fieldCapacityVolumetricWaterContentVarName = th_crit
wiltingPointVolumetricWaterContentVarName = th_wilt
dzSoilLayer = 0.1,0.25,0.65,1.3
dzSoilCompartment = 0.1,0.1,0.1,0.15,0.15,0.2,0.2,0.25,0.25,0.25,0.25,0.3

[SOIL_PARAMETERS]
soilParametersNC = None
adjustReadilyAvailableWater = 0
adjustCurveNumber = 1

[REPORTING]
formatNetCDF = NETCDF4
zlib = True
