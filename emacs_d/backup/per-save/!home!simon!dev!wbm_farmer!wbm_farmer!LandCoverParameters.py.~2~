from wbm.LandCoverParameters import *
from wbm.SoilParameters import *
from wbm.TopoParameters import *

from .CropParameters import *
from .FarmParameters import *
from .IrrigationParameters import *
from .FieldManagementParameters import *
from .PriceData import *

class ManagedLandWithFarmerBehaviourParameters(LandCoverParameters):
    def __init__(self, model_object, config_section_name):
        super(ManagedLandWithFarmerBehaviourParameters, self).__init__(model_object, config_section_name)
        self.soil_parameters_module = SoilParameters(model_object, config_section_name)
        self.topo_parameters_module = TopoParametersManagedLand(model_object, config_section_name)
        self.cover_fraction_module = CoverFraction(model_object, self.configuration)        
        self.farm_parameters_module = FarmParameters(model_object, self.configuration)
        # self.price_module = PriceData(model_object, self.configuration)
        self.crop_parameters_module = CropParameters(model_object, self.configuration)
        self.crop_area_module = CropArea(model_object, self.configuration)
        self.intercept_capacity_module = MinimumInterceptionCapacity(model_object, self.configuration)
        self.price_module = PriceData(model_object, self.configuration)
        self.root_depth_module = MaxRootDepthDynamic(model_object, self.configuration)
        self.root_fraction_module = RootFraction(model_object, self.configuration)
        self.field_mgmt_parameters_module = FieldManagementParametersManagedLand(model_object, self.configuration)
        self.irrigation_parameters_module = IrrigationParameters(model_object, config_section_name)

    def initial(self):
        self.soil_parameters_module.initial()
        self.topo_parameters_module.initial()
        self.cover_fraction_module.initial()
        self.farm_parameters_module.initial()
        # self.price_module.initial()
        self.crop_parameters_module.initial()
        self.crop_area_module.initial()
        self.intercept_capacity_module.initial()
        self.price_module.initial()
        self.root_depth_module.initial()
        self.root_fraction_module.initial()
        self.field_mgmt_parameters_module.initial()
        self.irrigation_parameters_module.initial()
        self.soil_parameters_module.compute_soil_hydraulic_parameters()

    def dynamic(self):
        self.soil_parameters_module.dynamic()
        self.topo_parameters_module.dynamic()
        self.cover_fraction_module.dynamic()
        self.farm_parameters_module.dynamic()
        # self.price_module.dynamic()
        self.crop_parameters_module.dynamic()
        self.crop_area_module.dynamic()
        self.intercept_capacity_module.dynamic()
        self.price_module.dynamic()
