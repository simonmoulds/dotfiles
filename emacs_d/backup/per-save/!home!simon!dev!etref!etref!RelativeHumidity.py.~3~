#!/usr/bin/env python
# -*- coding: utf-8 -*-

import numpy as np

from hm import file_handling

class MaxRelativeHumidity(object):
    def __init__(self, MaxRelativeHumidity_variable):
        self.var = MaxRelativeHumidity_variable
        
    def initial(self):
        self.set_surface_specific_humidity_input_filenames()

    def set_max_relative_humidity_input_filenames(self):
        self.var.max_relative_humidity_filename = \
            self.var._configuration.WEATHER['maxRelativeHumidityNC']
        self.var.max_relative_humidity_variable_name = \
            self.var._configuration.WEATHER['maxRelativeHumidityVariableName']
        self.var.max_relative_humidity_time_dim_name = \
            self.var._configuration.WEATHER['maxRelativeHumidityTimeDimName']
                
    def read_max_relative_humidity_data(self):
        if self.var.max_relative_humidity_filename is not None:            
            self.var.min_relative_humidity = file_handling.netcdf_to_array(
                self.var.max_relative_humidity_filename.format(
                    day=self.var._modelTime.currTime.day,
                    month=self.var._modelTime.currTime.month,
                    year=self.var._modelTime.currTime.year
                ),
                self.var.max_relative_humidity_filename,
                str(self.var._modelTime.fulldate),
                useDoy = None,
                cloneMapFileName = self.var.cloneMapFileName,
                LatitudeLongitude = True)[self.var.landmask]
            
    def dynamic(self):
        self.read_max_relative_humidity_data()
