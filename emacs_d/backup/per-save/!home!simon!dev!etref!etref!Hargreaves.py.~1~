import os
import string
import numpy as np

import pcraster as pcr
from hydro_model_builder.Model import Model
from hydro_model_builder import VirtualOS as vos
from hydro_model_builder import Messages

from LongwaveRadiation import LongwaveRadiation
from ShortwaveRadiation import ShortwaveRadiation
from ExtraterrestrialRadiation import ExtraterrestrialRadiation
from NetRadiation import NetRadiation
from SpecificHumidity import SpecificHumidity
from SurfacePressure import SurfacePressure
from Temperature import Temperature
from VapourPressureDeficit import VapourPressureDeficit
from Wind import Wind

import logging
logger = logging.getLogger(__name__)

class PenmanMonteith(Model):

    def initial(self):
        self.temperature_module = Temperature(self)
        self.longwave_radiation_module = LongwaveRadiation(self)
        self.shortwave_radiation_module = ShortwaveRadiation(self)
        self.extraterrestrial_radiation_module = ExtraterrestrialRadiation(self)
        self.specific_humidity_module = SpecificHumidity(self)
        self.surface_pressure_module = SurfacePressure(self)
        self.vapour_pressure_deficit_module = VapourPressureDeficit(self)
        self.net_radiation_module = NetRadiation(self)
        self.wind_module = Wind(self)

        self.longwave_radiation_module.initial()
        self.shortwave_radiation_module.initial()
        self.extraterrestrial_radiation_module.initial()
        self.specific_humidity_module.initial()
        self.surface_pressure_module.initial()
        self.vapour_pressure_deficit_module.initial()        
        self.net_radiation_module.initial()        
        self.temperature_module.initial()
        self.wind_module.initial()

        self.get_model_dimensions()
        
    def get_model_dimensions(self):
        latitudes = np.unique(pcr.pcr2numpy(pcr.ycoordinate(self.cloneMap), vos.MV))[::-1]
        longitudes = np.unique(pcr.pcr2numpy(pcr.xcoordinate(self.cloneMap), vos.MV))
        self.dimensions = {
            'lat' : latitudes,
            'lon' : longitudes,
            'time': None}
        
    def penman_monteith(self):    
        cp           = 1013         # specific heat of air 1013 [J kg-1 K-1]
        TimeStepSecs = 86400        # timestep in seconds
        rs           = 70           # surface resistance, 70 [s m-1]
        R            = 287.058      # Universal gas constant [J kg-1 K-1]
        eps          = 0.622        # ratio of water vapour/dry air molecular weights [-]
        
        rho = self.surface_pressure / (self.tmean * R) # density of air [kg m-3]
        Lheat = (2.501 - (0.002361 * (self.tmean - 273.15))) * 1e6 # Latent heat [J kg-1]

        # slope of vapour pressure [Pa K-1]
        deltop  = (4098. * (610.8 * np.exp((17.27 * (self.tmean - 273.15)) / ((self.tmean - 273.15) + 237.3))))
        delbase = ((self.tmean - 273.15) + 237.3) ** 2
        delta = deltop / delbase

        # psychrometric constant
        gamma = cp * self.surface_pressure / (eps * Lheat) 

        # aerodynamic resistance
        ra = 208. / self.wind_2m

        # Penman-Monteith equation
        PET_divd = np.maximum((delta * self.net_radiation + rho * cp * self.vapour_pressure_deficit / ra), 1)
        PET_divs = np.maximum((delta + gamma * (1 + rs / ra)), 1)
        PET     = np.maximum(PET_divd / PET_divs, 0)
        PETmm   = np.maximum((PET / Lheat * TimeStepSecs), 0)
        self.ETref = PETmm.copy()
    
    def dynamic(self):
        logger.info("Reading forcings for time %s", self._modelTime)
        self.temperature_module.dynamic()
        self.longwave_radiation_module.dynamic()
        self.shortwave_radiation_module.dynamic()
        self.extraterrestrial_radiation_module.dynamic()
        self.specific_humidity_module.dynamic()
        self.surface_pressure_module.dynamic()
        self.vapour_pressure_deficit_module.dynamic()
        self.net_radiation_module.dynamic()        
        self.wind_module.dynamic()
        self.penman_monteith()

