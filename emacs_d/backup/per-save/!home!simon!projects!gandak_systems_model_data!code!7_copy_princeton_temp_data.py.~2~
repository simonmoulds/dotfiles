def get_times(year):
    dt = datetime.datetime(year,1,1)
    end = datetime.datetime(year+1,1,1)
    step = datetime.timedelta(days=1)
    times = []
    while dt < end:
        times.append(dt)
        dt += step
    return times

prc_datadir = '/data/PRINCETON_IGP'

years = range(1970, 2013 + 1)

def resample_data(suffix):    
    for year in years:
        prc_fn = prc_datadir + '/' + suffix + '_daily_' + str(year) + '-' + str(year) + '_igp.nc'
        print(prc_fn)
        os.system('ncks -d lat,25.,28. -d lon,83.,86.5 ' + prc_fn + ' -O prc_tmp.nc')
        new_fn = '../../data/' + suffix + '_daily_' + str(year) + '-' + str(year) + '_gandak.nc'
        print(new_fn)
        os.rename('prc_tmp.nc', new_fn)
        os.system('rm prc_tmp.nc')
    
def main():
    for suffix in ['tmin','tmax','tas']:
        resample_data(suffix)        
    
if __name__ == '__main__':
    main()
