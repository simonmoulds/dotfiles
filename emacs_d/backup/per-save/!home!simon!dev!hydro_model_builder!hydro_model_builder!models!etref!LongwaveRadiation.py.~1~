import os
import string
import numpy as np
import file_handling as vos
import Messages

class LongwaveRadiation(object):
    def __init__(self, LongwaveRadiation_variable):
        self.var = LongwaveRadiation_variable
        
    def initial(self):
        self.set_longwave_radiation_input_filenames()
        
    def set_longwave_radiation_input_filenames(self):
        keys = ['downwellingLongwaveRadiationNC',
                'downwellingLongwaveRadiationVarName',
                'downwellingLongwaveRadiationTimeDimName']
        vals = [self.var._configuration.WEATHER[key] for key in keys]
        self.var.longwaveRadiationDownFileNC = vals[0]
        self.var.longwaveRadiationDownVarName = vals[1]
        self.var.longwaveRadiationDownTimeDimName = vals[2]

    def read_longwave_radiation_data(self):
        day, month, year = (self.var._modelTime.currTime.day,
                            self.var._modelTime.currTime.month,
                            self.var._modelTime.currTime.year)
        self.var.longwave_radiation = vos.netcdf_to_array(
            self.var.longwaveRadiationDownFileNC.format(day=day, month=month, year=year),
            self.var.longwaveRadiationDownVarName,
            str(self.var._modelTime.fulldate),
            useDoy = None,
            cloneMapFileName = self.var.cloneMapFileName,
            # cloneMapAttributes = self.var.cloneMapAttributes,
            LatitudeLongitude = True)[self.var.landmask]

    def dynamic(self):
        self.read_longwave_radiation_data()
