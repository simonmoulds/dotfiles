#!/bin/bash

# convert model mask file to geotiff w/ proper georeferencing
# N.B. original ascii map provided by Johanna Scheidegger (BGS)

gdal_translate \
    -of GTiff \
    -a_srs EPSG:4326 \
    $WD/data-raw/modelMask.asc \
    $WD/data/modelMask.tif \
    -overwrite

g.region region=${DOMAIN}_0.083333Deg
eval `g.region -g`
gdalwarp \
    -t_srs EPSG:4326 \
    -te $w $s $e $n \
    -tr 0.08333333333333 0.08333333333333 \
    -r near \
    $WD/data/modelMask.tif \
    $WD/data/modelMask_resamp.tif \
    -overwrite

r.in.gdal \
    input=$WD/data/modelMask_resamp.tif \
    output=modelMask \
    --overwrite

# r.cell.area is an extension module, so we need to check it's installed
g.extension extension=r.cell.area operation=add
r.cell.area \
    output=modelMaskCellArea \
    units=m2 \
    --overwrite

r.mapcalc \
    "landmask = modelMask" \
    --overwrite

r.out.gdal \
    input=modelMaskCellArea \
    output=$WD/data/modelMaskCellArea.tif \
    format=GTiff \
    --overwrite

r.out.gdal \
    input=landmask \
    output=$WD/data/land_frac_${DOMAIN}_0.083333Deg.tif
    format=GTiff \
    --overwrite

