class BaseClass(object):
    def __init__(self, land_cover, configuration):
        self.land_cover = land_cover
        self.configuration = configuration
    
class CoverFraction(BaseClass):

    def __init__(self, land_cover, configuration):
        super(CoverFraction, self).__init__(
            land_cover,
            configuration
        )
        self.dynamicLandCover = bool(int(self.land_cover.model._configuration.LAND_COVER_PARAMETERS['dynamicLandCover']))
        self.staticLandCoverYear = None
        if not self.dynamicLandCover:
            self.staticLandCoverYear = int(self.land_cover.model._configuration.LAND_COVER_PARAMETERS['staticLandCoverYear'])
        
    def initial(self):
        self.coverFractionNC = str(self.configuration['landCoverFractionInputFile'])
        self.coverFractionVarName = str(self.configuration['landCoverFractionVariableName'])
        self.land_cover.cover_fraction = np.zeros((self.land_cover.model.nCell))
        self.update_cover_fraction()
        
    def update_cover_fraction(self):
        
        # TODO: make flexible the day on which land cover is changed
        
        start_of_model_run = (self.land_cover.model._modelTime.timeStepPCR == 1)
        start_of_year = (self.land_cover.model._modelTime.doy == 1)
        if self.dynamicLandCover:
            if start_of_model_run or start_of_year:
                date = datetime.datetime(self.land_cover.model._modelTime.year, 1, 1, 0, 0, 0)
                cover_fraction = file_handling.netcdf_to_array(
                    self.coverFractionNC.format(
                        day=self.land_cover.model._modelTime.currTime.day,
                        month=self.land_cover.model._modelTime.currTime.month,
                        year=self.land_cover.model._modelTime.currTime.year),
                    self.coverFractionVarName,
                    date,
                    # useDoy = method_for_time_index,
                    # cloneMapAttributes = self.cloneMapAttributes,
                    cloneMapFileName = self.land_cover.model.cloneMapFileName,
                    LatitudeLongitude = True)[self.land_cover.model.landmask]
                cover_fraction = np.float64(cover_fraction)
                self.land_cover.cover_fraction = cover_fraction
        else:
            if start_of_model_run:
                date = datetime.datetime(self.staticLandCoverYear, 1, 1, 0, 0, 0)
                cover_fraction = file_handling.netcdf_to_array(
                    self.coverFractionNC.format(
                        day=self.land_cover.model._modelTime.currTime.day,
                        month=self.land_cover.model._modelTime.currTime.month,
                        year=self.land_cover.model._modelTime.currTime.year),
                    self.coverFractionVarName,
                    date,
                    # useDoy = method_for_time_index,
                    # cloneMapAttributes = self.cloneMapAttributes,
                    cloneMapFileName = self.land_cover.model.cloneMapFileName,
                    LatitudeLongitude = True)[self.land_cover.model.landmask]
                cover_fraction = np.float64(cover_fraction)
                self.land_cover.cover_fraction = cover_fraction
                
    def dynamic(self):
        self.update_cover_fraction()

class CropCoefficient(BaseClass):
    
    def initial(self):
        self.cropCoefficientNC = str(self.configuration['cropCoefficientInputFile'])
        self.cropCoefficientVarName = str(self.configuration['cropCoefficientVariableName'])
        self.land_cover.cropCoefficient = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
        self.update_crop_coefficient()
        
    def update_crop_coefficient(self):
        
        start_of_model_run = (self.land_cover.model._modelTime.timeStepPCR == 1)
        if start_of_model_run or (self.land_cover.model._modelTime.day in [1,11,21]):
            self.land_cover.cropCoefficient = file_handling.netcdf_to_array(
                self.cropCoefficientNC.format(
                    day=self.land_cover.model._modelTime.currTime.day,
                    month=self.land_cover.model._modelTime.currTime.month,
                    year=self.land_cover.model._modelTime.currTime.year),
                self.cropCoefficientVarName,
                datetime.datetime(
                    2000,
                    self.land_cover.model._modelTime.currTime.month,
                    self.land_cover.model._modelTime.currTime.day),
                # useDoy = method_for_time_index,
                # cloneMapAttributes = self.cloneMapAttributes,
                cloneMapFileName = self.land_cover.model.cloneMapFileName,
                LatitudeLongitude = True)[self.land_cover.model.landmask]
        
    def dynamic(self):
        self.update_crop_coefficient()

class MinimumInterceptionCapacity(BaseClass):
    def initial(self):
        self.land_cover.minInterceptCap = np.float(self.configuration['minInterceptCap'])
        self.land_cover.interception_capacity = (
            np.ones((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
            * self.land_cover.minInterceptCap)
        
    def dynamic(self):
        pass
        
class InterceptionCapacity(MinimumInterceptionCapacity):
    
    def initial(self):
        super(InterceptionCapacity, self).initial()
        self.interceptCapNC = str(self.configuration['interceptCapInputFile'])
        self.interceptCapVarName = str(self.configuration['interceptCapVariableName'])
        self.update_intercept_capacity()
        
    def update_intercept_capacity(self):        
        if self.interceptCapNC != "None":
            start_of_model_run = (self.land_cover.model._modelTime.timeStepPCR == 1)
            if start_of_model_run or (self.land_cover.model._modelTime.day in [1,11,21]):
                self.land_cover.interception_capacity = file_handling.netcdf_to_array(
                    self.interceptCapNC.format(
                        day=self.land_cover.model._modelTime.currTime.day,
                        month=self.land_cover.model._modelTime.currTime.month,
                        year=self.land_cover.model._modelTime.currTime.year),
                    self.interceptCapVarName,
                    datetime.datetime(
                        2000,
                        self.land_cover.model._modelTime.currTime.month,
                        self.land_cover.model._modelTime.currTime.day),
                    # useDoy = method_for_time_index,
                    # cloneMapAttributes = self.cloneMapAttributes,
                    cloneMapFileName = self.land_cover.model.cloneMapFileName,
                    LatitudeLongitude = True)[self.land_cover.model.landmask]
        self.land_cover.interception_capacity = self.land_cover.interception_capacity.clip(self.land_cover.minInterceptCap, None)
        
    def dynamic(self):
        self.update_intercept_capacity()

class RootFraction(BaseClass):
    def initial(self):
        self.rootFractionNC = str(self.configuration['rootFractionInputFile'])
        self.rootFractionVarName = str(self.configuration['rootFractionVariableName'])                
        self.read_root_fraction()
        
    def read_root_fraction(self):
        landmask = np.broadcast_to(
            self.land_cover.model.landmask,
            (2, self.land_cover.model.nLat, self.land_cover.model.nLon)
        )
        root_fraction = file_handling.netcdf_to_arrayWithoutTime(
            self.rootFractionNC,
            self.rootFractionVarName,
            cloneMapFileName = self.land_cover.model.cloneMapFileName)
        root_fraction = root_fraction[landmask].reshape(2, self.land_cover.model.nCell)
        root_fraction = np.broadcast_to(
            root_fraction[None,None,:,:],
            (self.land_cover.nFarm, self.land_cover.nCrop, 2, self.land_cover.model.nCell)
        )

        # Scale root fraction - adapted from CWATM
        # landcoverType.py lines 311-319

        # 1 - add top layer to root fraction input data
        root_fraction_adj = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nLayer, self.land_cover.model.nCell))
        top_layer_fraction = np.divide(
            self.land_cover.root_depth[...,0,:],
            (self.land_cover.root_depth[...,0,:] + self.land_cover.root_depth[...,1,:])
        )        
        root_fraction_adj[...,0,:] = top_layer_fraction * root_fraction[...,0,:]
        root_fraction_adj[...,1,:] = (1. - top_layer_fraction) * root_fraction[...,1,:]
        root_fraction_adj[...,2,:] = (1. - root_fraction[...,1,:])

        # 2 - scale so that the total root fraction sums to one
        root_fraction_sum = np.sum(root_fraction_adj, axis=-2)
        root_fraction_adj /= root_fraction_sum[...,None,:]
        self.land_cover.root_fraction = root_fraction_adj.copy()
        
    def dynamic(self):
        pass

class MaxRootDepth(BaseClass):
    def initial(self):
        self.land_cover.max_root_depth = np.ones((self.land_cover.model.nCell)) * 1.

    def compute_root_depth(self):
        """Function to compute the root depth in each soil 
        layer
        """
        self.land_cover.root_depth = np.zeros(
            (self.land_cover.nFarm,
             self.land_cover.nCrop,
             self.land_cover.model.nLayer,
             self.land_cover.model.nCell)
        )
        self.land_cover.root_depth[...,0,:] = self.land_cover.soil_depth[...,0,:].copy()

        # make sure that root depth in layer 1 does not exceed
        # the depth of the soil layer
        soildepth12 = (
            self.land_cover.soil_depth[...,1,:]
            + self.land_cover.soil_depth[...,2,:]
        )
        h1 = np.maximum(
            self.land_cover.soil_depth[...,1,:],
            self.land_cover.max_root_depth - self.land_cover.soil_depth[...,0,:]
        )
        self.land_cover.root_depth[...,1,:] = np.minimum(
            (soildepth12 - 0.05),
            h1
        )
        # make sure the root depth in layer 2 is at least 0.05m (?)
        self.land_cover.root_depth[...,2,:] = np.maximum(
            0.05,
            (soildepth12 - self.land_cover.root_depth[...,1,:])
        )
        
    def dynamic(self):
        pass
    
class MaxRootDepthFromFile(MaxRootDepth):
    def initial(self):
        super(MaxRootDepthFromFile, self).initial()
        self.maxRootDepthNC = str(self.configuration['maxRootDepthInputFile'])
        self.maxRootDepthVarName = str(self.configuration['maxRootDepthVariableName'])
        self.read_max_root_depth()
        self.compute_root_depth()
        
    def read_max_root_depth(self):
        max_root_depth = file_handling.netcdf_to_arrayWithoutTime(
            self.maxRootDepthNC,
            self.maxRootDepthVarName,
            cloneMapFileName = self.land_cover.model.cloneMapFileName
        )
        max_root_depth = max_root_depth[self.land_cover.model.landmask]
        max_root_depth *= self.land_cover.soildepth_factor  # CALIBRATION
        self.land_cover.max_root_depth = np.broadcast_to(
            max_root_depth[None,None,:],
            (self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell)
        )

class MaxRootDepthDynamic(MaxRootDepth):
    def initial(self):
        super(MaxRootDepthDynamic, self).initial()
        self.compute_max_root_depth()
        self.compute_root_depth()
        
    def compute_max_root_depth(self):
        self.land_cover.max_root_depth = self.land_cover.Zmin # TEMPORARY
    
    def dynamic(self):
        self.land_cover.max_root_depth[self.land_cover.GrowingSeasonIndex] = self.land_cover.Zmin[self.land_cover.GrowingSeasonIndex]
        self.land_cover.max_root_depth[np.logical_not(self.land_cover.GrowingSeasonIndex)] = 1.  # Global Crop Water Model
        self.compute_root_depth()

class LandCoverParameters(object):
    def __init__(self, land_cover, config_section_name):
        self.land_cover = land_cover
        self.configuration = getattr(
            self.land_cover.model._configuration,
            config_section_name)
        # TODO: move this somewhere else
        self.land_cover.minCropKc = np.float(self.land_cover.model._configuration.LAND_COVER_PARAMETERS['minCropKc'])

class SealedLandParameters(LandCoverParameters):
    """Class for parameters relevant to sealed land cover"""
    def __init__(self, land_cover, config_section_name):
        super(SealedLandParameters, self).__init__(
            land_cover,
            config_section_name
        )
        self.topo_parameters_module = TopoParametersSealed(land_cover, config_section_name)  # ???
        self.cover_fraction_module = CoverFraction(land_cover, self.configuration)
        self.intercept_capacity_module = MinimumInterceptionCapacity(land_cover, self.configuration)        
    def initial(self):
        self.topo_parameters_module.initial()
        self.cover_fraction_module.initial()
        self.intercept_capacity_module.initial()
    def dynamic(self):
        self.cover_fraction_module.dynamic()
        self.intercept_capacity_module.dynamic()

