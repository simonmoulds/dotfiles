library(raster)

myfun = function(template, ..., fun) {
    template[] = 0
    maps = list(...)
    maps_adj = list()    
    for (i in 1:length(maps)) {
        r = template
        map = maps[[i]]
        pts = SpatialPoints(map)
        r[pts] = r[pts] + map[pts]
        maps_adj[[i]] = r
    }
    res = stackApply(
        stack(maps_adj),
        indices=rep(1, length(maps_adj)),
        fun=fun)
    res
}

