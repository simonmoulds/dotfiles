# sm_wilt: wilting point
# hcap   : dry heat capacity
# hcon   : dry thermal conductivity
# albsoil: soil albedo

datadir = '../data'
res = '0pt25degree'
region = 'ssa'
method = 'cosby'
nlayer = 4
outdir = '../data'

clone_map = rasterio.open(
    os.path.join(
        datadir,
        'theta_sat_cosby_igp_layer1_0pt25degree.tif'
    )    
)
bbox = clone_map.bounds
xmin,ymin,xmax,ymax = bbox[0], bbox[1], bbox[2], bbox[3]

os.system('unzip -o ../data/ISLSCP_C4_1DEG_932.zip -d ../data')
os.system('gdal_translate -a_srs EPSG:4326 ../data/ISLSCP_C4_1DEG_932/data/c4_percent_1d.asc ../data/c4_percent_1d.tif')
