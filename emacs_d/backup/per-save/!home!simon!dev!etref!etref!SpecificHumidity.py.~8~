#!/usr/bin/env python
# -*- coding: utf-8 -*-

import numpy as np

from hm import file_handling

class SpecificHumidity(object):
    def __init__(self, SpecificHumidity_variable):
        self.var = SpecificHumidity_variable
        
    def initial(self):
        self.set_surface_specific_humidity_input_filenames()
        self.var.specific_humidity = np.zeros((self.var.nCell))
        
    def set_surface_specific_humidity_input_filenames(self):
        keys = ['nearSurfaceSpecificHumidityNC',
                'nearSurfaceSpecificHumidityVarName',
                'nearSurfaceSpecificHumidityTimeDimName']
        vals = [self.var._configuration.WEATHER[key] for key in keys]
        self.var.surfaceSpecificHumidityFileNC = vals[0]
        self.var.surfaceSpecificHumidityVarName = vals[1]
        self.var.surfaceSpecificHumidityTimeDimName = vals[2]

    def read_surface_specific_humidity_data(self):
        if self.var.has_specific_humidity:
            self.var.specific_humidity = file_handling.netcdf_to_array(
                self.var.surfaceSpecificHumidityFileNC.format(
                    day=self.var._modelTime.currTime.day,
                    month=self.var._modelTime.currTimemonth,
                    year=self.var._modelTime.currTimeyear
                ),
                self.var.surfaceSpecificHumidityVarName,
                str(self.var._modelTime.fulldate),
                useDoy = None,
                cloneMapFileName = self.var.cloneMapFileName,
                LatitudeLongitude = True)[self.var.landmask]
            
    def dynamic(self):
        self.read_surface_specific_humidity_data()
