#!/bin/bash

baseurl=http://hydrology.princeton.edu/data/pgf/v3/0.25deg/daily/
declare -a vars=("dlwrf" "dswrf" "prcp" "pres" "shum" "tas" "tmax" "tmin" "wind")
for var in "${vars[@]}"
do
    for year in {1948..1948}
    do
        filename="${var}"_daily_"${year}"-"${year}".nc
        url="${baseurl}"/"${filename}"
        wget "${url}" -O "${filename}"
    done    
done

           
