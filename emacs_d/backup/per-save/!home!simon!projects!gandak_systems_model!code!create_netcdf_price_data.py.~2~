import numpy as np
import datetime
import os
import gdal
import netCDF4
import re

ds = gdal.Open('../data/ksat_topsoil_gapfilled_5m.tif')
a = ds.ReadAsArray()
nlat,nlon = np.shape(a)
xres = 1./12
yres = 1./12

b = ds.GetGeoTransform() #bbox, interval
minx = b[0]
maxx = b[0] + nlon * xres
maxy = b[3] 
miny = b[3] + nlat * -yres

lon = np.arange(0,nlon) * xres + (minx + xres/2)
lat = np.arange(0,nlat) * yres + (miny + yres/2)
lat = lat[::-1]

nlon = np.size(lon)
nlat = np.size(lat)
ncrop = 6

import pandas
price_data = pandas.read_table(
    'data/gandak_price_data.txt',
    sep='\t',
    header=0,
    index_col=False)

# annual time series
years = price_data['YEAR']
year = np.min(years)
end_year = np.max(years)
times = []
while year < end_year + 1:
    times.append(datetime.datetime(year,1,1))
    year += 1
nt = len(times)

# crop price data (rice, wheat, sugarcane)
rice = price_data['PADY_TP']
wheat = price_data['WHT_TP']
sugarcane = price_data['SGUR_TP']

# fertiliser price data (N, P, K)
nitrogen = price_data['N_TP']
phosphorus = price_data['P_TP']
potassium = price_data['K_TP']

# diesel price
diesel = price_data['DIESEL_PRICE']

# create NetCDF file
nco = netCDF4.Dataset('../data/Gandak_price_data.nc','w',clobber=True)

# create dimensions, variables and attributes:
nco.createDimension('lon',nlon)
nco.createDimension('lat',nlat)
nco.createDimension('time',None)
nco.createDimension('crop',ncrop)

timeo = nco.createVariable('time','f4',('time'))
timeo.units = 'days since 1901-01-01 00:00:00'
timeo.calendar = 'standard'
timeo.standard_name = 'time'
timeo[:] = netCDF4.date2num(times, units=timeo.units, calendar=timeo.calendar)

lono = nco.createVariable('lon',np.float64,('lon'),zlib=True,least_significant_digit=16)
lono.units = 'degrees_east'
lono.standard_name = 'longitude'
lono[:]=lon

lato = nco.createVariable('lat',np.float64,('lat'),zlib=True,least_significant_digit=16)
lato.units = 'degrees_north'
lato.standard_name = 'latitude'
lato[:]=lat

# create container variable for CRS: lon/lat WGS84 datum
crso = nco.createVariable('crs','i4')
crso.long_name = 'Lon/Lat Coords in WGS84'
crso.grid_mapping_name='latitude_longitude'
crso.longitude_of_prime_meridian = 0.0
crso.semi_major_axis = 6378137.0
crso.inverse_flattening = 298.257223563

