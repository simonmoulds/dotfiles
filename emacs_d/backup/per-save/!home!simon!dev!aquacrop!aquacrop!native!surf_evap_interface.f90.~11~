module surf_evap_interface
  use iso_c_binding, only: c_double, c_int
  use soil_evaporation, only: surf_evap  
  implicit none

contains
  
  subroutine c_surf_evap( &
       es_pot, &
       es_act, &
       surface_storage, &
       rew, &
       w_surf, &
       w_stage_two, &
       evap_z, &
       evap_z_min, &
       n_farm, n_crop, n_cell
    )
   
    integer(c_int), intent(in) :: n_farm, n_crop, n_cell
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: es_pot
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: rew
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: evap_z_min
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(inout) :: es_act
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(inout) :: surface_storage
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(inout) :: w_surf
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(inout) :: w_stage_two
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(inout) :: evap_z
    ! integer(c_int) :: i, j, k
    integer :: i, j, k
    do i = 1, n_farm
       do j = 1, n_crop
          do k = 1, n_cell
             
             call surf_evap( &
                  es_pot(i,j,k), &
                  es_act(i,j,k), &
                  surface_storage(i,j,k), &
                  rew(i,j,k), &
                  w_surf(i,j,k), &
                  w_stage_two(i,j,k), &
                  evap_z(i,j,k), &
                  evap_z_min(i,j,k), &
                  n_farm, n_crop, n_cell)
             
          end do
       end do
    end do
    
  end subroutine c_surf_evap
  
end module surf_evap_interface

    
