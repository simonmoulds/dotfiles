import os
import numpy as np
import datetime
import scipy.interpolate as interpolate
import pandas
import rasterio
import re

from hydro_model_builder.ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list

class RefETData(object):
    def __init__(self, RefETData_variable):
        self.var = RefETData_variable
        self.var.RefETInputPath = (
            self.var._configuration.globalOptions['inputDir'] 
            + '/' + self.var._configuration.refETDataOptions['dataDir'])
        sd = str(self.var._configuration.refETDataOptions['startDate'])
        ed = str(self.var._configuration.refETDataOptions['endDate'])
        self.var.RefETStartDate = datetime.datetime.strptime(sd, '%Y-%m-%d')
        self.var.RefETEndDate = datetime.datetime.strptime(ed, '%Y-%m-%d')
        self.var.RefETDataOutputFile = vos.getFullPath(
            self.var._configuration.refETDataOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)
        
    def initial(self):
        pass

    def dynamic(self):
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)
        netcdf.create_netCDF(self.var.RefETDataOutputFile, 'ETref')
        pattern = re.compile('PM[0-9]{6}\.[0-9]{3}')
        itime=0
        dt = self.var.RefETStartDate
        step = datetime.timedelta(days=1)

        # Step through data, writing time and data to NetCDF
        for root, dirs, files in os.walk(self.var.RefETInputPath):
            dirs.sort()
            files.sort()
            for f in files:
                if re.match(pattern,f):
                    prc_path = os.path.join(root,f)
                    print prc_path
                    vos.gdal_warp(
                        prc_path,
                        'tmp.tif',
                        self.bbox[0],
                        self.bbox[1],
                        self.bbox[2],
                        self.bbox[3])
                    r = rasterio.open('tmp.tif')
                    arr = r.read(masked=True)[0,...]
                    # TODO: deal with nodata values properly
                    # mask = np.ma.getmask(arr)
                    # arr[mask] = 0.
                    netcdf.data2NetCDF(self.var.RefETDataOutputFile, 'ETref', arr, dt)
                    os.remove('tmp.tif')
                    dt += step
