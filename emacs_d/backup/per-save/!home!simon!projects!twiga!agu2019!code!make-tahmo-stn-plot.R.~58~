library(sf)
library(magrittr)
library(ggplot2)
library("rnaturalearth")
library("rnaturalearthdata")

meta = read.csv("../data/tahmo_stn_metadata.csv")
starttm =
    sprintf("%14.0f", meta$StartDate) %>%
    as.POSIXlt(., format="%Y%m%d%H%M%S")
yrs = starttm$year + 1900
meta[["StartYear"]] = sprintf("%4.0f", yrs)
sy = meta[["StartYear"]]
sy[sy %in% c("2012","2013","2014","2015")] = "<2016"
meta[["StartYear"]] = sy
meta %<>%
    dplyr::select(X, Y, StartYear) %>%
    setNames(c("longitude","latitude","startyear"))
meta$startyear = factor(meta$startyear)

meta_sf = st_as_sf(meta, coords=c("longitude","latitude"), crs=4326, agr="constant")

world <- ne_countries(scale = "medium", returnclass = "sf")
class(world)

theme_set(theme_bw())
p = ggplot(data = world) +
    geom_sf() + 
    geom_sf(data=meta_sf, aes(color=startyear), shape=16, size=1, show.legend="point") +
    coord_sf(xlim=c(-20,55), ylim=c(-37.5,40), expand=FALSE) +
    scale_color_brewer(palette="Dark2") + 
    scale_shape_manual(values=1) + 
    theme(legend.key=element_blank(), legend.title=element_blank())
p

ggsave(
    file.path("~/Dropbox/agu2019/tahmo_stn_locations.png"),
    p,
    device="png",
    width=5.5, height=4.5, units="in"
)
