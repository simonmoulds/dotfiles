#!/bin/bash

wd=$HOME/projects/gandak_systems_model

if [ ! -e /data/SRTM/hydrosheds_gandak_mosaic.tif ]
then
    gdalwarp /data/SRTM/*.tif /data/SRTM/hydrosheds_gandak_mosaic.tif
fi

echo 'export GRASS_MESSAGE_FORMAT=plain
r.mask -r
# r.in.gdal input=/data/SRTM/hydrosheds_gandak_mosaic.tif output=hydrosheds_gandak --overwrite
g.region rast=hydrosheds_gandak
eval `g.region -g`
g.region n=$n s=$s w=$w e=$e nsres=0:05 ewres=0:05
g.region -p
r.resamp.stats -w input=hydrosheds_gandak output=hydrosheds_gandak_5m method=average --overwrite
r.out.gdal -f input=hydrosheds_gandak_5m output=hydrosheds_gandak_5m.tif format=GTiff --overwrite
' > $wd/mygrassjob.sh

chmod u+x $wd/mygrassjob.sh
export GRASS_BATCH_JOB=$wd/mygrassjob.sh
grass $HOME/grassdata/latlong/PERMANENT
unset GRASS_BATCH_JOB
rm $wd/mygrassjob.sh

if [ -e hydrosheds_gandak_5m.tif ]
then
    mv hydrosheds_gandak_5m.tif $wd/data
    gdal_translate -ot Float32 -mo "PCRASTER_VALUESCALE=VS_SCALAR" -of PCRaster $wd/data/hydrosheds_gandak_5m.tif $wd/data/hydrosheds_gandak_5m.map
fi

e2o_radiation.py -S 1 -E 366 -D $wd/data/hydrosheds_gandak_5m.map -O $wd/data/output_rad -T 60 -f PCRaster
