# 5 - Write output
# ##################################### #

r.mask \
    raster=odaw_basin \
    --overwrite

r.out.gdal \
    input=accum \
    output=$WD/odaw_maps/odaw_accum_ll.tif \
    format=GTiff \
    # type=Int32 \
    --overwrite

r.out.gdal \
    input=odaw_basin \
    output=$WD/odaw_maps/odaw_basin_ll.tif \
    format=GTiff \
    type=Byte \
    --overwrite

r.out.gdal \
    input=nasadem_accra \
    output=$WD/odaw_maps/odaw_nasadem_dem_ll.tif \
    --overwrite

r.out.gdal \
    input=esa_lulc \
    output=$WD/odaw_maps/odaw_lulc_ll.tif \
    format=GTiff \
    type=Byte \
    --overwrite

r.out.gdal \
    input=osm_water_accra \
    output=$WD/odaw_maps/odaw_osm_water_ll.tif \
    format=GTiff \
    type=Byte \
    --overwrite

r.out.gdal \
    input=osm_water_accra \
    output=$WD/odaw_maps/odaw_osm_water_ll.tif \
    format=GTiff \
    type=Byte \
    --overwrite

for map in odaw_accum odaw_basin odaw_nasadem_dem odaw_lulc odaw_osm_water
do
    gdalwarp \
	-overwrite \
	-t_srs EPSG:32630 \
	$WD/odaw_maps/"$map"_ll.tif \
	$WD/odaw_maps/"$map"_utm30n.tif
done

ogr2ogr \
    -overwrite \
    -t_srs EPSG:32630 \
    $WD/odaw_maps/AMA_EA_utm30n.shp \
    $WD/AMA\ EA\ 2000\ census/AMA_EA.shp 
