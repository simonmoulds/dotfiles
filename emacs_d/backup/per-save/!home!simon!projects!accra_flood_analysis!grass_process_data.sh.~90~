#!/bin/bash

WD=$HOME/projects/accra_flood_analysis

# ##################################### #
# 1 - Mosaic NASADEM tiles
# ##################################### #

for zipf in NASADEM_HGT_*.zip
do
    unzip -o $zipf
done

gdalwarp \
    -overwrite \
    *.hgt \
    nasadem_accra.tif

gdalwarp \
    -te -0.30 5.50 -0.10 5.87 \
    nasadem_accra.tif \
    nasadem_accra_odaw.tif


