## Configuration file for Gandak baseline model run

function make_gandak_bau_config() {
    
    ## run information
    config = list(
        run_id = "gandak_bau"
        n_farmer = 50                           
        n_runs = 20                           
        params_fn = file.path("gandak_bau_params.R")
        irrigation_schedule_fn = file.path("gandak_bau_irrigation_schedule.R")
        climate_data_fn = file.path("sult_base_all_data_irr2.txt")
        rainfall_data_fn = file.path("sult_base_sult_precip_1971_2018.txt")
        price_data_fn = file.path("sult_base_all.variables_yield_interp_fert_cons.txt")
        diesel_price_data_fn = file.path("sult_base_diesel_prices_long.txt")
        well_cost_data_fn = file.path("well_cost_long.txt")
        yield_data_fn = file.path("sult_base_ln_crop_yield_sultanpur.txt")
    )
    config
}

