#!/usr/bin/env python
# -*- coding: utf-8 -*-

import numpy as np
from hm import file_handling
import logging
logger = logging.getLogger(__name__)

class CropYield(object):
    def __init__(self, land_cover):
        self.land_cover = land_cover

    def initial(self):
        self.land_cover.ETactCum = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
        self.land_cover.ETpotCum = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
        self.land_cover.Y = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
        self.land_cover.Production = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))        

    def update_cumulative_evapotranspiration(self):
        self.land_cover.ETactCum[np.logical_not(self.land_cover.GrowingSeasonIndex)] = 0
        self.land_cover.ETpotCum[np.logical_not(self.land_cover.GrowingSeasonIndex)] = 0            
        self.land_cover.ETactCum[self.land_cover.GrowingSeasonIndex] += self.land_cover.Tact[self.land_cover.GrowingSeasonIndex]
        self.land_cover.ETpotCum[self.land_cover.GrowingSeasonIndex] += self.land_cover.Tpot[self.land_cover.GrowingSeasonIndex]

    def update_crop_yield(self):
        cond1 = self.land_cover._modelTime.doy == self.land_cover.HarvestDateAdj
        ET_ratio = np.divide(
            self.land_cover.ETactCum,
            self.land_cover.ETpotCum,
            np.zeros_like(self.land_cover.ETpotCum),
            where=self.land_cover.ETpotCum>0)
        self.land_cover.Y[cond1] = (
            (self.land_cover.Yx
             * (1 - self.land_cover.Ky
                * (1 - ET_ratio)))
            / 1000)[cond1]  # tonne / hectare
        self.land_cover.Y[np.logical_not(cond1)] = 0

    def update_crop_production(self):
        self.land_cover.Production = (
            self.land_cover.Y
            * self.land_cover.FarmCropArea
            / 10000.
        )
        
    def dynamic(self):
        self.update_cumulative_evapotranspiration()
        self.update_crop_yield()
        self.update_crop_production()
