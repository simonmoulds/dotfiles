#!/bin/bash

wd=$HOME/projects/gandak_systems_model_data
datadir=/data/Globcover

if [ ! -e $datadir/GLOBCOVER_L4_200901_200912_V2.3_igp_ll.tif ]
then
    gdalwarp \
	-t_srs EPSG:4326 \
	-te 83 25 86.5 28 \
	-r near \
	$datadir/GLOBCOVER_L4_200901_200912_V2.3.tif \
	$datadir/GLOBCOVER_L4_200901_200912_V2.3_igp_ll.tif \
	-overwrite
fi

echo "11 14 20 = 1 Cropland
30 120 130 140 150 180 200 = 2 Grassland
40 50 60 70 90 100 110 160 170 = 3 Forest
190            = 4 Sealed area
210            = 5 Water bodies
220            = 6 Permanent snow and ice
*              = NULL
" > data/globcover_reclass_rules.txt

echo '#!/bin/bash
export GRASS_MESSAGE_FORMAT=plain
r.mask -r
wd=$HOME/projects/gandak_systems_model_data
datadir=/data/Globcover
outd=../data
g.region n=28.0 s=25 e=86.5 w=83 nsres=0:05 ewres=0:05 save=gandak --overwrite
r.cell.area output=gandak_cell_area units=km2 --overwrite
r.out.gdal input=gandak_cell_area output=$outd/Gandak_cell_area.tif format=GTiff --overwrite
r.in.gdal input=$datadir/GLOBCOVER_L4_200901_200912_V2.3_igp_ll.tif output=Globcover_2009 --overwrite
g.region raster=Globcover_2009 save=globcover --overwrite
r.reclass input=Globcover_2009 output=Globcover_2009_rcl rules=globcover_reclass_rules.txt
class=("cropland" "grassland" "forest" "sealed_area" "water_bodies" "permanent_snow_and_ice")
for i in "${!class[@]}"; 
do 
    ix=$(echo $i+1 | bc) 
    g.region region=globcover
    r.mapcalc "tmp = if(Globcover_2009_rcl==$ix,1.,0.)" --overwrite
    g.region region=gandak
    r.resamp.stats -w input=tmp output=Globcover_2009_${class[i]} method=average --overwrite
    r.out.gdal input=Globcover_2009_${class[i]} output=$outd/Globcover_2009_${class[i]}.tif format=GTiff --overwrite
done
' > $wd/mygrassjob.sh

chmod u+x $wd/mygrassjob.sh
export GRASS_BATCH_JOB=$wd/mygrassjob.sh
grass $HOME/grassdata/latlong/PERMANENT
unset GRASS_BATCH_JOB
rm $wd/mygrassjob.sh
