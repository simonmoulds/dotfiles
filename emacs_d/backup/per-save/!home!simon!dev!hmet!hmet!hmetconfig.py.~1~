    def check_format_args(self):
        msg = ''
        format_args_not_ok = False
        for filename in self.filename_dict.filename:
            if filename is not None:
                format_args = utils.get_format_args(filename)
                if len(format_args) > 0:
                    format_args_ok = utils.check_format_args_ok(
                        format_args, ['day', 'month', 'year'])
                    if not format_args_ok:
                        format_args_not_ok = True
                        msg += \
                            'Filename ' \
                            + filename \
                            + ' contains invalid format arguments:' \
                            + ' only day, month and year are allowable'\
                            + '\n'

        if format_args_not_ok:
            logger.error(msg)

