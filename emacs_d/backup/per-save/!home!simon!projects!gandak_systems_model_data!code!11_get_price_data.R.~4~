## Get price data from various sources, and create
## time series with consistent format

library(readxl)
library(magrittr)
library(tidyverse)

bihar_dists = c("Champaran","Muzaffarpur","Saran")
up_dists = c("Deoria","Gorakhpur")
dists = c(bihar_dists, up_dists)

## ===========================
## Consumer Price Index (2010)
## ===========================

library(wbstats)
## wbsearch("consumer price index")
cpi =
    wb(country="IND",indicator="FP.CPI.TOTL") %>%
    select(date, value) %>%
    mutate_all(funs(as.numeric)) %>%
    setNames(c("YEAR","CPI"))

## ==========================
## Fertiliser price - ICRISAT
## ==========================

## JoK model:
## x = read.table("~/projects/igp_livelihood_model/chanse/data/data/sult_base_all.variables_yield_interp_fert_cons.txt", header=T, stringsAsFactors = FALSE)

bihar_fert_price =
    read_excel("../data/ICRISAT/Bihar/dt_fert_prices_a_web.xlsx", col_names=TRUE, na=c("-1"))

up_fert_price =
    read_excel("../data/ICRISAT/UttarPradesh/dt_fert_prices_a_web.xlsx", col_names=TRUE, na=c("-1"))

years = data.frame(YEAR=1960:2015)
fert_price =
    rbind(bihar_fert_price, up_fert_price) %>%
    mutate(ID = "Gandak") %>%
    filter(DISTNAME %in% dists) %>%
    group_by(ID,YEAR) %>%
    summarise_at(vars(-STCODE,-STNAME,-DIST,-DISTNAME), funs(mean(., na.rm=TRUE))) %>%
    left_join(cpi, by="YEAR") %>%
    mutate_at(vars(ends_with("TP")),
              funs(. / (CPI / 100))) %>%
    right_join(years, by="YEAR") %>%
    zoo::na.locf()

## TODO: find more up-to-date information, because
## at the moment the data stops in the mid-1990s

write.table(fert_price,
            "../data/gandak_fert_price_data.txt",
            sep="\t",
            row.names=FALSE,
            col.names=TRUE)

## ====================
## Crop price - ICRISAT
## ====================

## crop price in Rs/100kg

bihar_crop_price =
    read_excel("../data/ICRISAT/Bihar/dt_fhp_a_web.xlsx", col_names=TRUE, na=c("-1"))

up_crop_price =
    read_excel("../data/ICRISAT/UttarPradesh/dt_fhp_a_web.xlsx", col_names=TRUE, na=c("-1"))

crop_price =
    rbind(bihar_crop_price, up_crop_price) %>%
    mutate(ID = "Gandak") %>% 
    filter(DISTNAME %in% dists) %>%
    group_by(ID,YEAR) %>%
    summarise_at(vars(-STCODE,-STNAME,-DIST,-DISTNAME), funs(mean(., na.rm=TRUE))) %>%
    
    left_join(cpi, by="YEAR") %>%
    mutate_at(
        vars(ends_with("TP")),
        funs(. * 10)) %>%               # Rs/100kg -> Rs/tonne
    mutate_at(
        vars(ends_with("TP")),
        funs(. / (CPI / 100))) %>%
    select(ID,YEAR,PADY_TP,WHT_TP,SGUR_TP) %>%
    right_join(years, by="YEAR") %>%
    zoo::na.locf()

write.table(crop_price,
            "../data/gandak_crop_price_data.txt",
            sep="\t",
            row.names=FALSE,
            col.names=TRUE)

