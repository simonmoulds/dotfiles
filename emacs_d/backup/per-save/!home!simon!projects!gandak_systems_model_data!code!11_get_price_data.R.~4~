daily_ts_1989_2010 = seq.POSIXt(
    as.POSIXct("01-01-1989", format="%d-%m-%Y"),
    as.POSIXct("31-12-2010", format="%d-%m-%Y"),
    by="day")

cpi_1989_2010 = cpi[cpi$YEAR %in% 1989:2010,]
cpi_xts =
    cpi_1989_2010 %>%
    mutate(YEAR = paste0("01-01-", YEAR)) %>%
    zoo::read.zoo(format="%d-%m-%Y") %>%
    xts::as.xts() %>%
    merge(xts::as.xts(daily_ts_1989_2010), join="right") %>%
    zoo::na.locf() %>%
    setNames("CPI") 

## Subset to match first and last date in time
## series data
ix = (zoo::index(cpi_xts) <= as.Date("2010-06-26")) & (zoo::index(cpi_xts) >= as.Date("1989-04-01"))
ix = which(ix)
cpi_xts = cpi_xts[ix,]

## First, apply CPI to time series data
diesel_price =
    diesel_price_data_raw %>% 
    setNames(c("Month","Day","Year","Petrol","Kerosene","Diesel","LPG")) %>%
    select(Month, Day, Year, Diesel) %>%
    mutate_at(vars("Diesel"), as.numeric) %>%
    mutate_at(vars("Day"), funs(formatC(., width=2, flag=0))) %>%
    unite(Date, Day, Month, Year, sep="-") %>%
    zoo::read.zoo(format="%d-%b-%Y") %>%
    xts::as.xts() %>%
    merge(cpi_xts, join="right") %>%
    zoo::na.locf() %>%
    as.data.frame() %>%
    setNames(c("Diesel","CPI")) %>%
    mutate(Date = row.names(.)) %>%
    mutate_at(
        vars(Diesel),
        funs(. / (CPI / 100)))

## Then extrapolate backwards and forwards in time,
## using last observation carried backwards,
## forwards
daily_ts_1960_2015 = seq.POSIXt(
    as.POSIXct("01-01-1960", format="%d-%m-%Y"),
    as.POSIXct("31-12-2015", format="%d-%m-%Y"),
    by="day")

diesel_price %<>%
    select(Date, Diesel) %>%
    zoo::read.zoo(format="%Y-%m-%d") %>%
    xts::as.xts() %>%
    merge(xts::as.xts(daily_ts_1960_2015), join="right") %>%
    zoo::na.locf(rule=2) %>%
    zoo::na.locf(fromLast=TRUE) %>%
    as.data.frame() %>%
    setNames(c("DIESEL_PRICE")) %>%
    mutate(DATE = row.names(.)) %>%
    select(DATE, DIESEL_PRICE)

