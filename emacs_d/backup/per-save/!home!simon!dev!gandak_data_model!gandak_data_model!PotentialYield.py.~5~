class PotentialYield(object):
    def __init__(self, PotentialYield_variable):
        self.var = PotentialYield_variable
        # self.var.CropTypes
        # self.var.nCrop
        # self.var.CropParametersInputDir = self.var._configuration.cropAreaOptions['cropAreaInputDir']
        self.var.PotentialYieldOutputFile = vos.getFullPath(
            self.var._configuration.potentialYieldOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)
        
    def initial(self):
        pass

    def dynamic(self):
        potential_yield_maps = []
        for crop in self.var.CropTypes:
            gaez_crop = lookup_crop_id(crop, 'GAEZ')
            fn = get_data_smart(
                'gandak_data_model',
                '../data' + '/' + 'potential_yield_' + gaez_crop.lower() + '_mixed_input.tif',
                as_string = False)
            arr = read_gdal_raster_image(fn, bbox, 0)
            potential_yield_maps.append(arr)

        potential_yield = np.stack(potential_yield_maps, axis=0)
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(self.var.PotentialYieldOutputFile, 'Yx')        
        netcdf.data2NetCDF(self.var.PotentialYieldOutputFile, 'Yx', potential_yield)


