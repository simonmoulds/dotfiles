r1 = read.table(file.path(mat_dir, "Output", "Sample_CropGrowth.txt"), header=TRUE, sep="\t") %>% dplyr::select(-X)
r2 = read.table(file.path(mat_dir, "Output", "Sample_WaterContents.txt"), header=TRUE, sep="\t") %>% dplyr::select(-X, -Year, -Month, -Day, -SimDay, -Season)
## r3 = read.table(file.path(mat_dir, "Output", "Sample_FinalOutput.txt"), header=TRUE, sep="\t") %>% dplyr::select(-X)
r4 = read.table(file.path(mat_dir, "Output", "Sample_WaterFluxes.txt"), header=TRUE, sep="\t") %>% dplyr::select(-X, -Year, -Month, -Day, -SimDay, -Season)

ts = paste(r1$Year, r1$Month, r1$Day, sep="-") %>% as.POSIXct("%Y-%m-%d")

md = cbind(data.frame(Date=ts), r1, r2, r4) %>% dplyr::select(-Year, -Month, -Day) %>% `[`(1:548,)

## read output of AquaCrop_Py
py_dir = "/home/simon/projects/AquaCrop/AquaCrop_Py"

library(ncdf4)

fs = list.files(file.path(py_dir, "Output", "netcdf"), pattern="^.*\\.nc$", full.names=TRUE)

data = vector(mode="list", length=length(fs))
nms = rep(NA, length(fs))
for (i in 1:length(fs)) {
    nc = nc_open(fs[i])
    nm = attributes(nc$var)$names[1]
    var = ncvar_get(nc, nm)
    if (nm == "water_content") {
        var = t(var[1,1,,]) %>% as.data.frame
        names(var) = paste0(c("X0.05m","X0.15m","X0.25m","X0.375m","X0.525m","X0.7m","X0.9m","X1.125m","X1.375m","X1.625m","X1.875m","X2.15m"))
    } else {
        var = data.frame(var[1,1,]) %>% setNames(nm)
    }
    data[[i]] = var
    nc_close(nc)
}
pd = do.call(cbind, data)

