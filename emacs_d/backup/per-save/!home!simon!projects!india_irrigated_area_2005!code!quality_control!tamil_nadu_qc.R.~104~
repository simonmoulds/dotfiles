## chickpea
## ########

if (dist_nm %in% c("Ariyalur","Chennai","Cuddalore","Sivaganga","Theni","Tiruvannamalai","Vellore","Villupuram")) {
    xx[["apy_chickpea-rabi"]] = xx[["mapspam_atot_chickpea"]][6]
    xx[["irr_chickpea-rabi"]] = xx[["mapspam_xirr_chickpea"]][6]
}

if (dist_nm %in% c("Coimbatore","Dharmapuri","Dindigul","Namakkal","Perambalur","Salem","Thoothukudi","Tiruchchirappalli","Virudhunagar")) {
    xx[["apy_chickpea-rabi"]] %<>% linear_interp(2)
    xx[["irr_chickpea-rabi"]] %<>% irr_frac_interp(xx[["apy_chickpea-rabi"]], 2, c(1,3))
    xx[["apy_chickpea-rabi"]] %<>% locf_interp(7:10, fromLast=TRUE)
}

if (dist_nm %in% c("Erode")) {
    xx[["apy_chickpea-rabi"]] %<>% linear_interp(2)
    xx[["irr_chickpea-rabi"]] %<>% irr_frac_interp(xx[["apy_chickpea-rabi"]], 2, c(1,3))
    xx[["apy_chickpea-rabi"]] %<>% locf_interp(7:11)
}

if (dist_nm %in% c("Madurai")) {
    xx[["apy_chickpea-rabi"]] %<>% locf_interp(1:2, fromLast=TRUE)
    xx[["apy_chickpea-rabi"]] %<>% locf_interp(7:10, fromLast=TRUE)
}

