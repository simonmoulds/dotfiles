library(magrittr)
library(lubridate)
library(dplyr)

datadir = "../data/pt_met_data/"

options(stringsAsFactors = FALSE)
x = read.csv(
    file.path(
        datadir,
        "tahmo_era5_stn_TA00339_met_2016-2019.csv"
    )
)
x$DATE %<>% as.POSIXct(format="%Y-%m-%d")
x$YEAR = year(x$DATE)
x$MONTH = month(x$DATE)
x$DATE %<>% as.POSIXct

x_mon = x %>% group_by(YEAR, MONTH) %>% summarize(P_TAHMO_AVG=sum(P_TAHMO))
x_mon$DAY = 1
x_mon %<>% unite(DATE, YEAR, MONTH, DAY, sep="-")
x_mon$DATE %<>% as.POSIXct(x_mon$DATE, format="%Y-%m-%d")

x %<>% left_join(x_mon)

library(ggplot2)
p = ggplot(x, aes(x=DATE, y=P_TAHMO_AVG)) +
    geom_point() + 
    geom_bar(data=x_mon, aesstat="identity", width=NULL) ## +
    ## geom_point(aes(x=DATE, y=P_TAHMO))
p

ggsave(
    file.path("~/Dropbox/agu2019/test.png"),
    p,
    device="png",
    width=4.5, height=4, units="in"
)
