class AOS_PreIrrigation(object):

    def __init__(self, iniItems):
        pass
    
    def AOS_PreIrrigation(self):
        """Function to calculate pre-irrigation when in net irrigation 
        mode.

        Updates the water content of each compartment (th) and the 
        pre-irrigation requirement (PreIrr).
        """
        # Expand soil properties to compartments
        th_wp = self.soil.th_wp[self.soil.layerIndex,:]
        th_fc = self.soil.th_fc[self.soil.layerIndex,:]

        # Expand dz and dzsum to rotations, lat, lon 
        dz = self.soil.dz[:,None,None,None] * np.ones((m,n,p))[None,:,:,:]
        dzsum = self.soil.dzsum[:,None,None,None] * np.ones((m,n,p))[None,:,:,:]

        # Get index of crops currently grown
        m,n,p = self.nRotation, self.nLat, self.nLon
        I,J,K = np.ogrid[:m,:n,:p]
        crop_index = (
            np.arange(0, self.GrowingSeason.shape[0])[:,None,None,None]
            * np.ones((m,n,p))[None,:,:,:]) 
        crop_index *= self.GrowingSeason
        crop_index = np.max(crop_index, axis=0)
        growing_season_index = np.any(self.GrowingSeason, axis=0)
        
        # Add rotation dimension to Zmin, then select crops currently grown
        Zmin = (self.crop.Zmin[:,None,:,:] * np.ones((m))[None,:,None,None])
        Zmin = Zmin[crop_index,I,J,K]
        Zmin[np.logical_not(growing_season_index)] = 0

        # Select net irrigation threshold for crops currently grown
        NetIrrSMT = self.NetIrrSMT[crop_index,I,J,K]

        # Calculate pre-irrigation requirement
        rootdepth = np.maximum(Zmin, self.Zroot)
        rootdepth = np.round(rootdepth * 100) / 100
        thCrit = (th_wp + ((NetIrrSMT / 100) * (th_fc - th_wp)))

        # Conditions for applying pre-irrigation
        cond1 = ((self.IrrMethod == 4)
                 & (self.DAP == 1)
                 & ((dzsum - dz) < rootdepth)
                 & (th < thCrit))

        # Update pre-irrigation and root zone water content
        preIrr_req = ((thCrit - self.th) * 1000 * dz)
        preIrr_req[np.logical_not(cond1)] = 0
        self.preIrr = np.sum(preIrr_req, axis=0)
        self.th[cond5] = thCrit[cond1]
