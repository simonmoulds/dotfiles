## Quality control for Goa

## Crops not grown: ...

## chickpea
## ########

xx[["apy_chickpea-rabi"]] = xx[["mapspam_atot_chickpea"]][6]
xx[["irr_chickpea-rabi"]] = xx[["mapspam_xirr_chickpea"]][6]

## coconut
## #######

xx[["apy_coconut-whole_year"]] = xx[["mapspam_atot_coconut"]][6]
xx[["irr_coconut-whole_year"]] = xx[["mapspam_xirr_coconut"]][6]

## groundnut
## #########

xx[["apy_groundnut-kharif"]][9:11] = xx[["apy_groundnut-rabi"]][9:11]
xx[["irr_groundnut-kharif"]][9:11] = xx[["irr_groundnut-rabi"]][9:11]

xx[["irr_groundnut-kharif"]][9] %<>% irr_frac_interp(xx[["apy_groundnut-kharif"]], 9:11, 8)

xx[["apy_groundnut-kharif"]] %<>% locf_interp(1:4, fromLast=TRUE)
xx[["irr_groundnut-kharif"]] %<>% locf_interp(1:4, fromLast=TRUE)

## other oil crops
## ###############

xx[["apy_other_oil_crops-kharif"]] = xx[["mapspam_atot_other_oil_crops"]][6]
xx[["irr_other_oil_crops-kharif"]] = xx[["mapspam_xirr_other_oil_crops"]][6]

## other pulses
## ############

xx[["irr_other_pulses-rabi"]] %<>% locf_interp(6:7)
xx[["apy_other_pulses-rabi"]] %<>% xx[["irr_other_pulses-rabi"]]

## rapeseed
## ########

xx[["irr_rapeseed-rabi"]] %<>% locf_interp(6:7)
xx[["apy_rapeseed-rabi"]] %<>% xx[["irr_rapeseed-rabi"]]

## rest of crops
## #############

xx[["irr_rest_of_crops-whole_year"]] = xx[["irr_rest_of_crops-summer"]]
xx[["irr_rest_of_crops-summer"]] = 0

xx[["apy_rest_of_crops-whole_year"]] %<>% locf_interp(1:4, fromLast=TRUE)
xx[["apy_rest_of_crops-whole_year"]] %<>% locf_interp(9:11)
xx[["irr_rest_of_crops-whole_year"]] %<>% locf_interp(1:4, fromLast=TRUE)
xx[["irr_rest_of_crops-whole_year"]] %<>% locf_interp(9:11)

## rice
## ####

xx[["apy_rice-summer"]] = 0
xx[["irr_rice-summer"]] = 0

xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 1:4, 5)

## sesameseed
## ##########

xx[["apy_sesameseed-kharif"]] = xx[["mapspam_atot_sesameseed"]][6]
xx[["irr_sesameseed-kharif"]] = xx[["mapspam_xirr_sesameseed"]][6]

