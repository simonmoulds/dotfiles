#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import numpy as np
import pcraster as pcr
from hydro_model_builder.Model import Model
from hydro_model_builder import VirtualOS as vos

from FAO66_behaviour import FAO66_behaviour

import logging
logger = logging.getLogger(__name__)

class LandSurface(Model):    
    def __init__(self, configuration, modelTime, initialState = None):
        super(LandSurface, self).__init__(
            configuration,
            modelTime,
            initialState)
        self.crop_module = FAO66_behaviour(self)
        # TODO: modularise this a bit, e.g.
        # * module to read forcing data
        # * module to represent soil column
        # * ...
        
    def initial(self):
        self.crop_module.initial()
        self.get_model_dimensions()
        
    def get_model_dimensions(self):
        # TODO: remove dependency on PCRaster
        latitudes = np.unique(pcr.pcr2numpy(pcr.ycoordinate(self.cloneMap), vos.MV))[::-1]
        longitudes = np.unique(pcr.pcr2numpy(pcr.xcoordinate(self.cloneMap), vos.MV))
        self.dimensions = {
            'lat'      : latitudes,
            'lon'      : longitudes,
            'time'     : None,
            'depth'    : np.arange(self.nComp),
            'crop'     : np.arange(self.nCrop),
            'farm'     : np.arange(self.nFarm),
            'category' : np.arange(self.nFarmSizeCategory)
        }
        
    def dynamic(self):
        self.crop_module.dynamic()
