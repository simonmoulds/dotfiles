get_maps = function(x, rgn, ...) {
    ntime = dim(x)[3]
    maps = list()
    for (i in 1:ntime) {
        xx = raster(rgn)
        xx[] = aperm(x[,,i], 2:1)
        maps[[i]] = xx
    }    
    maps = stack(maps)
    return(maps)
}

