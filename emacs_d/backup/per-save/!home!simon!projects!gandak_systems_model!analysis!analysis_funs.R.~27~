get_nc_var = function(fn) {
    nc = nc_open(fn)
    nm = attributes(nc$var)$names[1]
    var = ncvar_get(nc, nm)
    nc_close(nc)
    var
}

get_nc_var_dims = function(fn, var) {
    nc = nc_open(fn)
    ## nm = attributes(nc$var)$names[1]
    ## var = ncvar_get(nc, nm)
    dims = sapply(nc$var[[var]]$dim, FUN=function(x) x$name)
    nc_close(nc)
    dims
}

get_maps_by_crop = function(x, crop_idx, ...) {
    ntime = dim(x)[5]
    nfarm = dim(x)[4]
    maps = list()
    for (i in 2:ntime) {
        xx = raster(model_region)
        xx[] = 0
        for (j in 1:nfarm) {
            yy = raster(model_region)      
            yy[] = aperm(x[,,crop_idx,j,i], 2:1)
            xx = xx + yy
        }
        ix = length(maps) + 1
        maps[[ix]] = xx
    }
    maps = stack(maps)
    return(maps)
}

get_maps_aggr_crop = function(x, ...) {
    ntime = dim(x)[5]
    nfarm = dim(x)[4]
    ncrop = dim(x)[3]
    maps = list()
    for (i in 2:ntime) {
        xx = raster(model_region)
        xx[] = 0
        for (j in 1:nfarm) {
            for (k in 1:ncrop) {
                yy = raster(model_region)      
                yy[] = aperm(x[,,k,j,i], 2:1)
                xx = xx + yy
            }
        }
        ix = length(maps) + 1
        maps[[ix]] = xx
    }
    maps = stack(maps)
    return(maps)
}

get_maps_aggr_farm = function(x, rgn, ...) {
    ntime = dim(x)[4]
