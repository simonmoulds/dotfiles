aggr_maps = function(maps, fun=sum, ...) {
    ts = cellStats(maps, stat=fun)
    return(ts)
}

aggr_production_plot_fun = function(maps, fun=sum, years, ...) {
    df = data.frame(
        production=cellStats(maps, stat=fun),
        year=years)
    p = ggplot(data=df, aes(x=year, y=production)) +
        geom_line() +
        geom_point() +
        ## scale_x_continuous(breaks=seq(1970, 1980, by=2)) +
        labs(x="Year", y=expression("Production"~(tonne))) +
        theme(axis.text=element_text(size=12, colour="black"),
              axis.title=element_text(size=12))
    return(p)
}
