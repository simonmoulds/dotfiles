kenya_rgn=raster("../data/kenya_aquacrop_landmask_0pt25degree.tif")

get_mapspam_phys_area = function(path, crop, region) {
    fs = list.files(path, pattern=paste0("SPAM2005V3r2_global_[A-Z]{1}_[A-Z]{2}_", crop, "_[A-Z]{1}.tif$"), full.names=TRUE)
    crop_area = raster(fs[5]) %>% crop(extent(region)) %>% raster::aggregate(fact=3, fun=sum)
    crop_area
}

data(countriesCoarse)
ghana_poly = countriesCoarse[countriesCoarse$NAME %in% "Ghana",]
ghana_rast = rasterize(ghana_poly, ghana_rgn)

ghana_maize = get_mapspam_phys_area(
    "../data/mapspam/geotiff_global_phys_area",
    "MAIZ",
    ghana_rast) %>%
    `*`(ghana_rast) 
ghana_maize[!is.na(ghana_maize)] = TRUE
ghana_sorghum = get_mapspam_phys_area(
    "../data/mapspam/geotiff_global_phys_area",
    "SORG",
    ghana_rast) %>%
    `*`(ghana_rast)
ghana_sorghum[!is.na(ghana_sorghum)] = TRUE

kenya_maize = get_mapspam_phys_area(
    "../data/mapspam/geotiff_global_phys_area",
    "MAIZ",
    kenya_rast) %>%
    `*`(kenya_rast) 
kenya_maize[!is.na(kenya_maize)] = TRUE
kenya_sorghum = get_mapspam_phys_area(
    "../data/mapspam/geotiff_global_phys_area",
    "SORG",
    kenya_rast) %>%
    `*`(kenya_rast)
kenya_sorghum[!is.na(kenya_sorghum)] = TRUE
kenya_wheat = get_mapspam_phys_area(
    "../data/mapspam/geotiff_global_phys_area",
    "SORG",
    kenya_rast) %>%
    `*`(kenya_rast)
kenya_wheat[!is.na(kenya_wheat)] = TRUE

