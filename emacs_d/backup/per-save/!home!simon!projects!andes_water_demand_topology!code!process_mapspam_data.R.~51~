## script to estimate total irrigated area for Andes region @ 5 arcminute
## resolution, based on MapSPAM product

library(raster)
library(magrittr)

## extract MapSPAM data
## ####################

if (!dir.exists("data/MapSPAM")) {
    dir.create("data/MapSPAM")
}

system("unzip -o data-raw/dataverse_files.zip -d data/MapSPAM")
system("unzip -o data/spam2005v3r2_global_phys_area.geotiff.zip -d data")
system("unzip -o data/spam2005v3r2_global_harv_area.geotiff.zip -d data")

## define bounding box for study region
## ####################################

andes_rgn = raster(xmn=-85, xmx=-55, ymn=-30, ymx=15, resolution=1/12, crs="+proj=longlat +datum=WGS84")
andes_ext = extent(andes_rgn)

## load files
## ##########

fs = list.files("data/geotiff_global_harv_area", pattern="^SPAM2005V3r2_global_H_TI_[A-Z]{4}_I.tif$", full.names=TRUE) %>% sort

harv_irri = vector(mode="list", length=length(fs))
for (i in 1:length(fs)) {
    r = raster(fs[i]) %>% crop(andes_ext)
    harv_irri[[i]] = r
}

## get total irrigated area by adding the maps
## ###########################################

total_irrigated_area = stackApply(stack(harv_irri), indices=rep(1, length(harv_irri)), fun=sum)

## write output
## ############

writeRaster(total_irrigated_area, filename="data/andes_irrigated_area_2005_mapspam.tif", format="GTiff", overwrite=TRUE)

