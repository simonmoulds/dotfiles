# ==================
# intercept capacity
# ==================

lc_types = ['forest','grassland']
intercept_fs = ['interceptCapForest10days.nc','interceptCapGrassland10days.nc']

for index,lc in enumerate(lc_types):
    fs = intercept_fs[index]
    ic = netCDF4.Dataset('data/cwatm_input/landcover/' + lc + '/' + fs)
    lat = ic.variables['lat'][:][::-1]
    lon = ic.variables['lon'][:]
    times = ic.variables['time']
    t_units = times.units
    t_cal = times.calendar
    t_vals = times[:]
    ic_data = ic.variables['interceptcap'][:]
    ic_data = np.flip(ic_data, axis=1)
    ic.close()

    nlon = lon.size
    nlat = lat.size

    d = netCDF4.Dataset(outd + '/' + lc + '_interceptCap10days.nc','w')
    d.createDimension('lon',nlon)
    d.createDimension('lat',nlat)
    d.createDimension('time',None)

    lono = d.createVariable('lon',np.float32,('lon'),zlib=True,least_significant_digit=16)
    lono.units = 'degrees_east'
    lono.standard_name = 'longitude'
    lono.long_name = 'longitude'
    lono[:]=lon

    lato = d.createVariable('lat',np.float32,('lat'),zlib=True,least_significant_digit=16)
    lato.units = 'degrees_north'
    lato.standard_name = 'latitude'
    lato.long_name = 'longitude'
    lato[:]=lat

    time = d.createVariable('time',np.int32,('time'),zlib=True)
    time.units = t_units
    time.calendar = t_cal
    time.standard_name = 'time'
    time.long_name = t_units
    time[:]=times[:]

    # create container variable for CRS: lon/lat
    # WGS84 datum
    crso = d.createVariable('crs','i4')
    crso.long_name = 'Lon/Lat Coords in WGS84'
    crso.grid_mapping_name='latitude_longitude'
    crso.longitude_of_prime_meridian = 0.0
    crso.semi_major_axis = 6378137.0
    crso.inverse_flattening = 298.257223563

    intc = d.createVariable('interceptcap',np.float32,('time','lat','lon'),zlib=True,least_significant_digit=16,fill_value=fill_value)
    intc.units = '1'
    intc.standard_name = 'intercept'
    intc.long_name = 'interception capacity'
    intc[:] = ic_data

    d.Conventions='CF-1.6'
    d.close()

