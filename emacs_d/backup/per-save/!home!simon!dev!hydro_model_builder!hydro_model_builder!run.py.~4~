#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import sys

from pcraster2.dynamicFramework import DynamicFramework

from DeterministicRunner import DeterministicRunner
from ModelTime import ModelTime

from RefETConfiguration import RefETConfiguration
from PenmanMonteith import PenmanMonteith
from Hargreaves import Hargreaves
from PriestleyTaylor import PriestleyTaylor

import disclaimer
import variable_list

import logging
logger = logging.getLogger(__name__)

def run(method, configuration, currTimeStep, variable_list, initial_state, run_id):
    deterministic_runner = DeterministicRunner(
        method,
        configuration,
        currTimeStep,
        variable_list,
        initial_state,
        run_id
    )
    dynamic_framework = DynamicFramework(deterministic_runner, currTimeStep.nrOfTimeSteps)
    dynamic_framework.setQuiet(True)
    dynamic_framework.run()

# TODO: can this be a class, rather than a function?
def main():

    disclaimer.print_disclaimer()
    iniFileName = os.path.abspath(sys.argv[1])
    debug_mode = False
    if len(sys.argv) > 2:
        if sys.argv[2] == 'debug':
            debug_mode = True

    configuration = RefETConfiguration(
        iniFileName=iniFileName,
        debug_mode=debug_mode)
    
    currTimeStep = ModelTime()
    initial_state = None
    currTimeStep.getStartEndTimeSteps(
        configuration.globalOptions['startTime'],
        configuration.globalOptions['endTime'])
    logger.info('Transient simulation run has started')

    etref_method = configuration.RefETMethodSelection
    if 'PenmanMonteith' in etref_method:
        run(PenmanMonteith, configuration, currTimeStep, variable_list, initial_state, 'PenmanMonteith')
    if 'Hargreaves' in etref_method:
        run(Hargreaves, configuration, currTimeStep, variable_list, initial_state, 'Hargreaves')
    if 'PriestleyTaylor' in etref_method:
        run(PriestleyTaylor, configuration, currTimeStep, variable_list, initial_state, 'PriestleyTaylor')
    vos.clear_cache()
    
if __name__ == '__main__':
    disclaimer.print_disclaimer(with_logger=True)
    sys.exit(main())
