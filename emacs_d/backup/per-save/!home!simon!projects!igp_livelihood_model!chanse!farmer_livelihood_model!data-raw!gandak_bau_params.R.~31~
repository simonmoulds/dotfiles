## Parameter file for Sultanpur district

## farm characteristics
## ####################

## farm area (m2)
farm_area = 10000

## surface elevation (m)
surface_elev_masl = 79

## harvest day
harvest_day = 305

## irrigation efficiency
irrigation_eff = 0.4

## Pump efficiency multiplier:
## 100 = 1.00; 90  = 1.11; 80  = 1.25
## 70  = 1.43; 50  = 2.00; 30  = 3.33
fuel_eff = 2.00

## initial category probability
cat_prob = c(0.9,0.1,0.0)

## well depths associated with categories 1-3
well_depth1_masl = surface_elev_masl - 31.5
well_depth2_masl = surface_elev_masl - 31.5
well_depth3_masl = surface_elev_masl - 31.5

## initial savings upper and lower bounds
saving_lower = 50
saving_upper = 500

## Amount savings are reduced per year when farmers income
## is zero
savings_reduction = 0.8

## Percentage of income retained as savings
saving_percentage = 0.1

## hydrological parameters
## #######################

## aquifer specific yield
Sy = 0.10

## aquifer conductivity
k = 0.0864

## Drainage point elevation
z = 70

## Distance from modeled area to drainage point (m)
L = 11500

## Width of model area
w = sqrt(farm_area)

## Depth of Aquifer 
b = surface_elev_masl - 30

## Conductance for use in aquifer discharge calculation 
cond = (k*w*b)/L

## initial head
H_init_masl = surface_elev_masl - 2 ## 3.5

## root zone parameters
field_capacity = 0.3
wilting_point = 0.12 
root_zone_depletion_init = 0

## coefficients to control runoff, bare soil evaporation,
## and return flow
runoff_coef =  0.95          ## **calibration**
evaporation_loss_coef = 0.75 ## 0.591## **calibration**
return_flow_coef = 0.4       ## **checked**

## canal volume and leakage coefficient
canal_volume = 1 * 1 * 100
canal_leakage_coef = 0.6
## canal_prob = 0.3
canal_prob_upper = 0.2
canal_prob_lower = 0.1
