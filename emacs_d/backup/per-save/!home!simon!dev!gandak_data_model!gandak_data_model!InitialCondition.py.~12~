class InitialCondition(object):
    def __init__(self, InitialCondition_variable):
        self.var = InitialCondition_variable
        self.var.InitialConditionOutputFile = vos.getFullPath(
            self.var._configuration.initialConditionOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)

    def initial(self):
        pass

    def dynamic(self):
        th0_data_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcpf2_topsoil_gapfilled_5m.tif',
            as_string=False)

        th1_data_filename = get_data_smart(
            'gandak_data_model',
            '../data/wcpf2_subsoil_gapfilled_5m.tif',
            as_string=False)

        th = []
        for fn in [th0_data_filename, th1_data_filename]:
            arr = read_gdal_raster_image(fn, self.bbox, 0)
            th.append(arr)
        th = np.stack(th, axis=0)        
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(self.var.InitialConditionOutputFile, 'th')
        netcdf.data2NetCDF(self.var.InitialConditionOutputFile, 'th', th)








        
