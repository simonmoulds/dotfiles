class Tubewells(object):
    def __init__(self, land_cover, configuration):
        self.land_cover = land_cover
        self.configuration = configuration
        
    def initial(self):
        self.initial_tubewell_capacity()
        self.land_cover.TubewellOperatingHours = (
            np.full((self.land_cover.model.nCell), 12)
        ) # Hours
        self.land_cover.TubewellMaintenanceCost = (
            np.full((self.land_cover.model.nCell), 10000)
        ) # Rs
        self.land_cover.TubewellInstallationCost = (
            np.full((self.land_cover.model.nCell), 10000)
        ) # Rs
        self.land_cover.PumpCost = (
            np.full((self.land_cover.model.nCell), 10000)
        ) # Rs
        self.land_cover.PumpLifespan = (
            np.full((self.land_cover.model.nCell), 20)
        ) # years
        self.land_cover.PumpHorsePower = (
            np.full((self.land_cover.model.nCell), 7.5)
        ) # HP
        self.land_cover.TubewellLifespan = (
            np.full((self.land_cover.model.nCell), 20)
        ) # years
        self.land_cover.TubewellAge = (
            np.zeros((self.land_cover.nFarmSizeCategory, self.land_cover.nCell))
        ) # counter

    def reset_initial_conditions(self):
        pass
    
    def maximum_operating_hours(self):
        pass
    
    def maintenance_cost(self):
        pass

    def installation_cost(self):
        pass

    def pump_cost(self):
        pass

    def pump_horsepower(self):
        pass
        
    def initial_tubewell_capacity(self):
        initialTubewellCapacityNC = str(
            self.configuration['initialTubewellOwnershipInputFile'])
        tubewell_capacity_varname = str(
            self.configuration['initialTubewellOwnershipVariableName'])
        tubewell_ownership_factor = float(
            self.configuration['initialTubewellOwnershipScaleFactor'])
        tubewell_ownership_rate = file_handling.netcdf_to_arrayWithoutTime(
            initialTubewellCapacityNC,
            tubewell_capacity_varname,
            cloneMapFileName = self.land_cover.model.cloneMapFileName,
            LatitudeLongitude = True)
        mask = np.broadcast_to(self.land_cover.model.landmask, tubewell_ownership_rate.shape)
        tubewell_ownership_rate = np.reshape(
            tubewell_ownership_rate[mask],
            (self.land_cover.nFarmSizeCategory, self.land_cover.model.nCell)
        )
        tubewell_ownership_rate = np.float64(tubewell_ownership_rate)
        self.land_cover.tubewell_ownership_rate = tubewell_ownership_rate.copy()
        self.land_cover.tubewell_ownership_rate *= tubewell_ownership_factor
        
    def dynamic(self):
        pass

class CanalAccess(object):

    def __init__(self, land_cover, configuration):
        self.land_cover = land_cover
        self.configuration = configuration
        
    def initial(self):
        initialCanalAccessNC = str(self.configuration['initialCanalAccessInputFile'])
        canal_access_varname = str(self.configuration['initialCanalAccessVariableName'])
        try:
            canal_access = file_handling.netcdf_to_arrayWithoutTime(
                initialCanalAccessNC,
                canal_access_varname,
                cloneMapFileName = self.land_cover.model.cloneMapFileName,
                LatitudeLongitude = True)
        except:
            canal_access = np.ones(
                (self.land_cover.nFarmSizeCategory,
                 self.land_cover.model.nLat,
                 self.land_cover.model.nLon)
            )

        mask = np.broadcast_to(self.land_cover.model.landmask, canal_access.shape)
        canal_access = np.reshape(
            canal_access[mask],
            (self.land_cover.nFarmSizeCategory, self.land_cover.model.nCell))
        canal_access = np.float64(canal_access)
        self.land_cover.CanalAccess = canal_access.copy()

    def dynamic(self):
        pass

class DieselPrice(object):
    def __init__(self, land_cover, configuration):
        self.land_cover = land_cover
        self.configuration = configuration
        self.DieselPriceFileNC = (
            str(self.configuration['dieselPriceInputFile'])
        )
        self.DieselPriceVarName = (
            str(self.configuration['dieselPriceVariableName'])
        )

    def initial(self):
        self.land_cover.DieselPrice = np.zeros((self.land_cover.model.nCell))

    def reset_initial_conditions(self):
        pass
    
    def set_diesel_price(self):
        start_of_model_run = (self.land_cover.model._modelTime.timeStepPCR == 1)
        start_of_year = (self.land_cover.model._modelTime.doy == 1)
        if not self.DieselPriceFileNC == "None":
            if start_of_model_run or start_of_year:
                date = datetime.datetime(self.land_cover.model._modelTime.year, 1, 1, 0, 0, 0)
                diesel_price = file_handling.netcdf_to_array(
                    self.DieselPriceFileNC,
                    self.DieselPriceVarName,
                    date,
                    useDoy = None,
                    cloneMapFileName = self.land_cover.model.cloneMapFileName,
                    LatitudeLongitude = True)
                diesel_price = diesel_price[self.land_cover.model.landmask]
                self.land_cover.DieselPrice = diesel_price

    def dynamic(self):
        self.set_diesel_price()

