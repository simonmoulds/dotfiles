class FarmParameters(object):
    def __init__(self, land_cover, configuration):
        self.land_cover = land_cover
        self.configuration = configuration

        # this variable indicates the maximum number of tubewells in
        # each farm category (E.g. in the first category, which
        # represents farms with an area of 2 Ha (?), a farmer will
        # never need more than 2 tubewells to irrigate their land. On
        # the other hand, farms with an area of 10 Ha will need more
        # tubewells to irrigate their land.)
        self.land_cover.max_num_tubewells = np.array([2,2,3,3,5], dtype=np.int64)
        farm_index = []
        farm_category = []
        for index,value in enumerate(self.land_cover.max_num_tubewells):
            # n is the maximum number of tubewells plus one to represent
            # rainfed, multiplied by two in order to account for farms with
            # and without canal access.
            n = (value + 1) * 2
            farm_index += [index for i in range(n)]
            farm_category += [(index + 1) for i in range(n)]
            
        self.land_cover.farm_index = np.array(farm_index, dtype=np.int64)
        self.land_cover.farm_category = (
            np.array(farm_category, dtype=np.int64)[:,None]
            * np.ones((self.land_cover.model.nCell))[None,:]
        )            
        self.land_cover.nFarm = len(self.land_cover.farm_category)
        self.land_cover.nFarmSizeCategory = int(self.configuration['nFarmSizeCategory'])
        
        self.land_cover.start_of_agricultural_year = int(self.configuration['startOfAgriculturalYear'])        
        self.FarmAreaFileNC = (
            str(self.configuration['farmAreaInputFile']))
        self.FarmAreaVarName = (
            str(self.configuration['farmAreaVariableName']))
        # self.FarmCategoryFileNC = (
        #     str(self.configuration['farmCategoryInputFile']))
        # self.FarmCategoryVarName = (
        #     str(self.configuration['farmCategoryVariableName']))
        self.FarmCategoryAreaFileNC = (
            str(self.configuration['farmCategoryAreaInputFile']))
        self.FarmCategoryAreaVarName = (
            str(self.configuration['farmCategoryAreaVariableName']))
        self.AnnualChangeInFarmArea = (
            bool(int(self.configuration['annualChangeInFarmArea'])))
        # self.AnnualChangeInFarmCategory = (
        #     bool(int(self.configuration['annualChangeInFarmCategory'])))
        self.AnnualChangeInFarmCategoryArea = (
            bool(int(self.configuration['annualChangeInFarmCategoryArea'])))

        self.tubewell_module = Tubewells(land_cover, configuration)
        self.canal_access_module = CanalAccess(land_cover, configuration)
        self.diesel_price_module = DieselPrice(land_cover, configuration)
        
    def initial(self):
        self.set_farm_area()
        self.set_farm_category_area()
        self.set_number_of_farms_per_category()
        self.diesel_price_module.initial()  # TODO: put this somewhere else...?
        self.tubewell_module.initial()  # TODO: put this in InitialCondition
        self.canal_access_module.initial()  # TODO: put this in InitialCondition
        self.initial_irrigated_rainfed_area()  # TODO: put this in InitialCondition
        self.update_farm_subcategory_area()
        self.update_farm_subcategory_proportion()
        self.update_farm_subcategory_area_equipped_for_irrigation()
        self.update_tubewell_count()
        
    def update_first_day_of_year(self):
        """Function to update variables pertaining to the 
        start of the agricultural year
        """
        # note that we do not need to copy because
        # start_of_agricultural_year is an int, which is
        # immutable in Python (unlike a numpy array)
        start_of_agricultural_year = self.land_cover.start_of_agricultural_year
        isLeapYear = calendar.isleap(self.land_cover.model._modelTime.year)
        if (isLeapYear & (self.land_cover.start_of_agricultural_year >= 60)):
            start_of_agricultural_year += 1
            
        self.land_cover.IsFirstDayOfYear = False
        self.land_cover.IsLastDayOfYear = False
        if self.land_cover.model._modelTime.doy == start_of_agricultural_year:
            self.land_cover.IsFirstDayOfYear = True
        elif ((self.land_cover.model._modelTime.doy + 1) == start_of_agricultural_year):
            self.land_cover.IsLastDayOfYear = True

    def set_farm_area(self):
        """Function to read the mean area of each farm within 
        a given farm category.
        """
        if not self.FarmAreaFileNC == "None":
            start_of_model_run = (self.land_cover.model._modelTime.timeStepPCR == 1)
            start_of_year = (self.land_cover.model._modelTime.doy == 1)
            if self.AnnualChangeInFarmArea:
                if start_of_model_run or start_of_year:
                    date = datetime.datetime(self.land_cover.model._modelTime.year, 1, 1, 0, 0, 0)
                    farm_area_new = file_handling.netcdf_to_array(
                        self.FarmAreaFileNC,
                        self.FarmAreaVarName,
                        date,
                        useDoy = None,
                        cloneMapFileName = self.land_cover.model.cloneMapFileName,
                        LatitudeLongitude = True)
                    mask = np.broadcast_to(
                        self.land_cover.model.landmask,
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nLat, self.land_cover.model.nLon))
                    farm_area_new = np.reshape(
                        farm_area_new[mask],
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nCell))
                    farm_area_new = np.float64(farm_area_new)

                if np.any(self.land_cover.GrowingSeasonDayOne[0,:,:]):
                    self.land_cover.FarmArea[self.land_cover.GrowingSeasonDayOne[0,:,:]] = (
                        farm_area_new[self.land_cover.GrowingSeasonDayOne[0,:,:]])
            else:
                if start_of_model_run:
                    farm_area = file_handling.netcdf_to_arrayWithoutTime(
                        self.FarmAreaFileNC,
                        self.FarmAreaVarName,
                        cloneMapFileName = self.land_cover.model.cloneMapFileName)
                    # mask = np.broadcast_to(
                    #     self.land_cover.model.landmask,
                    #     (self.land_cover.nFarm, self.land_cover.model.nLat, self.land_cover.model.nLon))
                    mask = np.broadcast_to(
                        self.land_cover.model.landmask,
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nLat, self.land_cover.model.nLon))
                    farm_area = np.reshape(
                        farm_area[mask],
                        (self.land_cover.nFarm, self.land_cover.model.nCell)
                    )
                    farm_area = np.float64(farm_area)
                    self.land_cover.FarmArea = farm_area.copy()
                
    def set_farm_category_area(self):
        """Function to read the total area of all farms within 
        a category. For example, if the mean farm size of 
        category one is 2 Ha and there are 100 farms belonging 
        to that category, then the farm category area is 
        2 * 100 = 200 Ha.
        """
        if not self.FarmCategoryAreaFileNC == "None":
            start_of_model_run = (self.land_cover.model._modelTime.timeStepPCR == 1)
            start_of_year = (self.land_cover.model._modelTime.doy == 1)
            if self.AnnualChangeInFarmCategoryArea:
                if start_of_model_run or start_of_year:
                    date = datetime.datetime(self.land_cover.model._modelTime.year, 1, 1, 0, 0, 0)
                    farm_cat_area_new = file_handling.netcdf_to_array(
                        self.FarmCategoryAreaFileNC,
                        self.FarmCategoryAreaVarName,
                        date,
                        useDoy = None,
                        cloneMapFileName = self.land_cover.model.cloneMapFileName,
                        LatitudeLongitude = True)
                    mask = np.broadcast_to(
                        self.land_cover.model.landmask,
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nLat, self.land_cover.model.nLon))
                    farm_cat_area_new = np.reshape(
                        farm_cat_area_new[mask],
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nCell)
                    )
                    farm_cat_area_new = np.float64(farm_cat_area_new)                    

                if np.any(self.land_cover.GrowingSeasonDayOne):
                    self.land_cover.FarmCategoryArea[self.land_cover.GrowingSeasonDayOne] = (
                        farm_cat_area_new[self.land_cover.GrowingSeasonDayOne])
                    total_farm_category_area = np.broadcast_to(
                        np.sum(self.land_cover.FarmCategoryArea, axis=0)[None,:],
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nCell)
                    )                
                    scale_factor = np.divide(
                        self.land_cover.FarmCategoryArea,
                        total_farm_category_area,
                        out=np.zeros_like(self.land_cover.FarmCategoryArea),
                        where=total_farm_category_area > 0)
                    self.land_cover.FarmCategoryArea = (
                        self.land_cover.cover_fraction
                        * self.land_cover.model.grid_cell_area
                        * scale_factor)
                    
            else:
                if start_of_model_run:
                    farm_cat_area = file_handling.netcdf_to_arrayWithoutTime(
                        self.FarmCategoryAreaFileNC,
                        self.FarmCategoryAreaVarName,
                        cloneMapFileName = self.land_cover.model.cloneMapFileName
                    )
                    mask = np.broadcast_to(
                        self.land_cover.model.landmask,
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nLat, self.land_cover.model.nLon)
                    )
                    farm_cat_area = np.reshape(
                        farm_cat_area[mask],
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nCell)
                    )
                    farm_cat_area = np.float64(farm_cat_area)
                    self.land_cover.FarmCategoryArea = farm_cat_area.copy()

                    total_farm_category_area = np.broadcast_to(
                        np.sum(self.land_cover.FarmCategoryArea, axis=0)[None,:],
                        (self.land_cover.nFarmSizeCategory, self.land_cover.model.nCell)
                    )                
                    scale_factor = np.divide(
                        self.land_cover.FarmCategoryArea,
                        total_farm_category_area,
                        out=np.zeros_like(self.land_cover.FarmCategoryArea),
                        where=total_farm_category_area > 0)
                    self.land_cover.FarmCategoryArea = (
                        self.land_cover.cover_fraction
                        * self.land_cover.model.grid_cell_area
                        * scale_factor)
            
    def set_number_of_farms_per_category(self):
        self.land_cover.nFarmPerCategory = np.divide(
            self.land_cover.FarmCategoryArea,
            self.land_cover.FarmArea,
            out=np.zeros_like(self.land_cover.FarmArea),
            where=self.land_cover.FarmArea>0
        ).round()

        # update farm area so that FarmCategoryArea is a
        # multiple of FarmArea
        self.land_cover.FarmArea = np.divide(
            self.land_cover.FarmCategoryArea,
            self.land_cover.nFarmPerCategory,
            out=np.zeros_like(self.land_cover.nFarmPerCategory),
            where=self.land_cover.nFarmPerCategory>0
        )

    def initial_irrigated_rainfed_area(self):
        """Function to set the initial areas of irrigated 
        and rainfed farms
        """
        canal_probability = self.land_cover.CanalAccess.clip(0.,1.)
        
        # now work out the probability of owning n tubewells,
        # up to the maximum number of tubewells per farm category
        num_tubewell_per_subcategory_list = []
        num_farms_per_subcategory_list = []
        for index in range(self.land_cover.nFarmSizeCategory):

            # add one to account for rainfed (i.e. no tubewell)
            num_tubewell_per_subcategory = (
                np.arange(self.land_cover.max_num_tubewells[index] + 1)[:,None]
                * np.ones((self.land_cover.model.nCell))[None,:]
            )
            
            # we assume the distribution of tubewells can be modelled
            # using the Poisson distribution with parameter lambda, 
            # which we assume to equal the ownership rate. Hence, the
            # probability of owning at least one tubewell is 1 minus
            # the probability of owning none.
            lambdas = self.land_cover.tubewell_ownership_rate[index,...][None,...]

            # lambdas = tubewell_now / farm_nos
            # calculate probabilities as before, but then use this to apportion the initial tubewell numbers
            
            prob_tubewell = (
                ((lambdas ** num_tubewell_per_subcategory) * np.exp(-lambdas))
                / scipy.special.factorial(num_tubewell_per_subcategory)
            )
            
            # divide by sum so that probabilities sum to one, then
            # repeat to account for the same category with/without
            # canal access
            sum_prob_tubewell = np.sum(prob_tubewell, axis=0)
            prob_tubewell /= sum_prob_tubewell[None,...]
            prob_tubewell = np.repeat(prob_tubewell, 2, axis=0)
            num_tubewell_per_subcategory = np.repeat(
                num_tubewell_per_subcategory,
                2,
                axis=0)
            num_tubewell_per_subcategory_list.append(
                num_tubewell_per_subcategory
            )
            # probability of canal for this category
            prob_canal = canal_probability[index,...]
            prob_not_canal = 1. - prob_canal

            # compute proportion of each farm subcategory
            # within a given category
            farm_subcategory_proportion = (
                prob_tubewell *
                np.resize(
                    np.stack(
                        [prob_not_canal, prob_canal],
                        axis=0
                    ),
                    prob_tubewell.shape
                )
            )

            # this produces similar results to the method we deploy:
            # nt = (
            #     np.divide(
            #         self.land_cover.FarmCategoryArea[index,...],
            #         self.land_cover.FarmArea[index,...],
            #         out=np.zeros_like(self.land_cover.FarmArea[index,...]),
            #         where=self.land_cover.FarmArea[index,...]>0
            #     )
            #     * self.land_cover.tubewell_ownership_rate[index,...]
            #     )
            # print np.sum(nt)
            
            # compute the area of each subcategory
            farm_subcategory_area = (
                self.land_cover.FarmCategoryArea[index,...]
                * farm_subcategory_proportion
            )

            # get the number of farms per subcategory, round to
            # integers while preserving the sum
            # (https://stackoverflow.com/a/792473)
            num_farms_per_subcategory = np.divide(
                farm_subcategory_area,
                self.land_cover.FarmArea[index,...],
                out=np.zeros_like(farm_subcategory_area),
                where=self.land_cover.FarmArea[index,...]>0
            )
            num_farms_per_subcategory_floor = np.floor(
                num_farms_per_subcategory
            )
            num_farms_per_subcategory_remainder = (
                num_farms_per_subcategory
                - num_farms_per_subcategory_floor
            )
            # order the decimal remainder (negate so that
            # order is descending), then add one so that
            # the order starts at one rather than zero,
            # which is convenient for the next step.
            remainder_order = np.argsort(
                -num_farms_per_subcategory_remainder,
                axis=0
            )
            remainder_order += 1
            num_farms_to_add = (
                self.land_cover.nFarmPerCategory[index,...]
                - np.sum(
                    num_farms_per_subcategory_floor,
                    axis=0
                )
            )
            remainder_order[remainder_order > num_farms_to_add] = 0
            num_farms_per_subcategory_floor[remainder_order > 0] += 1
            num_farms_per_subcategory_list.append(num_farms_per_subcategory_floor)

        self.land_cover.num_farms_per_subcategory = np.concatenate(
            num_farms_per_subcategory_list,
            axis=0
        )
        self.land_cover.num_tubewell_per_subcategory = np.concatenate(
            num_tubewell_per_subcategory_list,
            axis=0
        )
        self.land_cover.has_canal_access = np.broadcast_to(
            np.resize(np.array([False,True]), self.land_cover.nFarm)[:,None],
            (self.land_cover.nFarm, self.land_cover.model.nCell)
        )
        self.land_cover.has_tubewell_access = (
            self.land_cover.num_tubewell_per_subcategory > 0
        )
        self.land_cover.has_irrigation = (
            self.land_cover.has_canal_access
            | self.land_cover.has_tubewell_access
        )
        
    def update_farm_subcategory_area(self):
        self.land_cover.farm_subcategory_area = (
            self.land_cover.FarmArea[self.land_cover.farm_index,...]
            * self.land_cover.num_farms_per_subcategory
        )

    def update_farm_subcategory_proportion(self):
        self.land_cover.farm_subcategory_proportion = np.divide(
            self.land_cover.farm_subcategory_area,
            self.land_cover.FarmCategoryArea[self.land_cover.farm_index,...],
            out=np.zeros_like(self.land_cover.farm_subcategory_area),
            where=self.land_cover.FarmCategoryArea[self.land_cover.farm_index,...]>0
        )

    def update_farm_subcategory_area_equipped_for_irrigation(self):
        self.land_cover.area_with_irrigation = (
            self.land_cover.farm_subcategory_area
            * self.land_cover.has_irrigation
        )
        self.land_cover.area_without_irrigation = (
            self.land_cover.farm_subcategory_area
            * np.logical_not(self.land_cover.has_irrigation)
        )

    def update_tubewell_count(self):
        self.land_cover.tubewell_count = (
            self.land_cover.num_tubewell_per_subcategory
            * self.land_cover.num_farms_per_subcategory
        )

    def dynamic(self):
        self.update_first_day_of_year()
        self.set_farm_area()
        self.set_farm_category_area()
        self.set_number_of_farms_per_category()        
        self.diesel_price_module.dynamic()        
        self.tubewell_module.dynamic()
        self.canal_access_module.dynamic()
        self.update_farm_subcategory_area()
        self.update_farm_subcategory_proportion()
        self.update_farm_subcategory_area_equipped_for_irrigation()
        self.update_tubewell_count()
