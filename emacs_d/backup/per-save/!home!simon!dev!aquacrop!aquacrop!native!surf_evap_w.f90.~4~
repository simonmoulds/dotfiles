module soil_evaporation_w
  use iso_c_binding, only: c_double, c_int
  use soil_evaporation
  implicit none

contains
  
  subroutine surf_evap_w( &
       es_pot, &
       es_act, &
       surface_storage, &
       rew, &
       w_surf, &
       w_stage_two, &
       evap_z, &
       evap_z_min, &
       n_farm, n_crop, n_cell
    )
   
    integer(c_int), intent(in) :: n_farm, n_crop, n_cell    
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: es_pot, es_act
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: surface_storage
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: rew
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: w_surf
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: w_stage_two
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: evap_z
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: evap_z_min
    
    real(c_double), dimension(n_comp), intent(in) :: dz, dz_sum
    
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: prec, et_ref
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: infl
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: irr, wet_surf
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: rew
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: evap_z_min, evap_z_max    
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: cc, cc_adj, ccx_act
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: kex, ccxw, fwcc, f_evap, f_wrel_exp
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(in) :: f_mulch, mulch_pct_gs, mulch_pct_os
    
    integer(c_int), dimension(n_farm, n_crop, n_cell), intent(in) :: irr_method
    integer(c_int), dimension(n_farm, n_crop, n_cell), intent(in) :: dap, delayed_cds, delayed_gdds
    integer(c_int), dimension(n_farm, n_crop, n_cell), intent(in) :: mulches
    integer(c_int), dimension(n_farm, n_crop, n_cell), intent(in) :: growing_season
    integer(c_int), dimension(n_farm, n_crop, n_cell), intent(in) :: senescence, premat_senes
    
    real(c_double), dimension(n_farm, n_crop, n_comp, n_cell), intent(inout) :: th
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(inout) :: es_act, e_pot
    real(c_double), dimension(n_farm, n_crop, n_cell), intent(inout) :: surface_storage, w_surf, w_stage_two, evap_z
    
    real(c_double), dimension(n_farm, n_crop, n_cell) :: w_evap_act, w_evap_sat, w_evap_fc, w_evap_wp, w_evap_dry
    real(c_double), dimension(n_farm, n_crop, n_cell) :: w_upper, w_lower, w_rel, w_check
    real(c_double), dimension(n_farm, n_crop, n_cell) :: es_pot, es_pot_mul, es_pot_irr
    real(c_double), dimension(n_farm, n_crop, n_cell) :: to_extract, to_extract_stage_one, to_extract_stage_two
    real(c_double), dimension(n_farm, n_crop, n_cell) :: edt
    real(c_double), dimension(n_farm, n_crop, n_cell) :: kr

    integer(c_int), dimension(n_farm, n_crop, n_cell) :: t_adj
    integer(c_int) :: i, j, k

    do i = 1, n_farm
       do j = 1, n_crop
          do k = 1, n_cell
             call soil_evap( &
                  prec(i,j,k), &
                  et_ref(i,j,k), es_act(i,j,k), e_pot(i,j,k), &
                  irr(i,j,k), irr_method(i,j,k), &
                  infl(i,j,k), &
                  th(i,j,:,k), th_sat(i,j,:,k), th_fc(i,j,:,k), th_wilt(i,j,:,k), th_dry(i,j,:,k), &
                  surface_storage(i,j,k), &
                  wet_surf(i,j,k), w_surf(i,j,k), w_stage_two(i,j,k), &
                  cc(i,j,k), cc_adj(i,j,k), ccx_act(i,j,k), &
                  evap_z(i,j,k), evap_z_min(i,j,k), evap_z_max(i,j,k), &
                  rew(i,j,k), kex(i,j,k), ccxw(i,j,k), fwcc(i,j,k), f_evap(i,j,k), f_wrel_exp(i,j,k), &
                  dz, dz_sum, &
                  mulches(i,j,k), f_mulch(i,j,k), mulch_pct_gs(i,j,k), mulch_pct_os(i,j,k), &
                  growing_season(i,j,k), senescence(i,j,k), premat_senes(i,j,k), &
                  calendar_type, dap(i,j,k), delayed_cds(i,j,k), delayed_gdds(i,j,k), &
                  time_step, evap_time_steps)
          end do
       end do
    end do
    
  end subroutine soil_evap_w
  
end module soil_evaporation_w

    
