class FarmParameters(object):
    def __init__(self, FarmParameters_variable):
        self.var = FarmParameters_variable
        self.var.nFarm = int(self.var._configuration.farmOptions['nFarm'])
        self.var.nFarmSizeCategory = int(self.var._configuration.farmOptions['nFarmSizeCategory'])
        self.var.StartOfYear = 305  # TODO: check this is right, and add to configuration
        self.var.FarmAreaFileNC = str(self.var._configuration.farmOptions['farmAreaNC'])
        self.var.FarmAreaVarName = str(self.var._configuration.farmOptions['farmAreaVariableName'])
        self.var.FarmCategoryFileNC = str(self.var._configuration.farmOptions['farmCategoryNC'])
        self.var.FarmCategoryVarName = str(self.var._configuration.farmOptions['farmCategoryVariableName'])
        self.var.FarmCategoryAreaFileNC = str(self.var._configuration.farmOptions['farmCategoryAreaNC'])
        self.var.FarmCategoryAreaVarName = str(self.var._configuration.farmOptions['farmCategoryAreaVariableName'])
        self.var.AnnualChangeInFarmArea = bool(int(self.var._configuration.farmOptions['AnnualChangeInFarmArea']))
        self.var.AnnualChangeInFarmCategory = bool(int(self.var._configuration.farmOptions['AnnualChangeInFarmCategory']))
        self.var.AnnualChangeInFarmCategoryArea = bool(int(self.var._configuration.farmOptions['AnnualChangeInFarmCategoryArea']))
        
    def initial(self):
        self.var.FarmArea = np.ones((self.var.nFarm, self.var.nCell))
        self.var.FarmCategory = np.ones((self.var.nFarm, self.var.nCell))
        self.var.FarmCategoryArea = np.ones((self.var.nFarmSizeCategory, self.var.nCell))
        self.set_farm_area()

    def update_first_day_of_year(self):
        isLeapYear = calendar.isleap(self.var._modelTime.year)
        day_of_year = self.var._modelTime.doy
        start_of_year = self.var.StartOfYear
        if (isLeapYear & (start_of_year >= 60)):
            start_of_year += 1            
        self.var.IsFirstDayOfYear = False
        self.var.IsLastDayOfYear = False
        if day_of_year == start_of_year:
            self.var.IsFirstDayOfYear = True
        elif ((day_of_year + 1) == start_of_year):
            self.var.IsLastDayOfYear = True

    def set_farm_area(self):
        if not self.var.FarmAreaFileNC == "None":
            if self.var.AnnualChangeInFarmArea:
                if self.var._modelTime.timeStepPCR == 1 or self.var._modelTime.doy == 1:
                    date = '%04i-%02i-%02i' % (self.var._modelTime.year, 1, 1)
                    farm_area_new = vos.netcdf2PCRobjClone(
                        self.var.FarmAreaFileNC,
                        self.var.FarmAreaVarName,
                        date,
                        useDoy = None,
                        cloneMapFileName = self.var.cloneMap,
                        LatitudeLongitude = True)
                    mask = np.broadcast_to(
                        self.var.landmask,
                        (self.var.nFarm, self.var.nLat, self.var.nLon))
                    farm_area_new = np.reshape(
                        farm_area_new[mask],
                        (self.var.nFarm, self.var.nCell))
                    # farm_area_new = np.broadcast_to(
                    #     farm_area_new[:,None,:],
                    #     (self.var.nFarm, self.var.nCrop, self.var.nCell))

                if np.any(self.var.GrowingSeasonDayOne[0,:,:]):
                    self.var.FarmArea[self.var.GrowingSeasonDayOne[0,:,:]] = (
                        farm_area_new[self.var.GrowingSeasonDayOne[0,:,:]])
            else:
                if self.var._modelTime.timeStepPCR == 1:
                    farm_area = vos.netcdf2PCRobjCloneWithoutTime(
                        self.var.FarmAreaFileNC,
                        self.var.FarmAreaVarName,
                        cloneMapFileName = self.var.cloneMap)
                    mask = np.broadcast_to(
                        self.var.landmask,
                        (self.var.nFarm, self.var.nLat, self.var.nLon))
                    farm_area = np.reshape(
                        farm_area[mask],
                        (self.var.nFarm, self.var.nCell))
                    self.var.FarmArea = farm_area.copy()
                    # self.var.FarmArea = np.broadcast_to(
                    #     farm_area[:,None,:],
                    #     (self.var.nFarm, self.var.nCrop, self.var.nCell))                    
                
    def set_farm_category_area(self):
        if not self.var.FarmCategoryAreaFileNC == "None":
            if self.var.AnnualChangeInFarmCategoryArea:
                if self.var._modelTime.timeStepPCR == 1 or self.var._modelTime.doy == 1:
                    date = '%04i-%02i-%02i' % (self.var._modelTime.year, 1, 1)
                    farm_cat_area_new = vos.netcdf2PCRobjClone(
                        self.var.FarmCategoryAreaFileNC,
                        self.var.FarmCategoryAreaVarName,
                        date,
                        useDoy = None,
                        cloneMapFileName = self.var.cloneMap,
                        LatitudeLongitude = True)
                    mask = np.broadcast_to(
                        self.var.landmask,
                        (self.var.nFarmSizeCategory, self.var.nLat, self.var.nLon))
                    farm_cat_area_new = np.reshape(
                        farm_cat_area_new[mask],
                        (self.var.nFarmSizeCategory, self.var.nCell))

                if np.any(self.var.GrowingSeasonDayOne):
                    self.var.FarmCategoryArea[self.var.GrowingSeasonDayOne] = (
                        farm_cat_area_new[self.var.GrowingSeasonDayOne])
            else:
                if self.var._modelTime.timeStepPCR == 1:
                    farm_cat_area = vos.netcdf2PCRobjCloneWithoutTime(
                        self.var.FarmCategoryAreaFileNC,
                        self.var.FarmCategoryAreaVarName,
                        cloneMapFileName = self.var.cloneMap)
                    mask = np.broadcast_to(
                        self.var.landmask,
                        (self.var.nFarmSizeCategory, self.var.nLat, self.var.nLon))
                    farm_cat_area = np.reshape(
                        farm_cat_area[mask],
                        (self.var.nFarmSizeCategory, self.var.nCell))
                    self.var.FarmCategoryArea = farm_cat_area.copy()
            
    def set_farm_category(self):
        if not self.var.FarmCategoryFileNC == "None":
            if self.var.AnnualChangeInFarmCategory:
                if self.var._modelTime.timeStepPCR == 1 or self.var._modelTime.doy == 1:
                    date = '%04i-%02i-%02i' % (self.var._modelTime.year, 1, 1)
                    farm_category_new = vos.netcdf2PCRobjClone(
                        self.var.FarmCategoryFileNC,
                        self.var.FarmCategoryVarName,
                        date,
                        useDoy = None,
                        cloneMapFileName = self.var.cloneMap,
                        LatitudeLongitude = True)
                    mask = np.broadcast_to(
                        self.var.landmask,
                        (self.var.nFarm, self.var.nLat, self.var.nLon))
                    farm_category_new = np.reshape(
                        farm_category_new[mask],
                        (self.var.nFarm, self.var.nCell))

                if np.any(self.var.GrowingSeasonDayOne):
                    self.var.FarmCategory[self.var.GrowingSeasonDayOne[0,:,:]] = (
                        farm_category_new[self.var.GrowingSeasonDayOne[0,:,:]])
            else:
                if self.var._modelTime.timeStepPCR == 1:
                    farm_category = vos.netcdf2PCRobjCloneWithoutTime(
                        self.var.FarmCategoryFileNC,
                        self.var.FarmCategoryVarName,
                        cloneMapFileName = self.var.cloneMap)
                    mask = np.broadcast_to(
                        self.var.landmask,
                        (self.var.nFarm, self.var.nLat, self.var.nLon))
                    farm_category = np.reshape(
                        farm_category[mask],
                        (self.var.nFarm, self.var.nCell))
                    self.var.FarmCategory = farm_category.copy()
                            
    def dynamic(self):
        self.update_first_day_of_year()
        self.set_farm_area()
        self.set_farm_category()
        self.set_farm_category_area()
