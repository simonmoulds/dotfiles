## Quality control for Himachal Pradesh

## Barley
## ######

xx[["irr_barley"]] %<>% locf_interp(61:63)
xx[["apy_barley"]] %<>% tot_frac_interp(xx[["irr_barley"]], 61:63, 60)

if (dist_nm %in% c("Kinnaur")) {
    xx[["irr_barley"]] %<>% irr_frac_interp(xx[["apy_barley"]], 32, 31)
}

if (dist_nm %in% c("Lahul & Spiti")) {
    xx[["apy_barley"]] %<>% tot_frac_interp(xx[["irr_barley"]], 30, 29)
    xx[["apy_barley"]] %<>% tot_frac_interp(xx[["irr_barley"]], 36:40, 35)
}

