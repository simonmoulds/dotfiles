class LandCoverFrac(object):    
    def __init__(self, LandCoverFrac_variable):
        self.var = LandCoverFrac_variable
        self.var.LandCoverFracOutputFile = str(
            self.var._configuration.LANDCOVER['landCoverPathOut'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)

    def initial(self):
        pass

    def dynamic(self):
        lc_types = [lc.strip() for lc in self.var._configuration.LANDCOVER['landCoverTypes'].split(',')]
        veg_types = ['forest','grassland','irrPaddy','irrNonPaddy']
        natural_veg_types = ['forest','grassland']
        
        # lc_filename = self.var._configuration.landCoverOptions['landCoverInputFile']
        lc_data = []
        for lc in lc_types:
            config_section = getattr(self.var._configuration, lc)
            lc_outpath = config_section['landCoverTypePathOut']
            
            # land cover fraction            
            lc_filename = config_section['landCoverFractionInputFile']
            fn = get_data_smart(
                'gandak_wb_data_model',
                '../data' + '/' + lc_filename.format(lc=lc),
                as_string = False)
            fn = lc_filename
            r = read_gdal_raster_image(fn, self.bbox, 0)  # write to netCDF
            lc_data.append(r)
            if lc in veg_types:
                # crop coefficient
                kc_filename = config_section['cropCoefficientInputFile']
                print kc_filename
            
                # root fraction
                rf_filename = config_section['rootFractionInputFile']
                print rf_filename
            
                # interception capacity
                if lc in natural_veg_types:
                    ic_filename = config_section['interceptCapInputFile']
                    print ic_filename

                # root depth
                rd_filename = config_section['maxRootDepthInputFile']
                print rd_filename
            
        
