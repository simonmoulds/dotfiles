#!/bin/bash

aosdir='/home/simon/projects/AquaCrop/AquaCrop_Py'
testdir='/home/simon/projects/AquaCrop/tests/aquacrop_python_test_data'

declare -a arr=("aos_ch7_tunis_wheat_ex1")

for elem in "${arr[@]}"
do
    for year in {2000..2000}
    # for year in {1979..2001}
    do
        config_fn = "${testdir}"/Config/"${elem}"_"${year}"_config.ini
        runner_fn = "${aosdir}"/deterministic_runner.py

        $runner_fn $config_fn aquacrop
    done
done

    echo Running test $elem
    # indir=${aosdir}/Input"${elem}"
    # outdir=${aosdir}/Output"${elem}"
    echo '%% Enter Location of Input files %%' > ${aosdir}/FileLocations.txt
    echo ${testdir}/Input"${elem}" >> ${aosdir}/FileLocations.txt
    echo '%% Enter Location of Output files %%' >> ${aosdir}/FileLocations.txt
    echo ${testdir}/Output"${elem}" >> ${aosdir}/FileLocations.txt
    chmod 755 ${aosdir}/FileLocations.txt
    cwd=`pwd`

    cd ${aosdir}
    octave --eval AquaCropOS_RUN
    cd ${cwd}
done


