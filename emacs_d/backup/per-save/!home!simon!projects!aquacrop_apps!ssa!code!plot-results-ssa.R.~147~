myfun = function(ncfile, varname, crop_ix=1, farm_ix=1, template, ...) {
    nc = nc_open(ncfile)
    var = ncvar_get(nc, varname, collapse_degen=FALSE)
    var_dim_ix = nc$var[[varname]][["dimids"]]
    var_dims = names(nc$dim)[var_dim_ix + 1]
    dims = c("lat","lon","time","crop","farm")
    perm = match(var_dims, dims[dims %in% var_dims])
    var = aperm(var, perm)
    var = var[,,,crop_ix,farm_ix]
    lat = ncvar_get(nc, "lat")
    lon = ncvar_get(nc, "lon")
    tm = ncvar_get(nc, "time")
    lat_descending = (lat[1] == max(lat))
    lon_ascending = (lon[1] == min(lon))
    maps = list()
    for (i in 1:length(tm)) {
        r = raster(template)
        r[] = var[,,i]
        maps[[i]] = r
    }
    st = stack(maps)
    nc_close(nc)
    st
}

get_val_at_point = function(ncfile, varname, pts, crop_ix=1, farm_ix=1, ...) {
    nc = nc_open(ncfile)
    var = ncvar_get(nc, varname, collapse_degen=FALSE)
    var_dim_ix = nc$var[[varname]][["dimids"]]
    var_dims = names(nc$dim)[var_dim_ix + 1]
    dims = c("lat","lon","time","crop","farm")
    perm = match(var_dims, dims[dims %in% var_dims])
    var = aperm(var, perm)
    var = var[,,,crop_ix,farm_ix]
    lat = ncvar_get(nc, "lat")
    lon = ncvar_get(nc, "lon")
    lat_ix = which.min(abs(lat - pts$y))[1]
    lon_ix = which.min(abs(lon - pts$x))[1]
    pt_val = R.utils::extract(var, indices=list("1"=lat_ix, "2"=lon_ix))
    nc_close(nc)
    pt_val
}

