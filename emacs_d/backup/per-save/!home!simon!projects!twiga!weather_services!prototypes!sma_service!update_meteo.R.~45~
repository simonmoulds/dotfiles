meteo = read.csv("princeton_data.csv")
nt = nrow(meteo)
write.table(
    meteo[1,,drop=FALSE],
    "simulated_realtime_met_data.R",
    sep=",",
    row.names=FALSE,
    col.names=TRUE
)

for (i in 2:nt) {
    write.table(
        meteo[i,,drop=FALSE],
        "simulated_realtime_met_data.R",
        append=TRUE,
        sep=",",
        row.names=FALSE,
        col.names=FALSE
    )
    Sys.sleep(1)
}

    
    
