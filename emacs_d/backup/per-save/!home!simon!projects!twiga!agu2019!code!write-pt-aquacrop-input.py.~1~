#!/usr/bin/env python
# coding: utf-8

import os
import shutil
import numpy as np
import netCDF4 as nc
import pandas as pd
import datetime
import time
import glob
import re

datadir = "../data"
met_datadir = "../data/pt_met_data/"
out_dir = "../data/aquacrop_runs"
if not os.path.exists(out_dir):    
    os.makedirs(out_dir)

met_filenames = glob.glob(
    met_datadir + '/' + 'tahmo_era5_stn_TA*_met_2016-2019.nc'
)

starttime = datetime.datetime(2016, 1, 1)
endtime = datetime.datetime(2018, 12, 31)

def main():
    
    for fn in met_filenames:

        # extract station code from filename
        code = re.search('TA[0-9]{5}', fn).group(0)

        # define input/output directories for model simulation
        run_dir = os.path.join(out_dir, code)
        run_input_dir = os.path.join(run_dir, 'input')
        run_output_dir = os.path.join(run_dir, 'output')
        run_config_dir = os.path.join(run_dir, 'config')
        if os.path.exists(run_input_dir):
            shutil.rmtree(run_input_dir)
        if os.path.exists(run_config_dir):
            shutil.rmtree(run_config_dir)
        os.makedirs(run_config_dir)
        os.makedirs(run_input_dir)
        if not os.path.exists(run_output_dir):
            os.makedirs(run_output_dir)

        # get relevant data from weather input
        ds = nc.Dataset(fn, 'r')
        lat_coord = ds.variables['lat'][:][0]
        lon_coord = ds.variables['lon'][:][0]
        timedim = ds.variables['time']
        dtime = list(nc.num2date(timedim[:], timedim.units, timedim.calendar))
        # starttime = dtime[0]
        # endtime = dtime[-1]
        ds.close()

        # copy met data to sim directory
        os.system('cp ' + fn + ' ' + run_input_dir)

        # write clone
        # ###########
        clone_fn_stn = os.path.join(
            run_input_dir,
            'clone_map_' + code + '.nc'
        )
        ds = nc.Dataset(clone_fn_stn, 'w')
        ds.description = 'clone map'
        ds.history = 'created ' + time.ctime(time.time())
        ds.createDimension('lat', 1)
        ds.createDimension('lon', 1)
        lats = ds.createVariable('lat', np.float64, ('lat',))
        lats.units = 'degrees_north'
        lats[:] = lat_coord
        lons = ds.createVariable('lon', np.float64, ('lon',))
        lons.units = 'degrees_east'
        lons[:] = lon_coord
        cln = ds.createVariable('clone', np.float64, ('lat','lon'))
        cln.units = '1'
        cln[:] = 1
        ds.close()        
        
        # extract CO2 data
        # ################
        co2_fn = os.path.join(
            datadir,
            'co2_annual_mean_mlo_0pt25degree.nc'
        )
        co2_fn_stn = os.path.join(
            run_input_dir,
            'co2_annual_mean_mlo_' + code + '.nc'
        )
        ncks_cmd = \
            'ncks --ovr -v co2 -d lon,' + str(lon_coord) \
            + ' -d lat,' + str(lat_coord) + ' ' \
            + co2_fn + ' ' + co2_fn_stn
        os.system(ncks_cmd)

        ds = nc.Dataset(co2_fn_stn, 'r+')
        ds['lat'][:] = lat_coord
        ds['lon'][:] = lon_coord
        ds.close()

        # extract crop parameters
        # #######################
        crop_fn = os.path.join(
            datadir,
            'crop_parameters.nc'
        )
        crop_fn_stn = os.path.join(
            run_input_dir,
            'crop_parameters_' + code + '.nc'
        )
        ncks_cmd = \
            'ncks --ovr -v PlantingDate,HarvestDate,PlantPop,CCx -d lon,' + str(lon_coord) \
            + ' -d lat,' + str(lat_coord) + ' ' \
            + crop_fn + ' ' + crop_fn_stn
        os.system(ncks_cmd)

        ds = nc.Dataset(crop_fn_stn, 'r+')
        ds['lat'][:] = lat_coord
        ds['lon'][:] = lon_coord
        ds.close()

        # extract soil parameters
        # #######################
        soil_fn = os.path.join(
            datadir,
            'soil_hydraulic_parameters.nc'
        )
        soil_fn_stn = os.path.join(
            run_input_dir,
            'soil_hydraulic_parameters_' + code + '.nc'
        )
        ncks_cmd = \
            'ncks --ovr -v k_sat,th_wilt,th_crit,th_sat -d lon,' + str(lon_coord) \
            + ' -d lat,' + str(lat_coord) + ' ' \
            + soil_fn + ' ' + soil_fn_stn
        os.system(ncks_cmd)

        ds = nc.Dataset(soil_fn_stn, 'r+')
        ds['lat'][:] = lat_coord
        ds['lon'][:] = lon_coord
        ds.close()

        # write config file
        # #################

        import configparser
        import collections
        config = configparser.ConfigParser()
        config.optionxform = str
        config['FILE_PATHS'] = collections.OrderedDict([
            ('PathIn', os.path.abspath(run_input_dir)),
            ('PathOut', os.path.abspath(os.path.join(run_output_dir, 'prec_era5')))
        ])

        config['MODEL_GRID'] = collections.OrderedDict([
            ('cloneMap', '${FILE_PATHS:PathIn}' + '/' + 'clone_map_' + code + '.nc'),
            ('landmask', str(None))
        ])

        config['CLOCK'] = collections.OrderedDict([
            ('startTime', str(starttime.year) + '-' + str(starttime.month) + '-' + str(starttime.day)),
            ('endTime', str(endtime.year) + '-' + str(endtime.month) + '-' + str(endtime.day)),
        ])

        config['INITIAL_WATER_CONTENT'] = collections.OrderedDict([
            ('initialConditionType', 'percent'),
            ('initialConditionPercent', str(0)),
            ('initialConditionInterpMethod', str(None))
        ])

        config['NETCDF_ATTRIBUTES'] = collections.OrderedDict([
            ('institution', 'Imperial College London, UK'),
            ('title', 'AquaCrop v5.0 output'),
            ('description', 'test version (by Simon Moulds)'),
            ('netcdf_y_orientation_follow_cf_convention', 'True'),
            ('formatNetCDF', 'NETCDF4'),
            ('zlib', 'True')
        ])            

        config['WEATHER'] = collections.OrderedDict([
            ('precipitationNC', '${FILE_PATHS:PathIn}' + '/' + os.path.basename(fn)),
            ('precipitationVarName', 'prec_era5'),
            ('precipitationTimeDimName', 'time'),
            ('precipitationOffset', str(0)),
            ('precipitationFactor', str(1)),
            ('meanDailyTemperatureNC', str(None)),
            ('meanDailyTemperatureVarName', str(None)),
            ('meanDailyTemperatureTimeDimName', 'time'),
            ('meanDailyTemperatureOffset', str(0)),
            ('meanDailyTemperatureFactor', str(1)),
            ('minDailyTemperatureNC', '${FILE_PATHS:PathIn}' + '/' + os.path.basename(fn)),
            ('minDailyTemperatureVarName', 'tmin_era5'),
            ('minDailyTemperatureTimeDimName', 'time'),
            ('minDailyTemperatureOffset', str(0)),
            ('minDailyTemperatureFactor', str(1)),
            ('maxDailyTemperatureNC', '${FILE_PATHS:PathIn}' + '/' + os.path.basename(fn)),
            ('maxDailyTemperatureVarName', 'tmax_era5'),
            ('maxDailyTemperatureTimeDimName', 'time'),
            ('maxDailyTemperatureOffset', str(0)),
            ('maxDailyTemperatureFactor', str(1)),
            ('refEvapotranspirationNC', '${FILE_PATHS:PathIn}' + '/' + os.path.basename(fn)),
            ('refEvapotranspirationVarName', 'eto_era5'),
            ('refEvapotranspirationTimeDimName', 'time'),
            ('refEvapotranspirationOffset', str(0)),
            ('refEvapotranspirationFactor', str(1))
        ])

        config['CARBON_DIOXIDE'] = collections.OrderedDict([
            ('carbonDioxideNC', '${FILE_PATHS:PathIn}' + '/' + os.path.basename(co2_fn_stn))
        ])

        config['WATER_TABLE'] = collections.OrderedDict([
            ('WaterTable', str(0)),
            ('VariableWaterTable', str(0)),
            ('groundwaterVarName', str(None)),
            ('groundwaterInputDir', str(None)),
            ('DailyGroundwaterNC', str(0)),
            ('groundwaterInputFile', str(None))
        ])

        config['LAND_COVER'] = collections.OrderedDict([])

        config['CROP_PARAMETERS'] = collections.OrderedDict([
            ('nCrop', str(1)),
            ('cropParametersNC', '${FILE_PATHS:PathIn}' + '/' + os.path.basename(crop_fn_stn)),
            ('CalendarType', str(2)),
            ('SwitchGDD', str(1)),
            ('GDDmethod', str(1)),
            ('cropID', str(2)),
            ('outDailyTotal', str('th,Y')),
            ('outYearMaxNC', str('Y'))
        ])

        config['IRRIGATION_MANAGEMENT'] = collections.OrderedDict([
            ('irrigationManagementNC', str(None)),
            ('irrigationScheduleNC', str(None))
        ])

        config['FIELD_MANAGEMENT'] = collections.OrderedDict([
            ('fieldManagementNC', str(None))
        ])

        zlayer = [0.1,0.25,0.65,1.3]
        zcomp = [0.1,0.1,0.1,0.15,0.15,0.2,0.2,0.25,0.25,0.25,0.25,0.3]
        config['SOIL_HYDRAULIC_PARAMETERS'] = collections.OrderedDict([
            ('calculateSoilHydraulicParametersFromSoilTexture', '0'),
            ('soilHydraulicParametersNC', '${FILE_PATHS:PathIn}' + '/' + os.path.basename(soil_fn_stn)),
            ('saturatedHydraulicConductivityVarName', 'k_sat'),
            ('saturatedVolumetricWaterContentVarName', 'th_sat'),
            ('fieldCapacityVolumetricWaterContentVarName', 'th_crit'),
            ('wiltingPointVolumetricWaterContentVarName', 'th_wilt'),
            ('dzSoilLayer',','.join(['%.5f' % num for num in zlayer])),
            ('dzSoilCompartment',','.join(['%.5f' % num for num in zcomp]))
        ])

        config['SOIL_PARAMETERS'] = collections.OrderedDict([
            ('soilParametersNC', str(None)),
            ('adjustReadilyAvailableWater', str(0)),
            ('adjustCurveNumber', str(1))
        ])        

        config['REPORTING'] = collections.OrderedDict([
            ('formatNetCDF', 'NETCDF4'),
            ('zlib', 'True')
        ])

        with open(os.path.join(run_config_dir, 'aquacrop_' + code + '_era5_config.ini'), 'w') as configfile:
            config.write(configfile)

        config['WEATHER']['precipitationVarName'] = 'prec_tahmo'
        config['FILE_PATHS']['PathOut'] = os.path.abspath(os.path.join(run_output_dir, 'prec_tahmo'))
        
        with open(os.path.join(run_config_dir, 'aquacrop_' + code + '_tahmo_config.ini'), 'w') as configfile:
            config.write(configfile)

if __name__ == '__main__':
    if len(met_filenames) > 0:
        main()
    else:
        print("No met data available")
