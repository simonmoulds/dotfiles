## rice
## ####

xx[["irr_rice-winter"]] = xx[["irr_rice-summer"]]
xx[["irr_rice-summer"]] = 0

## xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1, 2)
## xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 3:4, 5)

if (dist_nm %in% c("Changlang")) {
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 7, 6)
}

if (dist_nm %in% c("Changland","Dibang Valley","East Kameng","Lohit","Papum Pare","Tawang","Tirap","Upper Siang","Upper Subansiri","West Kameng","West Siang")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 3:4, 5)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1, 5)
}

if (dist_nm %in% c("East Siang")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:4, 5)
}

if (dist_nm %in% c("Lower Subansiri")) {
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 8:9, 7)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 3:4, 5)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1, 5)
}

