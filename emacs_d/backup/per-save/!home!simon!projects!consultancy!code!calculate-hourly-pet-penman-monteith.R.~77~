## Part 2: Met data
## ================
years = 2011:2014
nyears = length(years)
wind_data_list = vector(mode="list", length=nyears)
prec_data_list = vector(mode="list", length=nyears)
met_data_list = vector(mode="list", length=nyears)
rad_data_list = vector(mode="list", length=nyears)
for (i in 1:nyears) {
    year = years[i]
    wind_fn = file.path("data-raw", "MIDAS", paste0("midas-open_uk-mean-wind-obs_dv-201901_dumfriesshire_01023_eskdalemuir_qcv-1_", year, ".csv"))
    ## prec_fn = file.path("data-raw", "MIDAS", paste0("midas-open_uk-hourly-rain-obs_dv-201901_dumfriesshire_01023_eskdalemuir_qcv-1_", year, ".csv"))
    prec_fn = file.path("data-raw", "MIDAS", paste0("midas-open_uk-hourly-rain-obs_dv-201901_roxburghshire_00285_carterhouse_qcv-1_", year, ".csv"))
    met_fn = file.path("data-raw", "MIDAS", paste0("midas-open_uk-hourly-weather-obs_dv-201901_dumfriesshire_01023_eskdalemuir_qcv-1_", year, ".csv"))
    rad_fn = file.path("data-raw", "MIDAS", paste0("midas-open_uk-radiation-obs_dv-201901_dumfriesshire_01023_eskdalemuir_qcv-1_", year, ".csv"))
    wind_skip = get_num_rows_to_skip(wind_fn)
    prec_skip = get_num_rows_to_skip(prec_fn)
    met_skip = get_num_rows_to_skip(met_fn)
    rad_skip = get_num_rows_to_skip(rad_fn)
    wind_data_list[[i]] = read.csv(wind_fn, skip=wind_skip)
    prec_data_list[[i]] = read.csv(prec_fn, skip=prec_skip)
    met_data_list[[i]] = read.csv(met_fn, skip=met_skip)
    rad_data_list[[i]] = read.csv(rad_fn, skip=rad_skip)
}

wind_data = do.call(rbind, wind_data_list)
prec_data = do.call(rbind, prec_data_list)
met_data = do.call(rbind, met_data_list)
rad_data = do.call(rbind, rad_data_list)

## see documentation here:
## http://artefacts.ceda.ac.uk/badc_datadocs/ukmo-midas/ukmo_guide.html#2.4
## which states that all observations are entered against the
## correct hour GMT (i.e. daylight saving hours are taken
## into account). Hence create a complete time series which
## we can use to ensure the data is complete.
fmt="%Y-%m-%d %H:%M:%S"
starttime = as.POSIXct(
    "2011-01-01 00:00:00",
    tz="GMT",
    format=fmt
)
endtime = as.POSIXct(
    "2014-12-31 23:00:00",
    tz="GMT",
    format=fmt
)    
ts = data.frame(
    time=seq.POSIXt(
        starttime,
        endtime,
        by="1 hour"
    )
)

wind_data_clean =
    wind_data %>%
    dplyr::select("ob_end_time","mean_wind_speed") %>%
    setNames(c("time","mean_wind_speed")) %>%
    mutate(time=as.character(time)) %>%
    mutate(time=as.POSIXct(time, tz="GMT", format=fmt)) %>%
    dplyr::filter(!duplicated(time)) %>%
    right_join(ts)
    
prec_data_clean =
    prec_data %>%
    dplyr::select("ob_end_time","prcp_amt") %>%
    setNames(c("time","prcp_amt")) %>%
    mutate(time=as.character(time)) %>%
    mutate(time=as.POSIXct(time, tz="GMT", format=fmt)) %>%
    dplyr::filter(!duplicated(time)) %>%
    right_join(ts)

met_data_clean =
    met_data %>%
    dplyr::select("ob_time","air_temperature","stn_pres","rltv_hum","dewpoint") %>%
    setNames(c("time","air_temperature","stn_pres","rltv_hum","dewpoint")) %>%
    mutate(time=as.character(time)) %>%
    mutate(time=as.POSIXct(time, tz="GMT", format=fmt)) %>%
    dplyr::filter(!duplicated(time)) %>%
    right_join(ts)
    
rad_data_clean =
    rad_data %>%
    dplyr::select("ob_end_time","glbl_irad_amt") %>%
    setNames(c("time","glbl_irad_amt")) %>%
    mutate(time=as.character(time)) %>%
    mutate(time=as.POSIXct(time, tz="GMT", format=fmt)) %>%
    dplyr::filter(!duplicated(time)) %>%
    right_join(ts)

