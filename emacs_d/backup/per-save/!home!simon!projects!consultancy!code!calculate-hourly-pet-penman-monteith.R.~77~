## Part 3: ET0 (FAO Penman Monteith)
## =================================

## **CHECKED**
saturation_vapour_pressure =
    saturation_vapour_pressure_eq11(
        met_data_clean_filled$air_temperature
    )

## **CHECKED**
actual_vapour_pressure =
    actual_vapour_pressure_eq14(
        met_data_clean_filled$dewpoint
    )


## **CHECKED**
## MIDAS data report pressure in hPa -> divide by 10 to
## get kPa
psychrometric_constant =
    psychrometric_constant_eq8(
        met_data_clean_filled$stn_pres / 10
    )

## **CHECKED**
slope_saturation_vapour_pressure_curve =
    slope_saturation_vapour_pressure_curve_eq13(
        met_data_clean_filled$air_temperature
    )

## **CHECKED**
## multiply observed wind speed by 0.514444 to convert from
## knots to m/s
## MIDAS weather stations measure wind speed at 10m height
wind_speed_2m =
    wind_speed_eq47(
        wind_data_clean_filled$mean_wind_speed * 0.514444,
        z=10
    )

## get Julian day and clock time midpoint from time series
time_lt = as.POSIXlt(ts$time)
julian_day = time_lt$yday + 1
clock_time_at_midpoint = time_lt$hour + 0.5

## **CHECKED**
## note latitude/longitude converted to radians
extraterrestrial_radiation =
    extraterrestrial_radiation_eq28(
        latitude=55.3583 * (pi/180),
        julian_day=julian_day,
        longitude_of_tz=0 * (pi/180),
        longitude_of_measurement_site=2.51741 * (pi/180),
        clock_time_at_midpoint=clock_time_at_midpoint,
        length_of_calculation_period=1)

## **CHECKED**
## convert observed solar radiation from kJ m-2 to MJ m-2
solar_radiation =
    rad_data_clean_filled$glbl_irad_amt %>%
    `/`(1000)

## **CHECKED**
clear_sky_solar_radiation =
    clear_sky_solar_radiation_eq37(
        extraterrestrial_radiation,
        station_elevation=308
    )

## **CHECKED**
net_shortwave_radiation = net_shortwave_radiation_eq38(
    solar_radiation,
    albedo=0.23
)

## **CHECKED**
solar_declination = solar_declination_eq24(julian_day)

## **CHECKED**
sunset_hour_angle = sunset_hour_angle_eq25(
    latitude=55.3583 * (pi/180),
    solar_declination=solar_declination)

## **CHECKED**
solar_time_angle_midpoint = solar_time_angle_midpoint_eq31(
    longitude_of_tz=0,
    longitude_of_measurement_site=2.51741,
    clock_time_at_midpoint=clock_time_at_midpoint,
    julian_day=julian_day
)

net_longwave_radiation = net_longwave_radiation_eq39_subdaily(
    met_data_clean_filled$air_temperature,
    solar_radiation,
    clear_sky_solar_radiation,
    solar_time_angle_midpoint,
    sunset_hour_angle,
    default_nighttime_ratio=0.5,
    actual_vapour_pressure,
    length_of_calculation_period=1
)

net_radiation = net_radiation_eq40(
    net_shortwave_radiation,
    net_longwave_radiation)

soil_heat_flux = soil_heat_flux_eq45(
    net_radiation,
    clear_sky_solar_radiation
)

eto = hourly_reference_et_eq53(
    slope_saturation_vapour_pressure_curve,
    net_radiation,
    soil_heat_flux=soil_heat_flux,
    psychrometric_constant,
    met_data_clean_filled$air_temperature,
    saturation_vapour_pressure,
    actual_vapour_pressure,
    wind_speed_2m)

## precipitation data looks very high, so swap with GEAR1h
gear_prcp = read.csv(
    file.path(
        "data-raw",
        "11_SWAT - Copy",
        "05_Meteo",
        "gear1h_precip_2011-2014.csv"
    )    
)

topmodel_met_data = data.frame(
    time=ts$time,
    ## prec=prec_data_clean_filled$prcp_amt,
    prec=gear_prcp$prcp,
    eto=eto
)

