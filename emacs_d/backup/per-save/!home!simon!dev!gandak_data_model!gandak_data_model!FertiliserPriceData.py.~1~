class CropPriceData(object):
    def __init__(self, CropPriceData_variable):
        self.var = CropPriceData_variable
        self.var.CropPriceOutputFile = vos.getFullPath(
            self.var._configuration.cropPriceOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])

    def initial(self):
        pass

    def dynamic(self):
        price_data_filename = get_data_smart(
            'gandak_data_model',
            '../data/gandak_price_data.txt',
            as_string = False)

        price_data = pandas.read_table(
            price_data_filename,
            sep='\t',
            header=0,
            index_col=False)

        # annual time series
        years = price_data['YEAR']
        year = np.min(years)
        end_year = np.max(years)
        dates = []
        while year < end_year + 1:
            dates.append(datetime.datetime(year,1,1))
            year += 1
        nt = len(dates)

        # crop price data (rice, wheat, sugarcane)
        rice_price = np.array(
            price_data['PADY_TP'], dtype=np.float64)
        wheat_price = np.array(
            price_data['WHT_TP'], dtype=np.float64)
        sugarcane_price = np.array(
            price_data['SGUR_TP'], dtype=np.float64)

        rice_price = np.broadcast_to(
            rice_price[:,None,None],
            (nt, self.var.nLat, self.var.nLon)).copy()
        wheat_price = np.broadcast_to(
            wheat_price[:,None,None],
            (nt, self.var.nLat, self.var.nLon)).copy()
        sugarcane_price = np.broadcast_to(
            sugarcane_price[:,None,None],
            (nt, self.var.nLat, self.var.nLon)).copy()

        crop_price = np.stack((
            rice_price,
            rice_price,
            rice_price,
            rice_price,
            wheat_price,
            wheat_price,
            sugarcane_price,
            sugarcane_price), axis=1)
        
        print crop_price.shape
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(self.var.CropPriceOutputFile, 'crop_price')

        for index,date in enumerate(dates):
            netcdf.data2NetCDF(
                self.var.CropPriceOutputFile,
                'crop_price',
                crop_price[index,...],
                date)
        
