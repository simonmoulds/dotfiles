## sunflower
## #########

if (dist_nm %in% c("Dimapur")) {
    xx[["apy_sunflower-rabi"]] %<>% locf_interp(9)
    xx[["irr_sunflower-rabi"]] %<>% locf_interp(9)
    xx[["apy_sunflower-kharif"]] %<>% linear_interp(8)
}

if (dist_nm %in% c("Kohima")) {
    xx[["apy_sunflower-kharif"]] %<>% locf_interp(5:7)
    xx[["apy_sunflower-rabi"]] %<>% locf_interp(5:7)
}

if (dist_nm %in% c("Mokokchung")) {
    xx[["apy_sunflower-rabi"]] %<>% locf_interp(5)
    xx[["apy_sunflower-rabi"]] %<>% locf_interp(9, fromLast=TRUE)
    xx[["apy_sunflower-kharif"]] %<>% locf_interp(10:11)
}

if (dist_nm %in% c("Mon")) {
    xx[["apy_sunflower-rabi"]] %<>% locf_interp(5:8)
    xx[["apy_sunflower-kharif"]] %<>% locf_interp(5:8)
}

if (dist_nm %in% c("Phek")) {
    xx[["apy_sunflower-rabi"]] %<>% linear_interp(5:6)
    xx[["apy_sunflower-rabi"]] %<>% locf_interp(9, fromLast=TRUE)
    xx[["irr_sunflower-rabi"]] %<>% locf_interp(9, fromLast=TRUE)
    xx[["apy_sunflower-kharif"]] %<>% linear_interp(5:7)
    xx[["apy_sunflower-kharif"]] %<>% locf_interp(10:11)
}

if (dist_nm %in% c("Tuensang","Zunheboto")) {
    xx[["apy_sunflower-rabi"]] %<>% locf_interp(5:11)
    xx[["apy_sunflower-kharif"]] %<>% locf_interp(5:8, fromLast=TRUE)
}

if (dist_nm %in% c("Wokha")) {
    xx[["apy_sunflower-kharif"]] %<>% linear_interp(5:7)
    xx[["apy_sunflower-kharif"]] %<>% locf_interp(10:11)
    xx[["apy_sunflower-rabi"]] %<>% locf_interp(6:9)
}

