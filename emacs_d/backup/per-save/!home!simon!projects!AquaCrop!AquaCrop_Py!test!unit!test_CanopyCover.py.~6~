def test_canopy_cover_development_growth(canopycover):
    res = canopycover.canopy_cover_development(
        np.ones((1,1)),
        np.ones((1,1)),
        np.ones((1,1)),
        np.ones((1,1)),
        np.ones((1,1)), 'Growth')
    np.testing.assert_array_almost_equal(
        res, 0.9080, decimal=4)

