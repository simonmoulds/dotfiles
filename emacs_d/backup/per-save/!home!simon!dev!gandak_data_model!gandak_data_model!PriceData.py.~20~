class PriceData(object):
    def __init__(self, PriceData_variable):
        self.var = PriceData_variable
        self.var.CropPriceOutputFile = vos.getFullPath(
            self.var._configuration.priceOptions['cropPriceOutputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.var.FertiliserPriceOutputFile = vos.getFullPath(
            self.var._configuration.priceOptions['fertiliserPriceOutputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.var.DieselPriceOutputFile = vos.getFullPath(
            self.var._configuration.priceOptions['dieselPriceOutputFile'],
            self.var._configuration.globalOptions['outputDir'])

    def initial(self):
        pass

    def get_crop_price_data(self, price_data):
        pass

    def read_price_data(self, filename):
        price_data = pandas.read_table(
            filename,
            sep='\t',
            header=0,
            index_col=False)
        return price_data

    def get_annual_time_series(self, price_data):
        # annual time series
        years = price_data['YEAR']
        year = np.min(years)
        end_year = np.max(years)
        dates = []
        while year < end_year + 1:
            dates.append(datetime.datetime(year,1,1))
            year += 1
        return dates

    def get_daily_time_series(self, price_data):
        date_str = price_data['DATE']
        dates = []
        for date in price_data['DATE']:
            year, month, day = date.split("-")
            dates.append(datetime.datetime(int(year), int(month), int(day)))
        return dates
        
    def write_crop_price_data(self):
        price_data_filename = get_data_smart(
            'gandak_data_model',
            '../data/gandak_crop_price_data.txt',
            as_string = False)
        price_data = self.read_price_data(price_data_filename)        
        dates = self.get_annual_time_series(price_data)
        crop_price_data = []
        for crop in self.var.CropTypes:
            price_crop = lookup_crop_id(crop, 'PRICE')
            arr = np.array(price_data[price_crop], dtype=np.float64)
            arr = arr[:,None,None] * np.ones((self.var.nLat, self.var.nLon))[None,:,:]
            crop_price_data.append(arr)

        crop_price = np.stack(crop_price_data, axis=1)
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(self.var.CropPriceOutputFile, 'crop_price')

        for index,date in enumerate(dates):
            netcdf.data2NetCDF(
                self.var.CropPriceOutputFile,
                'crop_price',
                crop_price[index,...],
                date)

    def write_fertiliser_price_data(self):
        price_data_filename = get_data_smart(
            'gandak_data_model',
            '../data/gandak_fert_price_data.txt',
            as_string = False)
        price_data = self.read_price_data(price_data_filename)        
        dates = self.get_annual_time_series(price_data)
        nitrogen_price = np.array(price_data['N_TP'], dtype=np.float64)
        phosphorus_price = np.array(price_data['P_TP'], dtype=np.float64)
        potassium_price = np.array(price_data['K_TP'], dtype=np.float64)

        nitrogen_price = nitrogen_price[:,None,None] * np.ones((self.var.nLat, self.var.nLon))[None,:,:]
        phosphorus_price = phosphorus_price[:,None,None] * np.ones((self.var.nLat, self.var.nLon))[None,:,:]
        potassium_price = potassium_price[:,None,None] * np.ones((self.var.nLat, self.var.nLon))[None,:,:]

        print nitrogen_price.shape
        print nitrogen_price[0,...]
        
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(
            self.var.FertiliserPriceOutputFile,
            ['nitrogen_price','phosphorus_price','potassium_price'])
        for index,date in enumerate(dates):
            netcdf.data2NetCDF(
                self.var.FertiliserPriceOutputFile,
                'nitrogen_price',
                nitrogen_price[index,...], date)
            netcdf.data2NetCDF(
                self.var.FertiliserPriceOutputFile,
                'phosphorus_price',
                phosphorus_price[index,...], date)
            netcdf.data2NetCDF(
                self.var.FertiliserPriceOutputFile,
                'potassium_price',
                potassium_price[index,...], date)

    def write_diesel_price_data(self):
        price_data_filename = get_data_smart(
            'gandak_data_model',
            '../data/gandak_diesel_price_data.txt',
            as_string = False)
        price_data = self.read_price_data(price_data_filename)        
        dates = self.get_daily_time_series(price_data)
        diesel_price = np.array(price_data['DIESEL_PRICE'], dtype=np.float64)
        diesel_price = diesel_price[:,None,None] * np.ones((self.var.nLat, self.var.nLon))[None,:,:]
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(self.var.DieselPriceOutputFile, 'diesel_price')
        for index,date in enumerate(dates):
            netcdf.data2NetCDF(
                self.var.DieselPriceOutputFile,
                'diesel_price',
                diesel_price[index,...],
                date)
        
    def dynamic(self):
        self.write_crop_price_data()
        self.write_fertiliser_price_data()
        self.write_diesel_price_data()
        
