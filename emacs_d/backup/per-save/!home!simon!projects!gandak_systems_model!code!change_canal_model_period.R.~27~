## Specify startdate and enddate as yyyy-mm-dd
startdate = "1963-01-01"
enddate = "2017-07-06"

masterdir = "data/GandakCanalModel_master"
datadir = "data/GandakCanalModel"

## copy master to new directory
system(paste("cp -r", masterdir, datadir))

## =====================
## 1. Modify inflows.dat
## =====================
fn = file.path(datadir, "Input", "inflows.dat")
inflows = readLines(fn)
sl = grep("^//", inflows)[3]
inflow_hdr = inflows[1:(sl)]
inflow_dat = inflows[(sl+1):length(inflows)]
ts = seq(as.Date("1963-01-01"), as.Date("2017-07-06"), by="1 day")
if (length(ts) != length(inflow_dat)) stop()
ts1 = seq(as.Date(startdate), as.Date(enddate), by="1 day")
ts1_idx = ts %in% ts1
if (!any(ts1_idx)) stop()
new_inflow_dat = inflow_dat[ts1_idx]
new_inflows = c(inflow_hdr, new_inflow_dat)

## TODO: write data
fileCon = file(fn)
writeLines(new_inflows, fileCon)
close(fileCon)

