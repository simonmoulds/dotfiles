library(raster)
library(magrittr)
library(rgdal)

grid = raster(ncol=720, nrow=360, crs="+proj=longlat +datum=WGS84")
grid[] = 1
## land = raster("WFDEI-long-lat-ht.nc")
## pts = as(grid, "SpatialPoints") %>% as.data.frame
poopo = readOGR("poopo.kml", "poopo")
poopo = poopo[3,]
poopo_extent = extent(poopo)
poopo_grid = crop(grid, poopo_extent, snap='out')
poopo_raster_poly = rasterize(poopo, poopo_grid)
poopo_raster_lines = rasterize(as(poopo, "SpatialLines"), poopo_grid)
poopo_raster = stackApply(
    stack(poopo_raster_poly, poopo_raster_lines),
    indices=c(1,1),
    fun=sum,
    na.rm=TRUE)
plot(poopo_raster)
poopo_raster[!poopo_raster > 0] = NA
poopo_raster[!is.na(poopo_raster)] = 1
## pts = as.data.frame(poopo_raster, xy=TRUE)
## names(pts) = c("x","y","land")
## pts = pts[!is.na(pts$land),]
pts = as(poopo_raster, "SpatialPoints")
pts = as.data.frame(pts) %>% dplyr::arrange(x)
write.table
