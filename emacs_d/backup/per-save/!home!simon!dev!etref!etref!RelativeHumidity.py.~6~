class RelativeHumidity(object):
    def __init__(self, RelativeHumidity_variable):
        self.max_relative_humidity_module = MaxRelativeHumidity(RelativeHumidity_variable)
        self.min_relative_humidity_module = MinRelativeHumidity(RelativeHumidity_variable)
        self.mean_relative_humidity_module = MeanRelativeHumidity(RelativeHumidity_variable)

    def initial(self):
        self.max_relative_humidity_module.initial()
        self.min_relative_humidity_module.initial()
        self.mean_relative_humidity_module.initial()

    def dynamic(self):
        self.max_relative_humidity_module.dynamic()
        self.min_relative_humidity_module.dynamic()
        self.mean_relative_humidity_module.dynamic()
        
