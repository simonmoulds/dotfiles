#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import numpy as np
from hm import file_handling

import logging
logger = logging.getLogger(__name__)

class Accounting(object):

    def __init__(self, land_cover):
        self.land_cover = land_cover
        
    def initial(self):
        # TODO: estimate realistic initial values - set in config
        self.land_cover.SavingsAccount = np.zeros((self.land_cover.nFarm, self.land_cover.model.nCell))
        self.land_cover.CurrentAccount = (
            np.ones((self.land_cover.nFarm, self.land_cover.model.nCell))
            * 5000.
            * self.land_cover.num_farms_per_subcategory
        )
    
    def update_farm_accounts(self):

        # Treat savings account as 'potential investment'        
        positive_balance = self.land_cover.CurrentAccount > 0
        savings_rate = 0.01 # ***TODO*** calibration factor to account for costs we do not consider
        if self.land_cover.IsLastDayOfYear:
            self.land_cover.CurrentAccount[positive_balance] *= savings_rate
            self.land_cover.SavingsAccount[positive_balance] += self.land_cover.CurrentAccount[positive_balance]
            self.land_cover.CurrentAccount[positive_balance] = 0.
            self.land_cover.CurrentAccount += self.land_cover.AnnualIncome
            
    def dynamic(self):
        self.update_farm_accounts()
