library(magrittr)
library(tidyr)
library(dplyr)
library(ggplot2)
library(cowplot)

## Time parameters
maxtime = 50
dt = 0.01
t = seq(0, maxtime, dt)
n_time = length(t)

## Compute inter-arrival time of flood events, plus flood magnitude
t_mean = 1/dt
H_mult = 1
w = rep(0, n_time)
index = 0
t0 = 0
t1 = 0
theta=0.28

set.seed(42)
while (index < n_time) {
    x = runif(1)
    t1 = t0 + (t_mean * log(1/(1-x)))
    index = which.min(abs(t/dt - t1))
    y = runif(1)
    w[index] = H_mult * ((theta + 1) / theta) * (1 - (1 - y) ** theta)
    t0 = t1
}

compute_protection_increase = function(F, W, H, epsilon_T, xi_H) {
    ## Function to compute flood protection increase.
    ##
    ## Args:
    ## =====
    ## F : Flood damage
    ## W : Water level
    ## H : Current protection level    
    ## xi_H : TODO
    ##
    ## Return:
    ## =======
    ## Increase in flood protection
    ##
    if (F > 0) {
        R = epsilon_T * (W + xi_H * H - H)
    } else {
        R = 0
    }
    R
}

constrain_protection_increase = function(R0, F, G, T, gamma_E, check_incentive=TRUE, check_affordable=TRUE, allow_suboptimal=FALSE) {
    ## Function to balance the desired flood protection increase
    ## against the community socioeconomics.
    ##
    ## Args:
    ## =====
    ## R0 : Desired increase in flood protection
    ## F  : Flood damage experienced by the community
    ## G  : Community wealth
    ## gamma_E : Unit cost of flood protection increase
    ## allow_suboptimal : if TRUE, allow community to build flood
    ##   protection which would not protect against flood damage F
    ##
    ## Return:
    ## =======
    ## Increase in flood protection considering community
    ##   socioeconomics
    ##    
    R = R0

    ## 1. Is there an economic incentive to install the levee?
    if (check_incentive) {
        if (!((F * G) >= (gamma_E * R * sqrt(G)))) {
            R = 0                
        }
    }
    
    ## 2. Is there enough wealth to install the levee?
    if (check_affordable) {
        ## if (!((G - F * G) >= (gamma_E * R * sqrt(G)))) {
        if (!(T >= (gamma_E * R * sqrt(G)))) {
            R = 0            
            if (allow_suboptimal) {
                ## determine the maximum levee height that can be installed
                R_max = (G - F * G) / (gamma_E * sqrt(G))
                R = R_max
            }        
        }
    }    
    R
}

## Parameters
## ##########

n_community = 2
n_scenario = 3

## proportion of additional high water level due to levee heightening
xi_H = array(rep(c(0.5,0.5), each=n_scenario), c(n_scenario, n_community))

## slope of floodplain, resilience of human settlement
alpha_H = array(rep(c(10,7), each=n_scenario), c(n_scenario, n_community))

## maximum relative growth rate 
rho_E = array(rep(c(1,1), each=n_scenario), c(n_scenario, n_community))

## cost for unit height R and width sqrt(G) of levee raising (0.005 -> inf)
gamma_E = array(rep(c(0.005,0.005), each=n_scenario), c(n_scenario, n_community))

## distance at which people would accept to live, remembering past floods (0.005 -> inf)
lambda_P = array(rep(c(1,1), each=n_scenario), c(n_scenario, n_community))

## rate by which new properties can be built
sigma_P = array(rep(c(0.1,0.1), each=n_scenario), c(n_scenario, n_community))

## safety factor for raising of levees
epsilon_T = array(rep(c(1.1,1.1), each=n_scenario), c(n_scenario, n_community))

## rate of decay of levees
keta_T = array(rep(c(0.1,0.1), each=n_scenario), c(n_scenario, n_community))

## proportion of shock after flooding if levees are raised (0 -> 1)
alpha_S = array(rep(c(0.5,0.5), each=n_scenario), c(n_scenario, n_community))

## memory loss rate (0.01 -> 10)
mu_S = array(rep(c(0.215,0.215), each=n_scenario), c(n_scenario, n_community))

## tax rate
tau = array(0.1, c(n_scenario, n_community))
tau[2,] = c(0.15,0.15)
tau[3,] = c(0.2,0.2)

## redistribution
omega = array(rep(c(0.9,0.1), each=n_scenario), c(n_scenario, n_community))

## arrays to store results
dims = list(
    "scenario" = sprintf("s%d", 1:n_scenario),
    "time" = 1:n_time,
    "community" = sprintf("c%d", 1:n_community)
)
F = array(0, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)
R = array(0, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)
R0 = array(0, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)
S = array(0, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)
G = array(0.01, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)
T = array(0, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)
D = array(1, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)
H = array(0, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)
M = array(0, c(n_scenario, n_time, n_community)) %>% `dimnames<-`(dims)

for (i in 1:n_scenario) {
    
    for (j in 1:(n_time - 1)) {

        for (k in 1:n_community) {

            ## proportion of settlement that is damaged
            if ((w[j] + xi_H[i,k] * H[i,j,k]) > H[i,j,k]) {
                F[i,j,k] = 1 - exp(-(w[j] + xi_H[i,k] * H[i,j,k]) / (alpha_H[i,k] * D[i,j,k]))
            } else {
                F[i,j,k] = 0
            }

            ## raising of levees: first calculate the theoretical
            ## amount by which the community would want to raise
            ## the levee
            R0[i,j,k] = compute_protection_increase(
                F[i,j,k], w[j], H[i,j,k], epsilon_T[i,k], xi_H[i,k]
            )

            ## T[i,j,] is populated in the previous time step, e.g.
            ## T[i,j+1,k] = ...
            ## Hence we can get the tax reserve by summing the
            ## current row            
            if (sum(omega[i,k]) > 0) {
                tax_reserve = sum(T[i,j,]) * omega[i,k]
            } else {
                tax_reserve = T[i,j,k]
            }            
            R[i,j,k] = constrain_protection_increase(
                R0[i,j,k], F[i,j,k], G[i,j,k], tax_reserve, gamma_E[i,k],
                check_incentive=TRUE,
                check_affordable=TRUE
            )

            ## shock magnitude
            if (R[i,j,k] > 0) {
                S[i,j,k] = F[i,j,k] * alpha_S[i,k]
            } else {
                S[i,j,k] = 0
            }

            ## value of Dirac comb
            if (w[j] > 0) {
                Delta = 1 / dt
            } else {
                Delta = 0
            }

            ## compute system dynamics without redistribution
            income = rho_E[i,k] * (1 - D[i,j,k]) * G[i,j,k]
            tax = income * tau[i,k]
            flood_damage = Delta * F[i,j,k] * G[i,j,k]
            cost_of_levee = Delta * gamma_E[i,k] * R[i,j,k] * sqrt(G[i,j,k])
            
            ## change in wealth
            dG_dt = (income - tax - flood_damage)
            ## dG_dt = (
            ##     income * (1 - tau[i,k])
            ##     - Delta * (F[i,j,k] * G[i,j,k] + gamma_E[i,k] * R[i,j,k] * sqrt(G[i,j,k]))
            ## )

            ## change in tax income
            dT_dt = tax - cost_of_levee

            ## change in distance from river
            dD_dt = (M[i,j,k] - D[i,j,k] / lambda_P[i,k]) * (sigma_P[i,k] / sqrt(G[i,j,k]))

            ## change in levee height
            dH_dt = Delta * R[i,j,k] - keta_T[i,k] * H[i,j,k]

            ## change in community memory
            dM_dt = Delta * S[i,j,k] - mu_S[i,k] * M[i,j,k]

            ## update state variables
            G[i,j+1,k] = G[i,j,k] + dG_dt * dt
            T[i,j+1,k] = T[i,j,k] + dT_dt * dt
            D[i,j+1,k] = D[i,j,k] + dD_dt * dt
            H[i,j+1,k] = H[i,j,k] + dH_dt * dt
            M[i,j+1,k] = M[i,j,k] + dM_dt * dt
        }
    }
}

