import time
import ee
import re

# Initialize the Earth Engine module.
ee.Initialize()

# Poopo region, + buffer of 1/2 degree:
xmin, ymin, xmax, ymax = -70.9250, -20.1250, -66.3250, -14.0250
xmin -= 0.5
ymin -= 0.5
xmax += 0.5
ymax += 0.5
region = ee.Geometry.Rectangle(xmin, ymin, xmax, ymax)
res = 1./120
ncol = int((xmax-xmin) / res)
nrow = int((ymax-ymin) / res)

# If you want to change the MODIS product you will need
# to change this part of the code
dataset = \
    ee.ImageCollection("MODIS/NTSG/MOD16A2/105") \
      .filter(ee.Filter.date('2001-01-01', '2020-01-01'))
et = dataset.select('ET')
pet = dataset.select('PET')
qc = dataset.select('ET_QC')

count = dataset.size()
print(count.getInfo())
et_list = et.toList(count)
pet_list = pet.toList(count)
qc_list = qc.toList(count)

tasks = []
for i in range(count.getInfo()):

    et_img = ee.Image(et_list.get(i))
    pet_img = ee.Image(pet_list.get(i))
    qc_img = ee.Image(qc_list.get(i))

    et_id = re.sub('/', '_', et_img.get('system:id').getInfo()) + '_ET'
    pet_id = re.sub('/', '_', pet_img.get('system:id').getInfo()) + '_PET'
    qc_id = re.sub('/', '_', qc_img.get('system:id').getInfo()) + '_QC'

    et_task = ee.batch.Export.image.toDrive(
        image=et_img,
        description=et_id,
        scale=1000,
        crs='EPSG:4326',
        region=region.getInfo()['coordinates'],
        maxPixels=2e9,
        fileFormat='GeoTIFF',
        folder='earthengine'
    )
    pet_task = ee.batch.Export.image.toDrive(
        image=pet_img,
        description=pet_id,
        scale=1000,
        crs='EPSG:4326',
        region=region.getInfo()['coordinates'],
        maxPixels=2e9,
        fileFormat='GeoTIFF',
        folder='earthengine'
    )
    qc_task = ee.batch.Export.image.toDrive(
        image=qc_img,
        description=qc_id,
        scale=1000,
        crs='EPSG:4326',
        region=region.getInfo()['coordinates'],
        maxPixels=2e9,
        fileFormat='GeoTIFF',
        folder='earthengine'
    )

    et_task.start()
    pet_task.start()
    qc_task.start()

    tasks.append(et_task)
    tasks.append(pet_task)
    tasks.append(qc_task)

