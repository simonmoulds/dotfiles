    def get_model_dimensions(self):
        super(GandakWBDataModel, self).get_model_dimensions()
        
        # latitudes = np.unique(pcr.pcr2numpy(pcr.ycoordinate(self.cloneMap), vos.MV))[::-1]
        # longitudes = np.unique(pcr.pcr2numpy(pcr.xcoordinate(self.cloneMap), vos.MV))        
        zLayer = np.array([0.05,0.295,2.])
        zLayerBot = np.cumsum(zLayer)
        zLayerTop = zLayerBot - zLayer
        zLayerMid = (zLayerTop + zLayerBot) / 2
        nLayer = zLayer.size
        zComp = np.array([0.1,0.1,0.1,0.15,0.15,0.2,0.2,0.25,0.25,0.25,0.25,0.3])
        zCompBot = np.cumsum(zComp)
        zCompTop = zCompBot - zComp
        zCompMid = (zCompBot + zCompTop) / 2
        nComp = zComp.size

        self.dimensions['layer'] = zLayerMid
        self.dimensions['compartment'] = zCompMid
        self.dimensions['crop'] = np.arange(self.nCrop)
        self.dimensions['farm'] = np.arange(self.nFarm)
        self.dimensions['category'] = np.arange(self.nFarmSizeCategory)

