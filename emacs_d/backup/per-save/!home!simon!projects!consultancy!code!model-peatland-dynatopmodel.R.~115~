library(magrittr)
library(dplyr)
library(raster)
library(sf)
library(sp)
library(rgdal)
library(xts)
library(topmodel)
library(dynatopmodel)
library(lulcc)
library(ggplot2)
library(ggspatial)

options(stringsAsFactors=FALSE)

## read precipitation and pet data
met_data_fn = file.path(
    "data-raw",
    "11_SWAT - Copy",
    "05_Meteo",
    "topmodel_hourly_met_data.csv"
)

topmodel_met_data =
    read.csv(met_data_fn, header=TRUE) %>%
    mutate(time=as.POSIXct(
               time,
               tz="GMT",
               format="%Y-%m-%d %H:%M:%S")
           )
    
topmodel_met_data = xts(
    data.frame(
        prec=topmodel_met_data$prec,
        eto=topmodel_met_data$eto
    ),
    order.by=topmodel_met_data$time
)

## spatial input data: dem, landcover, peatland
dem = raster("data-raw/11_SWAT - Copy/02_DEM/EU_DEM_v11.tif")

landcover = raster("data-raw/11_SWAT\ -\ Copy/06_Landcover/01_Baseline/Catchment_full_clip.tif") 
landcover_legend = read.csv("data-raw/11_SWAT\ -\ Copy/06_Landcover/01_Baseline/Landcover_codes.csv")
landcover = raster::aggregate(landcover, fact=5, fun=modal)
names(landcover) = "landcover"

peatland_restoration = readOGR("data-raw/11_SWAT\ -\ Copy/06_Landcover/04_Peatland_restoration_scenario3/01_Location_of_peatland_restoration_units", layer="Peatland_restoration_units")
peatland_restoration = spTransform(
    peatland_restoration,
    crs(landcover)
)
peatland_restoration_raster = rasterize(
    peatland_restoration,
    landcover,
    field="Area"
)
peatland_restoration_raster[!is.na(peatland_restoration_raster)] = 1

## ================================= ## 
## ================================= ##
## 1. Only peatland restoration area ## 
## ================================= ##
## ================================= ##

mask = raster("data-raw/11_SWAT - Copy/01_Study_area/Peatland combined/pcomb_dem.tif")
mask[!is.na(mask)] = 1

## use this handy function from dynatopmodel to build the
## required input maps (dem, upslope area, twi)
dem %<>% crop(extent(mask)) %>% `*`(mask)
maps = build_layers(dem, fill.sinks=TRUE, deg=0.1)
dem = maps[[1]]
topographic_wetness_index = maps[[3]]

## landcover
landcover %<>%
    crop(extent(mask)) %>%
    `*`(mask) %>%
    setNames("landcover")

## peatland
peatland_restoration_raster %<>%
    crop(extent(mask)) %>%
    `*`(mask)

## let's see where the peatland restoration
## sites appear on the larger catchment
plot(landcover)
lines(peatland_restoration)

## how is peatland classified on the landcover map?
area =
    peatland_restoration_raster %>%
    `*`(landcover) %>%
    total
ix = match(area$categories, landcover_legend$ID)
area = data.frame(
    LC_ID=area$categories,
    LC_NAME=landcover_legend$Landcover_name[ix],
    lC_NCELL=area$total[1,]
)
show(area)

## create a new landcover class, add to legend
landcover[!is.na(peatland_restoration_raster)] = 16
landcover_legend %<>%
    rbind(
        data.frame(
            Landcover_name="Restored peatland",
            ID=16
        )
    )

## build channel network and routing table
chans = build_chans(
    dem=dem,
    drn=NULL,
    atb=topographic_wetness_index
)
routing_table = build_routing_table(dem, chans)

## create RasterStack which will be used to discretize
## catchment
layers = addLayer(maps$dem, maps$atb, landcover)

## N.B. there is a bug here - if area.thresh is too small then
## the dimensions of 'groups' and 'weights' will not match up,
## and the simulation will fail - introduced a check
disc = discretise(
    layers,
    cuts=list(atb=16, landcover=6),
    chans=chans,
    area.thresh=2/100
)
if (dim(disc$groups)[1] != dim(disc$weights)[1]) {
    stop()
}

## map hru to land cover type, and compute area
tab =
    as.data.frame(stack(disc$hru, landcover), na.rm=TRUE) %>%
    setNames(c("HRU","LC_ID")) %>%
    unique

ix = match(tab$LC_ID, landcover_legend$ID)
tab %<>%
    mutate(LC_NAME = landcover_legend$Landcover_name[ix]) %>%
    arrange(HRU)

area = lulcc::total(landcover, tab$LC_ID)
ix = match(tab$LC_ID, area$categories)
tab %<>%
    mutate(LC_NCELL = area$total[ix])

show(tab)

start_time = as.POSIXct(
    "2016-01-01 00:00:00",
    tz="GMT",
    format="%Y-%m-%d %H:%M:%S"
)
end_time = as.POSIXct(
    "2016-04-01 00:00:00",
    tz="GMT",
    format="%Y-%m-%d %H:%M:%S"
)
time_ix = (
    (index(topmodel_met_data) >= start_time) &
    (index(topmodel_met_data) <= end_time)
)
rain = topmodel_met_data$prec[time_ix] / 1000
pe = topmodel_met_data$eto[time_ix] / 1000

q = run.dtm(
    groups=disc$groups,
    weights=disc$weights,
    rain=rain,    
    pe=pe,
    routing=routing_table,
    graphics.show=FALSE
)

## q$catch.area = 10307150
Qsim = q$qsim * q$catch.area
names(Qsim) = "Qsim"

ggplot(Qsim, aes(x=Index, y=Qsim)) +
    geom_line() +
    xlab("") +
    ylab(expression(paste("Discharge (m"^"3","/hour)")))
ggsave("data/dynatopmodel_peatland_combined_2016.png", width=6, height=5, units="in")

