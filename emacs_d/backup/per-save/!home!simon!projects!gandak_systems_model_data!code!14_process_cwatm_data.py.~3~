    lato.units = 'degrees_north'
    lato.standard_name = 'latitude'
    lato.long_name = 'longitude'
    lato[:]=lat

    dpth = d.createVariable('depth',np.float32,('depth'),zlib=True,least_significant_digit=16)
    dpth.units = 'meter'
    dpth.standard_name = 'depth'
    dpth.long_name = 'depth'
