    print(lc)
    
    rf1 = netCDF4.Dataset('../data/cwatm_input/landcover/' + lc + '/rootFraction1.nc')
    lat = rf1.variables['lat'][:][::-1]
    lon = rf1.variables['lon'][:]
    rf1_data = rf1.variables['rootFraction1'][:]
    rf1_data = np.flipud(rf1_data)
    rf1.close()

    rf2 = netCDF4.Dataset('../data/cwatm_input/landcover/' + lc + '/rootFraction2.nc')
    rf2_data = rf2.variables['rootFraction2'][:]
