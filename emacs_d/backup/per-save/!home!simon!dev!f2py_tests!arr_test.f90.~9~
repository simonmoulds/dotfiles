module multtests

  integer, parameter :: int32 = 4
  integer, parameter :: int64 = 8
  integer, parameter :: real32 = 4
  integer, parameter :: real64 = 8

contains

  subroutine MULT0(a,nrow,ncol)

    integer(int32), intent(in) :: nrow, ncol
    real(real64), dimension(nrow,ncol), intent(inout) :: a

    do i=1,nrow
       do j=1,ncol
          a(i,j) = a(i,j) * 3.14
       end do
    end do

  end subroutine MULT0
end module multtests


