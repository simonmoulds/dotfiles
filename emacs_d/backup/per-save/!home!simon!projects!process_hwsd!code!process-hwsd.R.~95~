library(raster)
library(rgdal)
library(rhwsd)
library(RSQLite)
library(rhwsd)
library(magrittr)
library(dplyr)

options(stringsAsFactors = FALSE)

system("unzip /data/hwsd/HWSD_RASTER.zip -d /data/hwsd/HWSD_RASTER")
hwsd = raster("/data/hwsd/HWSD_RASTER/hwsd.bil")
proj4string(hwsd) <-"+proj=longlat +datum=WGS84 +ellps=WGS84 +towgs84=0,0,0"
writeRaster(hwsd, "hwsd.tif", overwrite=TRUE)

con = get.hwsd.con()
dbListTables(con)
dbGetQuery(con, "pragma table_info(HWSD_DATA)")$name
records = dbGetQuery(con, "SELECT T.* from HWSD_DATA as T")

## CLYPPT - T|S_CLAY
## SNDPPT - T|S_SAND
## SLTPPT - T|S_SILT
## BLDFIE - T|S_BULK_DENSITY
## CECSOL - T|S_CEC_SOIL
## ORCDRC - T|S_OC
## PHIHOX - T|S_PH_H2O

## It's possible to do reclassification in R, but it's very slow.
## Hence we do the work in GRASS GIS, using R to write the reclass
## rules for module r.reclass.

## we will take the dominant class, rather than averaging

uids = records$MU_GLOBAL %>% as.integer

vars = apply(
    expand.grid(
        c("T_","S_"),
        c("SAND","SILT","CLAY","BULK_DENSITY","CEC_SOIL","OC","PH_H2O")),
    1,
    paste0,
    collapse=""
)
tbls = vector(mode="list", length(vars)) %>% setNames(vars)
for (i in 1:length(vars)) {
    tbls[[i]] = data.frame(id=uids, val=NA)
}

for (i in 1:length(uids)) {
    id = uids[i]
    xx = records %>% filter(MU_GLOBAL %in% id)
    idx = which.max(xx$SHARE)
    for (j in 1:length(vars)) {
        var = vars[j]
        tbls[[var]][["val"]][i] = xx[[var]][idx]
    }
}

for (i in 1:length(vars)) {
    tbls[[i]] %<>% filter(!is.na(.[["val"]]))
    fn=paste0(tolower(vars[i]), "_rcl.txt")
    if (file.exists(fn)) {
        unlink(fn)
    }    
    for (j in 1:nrow(tbls[[i]])) {
        cat(formatC(tbls[[i]][["id"]][j], width=-10), "=", tbls[[i]][["val"]][j], "\n", file=fn, append=TRUE)
    }
    cat(formatC("*", width=-10), "=", "NULL", "\n", file=fn, append=TRUE)
}

