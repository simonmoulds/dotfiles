
[globalOptions]

# Set the input directory map in an absolute path. The input
# forcing and parameter directories will be relative to this
inputDir  = /home/simon/projects/gandak_systems_model/land_surface/input

# output directory (absolute)
outputDir = /home/simon/projects/gandak_systems_model/land_surface/output

# Map of clone (must be provided in PCRaster maps)
# (Spatial resolution and coverage are based on this map)
cloneMap = Gandak05min.clone.map

# The area/landmask of interest:
landmask = Gandak05min.landmask.map

# netcdf attributes for output files:
institution = Centre for Water Systems, University of Exeter
title       = AquaCrop v5.0 output
description = test version (by Simon Moulds) 

# Format: YYYY-MM-DD
startTime = 1970-06-01
endTime = 1971-12-31
# startTime = 2001-01-01
# endTime = 2001-01-10
# endTime = 1983-11-01
# endTime   = 2016-10-30

# Simulate off season
OffSeason = 1

# Initial conditions
initialConditionNC = Gandak_initial_condition_data.nc
initialConditionType = Num
initialConditionInterpMethod = Layer

# If initialConditionInterpMethod = Depth, supply depths
initialConditionDepth = None

[meteoOptions]
precipitationNC = IMD_GRIDDED_RF_DATA_PT5_MERGED_{year:d}.nc
precipitationVariableName = prcp
# precipitationNC = Gandak_precipitation_data.nc
# precipitationVariableName = precipitation
precipitationConstant = 0.
precipitationFactor = 86400.

minDailyTemperatureNC = tmin_daily_{year:d}-{year:d}_gandak.nc
tminVariableName = tmin
tminConstant = -273.15
tminFactor = 1.

maxDailyTemperatureNC = tmax_daily_{year:d}-{year:d}_gandak.nc
tmaxVariableName = tmax
tmaxConstant = -273.15
tmaxFactor = 1.

refETPotFileNC = ETref_Hargreaves_dailyTot_output.nc
refETPotVariableName = reference_crop_evapotranspiration

[carbonDioxideOptions]
carbonDioxideNC = Gandak_co2_concentration.nc

[groundwaterOptions]
# WaterTable = 1
# VariableWaterTable = 1
# groundwaterNC = gwlevel_{day:d}_{month:d}_{year:d}.nc
# groundwaterVariableName = level
# DailyGroundwaterNC = 1
# timeLag = 1
# initialGroundwaterLevelNC = Gandak_initial_groundwater_level_data.nc
# groundwaterInputDir = /var/data/chanse_model/gwlevel

# static water table, for testing:
WaterTable = 1
VariableWaterTable = 0
groundwaterNC = Gandak_groundwater_level_data.nc
groundwaterVariableName = level
timeLag = 0
groundwaterInputDir = /home/simon/projects/gandak_systems_model/land_surface/input

[canalOptions]
Canal = 0
VariableCanalSupply = 0
canalNC = canalflow_{day:d}_{month:d}_{year:d}.nc
canalVariableName = flow
DailyCanalNC = 1
timeLag = 1
initialCanalSupplyNC = Gandak_initial_canal_supply.nc
canalInputDir = /var/data/chanse_model/GandakCanalModel/Output/NetCDF/Flows

[cropOptions]
nCrop = 8
cropParameterNC = Gandak_crop_parameters.nc
cropAreaNC = Gandak_crop_area.nc
cropAreaVariableName = crop_area
croplandAreaNC = Gandak_cropland_area.nc
croplandAreaVariableName = cropland_area
AnnualChangeInCropArea = 0

CalendarType = 2
SwitchGDD = 1
GDDmethod = 2

PotYieldNC = Gandak_potential_yield_data.nc
PotYieldVariableName = Yx
AnnualChangeInPotYield = False

[farmOptions]
nFarm = 25
nFarmSizeCategory = 5
farmAreaNC = Gandak_farm_parameters.nc
farmAreaVariableName = farm_area
AnnualChangeInFarmArea = 0

farmCategoryAreaNC = Gandak_farm_parameters.nc
farmCategoryAreaVariableName = farm_category_area
AnnualChangeInFarmCategoryArea = 0

farmCategoryNC = Gandak_farm_parameters.nc
farmCategoryVariableName = farm_category
AnnualChangeInFarmCategory = 0

initialTubewellOwnershipNC = Gandak_farm_parameters.nc
initialTubewellOwnershipVariableName = tubewell_ownership

[irrMgmtOptions]
irrMgmtParameterNC = Gandak_irrigation_parameters.nc
irrScheduleNC = None

[fieldMgmtOptions]
fieldMgmtParameterNC = Gandak_field_management_parameters.nc

AnnualChangeInFertiliserAppRate = 0
NitrogenApplicationRateNC = None
NitrogenApplicationRateVariableName = None
PhosphorusApplicationRateNC = None
PhosphorusApplicationRateVariableName = None
PotassiumApplicationRateNC = None
PotassiumApplicationRateVariableName = None

[priceOptions]
cropPriceNC = Gandak_crop_price_data.nc
cropPriceVariableName = crop_price
NitrogenPriceNC = Gandak_fertiliser_price_data.nc
NitrogenPriceVariableName = nitrogen_price
PhosphorusPriceNC = Gandak_fertiliser_price_data.nc
PhosphorusPriceVariableName = phosphorus_price
PotassiumPriceNC = Gandak_fertiliser_price_data.nc
PotassiumPriceVariableName = potassium_price
dieselPriceNC = Gandak_diesel_price_data.nc
dieselPriceVariableName = diesel_price

[soilOptions]
soilAndTopoNC = Gandak_soil_data.nc

[reportingOptions]
netcdf_y_orientation_follow_cf_convention = False
formatNetCDF = NETCDF4
zlib = True
outDailyFarmTotNC = zGW
outDailyTotNC = zGW
outMonthAvgNC = zGW
outYearMaxNC = Y,YieldMean,ProductionMean
outYearAvgNC = zGW
outYearTotNC = RechargeVolMean,IrrMean

