#!/bin/bash
export GRASS_MESSAGE_FORMAT=plain
wd=/home/simon/dev/gandak_data_model/data-raw
v.in.ogr input=$wd/data/india_village_level_geospatial_socio_econ/india-village-census-2001-BR.shp output=bihar_census_2001 --overwrite
# v.in.ogr input=$wd/data/india_village_level_geospatial_socio_econ/india-village-census-2001-UP.shp output=up_census_2001 --overwrite
g.region n=2867650 s=2857650 e=981800 w=971800 res=1000
# g.region n=3047800 s=2687500 e=1228900 w=734700 res=1000
g.region -p
v.mkgrid map=grid_1km --overwrite
v.db.addcolumn map=bihar_census_2001 columns="area_size double precision"
v.to.db map=bihar_census_2001 option=area columns=area_size unit=kilometers
# v.info -c bihar_census_2001
v.overlay ainput=bihar_census_2001 binput=grid_1km operator=and output=bihar_census_2001_grid snap=1e-8 --overwrite
v.db.addcolumn map=bihar_census_2001_grid columns="new_area_size double precision"
v.to.db map=bihar_census_2001_grid option=area columns=new_area_size unit=kilometers
v.db.addcolumn map=bihar_census_2001_grid columns="area_weight double precision"
v.db.update map=bihar_census_2001_grid column=area_weight qcol="new_area_size/a_area_size"

# # TEST - THIS IS WORKING
# v.out.ogr input=bihar_census_2001_grid output=test.gpkg format=GPKG --overwrite

declare -a columns=("a_LAND_FORES" "a_CANAL_GOVT" "a_WELL_WO_EL" "a_WELL_W_EL" "a_TW_WO_EL" "a_TW_W_EL" "a_TANK_IRR" "a_RIVER_IRR" "a_W_FALL" "a_OTH_IRR" "a_TOT_IRR" "a_UN_IRR" "a_CULT_WASTE" "a_AREA_NA_CU")

for column in "${columns[@]}"
do
    echo $newcol
    newcol="${column}"_wt
    v.db.addcolumn map=bihar_census_2001_grid columns="${newcol} DOUBLE PRECISION"
    v.db.update map=bihar_census_2001_grid column="${newcol}" qcol="${column}*area_weight"
done

# TEST - TODO
v.out.ogr input=bihar_census_2001_grid output=test.gpkg format=GPKG --overwrite

