## ICRISAT - farmers land holding size (1970-2010)
data(icrisat)
## bh_dists = c("Champaran","Muzaffarpur","Saran","Patna","Darbhanga","Saharsa","Shahabad")
## up_dists = c("Azamgarh","Gorakhpur","Ballia","Deoria")
library(readxl)
bihar_apy = read_excel("data/ICRISAT/Bihar/dt-area-prod-a.xls")
up_apy = read_excel("data/ICRISAT/UttarPradesh/dt-area-prod-a.xls")
icrisat_apy = rbind(bihar_apy, up_apy)
icrisat_ids = c(901,902,903,904,906,907,911,220,221,222,224)
icrisat_apy %<>%
    filter(DIST %in% icrisat_ids) %>%
    filter(YEAR %in% 1980:2010)

years = icrisat_apy$YEAR
years = paste0(years, "-", substr(years + 1, 3, 4))
icrisat_apy$YEAR = years

lut = data.frame(
    DIST=icrisat_ids,
    GAUL_ID=c(17618,17613,17598,730,17628,17619,644,17894,17914,72651,17892)
)

icrisat_apy %<>%
    left_join(lut, ., by="DIST") %>%
    select("STNAME","DISTNAME","GAUL_ID","YEAR","RICE_TA","RICE_TQ","WHT_TA","WHT_TQ","SCAN_TA","SGUR_TQ") %>%
    setNames(c("State","District","GAUL_ID","date","rice_area","rice_production","wheat_area","wheat_production","sugarcane_area","sugarcane_production")) %>%
    mutate(State = toupper(State)) %>%
    mutate(District = toupper(District)) %>%
    mutate(date = paste0("X", gsub("-","_",date))) %>%
    arrange(State,District) %>%
    group_by(State,District)

## icrisat lut
icrisat_lut = read.table(sep=",", header=TRUE, text="
State,District_new,District
Bihar,Pashchim Champaran,Champaran
Bihar,Purba Champaran,Champaran
Bihar,Sitamarhi,Muzaffarpur
Bihar,Gopalganj,Saran
Bihar,Muzaffarpur,Muzaffarpur
Bihar,Siwan,Saran
Bihar,Saran,Saran
Bihar,Samastipur,Darbhanga
Bihar,Vaishali,Muzaffarpur
Uttar Pradesh,Maharajganj,Gorakhpur
Uttar Pradesh,Kushinagar,Deoria
Uttar Pradesh,Gorakhpur,Gorakhpur
Uttar Pradesh,Deoria,Deoria
")

icrisat_lut %<>%
    mutate(State = toupper(State)) %>%
    mutate(District = toupper(District))

icrisat_apy %<>%
    filter(District %in% icrisat_lut$District) %>%
    right_join(icrisat_lut, ., by=c("District","State")) %>%
    mutate(rice_yield = rice_production / rice_area) %>%
    mutate(District = District_new) %>%
    select(-District_new) %>%
    mutate(wheat_yield = wheat_production / wheat_area) %>%
    mutate(sugarcane_yield = sugarcane_production / sugarcane_area) %>%
    select(-ends_with("_area")) %>%
    select(-ends_with("_production"))

write.csv(icrisat_apy, "data/icrisat_apy_districtwise.csv", row.names=FALSE)
