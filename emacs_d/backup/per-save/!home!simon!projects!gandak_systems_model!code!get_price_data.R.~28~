## Get price data from various sources, and create
## time series with consistent format

library(readxl)
library(magrittr)
library(tidyverse)

bihar_dists = c("Champaran","Muzaffarpur","Saran")
up_dists = c("Deoria","Gorakhpur")
dists = c(bihar_dists, up_dists)

## ==========================
## Fertiliser price - ICRISAT
## ==========================
bihar_fert_price =
    read_excel("data-raw/ICRISAT/Bihar/dt_fert_prices_a_web.xlsx", col_names=TRUE, na=c("-1"))

up_fert_price =
    read_excel("data-raw/ICRISAT/UttarPradesh/dt_fert_prices_a_web.xlsx", col_names=TRUE, na=c("-1"))

combined_fert_price = rbind(bihar_fert_price, up_fert_price)

combined_fert_price$ID = "Gandak"

combined_fert_price %<>%
    filter(DISTNAME %in% dists) %>%
    group_by(ID,YEAR) %>%
    summarise_at(vars(-STCODE,-STNAME,-DIST,-DISTNAME), funs(mean(., na.rm=TRUE)))

## ====================
## Crop price - ICRISAT
## ====================

bihar_crop_price =
    read_excel("data-raw/ICRISAT/Bihar/dt_fhp_a_web.xlsx", col_names=TRUE, na=c("-1"))

up_crop_price =
    read_excel("data-raw/ICRISAT/UttarPradesh/dt_fhp_a_web.xlsx", col_names=TRUE, na=c("-1"))

combined_crop_price = rbind(bihar_crop_price, up_crop_price)

combined_crop_price$ID = "Gandak"

combined_crop_price %<>%
    filter(DISTNAME %in% dists) %>%
    group_by(ID,YEAR) %>%
    summarise_at(vars(-STCODE,-STNAME,-DIST,-DISTNAME), funs(mean(., na.rm=TRUE)))

