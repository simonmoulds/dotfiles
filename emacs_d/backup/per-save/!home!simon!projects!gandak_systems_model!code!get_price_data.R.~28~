library(zoo)

## join data, fill in missing values using LOCF
gandak_price_data =
    left_join(combined_crop_price, combined_fert_price, by=c("ID","YEAR")) %>%
    ungroup %>%
    mutate_at(vars(-ID, -YEAR), funs(na.locf(., na.rm=FALSE, rule=1))) %>%
    mutate_at(vars(-ID, -YEAR), funs(na.locf(., fromLast=TRUE, na.rm=FALSE, rule=1)))


