#!/bin/bash

# Jan 2020

export DOMAIN=gandak
export WD=$HOME/dev/wbm/data-raw
export AUXDIR=$WD/data/aux

# Make output directories
declare -a SUBDIRS=()
for subdir in "${SUBDIRS[@]}"
do
    if [ ! -d $WD/data/$subdir ]
    then
	mkdir $WD/data/$subdir
    fi
done
    
MAPSET=$HOME/grassdata/latlong/wbm
if [ ! -d $MAPSET ]
then
    grass -e -c $MAPSET
fi

