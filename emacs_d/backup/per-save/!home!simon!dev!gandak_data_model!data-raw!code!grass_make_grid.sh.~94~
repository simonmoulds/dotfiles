export GRASS_MESSAGE_FORMAT=plain

wd=/home/simon/dev/gandak_data_model/data-raw
datadir=/data/india_village_level_geospatial_socio_econ_data

# bbox
north=36
south=22.5
east=98
west=68

# region settings
g.region \
    n=$north \
    s=$south \
    e=$east \
    w=$west \
    res=0:00:30 \
    save=india_30s \
    --overwrite

r.mapcalc "template = 1" --overwrite

