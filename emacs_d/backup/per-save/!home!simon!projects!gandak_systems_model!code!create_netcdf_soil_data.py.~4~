import numpy as np
import datetime
import os
import gdal
import netCDF4
import re

ds = gdal.Open('../data/ksat_topsoil_gapfilled_5m.tif')
a = ds.ReadAsArray()
nlat,nlon = np.shape(a)
xres = 1./12
yres = 1./12

b = ds.GetGeoTransform() #bbox, interval
minx = b[0]
maxx = b[0] + nlon * xres
maxy = b[3] 
miny = b[3] + nlat * -yres

lon = np.arange(0,nlon) * xres + (minx + xres/2)
lat = np.arange(0,nlat) * yres + (miny + yres/2)
lat = lat[::-1]
# lon = np.linspace(minx + xres/2, maxx - xres/2, nlon)
# lat = np.linspace(miny + yres/2, maxy - yres/2, nlat)
layer = np.array([0.3,2.])
nlayer = len(layer)

# dt = datetime.datetime(1979,1,1)
# end = datetime.datetime(2014,1,1)
# step = datetime.timedelta(days=1)
# times = []
# while dt < end:
#     times.append(dt)
#     dt += step

# create NetCDF file
nco = netCDF4.Dataset('../data/Gandak_soil_params.nc','w',clobber=True)

# create dimensions, variables and attributes:
nco.createDimension('lon',nlon)
nco.createDimension('lat',nlat)
nco.createDimension('layer',nlayer)

lono = nco.createVariable('lon',np.float64,('lon'),zlib=True,least_significant_digit=16)
lono.units = 'degrees_east'
lono.standard_name = 'longitude'
lono[:]=lon

lato = nco.createVariable('lat',np.float64,('lat'),zlib=True,least_significant_digit=16)
lato.units = 'degrees_north'
lato.standard_name = 'latitude'
lato[:]=lat

lyro = nco.createVariable('layer','f4',('layer'))
lyro.units = 'm'
lyro.standard_name = 'depth'
lyro.long_name = 'soil layer thickness'
lyro[:]=layer

# create container variable for CRS: lon/lat WGS84 datum
crso = nco.createVariable('crs','i4')
crso.long_name = 'Lon/Lat Coords in WGS84'
crso.grid_mapping_name='latitude_longitude'
crso.longitude_of_prime_meridian = 0.0
crso.semi_major_axis = 6378137.0
crso.inverse_flattening = 298.257223563

nco.Conventions='CF-1.6'

# field capacity
# ##############

thfc = nco.createVariable('th_fc', np.float64, ('layer', 'lat', 'lon'), zlib=True,fill_value=np.float64(1e+20))
thfc.setncattr('standard_name', 'soil_moisture_content_at_field_capacity')
thfc.setncattr('long_name', 'soil moisture at field capacity')
thfc.setncattr('units','kg.m-2')
thfc.setncattr('_FillValue', np.float64(1e+20))
thfc.setncattr('missing_value', np.float64(1e+20))
thfc0 = gdal.Open('../data/wcpf2_topsoil_gapfilled_5m.tif')
thfc0_arr = thfc0.ReadAsArray()
thfc1 = gdal.Open('../data/wcpf2_subsoil_gapfilled_5m.tif')
thfc1_arr = thfc0.ReadAsArray()
thfc[0,:,:] = thfc0_arr
thfc[1,:,:] = thfc1_arr

# field capacity
# ##############

thwp = nco.createVariable('th_wp', np.float64, ('layer', 'lat', 'lon'), zlib=True,fill_value=np.float64(1e+20))
thwp.setncattr('standard_name', 'soil_moisture_content')
thwp.setncattr('long_name', 'soil moisture at permanent wilting point')
thwp.setncattr('units','kg.m-2')
thwp.setncattr('_FillValue', np.float64(1e+20))
thwp.setncattr('missing_value', np.float64(1e+20))
thwp0 = gdal.Open('../data/wcpf4.2_topsoil_gapfilled_5m.tif')
thwp0_arr = thwp0.ReadAsArray()
thwp1 = gdal.Open('../data/wcpf4.2_subsoil_gapfilled_5m.tif')
thwp1_arr = thwp0.ReadAsArray()
thwp[0,:,:] = thwp0_arr
thwp[1,:,:] = thwp1_arr

# saturated water content
# #######################

thsat = nco.createVariable('th_s', np.float64, ('layer', 'lat', 'lon'), zlib=True,fill_value=np.float64(1e+20))
thsat.setncattr('standard_name', 'soil_moisture_content')
thsat.setncattr('long_name', 'soil moisture at saturation')
thsat.setncattr('units','kg.m-2')
thsat.setncattr('_FillValue', np.float64(1e+20))
thsat.setncattr('missing_value', np.float64(1e+20))
thsat0 = gdal.Open('../data/wcsat_topsoil_gapfilled_5m.tif')
thsat0_arr = thsat0.ReadAsArray()
thsat1 = gdal.Open('../data/wcsat_subsoil_gapfilled_5m.tif')
thsat1_arr = thsat0.ReadAsArray()
thsat[0,:,:] = thsat0_arr
thsat[1,:,:] = thsat1_arr

# residual water content
# ######################

thres = nco.createVariable('th_dry', np.float64, ('layer', 'lat', 'lon'), zlib=True,fill_value=np.float64(1e+20))
thres.setncattr('standard_name', 'soil_moisture_content')
thres.setncattr('long_name', 'residual soil moisture')
thres.setncattr('units','kg.m-2')
thres.setncattr('_FillValue', np.float64(1e+20))
thres.setncattr('missing_value', np.float64(1e+20))
thres0 = gdal.Open('../data/wcres_topsoil_gapfilled_5m.tif')
thres0_arr = thres0.ReadAsArray()
thres1 = gdal.Open('../data/wcres_subsoil_gapfilled_5m.tif')
thres1_arr = thres0.ReadAsArray()
thres[0,:,:] = thres0_arr
thres[1,:,:] = thres1_arr

# saturated hydraulic conductivity
# ################################

ksat = nco.createVariable('ksat', np.float64, ('layer', 'lat', 'lon'), zlib=True,fill_value=np.float64(1e+20))
ksat.setncattr('standard_name', 'soil_hydraulic_conductivity_at_saturation')
ksat.setncattr('long_name', 'soil hydraulic conductivity at saturation')
ksat.setncattr('units','m.s-1')
ksat.setncattr('_FillValue', np.float64(1e+20))
ksat.setncattr('missing_value', np.float64(1e+20))
ksat0 = gdal.Open('../data/ksat_topsoil_gapfilled_5m.tif')
ksat0_arr = ksat0.ReadAsArray()
ksat1 = gdal.Open('../data/ksat_subsoil_gapfilled_5m.tif')
ksat1_arr = ksat0.ReadAsArray()
ksat[0,:,:] = ksat0_arr
ksat[1,:,:] = ksat1_arr

# curve number
# ############

cn = nco.createVariable('CN', np.float64, ('lat', 'lon'), zlib=True,fill_value=np.float64(1e+20))
cn.setncattr('standard_name', 'curve_number')
cn.setncattr('long_name', 'curve number')
cn.setncattr('units','1')
cn.setncattr('_FillValue', np.float64(1e+20))
cn.setncattr('missing_value', np.float64(1e+20))
# cn0 = gdal.Open('../data/ksat_topsoil_gapfilled_5m.tif')
# cn[:] = cn0.ReadAsArray()
cn[:] = 50                      # TEMPORARY

# Other parameters (TODO: provide description)
# ################

calcshp = nco.createVariable('CalcSHP', np.int32, ('lat','lon'))
calcshp[:] = 0

evapzsurf = nco.createVariable('EvapZsurf', np.float64, ('lat','lon'))
evapzsurf[:] = 0.04

evapzmin = nco.createVariable('EvapZmin', np.float64, ('lat','lon'))
evapzmin[:] = 0.15

evapzmax = nco.createVariable('EvapZmax', np.float64, ('lat','lon'))
evapzmax[:] = 0.30

kex = nco.createVariable('Kex', np.float64, ('lat','lon'))
kex[:] = 1.1

fevap = nco.createVariable('fevap', np.int32, ('lat','lon'))
fevap[:] = 4

fwrelexp = nco.createVariable('fWrelExp', np.float64, ('lat','lon'))
fwrelexp[:] = 0.4

fwcc = nco.createVariable('fwcc', np.float64, ('lat','lon'))
fwcc[:] = 50

adjrew = nco.createVariable('AdjREW', np.int32, ('lat','lon'))
adjrew[:] = 0

rew = nco.createVariable('REW', np.float64, ('lat','lon'))
rew[:] = 9

adjcn = nco.createVariable('AdjCN', np.int32, ('lat','lon'))
adjcn[:] = 1

# cn = nco.createVariable('CN', np.float64, ('lat','lon'))
# cn[:] = 61

zcn = nco.createVariable('zCN', np.float64, ('lat','lon'))
zcn[:] = 0.3

zgerm = nco.createVariable('zGerm', np.float64, ('lat','lon'))
zgerm[:] = 0.3

zres = nco.createVariable('zRes', np.float64, ('lat','lon'))
zres[:] = -999

fshape_cr = nco.createVariable('fshape_cr', np.float64, ('lat','lon'))
fshape_cr[:] = 16

# close netCDF
nco.close()

