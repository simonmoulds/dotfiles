# store the selected data source code
selected_datasource_code = "Tahmo.Stations.Data.Distribution.Hourly"

# TAHMO stations are spread over continental Africa
# we can ask the available locations through the TWIGA API

def main():
    # again we define a JSON request which we can send the the TWIGA API
    request_locations_tahmo = {
        "DataSourceCodes" : [selected_datasource_code],
        "StartDate" : "20170101000000",
        "EndDate" : "20180101000000"
    }

    # This time we send the request to the variables endpoint of the API
    locations_tahmo_response = requests.post(
        api + 'entity/locations/get',
        headers=api_header,
        data=json.dumps(request_locations_tahmo)
    )

    # The response of the API is in JSON. Parse this with Python
    locations_tahmo = locations_tahmo_response.json()
    location_codes = []
    location_names = []
    for loc in locations_tahmo['Locations'].keys():
        location_codes.append(locations_tahmo['Locations'][loc]["Code"])
        location_names.append(locations_tahmo['Locations'][loc]["Name"])

    # Try to retrieve data of TAHMO stations within an extent (e.g. Ghana)
    # N.B. "A spatial filter is required when requesting time series, either in the
    # form of LocationCodes or an Extent. When requesting grids, model grids or
    # ensemble grids as time series, this option cannot be used, since grid data is
    # not stored in locations as such."
    location_codes = location_codes[117:]
    for loc in location_codes:
        print(loc)
        request_tahmo_data = {
            "Readers": [{
                "DataSourceCode": selected_datasource_code,
                "Settings": {
                    # "LocationCodes": [tahmo_kmd_code],
                    "LocationCodes": [loc],
                    "VariableCodes": ["P"],
                    "StartDate": "20170101000000",
                    "EndDate": "20191115000000",
                    # "Extent" : {
                    #     "Xll" : 0,
                    #     "Yll" : 0,
                    #     "Xur" : 10,
                    #     "Yur" : 10,
                    #     "SpatialReference": {
                    #         "Epsg" : 4326
                    #     }
                    # },
                    "StructureType": "TimeSeries"
                }
            }]
        }

        # send the request to the TWIGA API, this time the modelTimeseries endpoint
        data_response = requests.post(
            api + 'data/get',
            headers=api_header,
            data=json.dumps(request_tahmo_data)
        )

        # parse response into JSON object
        tahmo_data = data_response.json()

        try:
            tahmo_data_df = pd.DataFrame(tahmo_data['Data'][0]['Data'])
            tahmo_data_df['Location'] = loc

            # convert the DateTime from string into datetime objects
            tahmo_data_df['DateTime'] = pd.to_datetime(tahmo_data_df['DateTime'])

            # rename the Value column to the name of the variable
            tahmo_data_df = tahmo_data_df.rename(columns={"Value": "P"})

            # we can now save the data to a csv file on your local computer
            fn = "tahmo_stn_" + loc + "_prec.csv"
            tahmo_data_df.to_csv(fn, index=False)
        except:
            print("Downloading data for station " + loc + " unsuccessful")

if __name__ == "__main__":
    main()
