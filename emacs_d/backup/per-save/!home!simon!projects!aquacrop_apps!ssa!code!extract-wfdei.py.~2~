import shutil
import os
import glob

wd = '/home/simon/projects/aquacrop_apps/ssa'

def run():
    wfdei_years = range(1979,2017)
    wfdei_vars = ['LWdown','PSurf','Qair','Rainf','Snowf','SWdown','Tair','Wind']
    try:
        os.mkdir("../data/WFDEI")
    except FileExistsError:
        pass
    for var in wfdei_vars:
        dir = os.path.join(
            '..',
            'data-raw',
            'WFDEI',
            var + '_daily_WFDEI'
            )
        newdir = os.path.join(
            '..',
            'data',
            'WFDEI',
            var + '_daily_WFDEI'
            )
        try:
            os.mkdir(newdir)
        except FileExistsError:
            pass
        
        fs = glob.glob(dir + '/*.gz')
        for f in fs:
            newf = os.path.join(
                newdir,
                os.path.splitext(
                    os.path.basename(f)
                )[0]
            )
            os.system("gunzip -v -c " + str(f) + " >! " + os.path.splitext(f)[0])
            
if __name__ == '__main__':
    run()
            
