library(magrittr)
library(lubridate)
library(dplyr)

datadir = "../data/pt_met_data/"

options(stringsAsFactors = FALSE)
x = read.csv(
    file.path(
        datadir,
        "tahmo_era5_stn_TA00339_met_2016-2019.csv"
    )
)
x$DATE %<>% as.POSIXct(format="%Y-%m-%d")
x$YEAR = year(x$DATE)
x$MONTH = month(x$DATE)
x$DATE %<>% as.POSIXct

library(ggplot2)
p = ggplot(x, aes(x=DATE, y=P_TAHMO)) +
    geom_bar() +
    geom_point()
