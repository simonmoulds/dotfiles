## maize
## #####

if (dist_nm %in% c("South Sikkim")) {
    xx[["apy_maize-kharif"]] %<>% locf_interp(6)
}

## other cereals
## #############

xx[["apy_other_cereals-kharif"]] %<>% locf_interp(2:4)
xx[["apy_other_cereals-rabi"]] %<>% locf_interp(2:4)

## other oil crops
## ###############

if (dist_nm %in% c("East")) {
    xx[["apy_other_oil_crops-kharif"]] %<>% locf_interp(2:11)
}

if (dist_nm %in% c("South Sikkim","West Sikkim")) {
    xx[["apy_other_oil_crops-kharif"]] %<>% locf_interp(2:4)
    xx[["apy_other_oil_crops-kharif"]] %<>% locf_interp(7:11)
}

