#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import string
import numpy as np
from . import file_handling as vos
from . import Messages

class Wind(object):
    
    def __init__(self, Wind_variable):
        self.var = Wind_variable

    def initial(self):
        self.set_wind_input_filenames()

    def set_wind_input_filenames(self):
        keys = ['nearSurfaceWindSpeedNC',
                'nearSurfaceWindSpeedVarName',
                'nearSurfaceWindSpeedTimeDimName']
        vals = [self.var._configuration.WEATHER[key] for key in keys]        
        self.var.windFileNC = vals[0]
        self.var.windVarName = vals[1]
        self.var.windTimeDimName = vals[2]
        
    def read_wind_data(self):
        day, month, year = (self.var._modelTime.currTime.day,
                            self.var._modelTime.currTime.month,
                            self.var._modelTime.currTime.year)
        self.var.wind = vos.netcdf2PCRobjClone(
            self.var.windFileNC.format(day=day, month=month, year=year),
            self.var.windVarName,
            str(self.var._modelTime.fulldate),
            useDoy = None,
            cloneMapFileName = self.var.cloneMap,
            # cloneMapAttributes = self.var.cloneMapAttributes,
            LatitudeLongitude = True)[self.var.landmask]

        z = 10. # height of wind speed variable (10 meters above surface)
        self.var.wind_2m = self.var.wind * 4.87 / (np.log(67.8 * z - 5.42))        

    def dynamic(self):
        self.read_wind_data()
        
