import numpy as np

import logging
logger = logging.getLogger(__name__)

class RootZoneWater(object):
    def __init__(self, land_cover):
        self.land_cover = land_cover

    def initial(self):
        arr_zeros = np.zeros(
            (self.land_cover.nFarm,
             self.land_cover.nCrop,
             self.land_cover.model.nLayer,
             self.land_cover.model.nCell)
        )
        self.land_cover.readily_available_water = arr_zeros.copy()
        self.land_cover.total_available_water = arr_zeros.copy()
        self.land_cover.wc_crit = arr_zeros.copy()
        self.update_root_zone_water_content()
        
    def update_root_zone_water_content(self):
        self.land_cover.wc = self.land_cover.th * self.land_cover.root_depth

    def compute_root_zone_depletion_factor(self):
        ETpot = np.minimum(0.1 * (self.land_cover.ETpot * 1000.), 1.)
        p = 1. / (0.76 + 1.5 * ETpot) - 0.4
        p += (ETpot - 0.6) / 4.
        p = p.clip(0., 1.)
        self.land_cover.root_zone_depletion_factor = p.copy()
        self.land_cover.root_zone_depletion_factor = np.broadcast_to(
            self.land_cover.root_zone_depletion_factor[:,:,None,:],
            (self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nLayer, self.land_cover.model.nCell))
        
    def compute_critical_water_content(self):
        # CWATM, soil.py, lines 210-212
        self.compute_root_zone_depletion_factor()
        self.land_cover.wc_crit = (
            ((1. - self.land_cover.root_zone_depletion_factor)
             * (self.land_cover.wc_fc - self.land_cover.wc_wp))
            + self.land_cover.wc_wp)

    def compute_readily_available_water(self):
        self.update_root_zone_water_content()
        self.land_cover.readily_available_water = (
            np.maximum(0., self.land_cover.wc - self.land_cover.wc_wp)
        )        
        # self.land_cover.readily_available_water = (
        #     np.maximum(0., self.land_cover.wc - self.land_cover.wc_wp)
        #     * self.land_cover.root_depth)

    def compute_total_available_water(self):
        self.land_cover.total_available_water = (
            np.maximum(0., self.land_cover.wc_fc - self.land_cover.wc_wp)
        )
        # self.land_cover.total_available_water = (
        #     np.maximum(0., self.land_cover.wc_fc - self.land_cover.wc_wp)
        #     * self.land_cover.root_depth)
        
    def dynamic(self):
        self.update_root_zone_water_content()
        self.compute_critical_water_content()
        self.compute_readily_available_water()
        self.compute_total_available_water()
        # print 'raw :',self.land_cover.readily_available_water[0,0,:,0]
        # print 'taw :',self.land_cover.total_available_water[0,0,:,0]
        # print 'crit:',self.land_cover.critical_available_water[0,0,:,0]

class RootZoneWaterNaturalVegetation(RootZoneWater):
    
    def compute_root_zone_depletion_factor(self):
        # CWATM, soil.py, lines 182-206
        
        # CWATM, soil.py, line 183: "to avoid a strange
        # behaviour of the p-formula's, ETref is set to a
        # maximum of 10mm/day"
        ETpot = np.minimum(0.1 * (self.land_cover.ETpot * 1000.), 1.)        
        p = 1. / (0.76 + 1.5 * ETpot) - 0.1 * (5. - self.land_cover.crop_group_number)
        p = np.where(
            self.land_cover.crop_group_number <= 2.5,
            p + (ETpot - 0.6)
             / (self.land_cover.crop_group_number
                * (self.land_cover.crop_group_number + 3.)),
            p)
        p = p.clip(0., 1.)
        self.land_cover.root_zone_depletion_factor = p.copy()
        self.land_cover.root_zone_depletion_factor = np.broadcast_to(
            self.land_cover.root_zone_depletion_factor[:,:,None,:],
            (self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nLayer, self.land_cover.model.nCell))
    
class RootZoneWaterIrrigatedLand(RootZoneWater):
    def compute_root_zone_depletion_factor(self):
        # do not use crop group number for irrigated crops,
        # because we assume that irrigated crops have low
        # adaptation to dry climate
        ETpot = np.minimum(0.1 * (self.land_cover.ETpot * 1000.), 1.)
        p = 1. / (0.76 + 1.5 * ETpot) - 0.4
        p += (ETpot - 0.6) / 4.
        p = p.clip(0., 1.)
        self.land_cover.root_zone_depletion_factor = p.copy()
        self.land_cover.root_zone_depletion_factor = np.broadcast_to(
            self.land_cover.root_zone_depletion_factor[:,:,None,:],
            (self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nLayer, self.land_cover.model.nCell))
