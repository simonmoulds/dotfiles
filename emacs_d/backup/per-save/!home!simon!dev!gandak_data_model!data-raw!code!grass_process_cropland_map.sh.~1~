# import land use/land cover data
r.in.gdal \
    input=/data/Decadal_LULC_India_1336/data/LULC_2005.tif \
    output=lulc_2005 \
    --overwrite

echo "1 = 0
2       = 1
3 thru 19 = 0
*       = NULL" > lulc_reclass_rules.txt
r.reclass \
    input=lulc_2005 \
    output=lulc_2005_crop \
    rules=lulc_reclass_rules.txt \
    --overwrite
