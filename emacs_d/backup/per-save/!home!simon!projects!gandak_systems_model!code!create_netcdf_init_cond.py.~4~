import numpy as np
import datetime
import os
import gdal
import netCDF4
import re

ds = gdal.Open('../data/ksat_topsoil_gapfilled_5m.tif')
a = ds.ReadAsArray()
nlat,nlon = np.shape(a)
xres = 1./12
yres = 1./12

b = ds.GetGeoTransform() #bbox, interval
minx = b[0]
maxx = b[0] + nlon * xres
maxy = b[3] 
miny = b[3] + nlat * -yres

lon = np.arange(0,nlon) * xres + (minx + xres/2)
lat = np.arange(0,nlat) * yres + (miny + yres/2)
lat = lat[::-1]
layer = np.array([0.3,2.])
nlayer = len(layer)

# dt = datetime.datetime(1979,1,1)
# end = datetime.datetime(2014,1,1)
# step = datetime.timedelta(days=1)
# times = []
# while dt < end:
#     times.append(dt)
#     dt += step

# create NetCDF file
nco = netCDF4.Dataset('../data/Gandak_initial_water_content.nc','w',clobber=True)

# create dimensions, variables and attributes:
nco.createDimension('lon',nlon)
nco.createDimension('lat',nlat)
nco.createDimension('layer',nlayer)

lono = nco.createVariable('lon',np.float64,('lon'),zlib=True,least_significant_digit=16)
lono.units = 'degrees_east'
lono.standard_name = 'longitude'
lono[:]=lon

lato = nco.createVariable('lat',np.float64,('lat'),zlib=True,least_significant_digit=16)
lato.units = 'degrees_north'
lato.standard_name = 'latitude'
lato[:]=lat

lyro = nco.createVariable('layer','f4',('layer'))
lyro.units = 'm'
lyro.standard_name = 'depth'
lyro.long_name = 'soil layer thickness'
lyro[:]=layer

# create container variable for CRS: lon/lat WGS84 datum
crso = nco.createVariable('crs','i4')
crso.long_name = 'Lon/Lat Coords in WGS84'
crso.grid_mapping_name='latitude_longitude'
crso.longitude_of_prime_meridian = 0.0
crso.semi_major_axis = 6378137.0
crso.inverse_flattening = 298.257223563

nco.Conventions='CF-1.6'

# initial condition - assume soil at field capacity

thini = nco.createVariable('th', np.float64, ('layer', 'lat', 'lon'), zlib=True,fill_value=np.float64(1e+20))
thini.setncattr('standard_name', 'soil_moisture_content_at_field_capacity')
thini.setncattr('long_name', 'soil moisture at field capacity')
thini.setncattr('units','kg.m-2')
thini.setncattr('_FillValue', np.float64(1e+20))
thini.setncattr('missing_value', np.float64(1e+20))
thfc0 = gdal.Open('../data/wcpf2_topsoil_gapfilled_5m.tif')
thfc0_arr = thfc0.ReadAsArray()
thfc1 = gdal.Open('../data/wcpf2_subsoil_gapfilled_5m.tif')
thfc1_arr = thfc0.ReadAsArray()
thini[0,:,:] = thfc0_arr
thini[1,:,:] = thfc1_arr

# close netCDF
nco.close()

