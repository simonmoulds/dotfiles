class SoilParameters(object):
    def __init__(self, SoilParameters_variable):
        self.var = SoilParameters_variable
        self.var.nLayer = 2     # TODO: put this in config
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)
        
    def initial(self):
        arr_zeros = np.zeros((self.var.nLayer, self.var.nLat, self.var.nLon))
        soil_parameters_with_depth = ['th_fc','th_wp','th_s','th_dry','ksat']
        for param in soil_parameters_with_depth:
            vars(self.var)[param] = arr_zeros.copy()
            
        # arr_zeros = np.zeros((self.var.nLat, self.var.nLon))
        # soil_parameters_without_depth = [
        #     'CN','CalcSHP','EvapZsurf','EvapZmin','EvapZmax','Kex',
        #     'fevap','fWrelExp','fwcc','AdjREW','REW','AdjCN','zCN',
        #     'zGerm','zRes','fshape_cr']
        # for param in soil_parameters_without_depth:
        #     vars(self.var)[param] = arr_zeros.copy()
        # self.var.soil_parameters = soil_parameters_with_depth + soil_parameters_without_depth

    def get_package_data_filename(self, filename):
        return get_data_smart('gandak_data_model',filename,as_string=False)
    
    def read_soil_data(self, filename):
        d = []
        for layer in range(self.var.nLayer):
            fn = filename.format(layer=layer)
            d.append(read_gdal_raster_image(fn, self.bbox, 0))
        d = np.stack(d, axis=0)
        return d                        

    def write_netcdf(self, filename, variable_name, data):
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(
            filename,
            variable_name)        
        netcdf.data2NetCDF(
            filename,
            variable_name,
            data)
        
    def dynamic(self):
        
        # soil depth
        # ##########
        soil_path_out = str(self.var._configuration.SOIL['soilPathOut'])        
        shutil.copy(
            str(self.var._configuration.SOIL['soilDepthOneInputFile']),
            soil_path_out)
        
        shutil.copy(
            str(self.var._configuration.SOIL['soilDepthTwoInputFile']),
            soil_path_out)
            
        # soil parameters
        # ###############        
        lc_types = [lc.strip() for lc in self.var._configuration.LANDCOVER['landCoverTypes'].split(',')]
        veg_types = ['forest','grassland','irrPaddy','irrNonPaddy']
        natural_veg_types = ['forest','grassland']
        for lc in lc_types:
            config_section = getattr(self.var._configuration, lc)

            if lc in veg_types:            
                th_fc_inpath = config_section['fieldCapacityInputFile']
                th_fc = self.read_soil_data(th_fc_inpath)
                th_fc_outpath = str(config_section['fieldCapacityOutputFile'])
                th_fc_varname = str(config_section['fieldCapacityOutputVariableName'])
                self.write_netcdf(
                    th_fc_outpath,
                    th_fc_varname,
                    th_fc)

                th_wp_inpath = config_section['wiltingPointInputFile']
                th_wp = self.read_soil_data(th_wp_inpath)
                th_wp_outpath = config_section['wiltingPointOutputFile']
                th_wp_varname = str(config_section['wiltingPointOutputVariableName'])
                self.write_netcdf(
                    th_wp_outpath,
                    th_wp_varname,
                    th_wp)

                th_sat_inpath = config_section['saturatedWaterContentInputFile']
                th_sat = self.read_soil_data(th_sat_inpath)
                th_sat_outpath = config_section['saturatedWaterContentOutputFile']
                th_sat_varname = str(config_section['saturatedWaterContentOutputVariableName'])
                self.write_netcdf(
                    th_sat_outpath,
                    th_sat_varname,
                    th_sat)

                th_dry_inpath = config_section['residualWaterContentInputFile']
                th_dry = self.read_soil_data(th_dry_inpath)
                th_dry_outpath = config_section['residualWaterContentOutputFile']
                th_dry_varname = str(config_section['residualWaterContentOutputVariableName'])
                self.write_netcdf(
                    th_dry_outpath,
                    th_dry_varname,
                    th_dry)

                ksat_inpath = config_section['KsatInputFile']
                ksat = self.read_soil_data(ksat_inpath)
                ksat_outpath = config_section['KsatOutputFile']
                ksat_varname = str(config_section['KsatOutputVariableName'])
                self.write_netcdf(
                    ksat_outpath,
                    ksat_varname,
                    ksat)
