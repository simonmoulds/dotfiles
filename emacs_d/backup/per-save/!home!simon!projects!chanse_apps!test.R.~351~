## ################################### ##
## simulation options
## ################################### ##

n_farmer = 50
n_crop = 2

start_time = as.POSIXlt("2000-01-01", tz="GMT", format="%Y-%m-%d")
end_time = as.POSIXlt("2017-10-31", tz="GMT", format="%Y-%m-%d")
ts = seq(start_time, end_time, by="1 day")

## ################################### ##
## weather data
## ################################### ##

climate_data = read.table(
    file.path("data", "sult_base_all_data_irr2.txt"),
    header=TRUE
) %>% 
    dplyr::mutate(date=as.POSIXct(date, tz="GMT", format="%Y-%m-%d"))

weather_ts =
    climate_data %>% 
    dplyr::select(etref=ETo_mm, precip=precip) %>%
    as.xts(order.by=climate_data$date) %>%
    merge(as.xts(ts), ., join="left")

## ################################### ##
## socioeconomic data
## ################################### ##

fertiliser_price_data = read.table(
    file.path("data", "sult_base_all.variables_yield_interp_fert_cons.txt"),
    header=TRUE
) %>%
    dplyr::mutate(date=as.POSIXct(year, tz="GMT", format="%Y-%m-%d"))

fertiliser_price_ts =
    fertiliser_price_data %>%
    dplyr::select(n=fert_n_p_per_kg, p=fert_p_p_per_kg, k=fert_k_p_per_kg) %>%
    as.xts(order.by=fertiliser_price_data$date)

diesel_price_data = read.table(
    file.path("data", "sult_base_diesel_prices_long.txt"),
    header=TRUE
) %>%
    dplyr::mutate(date=as.POSIXct(year, tz="GMT", format="%Y-%m-%d"))

diesel_price_ts =
    diesel_price_data %>%
    dplyr::select(diesel=dp) %>%
    as.xts(order.by=diesel_price_data$date)

well_price_data = read.table(
    file.path("data", "well_cost_long.txt"),
    header=TRUE
) %>%
    dplyr::mutate(date=as.POSIXct(year, tz="GMT", format="%Y-%m-%d"))

well_price_ts =
    well_price_data %>%
    dplyr::select(well=well_cost) %>%
    as.xts(order.by=well_price_data$date)

## merge data 
price_ts =
    merge(fertiliser_price_ts, well_price_ts, diesel_price_ts) %>%
    na.locf %>% 
    merge(as.xts(ts), ., join="left") %>%
    na.locf

