# -*- coding: utf-8 -*-

import os
import time
import numpy as np
from hydro_model_builder import VirtualOS as vos
from aquacrop.Messages import *

import logging
logger = logging.getLogger(__name__)

class CanalAccess(object):

    def __init__(self, CanalAccess_variable):
        self.var = CanalAccess_variable

    def initial(self):
        initialCanalAccessNC = str(self.var._configuration.canalOptions['initialCanalAccessNC'])
        try:
            canal_access = vos.netcdf2PCRobjCloneWithoutTime(
                initialCanalAccessNC,
                canal_access_varname,
                cloneMapFileName = self.var.cloneMap,
                LatitudeLongitude = True)
        except:
            canal_access = np.ones((self.var.nFarm, self.var.nLat, self.var.nLon))

        self.var.CanalAccess = canal_access.copy()

    def dynamic(self):
        pass
