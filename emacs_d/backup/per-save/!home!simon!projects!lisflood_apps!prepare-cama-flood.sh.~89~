#!/bin/bash

wd=$HOME/projects/lisflood_apps
auxdir=$wd/aux
if [ ! -d $auxdir ]
then
    mkdir $auxdir
fi
cd $wd

if [ ! -d $wd/CaMa-Flood_v396_20191225/ ]
then
    # rm -rf $wd/CaMa-Flood_v396_20191225/
    tar xvf $wd/CaMa-Flood_v396_20191225.tar.gz
fi

cd $wd/CaMa-Flood_v396_20191225/map
if [ ! -d glb_15min_orig ]
then   
    mv glb_15min glb_15min_orig
fi

for datadir in glb_05min glb_06min glb_15min
do    
    cp ../../${datadir}.tar.gz .
    tar xvf ${datadir}.tar.gz
    cp -r glb_15min_orig/src_param ${datadir}
    cd ${datadir}/src_param
    sed -i 's/Mkinclude/Mkinclude_Mac_gfortran/' Makefile    
    make clean
    make all
    bash s01-channel_params.sh
    cd ..
    cp rivlen.ctl rivman.ctl
    sed -i 's/rivlen.bin/rivman.bin/' rivman.ctl
    cd ..
done

