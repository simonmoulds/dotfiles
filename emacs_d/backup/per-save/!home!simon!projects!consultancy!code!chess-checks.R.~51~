## Convert coords here: https://epsg.io/
            
library(ncdf4)

start_ts = as.POSIXct("2012-01-01", tz="GMT", format="%Y-%m-%d")
end_ts = as.POSIXct("2015-12-31", tz="GMT", format="%Y-%m-%d")
ts = seq(start_ts, end_ts, by="1 day")
precip = rep(NA, length(ts))
eto = rep(NA, length(ts))
years = 2012:2015
months = formatC(1:12, width=2, flag=0)

## =============
## precipitation
## =============

start_ix = 1
for (i in 1:length(years)) {
    year = years[i]
    for (j in 1:length(months)) {
        month = months[j]
        fn = paste0("chess_precip_", year, month, ".nc")     
        nc = nc_open(file.path("/data", "CHESS", fn))
        x = ncvar_get(nc, "x")
        y = ncvar_get(nc, "y")
        t = ncvar_get(nc, "time")
        lat = ncvar_get(nc, "lat")
        lon = ncvar_get(nc, "lon")
        x_index = which(x %in% 367500)
        y_index = which(y %in% 607500)
        precip_mon = ncvar_get(nc, "precip")
        precip_mon = precip_mon[x_index,y_index,]
        end_ix = start_ix + length(t) - 1
        precip[start_ix:end_ix] = precip_mon
        start_ix = end_ix + 1
        nc_close(nc)
    }
}

## ============
## reference et
## ============

start_ix = 1
for (i in 1:length(years)) {
    year = years[i]
    for (j in 1:length(months)) {
        month = months[j]
        fn = paste0("chess_pet_wwg_", year, month, ".nc")     
        nc = nc_open(file.path("/data", "CHESS", fn))
        x = ncvar_get(nc, "x")
        y = ncvar_get(nc, "y")
        t = ncvar_get(nc, "time")
        ## lat = ncvar_get(nc, "lat")
        ## lon = ncvar_get(nc, "lon")
        x_index = which(x %in% 367500)
        y_index = which(y %in% 607500)
        eto_mon = ncvar_get(nc, "pet")
        eto_mon = eto_mon[x_index,y_index,]
        end_ix = start_ix + length(t) - 1
        eto[start_ix:end_ix] = eto_mon
        start_ix = end_ix + 1
        nc_close(nc)
    }
}

