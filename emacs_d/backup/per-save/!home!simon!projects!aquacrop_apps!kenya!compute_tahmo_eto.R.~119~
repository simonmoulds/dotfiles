library(water)
library(magrittr)
library(dplyr)
library(zoo)

options(stringsAsFactors = FALSE)

tahmo_data = read.csv("tahmo_weather_data.csv")
meta = read.csv("tahmo_stn_metadata.csv")
stns = unique(x$Station)
n_stns = length(stns)

wd_list = vector(mode="list", length=n_stns)

for (i in 1:length(stns)) {

    m = meta %>% dplyr::filter(Code %in% stns[i])    
    wd =
        tahmo_data %>%
        dplyr::filter(Station %in% stns[i]) %>%
        dplyr::select("DateTime","WindSpeed","RH","TMP","Radiation","P") %>%
        setNames(c("datetime","wind","RH","temp","radiation","prec"))
    
    wd$datetime %<>% as.POSIXct(tz="UTC", format="%m/%d/%Y %H:%M")

    ## create complete time series
    t0 = as.POSIXlt(wd$datetime[1])
    t0 = as.POSIXct(
        paste0(
            t0$year + 1900, "-",
            t0$mon + 1, "-",
            t0$mday, "00:00"
        ),
        tz="UTC"
    )
    t1 = as.POSIXlt(wd$datetime[length(wd$datetime)])
    t1 = as.POSIXct(
        paste0(
            t1$year + 1900, "-",
            t1$mon + 1, "-",
            t1$mday, "23:00"
        ),
        tz="UTC"
    )    
    ts = data.frame(datetime=seq.POSIXt(t0, t1, by="1 hour"))
    wd = wd %>% right_join(ts)
    
    wd$height = 2 # assumed height of weather station
    wd$lat = m$Y
    wd$long = m$X
    wd$elev = m$Z
    ## NB time is given in UTC, so long.z = 0 in all cases (I think!)
    ## TODO: double check units
    eto = hourlyET(wd, ET="ETo", long.z=0)
    wd$eto = eto

    ## compute daily summaries

    ## NB at this point we may want to convert to local time, so that tmin/tmax etc. refer to actual days (e.g. use package lutz)
    
    ## could use na_count to account for days with <100% data availability
    wd$na_count = as.numeric(!is.na(wd$eto))
    wd$date = format(wd$datetime, format="%Y-%m-%d")
    
    wd %<>% group_by(date)    
    eto_ts = wd %>% summarise_at("eto", sum)
    prec_ts = wd %>% summarise_at("prec", sum)
    tmin_ts = wd %>% summarise_at("temp", min) %>% setNames(c("date","tmin"))
    tmax_ts = wd %>% summarise_at("temp", max) %>% setNames(c("date","tmax"))

    ## merge data frames
    wd_day = eto_ts %>% left_join(prec_ts) %>% left_join(tmin_ts) %>% left_join(tmax_ts)
    wd_day$lat = m$Y
    wd_day$long = m$X
    wd_day$elev = m$Z
    wd_day$stn = stns[i]    
    wd_list[[i]] = wd
}
    
tahmo_data_daily_summary = do.call("rbind", wd_list) %>% as.tbl
