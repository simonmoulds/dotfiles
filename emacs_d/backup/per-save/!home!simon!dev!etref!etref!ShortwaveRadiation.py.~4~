import os
import string
import numpy as np
from hydro_model_builder import VirtualOS as vos
from hydro_model_builder import Messages

import logging
logger = logging.getLogger(__name__)

class ShortwaveRadiation(object):
    
    def __init__(self, ShortwaveRadiation_variable):
        self.var = ShortwaveRadiation_variable

    def initial(self):
        self.set_shortwave_radiation_input_filenames()
        
    def set_shortwave_radiation_input_filenames(self):
        keys = ['downwellingShortwaveRadiationNC',
                'downwellingShortwaveRadiationVarName',
                'downwellingShortwaveRadiationTimeDimName']
        vals = [self.var._configuration.meteoOptions[key] for key in keys]
        self.var.shortwaveRadiationDownFileNC = vals[0]
        self.var.shortwaveRadiationDownVarName = vals[1]
        self.var.shortwaveRadiationDownTimeDimName = vals[2]
        
    def read_shortwave_radiation_data(self):
        day, month, year = (self.var._modelTime.currTime.day,
                            self.var._modelTime.currTime.month,
                            self.var._modelTime.currTime.year)
        self.var.shortwave_radiation = vos.netcdf2PCRobjClone(
            self.var.shortwaveRadiationDownFileNC.format(day=day, month=month, year=year),
            self.var.shortwaveRadiationDownVarName,
            str(self.var._modelTime.fulldate),
            useDoy = None,
            cloneMapAttributes = self.var.cloneMapAttributes,
            LatitudeLongitude = True)#[self.var.landmask]

    def dynamic(self):
        self.read_shortwave_radiation_data()
        
