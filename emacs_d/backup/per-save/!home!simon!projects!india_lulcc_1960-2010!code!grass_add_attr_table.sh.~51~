#!/bin/bash

wd=$HOME/projects/india_lulcc_1960-2010

# create location from land use map, if it doesn't exist
if [ ! -d "$HOME/grassdata/lcc" ]
then
    grass72 -e -c $wd/maps/INDIA_LULC_MOD_2010.tif $HOME/grassdata/lcc
fi

echo "1:Cropland
2:Forest
3:Grassland
4:Shrubland
5:Wasteland
6:Barren land
7:Urban
8:Water bodies
9:Snow and ice" > categories.txt

echo 'export GRASS_MESSAGE_FORMAT=plain
r.mask -r
r.in.gdal input=maps/INDIA_LULC_MOD_2010.tif output=india
g.region rast=india
g.region -p

for year in \\{1..5\\}
do
    echo $year
    # fn=INDIA_LULC_MOD_${year}.tif
    # out=lu${year}_mod
    # r.in.gdal input=data/output_maps/${fn} output=${out} --overwrite
    # r.mapcalc "${out} = int(${out})" --overwrite
    # r.category map=${out} separator=: rules=categories.txt
    # r.out.gdal -c -m  -t input=${out} output=data/${fn} --overwrite
done
' > mygrassjob_pt1.sh

chmod u+x mygrassjob_pt1.sh
export GRASS_BATCH_JOB=$wd/mygrassjob_pt1.sh
grass $HOME/grassdata/lcc/PERMANENT
