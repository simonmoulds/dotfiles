class Irrigation(object):
    """Class to represent irrigation activities"""

    def __init__(self, land_cover):
        self.land_cover = land_cover

    def initial(self):
        arr_zeros = np.zeros((self.land_cover.nFarm, self.land_cover.nCrop, self.land_cover.model.nCell))
        self.land_cover.irrigation = np.copy(arr_zeros)
        self.land_cover.irrigation_volume = np.copy(arr_zeros)
        # self.land_cover.ETact_volume = np.copy(arr_zeros)  # TODO: move this somewhere else
        
    def dynamic(self):
        pass

class IrrigationNonPaddy(Irrigation):
    pass

class IrrigationPaddy(Irrigation):
    def dynamic(self):

        alpha_depletion = 1.    # see CWATM waterdemand.py, lines 129-131
        self.land_cover.irrigation = np.where(
            self.land_cover.cropCoefficient > 0.75,
            np.maximum(
                (alpha_depletion
                 * self.land_cover.zBund  # check units
                 - (self.land_cover.SurfaceStorage  # check units
                    + self.land_cover.water_available_for_infiltration)),  # check units
                0.),
            0.)

        # CWATM: "ignore demand if less that 1m3" - but I thought irrigation was a depth?

        self.land_cover.irrigation_efficiency = 1.  # TODO - put in input
        self.land_cover.irrigation /= self.land_cover.irrigation_efficiency
        self.land_cover.water_available_for_infiltration += self.land_cover.irrigation

class IrrigationNonPaddy(Irrigation):
    def dynamic(self):

        self.land_cover.infiltration_module.compute_infiltration_capacity()

        # compute total and readily available water in the top two soil layers
        self.land_cover.root_zone_water_module.compute_readily_available_water()
        self.land_cover.root_zone_water_module.compute_total_available_water()
        self.land_cover.root_zone_water_module.compute_critical_water_content()

        layer_index = np.array([0,1], np.int64)
        readily_available_water = np.sum(
            self.land_cover.readily_available_water[...,layer_index,:],
            axis=2)
        total_available_water = np.sum(
            self.land_cover.total_available_water[...,layer_index,:],
            axis=2)
        critical_available_water = np.sum(
            self.land_cover.wc_crit[...,layer_index,:],
            axis=2)
        
        alpha_depletion = 1.
        self.land_cover.irrigation = np.where(
            self.land_cover.cropCoefficient > 0.2,
            np.where(
                readily_available_water < (alpha_depletion * critical_available_water),
                np.maximum(0., alpha_depletion * total_available_water),
                0.),
            0.)

        self.land_cover.irrigation = self.land_cover.irrigation.clip(None, self.land_cover.potential_infiltration)

        # from CWATM, waterdemand.py line 335: "ignore demand if less than 1m3" - ***TODO***

        self.land_cover.irrigation_efficiency = 1.  # TODO - put in input
        self.land_cover.irrigation /= self.land_cover.irrigation_efficiency
        self.land_cover.water_available_for_infiltration += self.land_cover.irrigation

class IrrigationMultipleCrops(Irrigation):
    def dynamic(self):
        self.land_cover.irrigation[:] = 0.
        cond1 = ((self.land_cover.Bunds == 1) & (self.land_cover.GrowingSeasonIndex))
        self.land_cover.irrigation[cond1] = np.maximum(
            (self.land_cover.zBund
             - (self.land_cover.SurfaceStorage  # check units
                + self.land_cover.water_available_for_infiltration)),  # check units
            0.)[cond1]

        layer_index = np.array([0,1,2], np.int64)
        n_layer_index = layer_index.size
