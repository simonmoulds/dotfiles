## rice
## ####

if (dist_nm %in% c("Alappuzha","Ernakulam","Kottayam","Palakkad","Thrissur","Wayanad")) {
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:5, 6)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:5, 6)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:5, 6)
}

if (dist_nm %in% c("Idukki")) {
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:8, 9)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:8, 9)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:8, 9)
}

if (dist_nm %in% c("Kannur","Kasaragod","Kollam","Kozhikode","Malappuram")) {
    xx[["irr_rice-winter"]][1:5] = xx[["irr_rice-autumn"]][1:5]
    xx[["irr_rice-autumn"]] = 0
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:8, 9)
}


if (dist_nm %in% c("Pattanamtitta")) {
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:5, 6)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:6, 7)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:5, 6)
}

if (dist_nm %in% c("Thiruvananthapuram")) {
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:7, 8)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:6, 7)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:5, 6)
}

