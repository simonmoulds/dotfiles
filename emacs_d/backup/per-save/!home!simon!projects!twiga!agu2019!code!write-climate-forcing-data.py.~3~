#!/usr/bin/env python
# coding: utf-8

import os
import numpy as np
import netCDF4 as nc
import pandas as pd
import datetime
import time
import glob
import re

era5_datadir = "../data-raw/ERA5"
tahmo_datadir = "../data-raw/TAHMO"
met_datadir = "../data"
out_dir = "../data"

tahmo_metadata = pd.read_csv(
    os.path.join(
        tahmo_datadir,
        'tahmo_stn_metadata.csv'
    )
)

met_filenames = glob.glob(
    met_datadir + '/' + 'tahmo_era5_stn_*_met.csv'
)

def main():
    
    for fn in met_filenames:
    
        met_data = pd.read_csv(fn)

        prec_tahmo = np.array(met_data['P_TAHMO'])
        prec_era5 = np.array(met_data['P_ERA5'])
        tmin_era5 = np.array(met_data['TMIN_ERA5'])
        tmax_era5 = np.array(met_data['TMAX_ERA5'])
        eto_era5  = np.array(met_data['ETO_ERA5'])

        dates = [datetime.datetime.strptime(date, "%Y-%m-%d") for date in list(met_data['DATE'])]

        # TODO: include location data in file
        # (current method is a bit of a hack)
        code = re.search('TA[0-9]{5}', fn).group(0)
        idx = [index for index,value in enumerate(tahmo_metadata['Code']) if value in code]
        lat_coord = float(tahmo_metadata['Y'][idx])
        lon_coord = float(tahmo_metadata['X'][idx])

        # round to nearest 0.25 (corresponds to ERA5 lat/lon)
        lat_coord = round(lat_coord * 4) / 4
        lon_coord = round(lon_coord * 4) / 4

        # write netCDF output containing all met data for the
        # current location
        ds = nc.Dataset(os.path.join(out_dir, 'met_data_' + code + '_2010-2019.nc'), 'w')
        ds.description = 'meteorological forcing data'
        ds.history = 'created ' + time.ctime(time.time())
        ds.createDimension('latitude', 1)
        ds.createDimension('longitude', 1)
        ds.createDimension('time', None)

        lats = ds.createVariable('latitude', np.float64, ('latitude',))
        lats.units = 'degrees_north'
        lats[:] = lat_coord

        lons = ds.createVariable('longitude', np.float64, ('longitude',))
        lons.units = 'degrees_east'
        lons[:] = lon_coord

        times = ds.createVariable('time', np.int32, ('time',))
        times.units = 'days since 1900-01-01 00:00:00'
        times.calendar = 'gregorian'
        times[:] = nc.date2num(dates, units=times.units, calendar=times.calendar)

        prc = ds.createVariable('prec_tahmo', np.float64, ('time','latitude','longitude'))
        prc.units = 'mm d-1'
        prc[:] = prec_tahmo

        prc = ds.createVariable('prec_era5', np.float64, ('time','latitude','longitude'))
        prc.units = 'mm d-1'
        prc[:] = prec_era5

        # prc = dataset.createVariable('prec_tamsat', np.float64, ('time','latitude','longitude'))
        # prc = 'mm d-1'
        # prc[:] = np.array(prec_data['TAMSAT'])[:,None,None]

        # prc = dataset.createVariable('prec_GPM', np.float64, ('time','latitude','longitude'))
        # prc = 'mm d-1'
        # prc[:] = np.array(prec_data['GPM'])[:,None,None]

        tmin = ds.createVariable('tmin_era5', np.float64, ('time','latitude','longitude'))
        tmin.units = 'deg_c'
        tmin[:] = tmin_era5

        tmax = ds.createVariable('tmax_era5', np.float64, ('time','latitude','longitude'))
        tmax.units = 'deg_c'
        tmax[:] = tmax_era5

        eto = ds.createVariable('eto_era5', np.float64, ('time','latitude','longitude'))
        eto.units = 'mm d-1'
        eto[:] = eto_era5

        ds.close()

if __name__ == '__main__':
    if len(met_filenames) > 0:
        main()
    else:
        print("No met data available")
