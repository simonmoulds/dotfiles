class LandCover(object):
    def __init__(self, model, config_section_name):
        self.model = model
        self.configuration = getattr(
            self.model._configuration,
            config_section_name
            )        
        self.copy_model_attributes()
        
    def copy_model_attributes(self):        
        # self._configuration = self.var._configuration
        # self._modelTime = self.var._modelTime
        # self.cloneMap = self.var.cloneMap
        # self.cloneMapFileName = self.var.cloneMapFileName
        # self.landmask = self.var.landmask
        # self.grid_cell_area = self.var.grid_cell_area
        # self.dimensions = self.var.dimensions
        # self.nLat, self.nLon, self.nCell = self.var.nLat, self.var.nLon, self.var.nCell
        self.nFarm, self.nCrop = 1, 1
        # self.weather = self.var.weather
        # self.groundwater = self.var.groundwater
        
    def initial(self):
        pass
    
    def add_dimensions(self):
        """Function to add dimensions to model dimensions 
        object. This is necessary if the LandCover object 
        contains a reporting method."""
        self.model.dimensions['farm'] = np.arange(self.nFarm)
        self.model.dimensions['crop'] = np.arange(self.nCrop)

    def dynamic(self):
        pass

class NaturalVegetation(LandCover):
    def __init__(self, model, config_section_name):
        super(NaturalVegetation, self).__init__(
            model,
            config_section_name)

        self.lc_parameters_module = NaturalVegetationParameters(self)
        self.initial_condition_module = InitialConditionNaturalVegetation(self)

    def initial(self):
        self.lc_parameters_module.initial()
        self.initial_condition_module.initial()
        
    def dynamic(self):
        self.lc_parameters_module.dynamic()
        self.initial_condition_module.dynamic()

