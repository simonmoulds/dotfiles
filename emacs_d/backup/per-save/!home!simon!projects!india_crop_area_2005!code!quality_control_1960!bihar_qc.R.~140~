    xx[["irr_barley"]] %<>% linear_interp(50)
}

if (dist_nm %in% c("Bhagalpur","Gaya","Patna","Saran","Shahabad")) {
    xx[["irr_barley"]] %<>% irr_frac_interp(xx[["apy_barley"]], 44:49,43)
}

if (dist_nm %in% c("Singhbhum","Ranchi")) {
    xx[["apy_barley"]] = 0
    xx[["irr_barley"]] = 0
}

