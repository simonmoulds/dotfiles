## Quality control for Bihar

## Barley
## ######

xx[["apy_barley"]] %<>% locf_interp(61:63)

xx[["irr_barley"]] %<>% irr_frac_interp(xx[["apy_barley"]], 44:49, 44)

if (dist_nm %in% c("Bastar","Hazaribag.Dhanbad","Palamu","Ranchi")) {
    xx[["apy_barley"]] %<>% tot_frac_interp(xx[["irr_barley"]], 44:61, 41)
    xx[["apy_barley"]] %<>% linear_interp(43:50)
    xx[["irr_barley"]] %<>% linear_interp(43:50)
}

