class BaseClass(object):
    def __init__(self, land_cover):
        self.land_cover = land_cover

class CoverFractionData(BaseClass):    
    def __init__(self, land_cover):
        super(CoverFractionData, self).__init__(land_cover)
        self.bbox = file_handling.get_gdal_extent(self.land_cover.model.cloneMap, self.land_cover.model.cloneMapFileName)            
    def initial(self):
        pass

    def dynamic(self):
        lc_filename = str(
            self.land_cover.configuration['landCoverFractionInputFile']
        )
        lc_output_filename = str(
            self.land_cover.configuration['landCoverFractionOutputFile']
        )
        lc_output_variable_name = str(
            self.land_cover.configuration['landCoverFractionOutputVariableName']
        )
        lc_frac = file_handling.read_GDAL(lc_filename, self.bbox).data[0,...]
        netcdf = OutputNetCDF(
            self.land_cover.model._configuration.NETCDF_ATTRIBUTES,
            self.land_cover.dimensions,
            variable_list)        
        netcdf.create_netCDF(
            lc_output_filename,
            lc_output_variable_name
        )            
        netcdf.add_data_to_netcdf(
            lc_output_filename,
            lc_output_variable_name,
            lc_frac,
            timeStamp=datetime.datetime(
                2009,1,1,0,0,0
            ))

