class PriceData(BaseClass):
    def __init__(self, land_cover):
        super(PriceData, self).__init__(land_cover)

    def initial(self):
        pass

    def get_crop_price_data(self, price_data):
        pass

    def read_price_data(self, filename):
        price_data = pd.read_table(
            filename,
            sep='\t',
            header=0,
            index_col=False)
        return price_data

    def get_annual_time_series(self, price_data):
        # annual time series
        years = price_data['YEAR']
        year = np.min(years)
        end_year = np.max(years)
        dates = []
        while year < end_year + 1:
            dates.append(datetime.datetime(year,1,1))
            year += 1
        return dates

    def get_daily_time_series(self, price_data):
        date_str = price_data['DATE']
        dates = []
        for date in price_data['DATE']:
            year, month, day = date.split("-")
            dates.append(datetime.datetime(int(year), int(month), int(day)))
        return dates
        
    def write_crop_price_data(self):
        price_data = self.read_price_data('../data/gandak_crop_price_data.txt')
        dates = self.get_annual_time_series(price_data)
        crop_price_data = []
        for crop in self.land_cover.CropTypes:
            price_crop = lookup_crop_id(crop, 'PRICE')
            arr = np.array(price_data[price_crop], dtype=np.float64)
            arr = arr[:,None,None] * np.ones((self.land_cover.model.nLat, self.land_cover.model.nLon))[None,:,:]
            crop_price_data.append(arr)

        crop_price = np.stack(crop_price_data, axis=1)
        netcdf = OutputNetCDF(
            self.land_cover.model._configuration.NETCDF_ATTRIBUTES,
            self.land_cover.dimensions,
            variable_list
        )        
        netcdf.create_netCDF(
            str(self.land_cover.configuration['cropPriceOutputFile']),
            'crop_price'
        )
        for index,date in enumerate(dates):
            netcdf.add_data_to_netcdf(
                str(self.land_cover.configuration['cropPriceOutputFile']),
                'crop_price',
                crop_price[index,...],
                date
            )

    def write_fertiliser_price_data(self):
        price_data = self.read_price_data('../data/gandak_fert_price_data.txt')
        dates = self.get_annual_time_series(price_data)

        nitrogen_price = np.array(price_data['N_TP'], dtype=np.float64)
        phosphorus_price = np.array(price_data['P_TP'], dtype=np.float64)
        potassium_price = np.array(price_data['K_TP'], dtype=np.float64)
        
        nitrogen_price = nitrogen_price[:,None,None] * np.ones((self.land_cover.model.nLat, self.land_cover.model.nLon))[None,:,:]
        phosphorus_price = phosphorus_price[:,None,None] * np.ones((self.land_cover.model.nLat, self.land_cover.model.nLon))[None,:,:]
        potassium_price = potassium_price[:,None,None] * np.ones((self.land_cover.model.nLat, self.land_cover.model.nLon))[None,:,:]

        netcdf = OutputNetCDF(
            self.land_cover.model._configuration.NETCDF_ATTRIBUTES,
            self.land_cover.dimensions,
            variable_list
        )
        netcdf.create_netCDF(
            str(self.land_cover.configuration['fertiliserPriceOutputFile']),
            ['nitrogen_price','phosphorus_price','potassium_price']
        )
        
        for index,date in enumerate(dates):
            netcdf.add_data_to_netcdf(
                str(self.land_cover.configuration['fertiliserPriceOutputFile']),
                'nitrogen_price',
                nitrogen_price[index,...],
                date,
                index
            )
            netcdf.add_data_to_netcdf(
                str(self.land_cover.configuration['fertiliserPriceOutputFile']),                
                'phosphorus_price',
                phosphorus_price[index,...],
                date,
                index
            )
            netcdf.add_data_to_netcdf(
                str(self.land_cover.configuration['fertiliserPriceOutputFile']),
                'potassium_price',
                potassium_price[index,...],
                date,
                index
            )

    def write_diesel_price_data(self):
        price_data = self.read_price_data('../data/gandak_diesel_price_data.txt')
        dates = self.get_daily_time_series(price_data)
        diesel_price = np.array(price_data['DIESEL_PRICE'], dtype=np.float64)
        diesel_price = diesel_price[:,None,None] * np.ones((self.land_cover.model.nLat, self.land_cover.model.nLon))[None,:,:]
        netcdf = OutputNetCDF(
            self.land_cover.model._configuration.NETCDF_ATTRIBUTES,
            self.land_cover.dimensions,
            variable_list
        )
        netcdf.create_netCDF(
            str(self.land_cover.configuration['dieselPriceOutputFile']),
            'diesel_price'
        )
        for index,date in enumerate(dates):
            netcdf.add_data_to_netcdf(
                str(self.land_cover.configuration['dieselPriceOutputFile']),
                'diesel_price',
                diesel_price[index,...],
                date
            )
        
    def dynamic(self):
        self.write_crop_price_data()
        self.write_fertiliser_price_data()
        self.write_diesel_price_data()
        
