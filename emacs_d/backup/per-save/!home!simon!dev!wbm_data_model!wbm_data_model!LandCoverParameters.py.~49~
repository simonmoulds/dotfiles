        super(FarmParameters, self).__init__(land_cover)
        self.land_cover.nFarmSizeCategory = int(self.land_cover.configuration['nFarmSizeCategory'])
        farm_per_category = str(self.land_cover.configuration['nFarmPerCategory'])
        farm_per_category = [int(x) for x in farm_per_category.split(",")]
        if (len(farm_per_category) == 1) and (self.land_cover.nFarmSizeCategory > 1):
            farm_per_category = [farm_per_category[0] for i in range(self.land_cover.nFarmSizeCategory)]
        self.land_cover.nFarmPerCategory = np.array(farm_per_category)
        self.land_cover.nFarm = np.sum(self.land_cover.nFarmPerCategory)
        # TODO: make this part of model object
        self.bbox = file_handling.get_gdal_extent(
            self.land_cover.model.cloneMap,
            self.land_cover.model.cloneMapFileName
        )
            
    def initial(self):
        self.land_cover.farm_parameter_names = ['farm_category','farm_area','farm_category_area','tubewell_ownership','canal_access']

    def dynamic(self):
        netcdf = OutputNetCDF(
            self.land_cover.model._configuration.NETCDF_ATTRIBUTES,
            self.land_cover.dimensions,
            variable_list
        )
        netcdf.create_netCDF(
            str(self.land_cover.configuration['farmParametersOutputFile']),
            self.land_cover.farm_parameter_names
        )

        # farm category
        farm_category = np.arange(1, self.land_cover.nFarmSizeCategory + 1)
        farm_category = np.repeat(
            farm_category,
            np.array(self.land_cover.nFarmPerCategory))
        farm_category = (
            farm_category[:,None,None]
            * np.ones((self.land_cover.model.nLat, self.land_cover.model.nLon))
        )        
        netcdf.add_data_to_netcdf(
            str(self.land_cover.configuration['farmParametersOutputFile']),
