        # initial tubewell ownership
        tw_ownership_list = []
        for index,suffix in enumerate(['marg','small','semim','medium','large']):
            fn = '../data/' + suffix + '_tw_ownership_rate.tif'
            ar = file_handling.read_GDAL(fn, self.bbox).data[0,...]
            tw_ownership_list.append(ar[None,:,:] * np.ones((self.land_cover.nFarmPerCategory[index]))[:,None,None])
        tw_ownership = np.concatenate(tw_ownership_list, axis=0)
        # tw_ownership_binary = (
        #     tw_ownership
        #     > np.random.random((self.land_cover.nFarm, self.land_cover.model.nLat, self.land_cover.model.nLon))
        # )        
