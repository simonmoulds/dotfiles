def lookup_crop_id(crop_ref, column):
    row_ix = [i for i,s in enumerate(crop_names['ID']) if crop_ref.upper() in s]
    if len(row_ix) == 1:
        row_ix = row_ix[0]
    return crop_names[column][row_ix]
    
class CropParameters(BaseClass):
    def __init__(self, land_cover):
        super(CropParameters, self).__init__(land_cover)        
        self.land_cover.CropParametersOutputFile = str(self.land_cover.configuration['cropParametersOutputFile'])
        self.bbox = file_handling.get_gdal_extent(
            self.land_cover.model.cloneMap,
            self.land_cover.model.cloneMapFileName
        )
        
    def initial(self):
        self.land_cover.crop_parameter_names = [
            'PlantingDate','HarvestDate','L_ini','L_dev','L_mid',
            'L_late','Kc_ini','Kc_mid','Kc_end','Zmin','Zmax',
            'p_std','Ky']        
        arr_zeros = np.zeros((self.land_cover.nCrop, self.land_cover.model.nLat, self.land_cover.model.nLon))
        for param in self.land_cover.crop_parameter_names:
            vars(self.land_cover)[param] = arr_zeros.copy()
        
    def read_gcwm_crop_data(self):
        gcwm_data_filename = "../data/gcwm_crop_data.csv"  # TODO
        with open(gcwm_data_filename, 'rt') as f:
            reader = csv.reader(f, delimiter=',',)
            next(reader, None)
            crop_data = {}
            for row in reader:
                if row[0] not in crop_data:
                    key = row[0].upper()
                    crop_data[key] = {}
                    crop_data[key]['L_ini'] = float(row[1])
                    crop_data[key]['L_dev'] = float(row[2])
                    crop_data[key]['L_mid'] = float(row[3])
                    crop_data[key]['L_late'] = float(row[4])
                    crop_data[key]['Kc_ini'] = float(row[5])
                    crop_data[key]['Kc_mid'] = float(row[6])
                    crop_data[key]['Kc_end'] = float(row[7])
                    crop_data[key]['rd_irr'] = float(row[8])
                    crop_data[key]['rd_rain'] = float(row[9])
                    crop_data[key]['p_std'] = float(row[10])
                    
        return crop_data

    def read_crop_planting_and_harvest_day(self):        
        # Retrieve planting and harvest date from raster images
        map_path = '/home/simon/projects/india_crop_area_2005/data/output_2005/growing_season_maps'
        start_day = np.array([1,32,60,91,121,152,182,213,244,274,305,335])
        end_day = np.array([31,59,90,120,151,181,212,243,273,304,334,365])
        harvest_day = []
        planting_day = []
        for index, name in enumerate(self.land_cover.CropTypes):
            # names of files containing planting and harvest dates of
            # crop under consideration
            x = os.path.join(map_path, 'INDIA_' + name.upper() + '_2005_SOWING.tif')
            y = os.path.join(map_path, 'INDIA_' + name.upper() + '_2005_HARVESTING.tif')
            if os.path.isfile(x) and os.path.isfile(y):
                xarr = file_handling.read_GDAL(x, self.bbox).data[0,...]
                yarr = file_handling.read_GDAL(y, self.bbox).data[0,...]  
                pd = np.zeros_like(xarr)
                hd = np.zeros_like(xarr)
                for i in range(xarr.shape[0]):
                    for j in range(xarr.shape[1]):
                        if xarr[i,j] > 0:
                            pd_ix = int(xarr[i,j]) - 1
                            hd_ix = int(yarr[i,j]) - 1
                            pd[i,j] = start_day[pd_ix]
                            hd[i,j] = end_day[hd_ix]
                        else:
                            pd[i,j] = xarr[i,j]
                            hd[i,j] = yarr[i,j]

                planting_day.append(pd)
                harvest_day.append(hd)

        self.land_cover.PlantingDate = np.stack(planting_day, axis=0)
        self.land_cover.HarvestDate = np.stack(harvest_day, axis=0)

    def read_parameters(self):
        crop_data = self.read_gcwm_crop_data()        
        for index,crop in enumerate(self.land_cover.CropTypes):
            key = lookup_crop_id(crop, 'GCWM')            
            self.land_cover.L_ini[index,...] = (crop_data[key]['L_ini'])
            self.land_cover.L_dev[index,...] = (crop_data[key]['L_dev'])
            self.land_cover.L_mid[index,...] = (crop_data[key]['L_mid'])
            self.land_cover.L_late[index,...] = (crop_data[key]['L_late'])
            self.land_cover.Kc_ini[index,...] = (crop_data[key]['Kc_ini'])
            self.land_cover.Kc_mid[index,...] = (crop_data[key]['Kc_mid'])
            self.land_cover.Kc_end[index,...] = (crop_data[key]['Kc_end'])
            if crop.startswith('irr'):
                self.land_cover.Zmax[index,...] = (crop_data[key]['rd_irr'])
            elif crop.startswith('rain'):
                self.land_cover.Zmax[index,...] = (crop_data[key]['rd_rain'])
            self.land_cover.p_std[index,...] = (crop_data[key]['p_std'])

        # TEMPORARY            
        self.land_cover.Zmin = self.land_cover.Zmax
        self.land_cover.Ky = np.full((self.land_cover.nCrop, self.land_cover.model.nLat, self.land_cover.model.nLon), 1)
        
    def dynamic(self):
        self.read_crop_planting_and_harvest_day()
        self.read_parameters()
        netcdf = OutputNetCDF(
            self.land_cover.model._configuration.NETCDF_ATTRIBUTES,
            self.land_cover.dimensions,
            variable_list
            )
        netcdf.create_netCDF(
            self.land_cover.CropParametersOutputFile,
            self.land_cover.crop_parameter_names
        )
        for param in self.land_cover.crop_parameter_names:
            netcdf.add_data_to_netcdf(
                self.land_cover.CropParametersOutputFile,
                param,
                vars(self.land_cover)[param]
            )

