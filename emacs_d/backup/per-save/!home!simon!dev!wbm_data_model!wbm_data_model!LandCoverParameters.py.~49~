class SoilHydraulicParameters(BaseClass):

    def __init__(self, land_cover):
        super(SoilHydraulicParameters, self).__init__(land_cover)
        self.land_cover.model.nLayer = 3  # TODO - put somewhere else
        self.bbox = file_handling.get_gdal_extent(self.land_cover.model.cloneMap, self.land_cover.model.cloneMapFileName)
        
    def initial(self):
        pass
    
    def read_soil_data(self, filename):
        d = []
        for layer in range(self.land_cover.model.nLayer):
            fn = filename.format(layer=layer)
            r = file_handling.read_GDAL(fn, self.bbox).data[0,...]
            d.append(r)
        d = np.stack(d, axis=0)
        return d                        

    def write_netcdf(self, filename, variable_name, data):
        netcdf = OutputNetCDF(
            self.land_cover.model._configuration.NETCDF_ATTRIBUTES,
            self.land_cover.dimensions,
            variable_list
        )
        netcdf.create_netCDF(
            filename,
            variable_name
        )
        netcdf.add_data_to_netcdf(
            filename,
            variable_name,
            data
        )
    
    def dynamic(self):
        th_fc = self.read_soil_data(
            self.land_cover.configuration['fieldCapacityInputFile']
        )
        self.write_netcdf(
            str(self.land_cover.configuration['fieldCapacityOutputFile']),
            str(self.land_cover.configuration['fieldCapacityOutputVariableName']),
            th_fc
        )

        th_wp = self.read_soil_data(
            self.land_cover.configuration['wiltingPointInputFile']
        )
        self.write_netcdf(
            str(self.land_cover.configuration['wiltingPointOutputFile']),
            str(self.land_cover.configuration['wiltingPointOutputVariableName']),
            th_wp
        )

        th_sat = self.read_soil_data(
            self.land_cover.configuration['saturatedWaterContentInputFile']
        )
        self.write_netcdf(
            self.land_cover.configuration['saturatedWaterContentOutputFile'],
            str(self.land_cover.configuration['saturatedWaterContentOutputVariableName']),
            th_sat
        )
        
        th_dry = self.read_soil_data(
            self.land_cover.configuration['residualWaterContentInputFile']
        )
        self.write_netcdf(
            str(self.land_cover.configuration['residualWaterContentOutputFile']),
            str(self.land_cover.configuration['residualWaterContentOutputVariableName']),
            th_dry
        )
        
        ksat = self.read_soil_data(
            self.land_cover.configuration['KsatInputFile']
        )
        self.write_netcdf(
            str(self.land_cover.configuration['KsatOutputFile']),
            str(self.land_cover.configuration['KsatOutputVariableName']),
            ksat)

class FarmParameters(BaseClass):
