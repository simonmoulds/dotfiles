// [[Rcpp::export]]
NumericVector testfill(unsigned int n) {
  NumericVector out(n, 0);
  return out;
}

// [[Rcpp::export]]
arma::vec testcols(arma::cube x, unsigned int rowidx, unsigned int colidx) {
  arma::vec xsub;
  // xsub = x.col(idx-1);
  xsub = x.tube(rowidx-1,colidx-1);
  return xsub;
}

// [[Rcpp::export]]
unsigned int testsize(arma::vec x) {
  unsigned int n = x.n_elem;
  return n;
}

// [[Rcpp::export]]
double testsum(arma::vec x) {
  double n = arma::accu(x);
  return n;
}

// [[Rcpp::export]]
arma::mat testmult(arma::vec x, arma::mat y) {
  y.each_col() %= x;
  return y;
}
