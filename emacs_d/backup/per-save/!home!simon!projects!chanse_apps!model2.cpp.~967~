// [[Rcpp::export]]
arma::cube testelem(arma::cube x, arma::mat y) {
  arma::cube out = x.each_slice() / y;
  return out;
}

// [[Rcpp::export]]
arma::vec testmin(arma::vec x) {
  arma::vec out = x;
  out = arma::clamp(out, 0., 5.);
  return out;
}

// [[Rcpp::export]]
arma::cube testmult2(arma::mat x, arma::mat y) {
  unsigned int ncrop = x.n_cols;
  unsigned int nfarm = y.n_cols;
  unsigned int nxy = x.n_rows;
  arma::cube out = arma::zeros(nxy,ncrop,nfarm);
  out.each_slice() = x;
  for (unsigned int i = 0; i < ncrop; i++) {
    out.col(i) %= y;
  }  
  return out;
}   

// [[Rcpp::export]]
arma::umat testcompare(arma::mat x, arma::mat y) {
  arma::umat XX = (x >= y);
  return XX;
}

// TODO: no need to loop over space - use armadillo vector ops
// N.B. arma::vec is shorthand for arma::colvec
List hydrology_model_cube(arma::colvec prec,  // (space)
			  arma::colvec etref, // (space)
			  arma::mat p,	      // (space,crop)
			  arma::mat rd,	      // (space,crop)
			  arma::mat H,	      // (space,farm)
			  arma::cube smd,     // (space,farm,crop)
			  arma::cube irr_dmd, // (space,farm,crop)
			  arma::mat irr_eff, // (space,farm)
			  arma::mat wd,	      // (space,farm)
			  arma::colvec max_wd, // (space)
			  double max_pump_cap,
			  arma::mat canal_access, // (space,farm)
			  arma::cube crop_area,	  // (space,farm,crop)
			  arma::mat farm_area,	  // (space,farm)
			  arma::mat taw,	  // (space,crop)
			  arma::mat raw,	  // (space,crop)
			  arma::colvec z,	  // (space)
			  arma::mat canal_vol, // (space,farm)
			  arma::colvec canal_leak_f, // (space)
			  arma::colvec th_fc,	     // (space)
			  arma::colvec th_wp,	     // (space)
			  arma::colvec baseflow_index, // (space)
			  arma::colvec runoff_f,     // (space)
			  arma::colvec evap_f	     // (space)
			  ) {

  // unsigned int nxy = prec.n_rows;
  // unsigned int nfarm = farm_area.n_cols;
  // unsigned int ncrop = p.n_cols;

  // ***************************
  // Calculate irrigation volume
  // ***************************
  arma::umat can_irrigate = (canal_access || (H > wd)); // space,farm
  arma::cube irr_vol = (crop_area % irr_dmd); // space,farm,crop
  // each slice is a matrix with dims (space,farm)
  irr_vol.each_slice() %= ((1. + irr_eff) % can_irrigate);
  // calc total irr vol by summing along slice dimension (=2)
  arma::mat tot_irr_vol = arma::sum(irr_vol,2);
  // scale by maximum pumping capacity
  arma::mat scale_f = max_pump_cap / tot_irr_vol; // space,farm
  irr_vol.each_slice() %= scale_f;
  // calc outstanding demand
  arma::cube irr_depth = irr_vol / crop_area;
  irr_depth.each_slice() /= (1. + irr_eff);
  irr_dmd -= irr_depth;
  // calc actual ET (mm)
  arma::cube ks = smd.each_slice([&](arma::mat X) {
				   X = (taw - X.each_col());
				   X = (X.each_col()) / ((1. - p) % taw);
				 });
  // etact = ks * etref
  arma::cube etact = ks.each_slice([&](arma::mat X) {
				     X = (X.each_col() % etref);
				   });  
  // effective precipitation (multiply by farm area to get volume)  
  arma::mat p_eff = farm_area.each_col() % ((prec / 1000.) % runoff_f % evap_f);
  // infiltration volume - effective prec vol + irrigation volume
  arma::cube infl_vol = irr_vol.each_slice([&](arma::mat X) { X = (X.each_col() % evap_f) + p_eff;});
  smd += etact - (infl_vol.each_slice() / farm_area);
  // runoff
  arma::cube excess = smd.each_slice([&](arma::mat X)
				     {
				       X = X.each_col() - taw;
				     });
  excess = arma::clamp(excess, 0., excess.max());
  smd = arma::clamp(smd, 0., smd.max());
  arma::cube runoff = excess.each_slice([&](arma::mat X) { X = X.each_col() % baseflow_index;});
  arma::cube recharge = excess - runoff;
  arma::cube recharge_vol = recharge.each_slice() * farm_area;
  // sum along crop dimension
  arma::mat tot_recharge_vol = arma::sum(recharge_vol,2); 
  
  // update hydraulic head (farm, crop)
  // 
  // N.B. currently not modelling outflow
  arma::mat H_new = H + tot_recharge_vol;
  // if the farmer has canal access then the updated
  // hydraulic head accounts for canal leakage and
  // recharge
  arma::mat canal_leakage = canal_leak_f.each_col() % canal_vol % canal_access;
  H_new += canal_leakage;
  // otherwise irrigation is taken from groundwater
  arma::umat gw_avail = (H > wd);
  H_new -= (tot_irr_vol % gw_avail);
  // update recharge volume to include canal leakage
  tot_recharge_vol += canal_leakage;
  // ensure hydraulic head is between maximum head
  // and surface elevation
  // H_new = arma::clamp(H_new, max_wd, z.each_col());
  H_new = H_new.each_col([&](arma::colvec& X) {
			   arma::uvec above_z = X > z;
			   arma::uvec below_max_wd = X < max_wd;
			   X = X % above_z + (z % above_z);
			   X = X % below_max_wd + (max_wd % below_max_wd);
			 });

  return List::create(Named("etact") = etact, _["H"] = H_new, _["smd"] = smd, _["abstraction"] = tot_irr_vol, _["unmet_irr_dmd"] = irr_dmd, _["recharge"] = tot_recharge_vol);
  
}


