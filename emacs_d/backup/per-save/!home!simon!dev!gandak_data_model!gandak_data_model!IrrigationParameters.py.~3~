import os
import numpy as np
import rasterio
import csv
import pkgutil

from hydro_model_builder.ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list
from get_data_smart import get_data_smart

class IrrigationParameters(object):
    def __init__(self, IrrigationParameters_variable):
        self.var = IrrigationParameters_variable
        self.var.IrrigationParameterOutputFile = vos.getFullPath(
            self.var._configuration.irrigationParameterOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        
    def initial(self):
        pass

    def dynamic(self):
        
        irrmethod = np.array([1,0,1,0,1,0,1,0])[:,None,None] * np.ones((self.var.nLat, self.var.nLon))
        irrinterval = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 3)
        smt1 = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 70.)
        smt2 = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 70.)
        smt3 = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 70.)
        smt4 = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 70.)
        maxirr = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 25.)
        appeff = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 90.)
        netirrsmt = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 80.5)
        wetsurf = np.full((self.var.nCrop, self.var.nLat, self.var.nLon), 100.)

        irrigation_parameters = {
            'IrrMethod' : irrmethod,
            'IrrInterval' : irrinterval,
            'SMT1' : smt1,
            'SMT2' : smt2,
            'SMT3' : smt3,
            'SMT4' : smt4,
            'MaxIrr' : maxirr,
            'AppEff' : appeff,
            'NetIrrSMT' : netirrsmt,
            'WetSurf' : wetsurf}
        
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)
        netcdf.create_netCDF(self.var.IrrigationParameterOutputFile, irrigation_parameters.keys())
        for key, value in irrigation_parameters.iteritems():
            netcdf.data2NetCDF(self.var.IrrigationParameterOutputFile, key, value)

