# AquaCrop crop growth model

import os
import time
import numpy as np
from hydro_model_builder import VirtualOS as vos
from aquacrop.Messages import *
import logging
logger = logging.getLogger(__name__)

class FarmDynamics(object):

    def __init__(self, FarmDynamics_variable):
        self.var = FarmDynamics_variable

    def initial(self):
        pass

    def nitrogen_cost(self):
        # application rate is tonne / hectare
        self.var.NitrogenCost = (
            self.var.NitrogenAppRate
            * self.var.NitrogenPrice
            * self.var.CropArea)
    
    def phosphorus_cost(self):
        self.var.PhosphorusCost = (
            self.var.PhosphorusAppRate
            * self.var.PhosphorusPrice
            * self.var.CropArea)

    def potassium_cost(self):
        self.var.PotassiumCost = (
            self.var.PotassiumAppRate
            * self.var.PotassiumPrice
            * self.var.CropArea)

    def diesel_pump_cost(self):
        fuel_efficiency = 1.
        unit_fuel_consumption = (0.1133 * self.var.zGW) + 0.7949
        unit_fuel_consumption = unit_fuel_consumption * fuel_efficiency / 102.87
        # total_fuel_consumption = unit_fuel_consumption * self.var.GwPumpingVol
        self.var.DieselPumpCost = (
            unit_fuel_consumption
            * self.var.GwPumpingVol
            * self.var.DieselPrice
            * 0.4)              # TODO: ask JoK the reason for multiplying by 0.4 (subsidy?)

    def electric_pump_cost(self):
        self.var.ElectricPumpCost = 0.

    def farm_income(self):
        self.CropSales = (
            self.var.Y
            * self.var.CropArea
            * self.var.CropPrice)

    def update_annual_income(self):
        self.var.AnnualIncome += self.CropSales
        
    def update_farm_savings_account(self):
        pass

    def update_farm_current_account(self):
        pass
    
    def dynamic(self):
        # Find out what the farm income is for the present time step
        self.farm_income()

        # Compute fertiliser costs
        self.nitrogen_cost()
        self.phosphorus_cost()
        self.potassium_cost()

        # Compute irrigation costs
        self.diesel_pump_cost()
        self.electric_pump_cost()

        
