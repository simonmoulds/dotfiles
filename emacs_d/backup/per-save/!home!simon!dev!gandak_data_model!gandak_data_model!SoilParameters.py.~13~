#!/usr/bin/env python
# -*- coding: utf-8 -*-

import os
import numpy as np
import rasterio
import csv
import pkgutil

from hydro_model_builder.ncConverter import np2netCDF
from hydro_model_builder import VirtualOS as vos

import variable_list as variable_list
from utils import *

class SoilParameters(object):
    def __init__(self, SoilParameters_variable):
        self.var = SoilParameters_variable
        self.var.SoilParameterOutputFile = vos.getFullPath(
            self.var._configuration.soilParameterOptions['outputFile'],
            self.var._configuration.globalOptions['outputDir'])
        self.bbox = vos.get_clone_map_extent(self.var._configuration.cloneMap)
        
    def initial(self):
        arr_zeros = np.zeros((2, self.var.nLat, self.var.nLon))
        soil_parameters_with_depth = ['th_fc','th_wp','th_s','th_dry','ksat']
        for param in soil_parameters_with_depth:
            vars(self.var)[param] = arr_zeros.copy()
            
        arr_zeros = np.zeros((self.var.nLat, self.var.nLon))
        soil_parameters_without_depth = [
            'CN','CalcSHP','EvapZsurf','EvapZmin','EvapZmax','Kex',
            'fevap','fWrelExp','fwcc','AdjREW','REW','AdjCN','zCN',
            'zGerm','zRes','fshape_cr']
        for param in soil_parameters_without_depth:
            vars(self.var)[param] = arr_zeros.copy()
        self.var.soil_parameters = soil_parameters_with_depth + soil_parameters_without_depth

    def get_package_data_filename(self, filename):
        return get_data_smart('gandak_data_model',filename,as_string=False)
    
    def read_field_capacity_data(self):
        thfc0_fn = self.get_package_data_filename('../data/wcpf2_topsoil_gapfilled_5m.tif')
        thfc1_fn = self.get_package_data_filename('../data/wcpf2_subsoil_gapfilled_5m.tif')
        thfc0 = read_gdal_raster_image(thfc0_fn, self.bbox, 0)
        thfc1 = read_gdal_raster_image(thfc1_fn, self.bbox, 0)
        self.var.th_fc = np.stack([thfc0, thfc1], axis=0)

    def read_wilting_point_data(self):
        thwp0_fn = self.get_package_data_filename('../data/wcpf4.2_topsoil_gapfilled_5m.tif')
        thwp1_fn = self.get_package_data_filename('../data/wcpf4.2_subsoil_gapfilled_5m.tif')
        thwp0 = read_gdal_raster_image(thwp0_fn, self.bbox, 0)
        thwp1 = read_gdal_raster_image(thwp1_fn, self.bbox, 0)
        self.var.th_wp = np.stack([thwp0, thwp1], axis=0)

    def read_saturated_water_content_data(self):
        thsat0_fn = self.get_package_data_filename('../data/wcsat_topsoil_gapfilled_5m.tif')
        thsat1_fn = self.get_package_data_filename('../data/wcsat_subsoil_gapfilled_5m.tif')
        thsat0 = read_gdal_raster_image(thsat0_fn, self.bbox, 0)
        thsat1 = read_gdal_raster_image(thsat1_fn, self.bbox, 0)
        self.var.th_s = np.stack([thsat0, thsat1], axis=0)

    def read_residual_water_content_data(self):
        thres0_fn = self.get_package_data_filename('../data/wcres_topsoil_gapfilled_5m.tif')        
        thres1_fn = self.get_package_data_filename('../data/wcres_subsoil_gapfilled_5m.tif')
        thres0 = read_gdal_raster_image(thres0_fn, self.bbox, 0)
        thres1 = read_gdal_raster_image(thres1_fn, self.bbox, 0)
        self.var.th_dry = np.stack([thres0, thres1], axis=0)

    def read_saturated_hydraulic_conductivity_data(self):
        ksat0_fn = self.get_package_data_filename('../data/ksat_topsoil_gapfilled_5m.tif')
        ksat1_fn = self.get_package_data_filename('../data/ksat_subsoil_gapfilled_5m.tif')
        ksat0 = read_gdal_raster_image(ksat0_fn, self.bbox, 0)
        ksat1 = read_gdal_raster_image(ksat1_fn, self.bbox, 0)
        self.var.ksat = np.stack([ksat0, ksat1], axis=0)
        
    def dynamic(self):
        self.read_field_capacity_data()
        self.read_wilting_point_data()
        self.read_saturated_water_content_data()
        self.read_residual_water_content_data()
        self.read_saturated_hydraulic_conductivity_data()

        self.var.CN[:] = 50
        self.var.CalcSHP[:] = 0
        self.var.EvapZsurf[:] = 0.4
        self.var.EvapZmin[:] = 0.15
        self.var.EvapZmax[:] = 0.30
        self.var.Kex[:] = 1.1
        self.var.fevap[:] = 4.
        self.var.fWrelExp[:] = 0.4
        self.var.fwcc[:] = 50.
        self.var.AdjREW[:] = 0.
        self.var.REW[:] = 9.
        self.var.zCN[:] = 0.3
        self.var.zGerm[:] = 0.3
        self.var.zRes[:] = -999
        self.var.fshape_cr[:] = 16
        
        netcdf = np2netCDF(
            self.var._configuration,
            self.var.dimensions,
            variable_list)        
        netcdf.create_netCDF(self.var.SoilParameterOutputFile, self.var.soil_parameters + 'comp')
        for param in self.var.soil_parameters:        
            netcdf.data2NetCDF(self.var.SoilParameterOutputFile, param, vars(self.var)[param])
