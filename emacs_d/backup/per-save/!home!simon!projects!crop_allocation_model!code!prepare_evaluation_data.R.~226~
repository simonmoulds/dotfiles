## For each MapSPAM crop type we have to produce an equivalent map for 1970

library(raster)
library(magrittr)
library(tidyr)
library(dplyr)
library(rgdal)
library(ggplot2)
library(gstat)
options(stringsAsFactors = FALSE)

source("code/helpers.R")

## suffix = "_eck4"
suffix = "_ll"
fact = 3

india_rgn = raster("../india_crop_area_2005/data/output_2005/seasonal_maps/INDIA_IRR_WHEAT_RABI_2005.tif")
india_rgn = !is.na(india_rgn) %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else .}
india_rgn[india_rgn == 0] = NA
india_ext = extent(india_rgn)
cell_area = readRDS("data/india_rgn_cell_area.rds")
cell_ix = readRDS("data/india_rgn_cell_ix.rds")

mapspam_path = "data/mapspam_data"
gaez_path = "data/gaez_data"
crop_path = "../india_crop_area_2005/data/output_1960/seasonal_maps"
crop_2005_path = "../india_crop_area_2005/data/output_2005/seasonal_maps"
## weights matrix for neighbourhood calculation (suitability)
nbw = matrix(data=1, nrow=5, ncol=5)

system("unzip -o data-raw/Production_Crops_E_All_Data.zip -d data")
faostat =
    read.csv("data/Production_Crops_E_All_Data.csv") %>%
    filter(Area %in% "India", Element %in% "Area harvested")

## ======================================
## kharif crops
## ======================================

## barley
## ######

barl_irri_kharif = raster(file.path(crop_path, "INDIA_RAIN_BARLEY_KHARIF_1970.tif"))
barl_irri_kharif[!is.na(barl_irri_kharif)] = 0
barl_rain_kharif = raster(file.path(crop_path, "INDIA_RAIN_BARLEY_KHARIF_1970.tif"))
barl_kharif = list(irri=barl_irri_kharif,
                   rain=barl_rain_kharif)

barl_yield =
    get_mapspam_data("barl", mapspam_path, "yield", suffix=suffix) %>%
    lapply(FUN=function(x) x %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else . } %>% crop(india_ext) %>% `*`(india_rgn)) %>%
    `[`(c("irri","rain"))

barl_suit =
    get_gaez_suit_data("brl", gaez_path, suffix=suffix) %>%
    lapply(FUN=function(x) x %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else . } %>% crop(india_ext) %>% `*`(india_rgn)) %>%
    `[`(c(1,3)) %>%
    setNames(c("irri","rain"))

barl_potyld =
    get_gaez_potyld_data("brly", gaez_path, suffix=suffix) %>%
    lapply(FUN=function(x) x %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else . } %>% crop(india_ext) %>% `*`(india_rgn)) %>%
    `[`(c(1,3)) %>%
    setNames(c("irri","rain"))

barl_nb = get_mapspam_neighb(list(irri=barl_irri_kharif, rain=barl_rain_kharif), w=nbw, fun=mean, na.rm=TRUE, pad=TRUE)

print("interpolating barl yield...")
barl_yield = interpolate_yield(barl_yield, barl_suit, input_levels=c("irri","rain"))

barl_irri_kharif_yield = barl_yield$irri
barl_rain_kharif_yield = barl_yield$rain

barl_irri_kharif_suit = barl_suit$irri
barl_rain_kharif_suit = barl_suit$rain

barl_irri_kharif_potyld = barl_potyld$irri
barl_rain_kharif_potyld = barl_potyld$rain

barl_irri_kharif_nb = barl_nb$irri
barl_rain_kharif_nb = barl_nb$rain

