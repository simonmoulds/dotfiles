d = nc.Dataset('input/Tair_daily_WFDEI/Tair_daily_WFDEI_200001.nc', 'r+', 'NETCDF3')
tname = "timestp"

nctime = d.variables[tname][:]
t_unit = d.variables[tname].units 

try :
    t_cal = d.variables[tname].calendar
except AttributeError :
    t_cal = u"gregorian" # or standard

datevar = []
datevar.append(nc.num2date(nctime, units=t_unit, calendar=t_cal))

