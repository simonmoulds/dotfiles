from crop_growth_funs import *

class GrowingDegreeDay(object):

    def __init__(self, GrowingDegreeDay_variable):
        self.var = GrowingDegreeDay_variable

    def dynamic(self):
        """Function to calculate number of growing degree days on 
        current day
        """
        tmax = meteo.tmax[None,:,:] * np.ones((self.var.nRotation))[:,None,None]
        tmin = meteo.tmin[None,:,:] * np.ones((self.var.nRotation))[:,None,None]
        self.var.GDD = growing_degree_day(tmax, tmin, self.var.Tbase, self.var.Tupp, self.var.GDDmethod)
