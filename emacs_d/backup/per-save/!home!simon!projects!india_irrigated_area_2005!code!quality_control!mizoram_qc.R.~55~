## rice
## ####

if (dist_nm %in% c("Aizawl","Kolasib","Lunglei")) {
    xx[["irr_rice-winter"]] = xx[["irr_rice-autumn"]]
    xx[["irr_rice-winter"]][1:2] = xx[["irr_rice-summer"]][1:2]
    xx[["irr_rice-winter"]][9:11] = xx[["irr_rice-summer"]][9:11]
    xx[["irr_rice-autumn"]] = 0
    xx[["irr_rice-summer"]] = 0
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 6, c(5,7))
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 11, 10)
}

if (dist_nm %in% c("Champhai")) {
    xx[["irr_rice-winter"]][4:7] = xx[["irr_rice-autumn"]][4:7]
    xx[["irr_rice-winter"]][9:11] = xx[["irr_rice-summer"]][9:11]
    xx[["irr_rice-autumn"]] = 0
    xx[["irr_rice-summer"]] = 0
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:3, 4)
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 6, c(5,7))
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 11, 10)
}

if (dist_nm %in% c("Lawngtlai","Mamit","Serchhip")) {
    xx[["irr_rice-winter"]] = xx[["irr_rice-autumn"]]
    xx[["irr_rice-winter"]][9:11] = xx[["irr_rice-summer"]][9:11]
    xx[["irr_rice-autumn"]] = 0
    xx[["irr_rice-summer"]] = 0
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 6, c(5,7))
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 11, 10)
    xx[["apy_rice-winter"]] %<>% locf_interp(1:4, fromLast=TRUE)
    xx[["irr_rice-winter"]] %<>% locf_interp(1:4, fromLast=TRUE)
}

if (dist_nm %in% c("Saiha")) {
    xx[["irr_rice-winter"]] = xx[["irr_rice-autumn"]]
    xx[["irr_rice-winter"]][2] = xx[["irr_rice-summer"]][2]
    xx[["irr_rice-winter"]][9:11] = xx[["irr_rice-summer"]][9:11]
    xx[["irr_rice-autumn"]] = 0
    xx[["irr_rice-summer"]] = 0
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 6, c(5,7))
    xx[["apy_rice-winter"]] %<>% tot_frac_interp(xx[["irr_rice-winter"]], 11, 10)
    xx[["apy_rice-winter"]] %<>% locf_interp(1, fromLast=TRUE)
    xx[["irr_rice-winter"]] %<>% locf_interp(1, fromLast=TRUE)
}

