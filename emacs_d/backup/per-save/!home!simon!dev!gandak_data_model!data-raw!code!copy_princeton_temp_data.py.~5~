def get_times(year):
    dt = datetime.datetime(year,1,1)
    end = datetime.datetime(year+1,1,1)
    step = datetime.timedelta(days=1)
    times = []
    while dt < end:
        times.append(dt)
        dt += step
    return times

# Make grid file
xres = 1./12
yres = 1./12
nlat,nlon = 36,42
minx,miny = 83,25
lon = np.arange(0,nlon) * xres + (minx + xres/2)
lat = np.arange(0,nlat) * yres + (miny + yres/2)
lat = lat[::-1]

grid = netCDF4.Dataset('grid.nc','w')
grid.createDimension('lon',nlon)
grid.createDimension('lat',nlat)
lono = grid.createVariable('lon',np.float32,('lon'),zlib=True,least_significant_digit=16)
lono.units = 'degrees_east'
lono.standard_name = 'longitude'
lono.long_name = 'longitude'
lono[:]=lon

lato = grid.createVariable('lat',np.float32,('lat'),zlib=True,least_significant_digit=16)
lato.units = 'degrees_north'
lato.standard_name = 'latitude'
lato.long_name = 'longitude'
lato[:]=lat

dummy = grid.createVariable('dummy',np.float32,('lat','lon'))
dummy.units = '1'
dummy.standard_name = 'dummy'
dummy.long_name = 'dummy'
dummy[:]=1

grid.Conventions='CF-1.6'
grid.close()

