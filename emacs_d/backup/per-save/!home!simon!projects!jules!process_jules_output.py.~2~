# guess the resolution
    
def guess_resolution(x):
    x_sort = np.sort(x)
    x_diff = np.diff(x_sort)
    x_uniq = np.unique(x_diff)
    if x_uniq.size == 1:
        if x_uniq == 0:
            raise Exception('All values are the same')
    elif x_uniq.size == 2:
        if x_uniq.min() > 0:
            raise Exception('More than one non-zero value')
    else:
        raise Exception('More than one non-zero value')        
    return np.max(x_diff)        

