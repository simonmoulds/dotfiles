## Time parameters
maxtime = 50
dt = 1#0.001
t = seq(0, maxtime, dt)
nt = length(t)

## Compute inter-arrival time of flood events, plus flood magnitude
t_mean = 1
H_mult = 1
w = rep(0, nt)
index = 0
t_flood0 = 0
while (index < nt) {
    x = runif(1)
    t_flood = t_flood0 + (t_mean * log(1/(1-x)))
    ## t_flood = round(t_flood, digits=log10(1/dt))
    index = which.min(abs(t - t_flood))
    y = runif(1)
    w[index] = H_mult * ((theta + 1) / theta) * (1 - (1 - y) ** theta)
    t_flood0 = t_flood
}

## Parameters
alpha_H = 10
xi_H = 0.2
rho_D = 0.03
alpha_D = 5
epsilon_T = 1.1
keta_T = 2e-05
mu_S = 0.06 
## theta = 0.28
## gamma_E = 0.005
## lambda_P = 1 # range 0 -> 5
## sigma_P = 0.1
## alpha_S = 0.5 

## State variables
F = rep(0, nt)
## G = rep(0.01, nt)
D = rep(0.1, nt)
## R = rep(0, nt)
H = rep(0, nt)
## S = rep(0, nt)
M = rep(0, nt)

for (i in 1:nt) {

    ## proportion of settlement that is damaged
    if ((w[i] + xi_H * H[i]) > H[i]) {
        F[i] = 1 - exp(-(w[i] + xi_H * H[i]) / alpha_H)
    } else {
        F[i] = 0
    }
    
    ## raising of levees
    if (F[i] > 0) { 
        R[i] = epsilon_T * (w[i] + xi_H * H[i] - H[i])
        ## if (!(((F[i] * G[i]) > (gamma_E * R[i] * sqrt(G[i]))) & ((G[i] - F[i] * G[i]) > (gamma_E * R[i] * sqrt(G[i]))))) {
        ##     R[i] = 0
        ## }        
    } else {
        R[i] = 0
    }


    ## ## community shock
    ## if (R[i] > 0) {
    ##     S[i] = alpha_S * F[i]
    ## } else {
    ##     S[i] = F[i]
    ## }
    
    ## value of Dirac comb
    if (w[i] > 0) {
        Delta = 1
    } else {
        Delta = 0
    }

    ## distance from the river
    ## dG_dt = rho_E * (1 - D[i]) * G[i] - Delta * (F[i] * G[i] + gamma_E * R[i] * sqrt(G[i]))
    dD_dt = (M[i] - D[i] / lambda_P) * sigma_P / sqrt(G[i])
    dH_dt = Delta * R[i] - keta_T * H[i]
    dM_dt = Delta * S[i] - mu_S * M[i]

    ## G[i+1] = max(0, G[i] + dG_dt)
    D[i+1] = max(0, D[i] + dD_dt)
    H[i+1] = max(0, H[i] + dH_dt)
    M[i+1] = max(0, M[i] + dM_dt)
}

