## Water balance model, based on the Global Crop Water Model

is_leap_year = function(year) {
    res = ifelse(((year %% 4 == 0 & year %%100 != 0) | (year %% 400 == 0)), TRUE, FALSE)
    res
}    

get_growing_season_index = function(time, pd, hd) {
    time = as.POSIXlt(time)
    nt = length(time)
    day = time$yday + 1
    month = time$mon + 1
    year = time$year + 1900
    leap = is_leap_year(year)
    pd_rep = rep(pd, nt)
    hd_rep = rep(hd, nt)
    
    ## adjust for leap year
    if (pd > 59) {
        pd_rep[leap] = pd_rep[leap] + 1
    }
    if (hd > 59) {
        hd_rep[leap] = hd_rep[leap] + 1
    }

    ## get a logical index showing when the growing season
    ## occurs
    if (pd < hd) {
        growing_season = ((day >= pd_rep) & (day <= hd_rep))
    } else if (pd > hd) {
        growing_season = ((day >= pd_rep) | (day <= hd_rep))
    }
    growing_season
}

compute_kc = function(time, pd, hd, crop_params, default_val=0.5) {
    ## get Julian day
    time = as.POSIXlt(time)
    nt = length(time)

    ## We need to extend the time series so that it includes
    ## the final day of the current growing season. The
    ## simplest way to do this is to add a year (i.e. 365
    ## days) to the supplied time series. Later we will cut
    ## it back down to size.
    time_ext = seq.POSIXt(
        from=time[1],
        by="1 day",
        length.out=nt + 365
    )
    time_ext = as.POSIXlt(time_ext)
    nt_ext = length(time_ext)
    day = time_ext$yday + 1
    month = time_ext$mon + 1
    year = time_ext$year + 1900
    leap = is_leap_year(year)

    pd_rep = rep(pd, nt_ext)
    hd_rep = rep(hd, nt_ext)
    
    ## adjust for leap year
    if (pd > 59) {
        pd_rep[leap] = pd_rep[leap] + 1
    }
    if (hd > 59) {
        hd_rep[leap] = hd_rep[leap] + 1
    }

    ## get a logical index showing when the growing season
    ## occurs
    if (pd < hd) {
        growing_season = ((day >= pd_rep) & (day <= hd_rep))
    } else if (pd > hd) {
        growing_season = ((day >= pd_rep) | (day <= hd_rep))
    }

    ## get a logical index showing when the planting day
    ## occurs
    pd_logical = (day == pd_rep)

    ## 'dap' is a vector showing the days after planting for
    ## each growing season in the supplied time series. Times
    ## outside the growing season are assigned NA.
    dap = seq(1, nt_ext)
    dap[!pd_logical] = NA
    dap = zoo::na.locf(dap, na.rm=FALSE)
    dap = seq(1, nt_ext) - dap
    dap[!growing_season] = NA
    dap[!is.na(dap)] = dap[!is.na(dap)] + 1

    ## 'nday' is a vector containing the total number of days
    ## in the growing season which *starts* in the
    ## corresponding year. 
    nday = hd_rep - pd_rep
    nday[!pd_logical] = NA
    nday = zoo::na.locf(nday, na.rm=FALSE)
    nday[!growing_season] = NA

    ## For each day in the growing season, work out the
    ## fraction of the growing season which has elapsed.
    ## Times outside the growing season are assigned an
    ## arbitrary number greater than 1, which is necessary
    ## for the next step.
    frac = dap / nday
    frac[!growing_season] = 10

    ## Accumulated proportional growing season length: we
    ## compare these values with those in 'frac' to work
    ## out the growing stage.
    L_accum = cumsum(
        c(crop_params$L_ini,
          crop_params$L_dev,
          crop_params$L_mid,
          crop_params$L_late
          ))
    
    ## Generate Kc values, assigning the default value for
    ## times outside the growing season. To work out the
    ## correct Kc value during the growing season, we
    ## assign Kc_ini, Kc_mid and Kc_end values by comparing
    ## the accumulated proportional growing season lengths
    ## with the daily values of the fraction of the growing
    ## season elapsed. For the development and late periods
    ## we use linear interpolation between Kc_ini and Kc_mid,
    ## and Kc_mid and Kc_end, respectively.
    Kc = rep(NA, nt_ext)
    Kc[!growing_season] = default_val
    Kc[frac <= L_accum[1]] = crop_params$Kc_ini
    Kc[(frac > L_accum[2]) & (frac <= L_accum[3])] = crop_params$Kc_mid
    Kc[frac == 1] = crop_params$Kc_end
    Kc = zoo::na.approx(Kc)
    Kc = Kc[1:nt]
    Kc
}

compute_p_std = function(time, pd, hd, crop_params, default_val=0.55) {
    growing_season = get_growing_season_index(time, pd, hd)
    p_std = rep(default_val, length(time))
    p_std[growing_season] = crop_params$p_std
    p_std
}

compute_zr = function(time, pd, hd, crop_params, default_val=1) {
    growing_season = get_growing_season_index(time, pd, hd)
    zr = rep(default_val, length(time))
    zr[growing_season] = crop_params$rd_rain
    zr = zr * 1000
    zr
}

get_crop_params = function(db, crop) {
    row_ix = which(db$Crop %in% crop)
    params =
        db %>%
        `[`(row_ix,) %>%
        dplyr::select(-Crop) %>%
        as.list
    params
}

model = function(prec, eto, kc, p_std, zr, s0, taw, gamma) {
    ## This function implements the water balance which is
    ## included in the Global Crop Water Model.
    ## 
    ## Equation numbers in comments refer to those in the
    ## GCWM documentation: https://tinyurl.com/y4he5cmv
    ## [accessed 21/05/2019]
    ##
    ## Args:
    ##   prec  : precipitation (mm/day)
    ##   eto   : reference ET (mm/day); e.g. computed from
    ##           Penman-Monteith or Hargreaves
    ##   kc    : crop coefficient (-)
    ##   p_std : crop specific depletion fraction (-)
    ##   zr    : rooting depth (mm)
    ##   s0    : initial soil water storage (mm)
    ##   taw   : total available water (mm)
    ##   gamma : runoff exponent (?)
    ##
    ## Returns:
    ##   Updated soil water storage (mm)
    etc = kc * eto                      # eqn 28
    p = p_std + 0.04 * (5 - etc)        # eqn 31
    ks = min((s0 / ((1 - p) * taw)), 1) # eqn 30
    eta = ks * etc                      # eqn 29
    runoff = prec * (s0 / taw) ** gamma # eqn 34
    s1 = max(s0 + prec - runoff - eta, 0) # eqn 32
    return(s1)
}
