[globalOptions]

# Set the input directory map in an absolute path
inputDir  = /home/simon/projects/RefET/examples/WFDEI/input

# Set the output directory in an absolute path
outputDir = /home/simon/projects/RefET/examples/WFDEI/output

# Map of clone (must be provided in PCRaster maps)
# - Spatial resolution and coverage are based on this map:
cloneMap = Gandak30min.clone.map

# The area/landmask of interest:
landmask = Gandak30min.landmask.map

# NetCDF attributes for output files:
institution = Centre for Water Systems, University of Exeter
title       = RefET model output
description = WFDEI example (by Simon Moulds) 

# Start/end time (YYYY-MM-DD)
startTime = 1982-05-01
endTime = 1983-10-30

# Method (one or more of PenmanMonteith, PriestleyTaylor, Hargreaves; comma-delimited if required)
method = PenmanMonteith,PriestleyTaylor,Hargreaves

[meteoOptions]

# TODO: meteoDataSource = WFDEI (with method in Configuration to define relevant variables)

temperatureNC = WFDEI/Tair_daily_WFDEI/Tair_daily_WFDEI_{year:0>4}{month:0>2}.nc
compute_daily_min_max_temp_from_subdaily_data = True
subDailyTemperatureNC = WFDEI/Tair_WFDEI/Tair_WFDEI_{year:0>4}{month:0>2}.nc
temperatureVariableName = temperature

downwellingLongwaveRadiationNC = WFDEI/LWdown_daily_WFDEI/LWdown_daily_WFDEI_{year:0>4}{month:0>2}.nc
surfaceAtmosphericPressureNC = WFDEI/PSurf_daily_WFDEI/PSurf_daily_WFDEI_{year:0>4}{month:0>2}.nc
nearSurfaceSpecificHumidityNC = WFDEI/Qair_daily_WFDEI/Qair_daily_WFDEI_{year:0>4}{month:0>2}.nc
downwellingShortwaveRadiationNC = WFDEI/SWdown_daily_WFDEI/SWdown_daily_WFDEI_{year:0>4}{month:0>2}.nc
nearSurfaceWindSpeedNC = WFDEI/Wind_daily_WFDEI/Wind_daily_WFDEI_{year:0>4}{month:0>2}.nc

[reportingOptions]
# Should we follow the netCDF Climate and Forecast Conventions?
netcdf_y_orientation_follow_cf_convention = True
formatNetCDF = NETCDF4
zlib = True
