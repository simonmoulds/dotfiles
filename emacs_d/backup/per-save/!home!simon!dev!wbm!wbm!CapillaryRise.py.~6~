import numpy as np

import logging
logger = logging.getLogger(__name__)


class CapillaryRise(object):
    def __init__(self, land_cover):
        self.land_cover = land_cover
        self.capillary_rise = True

    def initial(self):
        arr_zeros = np.zeros(
            (self.land_cover.nFarm,
             self.land_cover.nCrop,
             self.land_cover.model.nCell)
        )
        self.land_cover.capillary_rise_frac = arr_zeros.copy()
        self.land_cover.capillary_rise_from_gw = arr_zeros.copy()

    def compute_capillary_rise_frac(self):

        zGW = self.land_cover.model.groundwater.zGW[None, None, :]

        def compute_cap_rise(frac, dz1, dz0, zgw):
            return frac - (dz1 - zgw) * 0.1 / np.maximum(1e-3, dz1 - dz0)

        # approximate height of groundwater table and
        # corresponding reach of cell under influence of
        # capillary rise
        if self.capillary_rise:
            CRFRAC = np.minimum(
                1.,
                compute_cap_rise(1., self.land_cover.dzRel0100,
                                 self.land_cover.dzRel0090, zGW)
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0090,
                compute_cap_rise(0.9, self.land_cover.dzRel0090,
                                 self.land_cover.dzRel0080, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0080,
                compute_cap_rise(0.8, self.land_cover.dzRel0080,
                                 self.land_cover.dzRel0070, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0070,
                compute_cap_rise(0.7, self.land_cover.dzRel0070,
                                 self.land_cover.dzRel0060, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0060,
                compute_cap_rise(0.6, self.land_cover.dzRel0060,
                                 self.land_cover.dzRel0050, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0050,
                compute_cap_rise(0.5, self.land_cover.dzRel0050,
                                 self.land_cover.dzRel0040, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0040,
                compute_cap_rise(0.4, self.land_cover.dzRel0040,
                                 self.land_cover.dzRel0030, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0030,
                compute_cap_rise(0.3, self.land_cover.dzRel0030,
                                 self.land_cover.dzRel0020, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0020,
                compute_cap_rise(0.2, self.land_cover.dzRel0020,
                                 self.land_cover.dzRel0010, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0010,
                compute_cap_rise(0.1, self.land_cover.dzRel0010,
                                 self.land_cover.dzRel0005, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0005,
                compute_cap_rise(0.05, self.land_cover.dzRel0005,
                                 self.land_cover.dzRel0001, zGW),
                CRFRAC
            )
            CRFRAC = np.where(
                zGW < self.land_cover.dzRel0001,
                compute_cap_rise(0.01, self.land_cover.dzRel0001, 0., zGW),
                CRFRAC
            )
            self.land_cover.capillary_rise_fraction = np.maximum(
                0., np.minimum(1., CRFRAC))

        else:
            self.land_cover.capillary_rise_fraction = 0.

    def dynamic(self):
        self.compute_capillary_rise_frac()

        # saturation term in van Genuchten equation
        available_water = np.maximum(
            0., self.land_cover.wc - self.land_cover.wc_res)
        sat_term = np.divide(
            available_water,
            self.land_cover.wc_range,
            out=np.zeros_like(self.land_cover.wc),
            where=self.land_cover.wc_range > 0)
        sat_term = sat_term.clip(0., 1.)

        k = (
            self.land_cover.ksat
            * np.sqrt(sat_term)
            * np.square(
                1. - (1. - sat_term ** self.land_cover.van_genuchten_inv_m)
                ** self.land_cover.van_genuchten_m)
        )

        sat_term_fc = (
            np.maximum(0., self.land_cover.wc - self.land_cover.wc_res)
            / (self.land_cover.wc_fc - self.land_cover.wc_res)
        )
        capillary_rise1 = np.minimum(
            np.maximum(0., (1. - sat_term_fc[..., 0, :]) * k[..., 1, :]),
            self.land_cover.k_fc12
        )
        capillary_rise2 = np.minimum(
            np.maximum(0., (1. - sat_term_fc[..., 1, :]) * k[..., 2, :]),
            self.land_cover.k_fc23
        )

        self.land_cover.capillary_rise_from_gw = np.maximum(
            0.,
            (1. - sat_term_fc[..., 2, :]) *
            np.sqrt(self.land_cover.ksat[..., 2, :] * k[..., 2, :])
        )
        self.land_cover.capillary_rise_from_gw *= (
            0.5 * self.land_cover.capillary_rise_frac)
        self.land_cover.capillary_rise_from_gw = self.land_cover.capillary_rise_from_gw.clip(
            0, None)  # storGroundwater???

        self.land_cover.wc[..., 0, :] += capillary_rise1
        self.land_cover.wc[..., 1, :] += (capillary_rise2 - capillary_rise1)
        self.land_cover.wc[..., 2,
                           :] += (self.land_cover.capillary_rise_from_gw - capillary_rise2)

        self.land_cover.th = self.land_cover.wc / self.land_cover.root_depth

