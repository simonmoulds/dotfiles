class ExtraterrestrialRadiation(object):
    def __init__(self, ExtraterrestrialRadiation_variable):
        self.var = ExtraterrestrialRadiation_variable

    def initial(self):
        print type(self.var.cloneMap)
        latitudes = np.unique(pcr.pcr2numpy(pcr.ycoordinate(pcr.boolean(self.var.cloneMap)), vos.MV))[::-1]
        latitudes = latitudes[:,None] * np.ones((self.var.nLon))[None,:]
        self.var.latitudes = latitudes[self.var.landmask]

    def compute_extraterrestrial_radiation(self):
        JULDAY = self.var._modelTime.doy
        LatRad = self.var.latitudes * np.pi / 180.0
        declin = (0.4093 * (np.sin(((2.0 * np.pi * JULDAY) / 365.0) - 1.405)))
        arccosInput = (-(np.tan(LatRad)) * (np.tan(declin)))
        arccosInput = np.clip(arccosInput, -1, 1)
        sunangle = np.arccos(arccosInput)
        distsun = 1 + 0.033 * (np.cos((2 * np.pi * JULDAY) / 365.0))
        self.var.extraterrestrial_radiation = (
            ((24 * 60 * 0.082) / np.pi)
            * distsun
            * (sunangle
               * (np.sin(LatRad))
               * (np.sin(declin))
               + (np.cos(LatRad))
               * (np.cos(declin))
               * (np.sin(sunangle)))) # MJ m-2 d-1
        
    def dynamic(self):
        self.compute_extraterrestrial_radiation()
