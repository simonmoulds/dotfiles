#' Create a fertiliser_price_data object.
#'
#' @param nitrogen_price Numeric vector, xts.
#' @param phosphorous_price Numeric vector, xts.
#' @param potassium_price Numeric vector, xts.
#'
#' @return fertiliser_price_data
#' 
fertiliser_price_data = function(nitrogen_price,
                                 phosphorous_price,
                                 potassium_price) {
    x = data.frame(
        nitrogen_price = nitrogen_price,
        phosphorous_price = phosphorous_price,
        potassium_price = potassium_price
    )
    structure(x, "fertiliser_price_data")
}

#' Create a diesel_price_data object.
#'
#' @param diesel_price Numeric vector, xts.
#'
#' @return diesel_price_data
#'
diesel_price_data = function(diesel_price) {
    x = data.frame(
        diesel_price = diesel_price
    )
    structure(x, "diesel_price")
}

#' Create a crop_price_data object.
#'
#' @param crop_price Data frame, xts.
#' @param time POSIX, optional.
#'
#' @return crop_price_data
#'
crop_price_data = function(crop_price, time) {
    structure(crop_price, "crop_price_data")
}
    
