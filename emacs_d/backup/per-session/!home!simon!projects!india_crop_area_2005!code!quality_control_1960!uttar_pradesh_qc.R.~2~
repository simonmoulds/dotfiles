    xx[["apy_rice"]] %<>% tot_frac_interp(rowSums(data.frame(xx[["irr_rice-summer"]], xx[["irr_rice-autumn"]], xx[["irr_rice-winter"]]), na.rm=TRUE), 53, 52)
}

