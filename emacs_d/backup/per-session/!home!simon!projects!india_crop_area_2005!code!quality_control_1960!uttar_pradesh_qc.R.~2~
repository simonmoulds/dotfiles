    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice"]], 36:38, 35)
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice"]], 53, 52)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice"]], 36:38, 35)
}

