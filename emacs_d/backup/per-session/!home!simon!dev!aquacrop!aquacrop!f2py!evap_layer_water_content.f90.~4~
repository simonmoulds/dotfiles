SUBROUTINE evap_layer_water_content(nx,ny,A,B,C)
  INTEGER :: i, j
  INTEGER, INTENT(in) :: nx,ny
  REAL(8), DIMENSION(nx,ny), INTENT(in) :: A,B
  REAL(8), DIMENSION(nx,ny), INTENT(out) :: C
  DO i = 1, nx
     DO j = 1, ny
        C = A(i,j) + B(i,j)
     END DO
  END DO
END SUBROUTINE evap_layer_water_content

