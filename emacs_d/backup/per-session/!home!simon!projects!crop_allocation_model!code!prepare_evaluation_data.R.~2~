options(stringsAsFactors = FALSE)

source("code/helpers.R")

## suffix = "_eck4"
suffix = "_ll"
fact = 3

india_rgn = raster("../india_crop_area_2005/data/output_2005/seasonal_maps/INDIA_IRR_WHEAT_RABI_2005.tif")
india_rgn = !is.na(india_rgn) %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else .}
india_rgn[india_rgn == 0] = NA
india_ext = extent(india_rgn)
cell_area = readRDS("data/india_rgn_cell_area.rds")
cell_ix = readRDS("data/india_rgn_cell_ix.rds")

mapspam_path = "data/mapspam_data"
gaez_path = "data/gaez_data"
crop_path = "../india_crop_area_2005/data/output_1960/seasonal_maps"
crop_2005_path = "../india_crop_area_2005/data/output_2005/seasonal_maps"
## weights matrix for neighbourhood calculation (suitability)
nbw = matrix(data=1, nrow=5, ncol=5)

system("unzip -o data-raw/Production_Crops_E_All_Data.zip -d data")
faostat =
    read.csv("data/Production_Crops_E_All_Data.csv") %>%
    filter(Area %in% "India", Element %in% "Area harvested")
    
## kharif crops

## rice
rice_irri_kharif = raster(file.path(crop_path, "INDIA_IRR_RICE_KHARIF_1970.tif")) 
rice_rain_kharif = raster(file.path(crop_path, "INDIA_RAIN_RICE_KHARIF_1970.tif"))

rice_yield =
    get_mapspam_data("rice", mapspam_path, "yield", suffix=suffix) %>%
    lapply(FUN=function(x) x %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else . } %>% crop(india_ext) %>% `*`(india_rgn)) %>%
    `[`(c("irri","rain"))

rice_suit_w = get_gaez_suit_data("rcw", gaez_path, suffix=suffix)
rice_suit_d = get_gaez_suit_data("rcd", gaez_path, suffix=suffix)

rice_suit =
    c(rice_suit_w[1], rice_suit_d[1]) %>%
    ## c(rice_suit_w[1:2], rice_suit_d[1:3]) %>%
    lapply(FUN=function(x) x %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else . } %>% crop(india_ext) %>% `*`(india_rgn)) %>%
    `[`(c(1,2)) %>%
    setNames(c("irri","rain"))

rice_potyld_w = get_gaez_potyld_data("ricw", gaez_path, suffix=suffix)
rice_potyld_d = get_gaez_potyld_data("ricd", gaez_path, suffix=suffix)

rice_potyld =
    c(rice_potyld_w[1], rice_potyld_d[1]) %>%
    ## c(rice_potyld_w[1:2], rice_potyld_d[1:3]) %>%
    lapply(FUN=function(x) x %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else . } %>% crop(india_ext) %>% `*`(india_rgn)) %>%
    `[`(c(1,2)) %>%
    setNames(c("irri","rain"))

rice_nb = get_mapspam_neighb(list(irri=rice_irri_kharif, rain=rice_rain_kharif), w=nbw, fun=mean, na.rm=TRUE, pad=TRUE)

print("interpolating rice yield...")
rice_yield = interpolate_yield(rice_yield, rice_suit, input_levels=c("irri","rain"))

rice_irri_kharif_yield = rice_yield$irri
rice_rain_kharif_yield = rice_yield$rain

rice_irri_kharif_suit = rice_suit$irri
rice_rain_kharif_suit = rice_suit$rain

rice_irri_kharif_potyld = rice_potyld$irri
rice_rain_kharif_potyld = rice_potyld$rain

