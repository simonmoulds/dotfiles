## Generate peak over threshold time series
## ########################################

## Time parameters
maxtime = 50
dt = 0.01
t = seq(0, maxtime, dt)
n_time = length(t)

## Compute inter-arrival time of flood events, plus flood magnitude
t_mean = 1/dt
H_mult = 1
w = rep(0, n_time)
index = 0
t0 = 0
t1 = 0
theta=0.28

set.seed(42)
## set.seed(8)
while (index < n_time) {
    x = runif(1)
    t1 = t0 + (t_mean * log(1/(1-x)))
    index = which.min(abs(t/dt - t1))
    y = runif(1)
    w[index] = H_mult * ((theta + 1) / theta) * (1 - (1 - y) ** theta)
    t0 = t1
}

## Run scenarios
## #############

## Parameter description:
## xi_H      : proportion of additional high water level due
##             to levee heightening
## gamma_E   : cost for unit height R and width sqrt(G) of
##             levee raising (0.005 -> inf)
## epsilon_T : safety factor for raising of levees
## keta_T    : rate of decay of levees
## alpha_H   : slope of floodplain, resilience of human
##             settlement
## rho_E     : maximum relative growth rate 
## lambda_P  : distance at which people would accept to live,
##             remembering past floods (0.005 -> inf)
## sigma_P   : rate by which new properties can be built
## alpha_S   : proportion of shock after flooding if levees
##             are raised (0 -> 1)
## mu_S      : memory loss rate (0.01 -> 10)
## s         : sensitivity
## omega     : redistribution

nc = 2 # number of communities
ns = 3 # number of scenarios

params = list(
    xi_H      = array(rep(c(0.5,0.5), each=ns), c(ns, nc)),
    gamma_E   = array(rep(c(0.05,0.5), each=ns), c(ns, nc)),
    epsilon_T = array(rep(c(1.1,1.1), each=ns), c(ns, nc)),
    keta_T    = array(rep(c(0.1,0.1), each=ns), c(ns, nc)),
    alpha_H   = array(rep(c(10,10), each=ns), c(ns, nc)),
    rho_E     = array(rep(c(1,1), each=ns), c(ns, nc)),
    lambda_P  = array(rep(c(2,2), each=ns), c(ns, nc)),
    sigma_P   = array(rep(c(0.1,0.1), each=ns), c(ns, nc)),
    alpha_S   = array(rep(c(0.5,0.5), each=ns), c(ns, nc)),
    mu_S      = array(rep(c(0.215,0.215), each=ns), c(ns, nc)),
    s         = array(rep(c(1,1), each=ns), c(ns, nc)),
    omega     = array(rep(c(0.1,0.5,1), times=ns), c(ns, nc))
)

init = list(G=0.01, D=1, H=0, M=0)

## Scenario 1

## In these scenarios we set the cost of installing levee protection
## for communities living in unplanned settlements to be prohibitively
## high, then experiment with the cost of levee protection to the
## planned settlement

## Techno-society, cheap protection
params$alpha_H   = array(rep(c(10,8), each=ns), c(ns, nc))
params$rho_E    = array(rep(c(1.1,1), each=ns), c(ns, nc))
params$gamma_E  = array(rep(c(0.05,10), each=ns), c(ns, nc))
params$lambda_P = array(rep(c(2,1), each=ns), c(ns,nc))

out = model_ineq(w, init, params, nc, ns)
p = make_plot(out$G, out$H, out$D, out$F)
grid::grid.draw(p)

png("~/Dropbox/plots/flood_ineq_scen1.png", width=5, height=5, units="in", res=320)
grid::grid.draw(p)
dev.off()

