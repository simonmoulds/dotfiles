#!/bin/bash

wd=$HOME/projects/india_lulcc_1960-2010

# =======================================
# read maps into GRASS
# =======================================

echo 'export GRASS_MESSAGE_FORMAT=plain
g.region region=india_rgn
for map in data/district_suit_maps/*.tif
do
    nm=$(basename $map .tif)
    r.in.gdal input=$map output=$nm --overwrite
done

ag_maps=`g.list type=raster separator=, pattern="agriculture_suit_*"`
r.patch in=$ag_maps out=agriculture_suit --overwrite
g.remove -f type=raster name=$ag_maps

forest_maps=`g.list type=raster separator=, pattern="forest_suit_*"`
r.patch in=$forest_maps out=forest_suit --overwrite
g.remove -f type=raster name=$forest_maps

grassland_maps=`g.list type=raster separator=, pattern="grassland_suit_*"`
r.patch in=$grassland_maps out=grassland_suit --overwrite
g.remove -f type=raster name=$grassland_maps

shrubland_maps=`g.list type=raster separator=, pattern="shrubland_suit_*"`
r.patch in=$shrubland_maps out=shrubland_suit --overwrite
g.remove -f type=raster name=$shrubland_maps

wasteland_maps=`g.list type=raster separator=, pattern="wasteland_suit_*"`
r.patch in=$wasteland_maps out=wasteland_suit --overwrite
g.remove -f type=raster name=$wasteland_maps

urban_maps=`g.list type=raster separator=, pattern="urban_suit_*"`
r.patch in=$urban_maps out=urban_suit --overwrite
g.remove -f type=raster name=$urban_maps

r.mapcalc "barren_suit = if(isnull(agriculture_suit),null(),0.5)" --overwrite

r.out.gdal input=agriculture_suit output=data/agriculture_suit.tif createopt="COMPRESS=DEFLATE" --overwrite
r.out.gdal input=forest_suit output=data/forest_suit.tif createopt="COMPRESS=DEFLATE" --overwrite
r.out.gdal input=grassland_suit output=data/grassland_suit.tif createopt="COMPRESS=DEFLATE" --overwrite
r.out.gdal input=shrubland_suit output=data/shrubland_suit.tif createopt="COMPRESS=DEFLATE" --overwrite
r.out.gdal input=wasteland_suit output=data/wasteland_suit.tif createopt="COMPRESS=DEFLATE" --overwrite
r.out.gdal input=urban_suit output=data/urban_suit.tif createopt="COMPRESS=DEFLATE" --overwrite
r.out.gdal input=barren_suit output=data/barren_suit.tif createopt="COMPRESS=DEFLATE" --overwrite

' > mygrassjob_pt1.sh

chmod u+x mygrassjob_pt1.sh
export GRASS_BATCH_JOB=$wd/mygrassjob_pt1.sh
grass $HOME/grassdata/lcc/PERMANENT
unset GRASS_BATCH_JOB
rm mygrassjob_pt1.sh
