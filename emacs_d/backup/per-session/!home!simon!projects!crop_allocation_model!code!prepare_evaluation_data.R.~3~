## For each MapSPAM crop type we have to produce an equivalent map for 1970

library(raster)
library(magrittr)
library(tidyr)
library(dplyr)
library(rgdal)
library(ggplot2)
library(gstat)
options(stringsAsFactors = FALSE)

source("code/helpers.R")

## suffix = "_eck4"
suffix = "_ll"
fact = 3

india_rgn = raster("../india_crop_area_2005/data/output_2005/seasonal_maps/INDIA_IRR_WHEAT_RABI_2005.tif")
india_rgn = !is.na(india_rgn) %>% { if(fact > 1) raster::aggregate(x=., fact=fact, fun=mean) else .}
india_rgn[india_rgn == 0] = NA
india_ext = extent(india_rgn)
cell_area = readRDS("data/india_rgn_cell_area.rds")
cell_ix = readRDS("data/india_rgn_cell_ix.rds")

mapspam_path = "data/mapspam_data"
gaez_path = "data/gaez_data"
crop_path = "../india_crop_area_2005/data/output_1960/seasonal_maps"
crop_2005_path = "../india_crop_area_2005/data/output_2005/seasonal_maps"
## weights matrix for neighbourhood calculation (suitability)
nbw = matrix(data=1, nrow=5, ncol=5)

system("unzip -o data-raw/Production_Crops_E_All_Data.zip -d data")
faostat =
    read.csv("data/Production_Crops_E_All_Data.csv") %>%
    filter(Area %in% "India", Element %in% "Area harvested")

