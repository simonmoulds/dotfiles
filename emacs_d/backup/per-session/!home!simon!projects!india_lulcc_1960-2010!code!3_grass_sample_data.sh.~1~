#!/bin/bash

wd=$HOME/projects/india_lulcc_1960-2010

# =================
# reclass lulc maps
# =================

# original classification (for reference):

# 1  - deciduous_broadleaf_forest
# 2  - cropland
# 3  - built_up_land
# 4  - mixed_forest
# 5  - shrubland
# 6  - barren_land
# 7  - fallow_land
# 8  - wasteland
# 9  - water_bodies
# 10 - plantations
# 11 - aquaculture
# 12 - mangrove_forest
# 13 - salt_pan
# 14 - grassland
# 15 - evergreen_broadleaf_forest
# 16 - deciduous_needleleaf_forest
# 17 - permanent_wetlands
# 18 - snow_ice
# 19 - evergreen_needleleaf_forest

echo '2 7 10    = 1 agriculture
1 4 12 15 16 19 = 2 forest
14              = 3 grassland
5               = 4 shrubland
8               = 5 wasteland
6 13            = 6 barren land
3               = 7 urban
9 11 17         = 8 water bodies
18              = 9 snow' > reclass_rules.txt

echo 'export GRASS_MESSAGE_FORMAT=plain
r.mask -r
g.region region=india_rgn
r.reclass input=lulc_1985 output=lu1985 rules=reclass_rules.txt --overwrite
r.reclass input=lulc_1995 output=lu1995 rules=reclass_rules.txt --overwrite
r.reclass input=lulc_2005 output=lu2005 rules=reclass_rules.txt --overwrite
' > mygrassjob.sh

chmod u+x mygrassjob.sh
export GRASS_BATCH_JOB=$wd/mygrassjob.sh
grass $HOME/grassdata/lcc/PERMANENT
unset GRASS_BATCH_JOB
rm mygrassjob.sh reclass_rules.txt

# ======================
# generate random points
# ======================

echo 'export GRASS_MESSAGE_FORMAT=plain
r.mask -r
g.region region=india_rgn
r.sample.category input=lu2005 output=lu2005_roi sampled=elevation,slope,aspect,bio1,bio2,bio3,bio4,bio5,bio6,bio7,bio8,bio9,bio10,bio11,bio12,popdens,access,dist2rd npoints=1000 --overwrite

v.out.ogr input=lu2005_roi type=point output=data/training_points.shp --overwrite

r.out.gdal input=lu1985 output=data/lulc_1985_rcl_lcc.tif createopt="COMPRESS=DEFLATE" --overwrite
r.out.gdal input=lu1995 output=data/lulc_1995_rcl_lcc.tif createopt="COMPRESS=DEFLATE"  --overwrite
r.out.gdal input=lu2005 output=data/lulc_2005_rcl_lcc.tif createopt="COMPRESS=DEFLATE"  --overwrite

r.out.gdal input=elevation output=data/elevation.tif createopt="COMPRESS=DEFLATE"  --overwrite
r.out.gdal input=slope output=data/slope.tif createopt="COMPRESS=DEFLATE"  --overwrite
r.out.gdal input=aspect output=data/aspect.tif createopt="COMPRESS=DEFLATE"  --overwrite
r.out.gdal input=popdens output=data/popdens.tif createopt="COMPRESS=DEFLATE"  --overwrite
r.out.gdal input=access output=data/access.tif createopt="COMPRESS=DEFLATE"  --overwrite
r.out.gdal input=dist2rd output=data/dist2rd.tif createopt="COMPRESS=DEFLATE,BIGTIFF=YES"  --overwrite

for bioclim_var in bio1 bio2 bio3 bio4 bio5 bio6 bio7 bio8 bio9 bio10 bio11 bio12
do
    nm=$(echo $bioclim_var | sed "s/\(bio\)\([0-9]\)/\1clim_var\2/")
    r.out.gdal input="$bioclim_var" output=data/"$nm".tif createopt="COMPRESS=DEFLATE,BIGTIFF=YES" --overwrite
done
' > mygrassjob.sh

chmod u+x mygrassjob.sh
export GRASS_BATCH_JOB=$wd/mygrassjob.sh
grass $HOME/grassdata/lcc/PERMANENT
unset GRASS_BATCH_JOB
rm mygrassjob.sh
