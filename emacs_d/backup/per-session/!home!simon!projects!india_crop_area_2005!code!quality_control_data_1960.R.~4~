combine_data <- function(d1, d2) {
    dists <- unique(d1$ADM2_CODE)
    data <- list()
    ix  <- which(names(d1) %in% names(d2))
    ixx <- which(!names(d2) %in% names(d1))
    for (i in 1:length(dists)) {
        ix1 <- which(d1$ADM2_CODE %in% dists[i])
        dd1 <- d1[ix1,]
        
        if (dists[i] %in% d2$ADM2_CODE) {
            ix2 <- which(d2$ADM2_CODE %in% dists[i])
            dd2 <- d2[ix2,]
            for (j in 1:nrow(dd1)) {
                for (k in ix) {
                    if (is.na(dd1[j,k])) {
                        dd1[j,k] <- dd2[j,k]
                    }
                }
            }
            dd1 <- cbind(dd1, dd2[,ixx])
        } else {
            dd2 <- as.data.frame(matrix(data=NA, nrow=nrow(dd1), ncol=ncol(d2)))
            names(dd2) <- names(d2)
            dd1 <- cbind(dd1, dd2[,ixx])
        }
        data[[i]] <- dd1
    }
    data <- do.call(rbind, data)
    data
}

