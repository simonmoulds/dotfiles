> I think you can fix this for both the current and the future version of
> "raster" with these changes in the the crossTabulate method:
>
> #replace
> #ct <- raster::crosstab(x, y, ...)
> #with
> ct <- raster::crosstab(x, y, long=TRUE, ...)
> m <- as.data.frame(matrix(data = NA, nrow = length(categories),  ncol =
> length(categories)))
> for (i in 1:length(categories)) {
>     cat1 <- categories[i]
>     for (j in 1:length(categories)) {
>         cat2 <- categories[j]
>         #replace
>         #ix <- which(ct$Var1 == cat1 & ct$Var2 == cat2)
>         #with
>         ix <- which(ct[,1] == cat1 & ct[,2] == cat2)
>
