[FILE_PATHS]
PathIn = /home/simon/projects/AquaCrop/Input
PathOut = /home/simon/projects/AquaCrop/Output

[MODEL_GRID]
# Map of clone (*currently* must be provided as PCRaster map)
# - Spatial resolution and coverage are based on this map:
cloneMap = ${FILE_PATHS:PathIn}/Gandak30min.clone.tif

# The area/landmask of interest:
landmask = ${FILE_PATHS:PathIn}/Gandak30min.landmask.tif

[CLOCK]
# Format:               YYYY-MM-DD (model runs on daily time step)
startTime = 1982-05-01
endTime = 1983-10-30
# endTime   = 2016-10-30

[INITIAL_WATER_CONTENT]
initialConditionInputFile = ${FILE_PATHS:PathIn}/initial_conditions_aos_default_data.nc
InterpMethod = 'layer'

[WEATHER]
meteoPathIn = ${FILE_PATHS:PathIn}
precipitationInputFile = ${meteoPathIn}/prec_aos_default_data.nc
precipitationVariableName = precipitation
precipitationConstant = 0.
precipitationFactor = 86400.

minDailyTemperatureInputFile = ${meteoPathIn}/temp_aos_default_data.nc
minDailyTemperatureVariableName = Tmin
minDailyTemperatureConstant = 0
minDailyTemperatureFactor = 1.

maxDailyTemperatureInputFile = ${meteoPathIn}/temp_aos_default_data.nc
maxDailyTemperatureVariableName = Tmax
maxDailyTemperatureConstant = 0
maxDailyTemperatureFactor = 1.

avgDailyTemperatureInputFile = ${meteoPathIn}/temp_aos_default_data.nc
avgDailyTemperatureVariableName = Tmax
avgDailyTemperatureConstant = 0
avgDailyTemperatureFactor = 1.

refETPotInputFile = ${meteoPathIn}/eto_aos_default_data.nc
refETPotVariableName = referencePotET
refETPotConstant = 0.
refETPotFactor = 1.

[CARBON_DIOXIDE]
carbonDioxideInputFile = ${FILE_PATHS:PathIn}/annual_co2_conc_aos_default_data.nc

[WATER_TABLE]
WaterTable = 0
VariableWaterTable = 0
DailyGroundwaterInputFile = 0
groundwaterInputFile = ${FILE_PATHS:PathIn}/groundwater_test.nc
groundwaterVariableName = groundwater
timeLag = 0

[LAND_COVER]
landCoverPath = ${FILE_PATHS:PathIn}/landcover
landCoverTypes = cropland
landCoverTypesShort = c
# Should land cover fractions sum to one?
forceCoverFractionSumToEqualOne = 0
# Land cover can vary from year to year
dynamicLandCover = 0
# If not dynamic, which year should be used?
staticLandCoverYear = 2009

[CROP_PARAMETERS]
landCoverFractionInputFile = None
landCoverFractionVariableName = None
nCrop = 1
nRotation = 1
cropParametersInputFile = ${FILE_PATHS:PathIn}/params_aos_default_data.nc
CalendarType = 2
SwitchGDD = 1
GDDmethod = 2
cropAreaInputFile = None
cropAreaVariableName = None
croplandAreaInputFile = None
croplandAreaVariableName = None
AnnualChangeInCropArea = 0
outDailyTotal = GDD
# outDailyTotal = GDD,Zroot,DeepPerc,Irr,Infl,Runoff,B,CC,TrAct,th

[FARM_PARAMETERS]
nFarm = 1
farmAreaInputFile = None
farmAreaVariableName = None
AnnualChangeInFarmArea = 0

[IRRIGATION_MANAGEMENT]
irrigationManagementInputFile = ${FILE_PATHS:PathIn}/params_aos_default_data.nc
irrigationScheduleInputFile = None

[FIELD_MANAGEMENT]
fieldManagementInputFile = ${FILE_PATHS:PathIn}/params_aos_default_data.nc

[SOIL_PARAMETERS]
soilParametersInputFile = ${FILE_PATHS:PathIn}/params_aos_default_data.nc
nComp = 12
nLayer = 1

[REPORTING]
netcdf_y_orientation_follow_cf_convention = False
outDailyTotal = None
formatNetCDF = NETCDF4
zlib = True

[NETCDF_ATTRIBUTES]
institution = Centre for Water Systems, University of Exeter
title       = AquaCrop v5.0 output
description = test version (by Simon Moulds) 
netcdf_y_orientation_follow_cf_convention = True
formatNetCDF = NETCDF4
zlib = True

