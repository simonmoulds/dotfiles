
**************************************************
* CropRota                                       *
* A Model to find opitmal crop rotations         *
* from observed crop mix data                    *
* 8 November 2010                                *
* developed by Erwin Schmid, Martin Schönhart    *
* and Uwe Schneider                              *
* correspondence to martin.schoenhart@boku.ac.at *
**************************************************


Sets
 crop  set of crops to be represented in the model
 /winter_wheat,sugar_beet,rape_seed/

 crop_group_1(crop)  crops or crop groups with frequency constraints in a rotation
 /sugar_beet/

 crop_group3(crop)
 /rape_seed/

Alias(crop,crop2,crop3)

Parameter farmshare_P(crop) crop mixes observed on the farm or region
 /winter_wheat    0.8
  rape_seed       0.1
  sugar_beet      0.1/

Table combival_P(crop,crop2) expert-based score matrix with pre-crops and main crops
                 winter_wheat    rape_seed    sugar_beet
winter_wheat          4             10            10
rape_seed            10              0             4
sugar_beet            8              0             2

Scalar  penalty_P for slack variables
 /99./

Parameters
 crop_group_1_ind(crop)
 crop_group3_ind(crop);

 crop_group_1_ind(crop_group_1)
      $farmshare_P(crop_group_1) = 1;

 crop_group3_ind(crop_group3)
      $farmshare_P(crop_group3) = 1;

Free Variables
  points_V                     total value scores to be maximized

Positive Variables
  monoculture_V(crop)          crop rotation with 1 crop
  twopartrot_V(crop,crop2)     crop rotation with 2 crops
  Npartrot_V(crop,crop2,crop3) crop rotation with N crops
  artplus_V(crop)              positive slack variable
  artminus_V(crop)             negative slack variable

Equations
  objective_E      objective function (1)
  match_E(crop)    link between observed and modeled data (2)
  freqConst_1_E    frequency constraint - here max. one occurance within 3 yrs. (3)
  freqConst3_E    frequency constraint - here max. one occurance within 2 yrs. (3)
  prevRot_E        supresses rotation if equivalent shorter rotation is available (e.g. crop_crop);


objective_E..

points_V   =E=

 +  SUM(crop
         $(farmshare_P(crop)and
           combival_P(crop,crop)),
       combival_P(crop,crop) * (1./1.) * monoculture_V(crop))

 +  SUM((crop,crop2)
         $(farmshare_P(crop) and
           farmshare_P(crop2)and
           combival_P(crop,crop2)and
           combival_P(crop2,crop)),
       combival_P(crop,crop2) * (1./2.) *
       (twopartrot_V(crop2,crop)
       + twopartrot_V(crop,crop2)))

 +  SUM((crop,crop2,crop3)
         $(farmshare_P(crop) and
           farmshare_P(crop2) and
           farmshare_P(crop3)and
           combival_P(crop,crop2)and
           combival_P(crop2,crop3)and
           combival_P(crop3,crop))   ,
       combival_P(crop,crop2) * (1./3.)*
       (Npartrot_V(crop,crop2,crop3)
       + Npartrot_V(crop3,crop,crop2)
       + Npartrot_V(crop2,crop3,crop)))

 -  SUM(crop
         $farmshare_P(crop),
       penalty_P * (artminus_V(crop) + artplus_V(crop)));


match_E(crop)..

  monoculture_V(crop)$(farmshare_P(crop)and
                       combival_P(crop,crop))

  + SUM(crop2
          $(farmshare_P(crop) and
            farmshare_P(crop2)and
            combival_P(crop,crop2)and
            combival_P(crop2,crop)),
        twopartrot_V(crop,crop2)/2.
        + twopartrot_V(crop2,crop)/2.)

  + SUM((crop2,crop3)
          $(farmshare_P(crop) and
            farmshare_P(crop2) and
            farmshare_P(crop3)and
           combival_P(crop,crop2)and
           combival_P(crop2,crop3)and
           combival_P(crop3,crop)),
        Npartrot_V(crop,crop2,crop3)/3.
        + Npartrot_V(crop3,crop,crop2)/3.
        + Npartrot_V(crop2,crop3,crop)/3.)

  -  artminus_V(crop)$farmshare_P(crop)
  +  artplus_V(crop)$farmshare_P(crop)

  =E= farmshare_P(crop);


freqConst_1_E
      $(Sum(crop$crop_group_1_ind(crop),1) gt 0)..

  + Sum(crop
       $(farmshare_P(crop) and
        (crop_group_1_ind(crop) gt 0.)and
        combival_P(crop,crop)),
       monoculture_V(crop))

  + SUM((crop,crop2)
       $(farmshare_P(crop) and
         farmshare_P(crop2) and
        ((crop_group_1_ind(crop)
          +crop_group_1_ind(crop2)) gt 0.)and
         combival_P(crop,crop2)and
         combival_P(crop2,crop)),
       twopartrot_V(crop,crop2))

  + SUM((crop,crop2,crop3)
       $(farmshare_P(crop) and
         farmshare_P(crop2) and
         farmshare_P(crop3) and
        ((crop_group_1_ind(crop)
          +crop_group_1_ind(crop2)
          +crop_group_1_ind(crop3)) gt 1.)and
          combival_P(crop,crop2)and
          combival_P(crop2,crop3)and
          combival_P(crop3,crop)),
       Npartrot_V(crop,crop2,crop3))

  =E= 0.;

freqConst3_E
      $(Sum(crop$crop_group3_ind(crop),1) gt 0)..

  + Sum(crop
       $(farmshare_P(crop) and
        (crop_group3_ind(crop) gt 0.)and
        combival_P(crop,crop)),
       monoculture_V(crop))

  + SUM((crop,crop2)
       $(farmshare_P(crop) and
         farmshare_P(crop2) and
        ((crop_group3_ind(crop)
          +crop_group3_ind(crop2)) gt 1.)and
         combival_P(crop,crop2)and
         combival_P(crop2,crop)),
       twopartrot_V(crop,crop2))

  + SUM((crop,crop2,crop3)
       $(farmshare_P(crop) and
         farmshare_P(crop2) and
         farmshare_P(crop3) and
        ((crop_group3_ind(crop)
          +crop_group3_ind(crop2)
          +crop_group3_ind(crop3)) gt 1.)and
          combival_P(crop,crop2)and
          combival_P(crop2,crop3)and
          combival_P(crop3,crop)),
       Npartrot_V(crop,crop2,crop3))

  =E= 0.;


PrevRot_E..
  + SUM(crop
        $(farmshare_P(crop)and
         combival_P(crop,crop)),
     twopartrot_V(crop,crop))

   + SUM((crop)
        $(farmshare_P(crop)and
         combival_P(crop,crop)),
      Npartrot_V(crop,crop,crop))

   =E= 0;


MODEL CropRota /objective_E,match_E,prevRot_E,freqConst_1_E,freqConst3_E/;
*prevRot_E,freqConst_1_E,freqConst3_E


display
crop_group3_ind;

SOLVE CropRota USING LP MAXIMIZING Points_V ;


* FILE ROTREPORT /FarmCRS.gms/;
FILE ROTREPORT /results.txt/;

PUT ROTREPORT;
PUT "CRS;Kultur1;Kultur2;Kultur3;Kultur4;Kultur5;Kultur6;Gliedrigkeit;rel_wert"/;

ROTREPORT.LW=0;
ROTREPORT.TW=0;
ROTREPORT.NW=0;

*LW = width of set element, NW= numeric field width, quoted and explanatory field width
Scalar
counter;

Counter = 1.;

PUT ROTREPORT
LOOP(crop$Monoculture_V.l(crop),
ROTREPORT.ND=0;
 PUT "CRS",Counter;
ROTREPORT.ND=4;
 Put ";",crop.tl,";",";",";",";",";",";1",";",Monoculture_V.l(crop)  /;
 Counter = Counter +1.;
    );

LOOP((crop,crop2)$Twopartrot_V.L(crop,crop2),
ROTREPORT.ND=0;
 PUT "CRS",Counter;
ROTREPORT.ND=4;
 Put ";",crop.tl,";",crop2.tl,";",";",";",";",";2",";",Twopartrot_V.L(crop,crop2)  /;
 Counter = Counter +1.;
    );

LOOP((crop,crop2,crop3) $Npartrot_V.L(crop,crop2,crop3),
ROTREPORT.ND=0;
 PUT "CRS",Counter;
ROTREPORT.ND=4;
 PUT ";",crop.tl,";",crop2.tl,";",crop3.tl,";",";",";",";3",";",Npartrot_V.L(crop,crop2,crop3)  /;
 Counter = Counter +1.;
    );









