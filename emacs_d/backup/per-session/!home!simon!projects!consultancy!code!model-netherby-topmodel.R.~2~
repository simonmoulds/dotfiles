## read data, doing the necessary data processing if not
## already done
if (length(list.files("data","[a-z]*_scenario_data.rds")) != 4) {
    source("code/load-data.R")
}

baseline_scenario_data = readRDS("data/baseline_scenario_data.rds")
peatland_scenario_data = readRDS("data/peatland_scenario_data.rds")
woodland_scenario_data = readRDS("data/woodland_scenario_data.rds")
agroforestry_scenario_data = readRDS("data/agroforestry_scenario_data.rds")

## prepare index of time period to be studied
start_time = as.POSIXct(
    "2011-01-01 00:00:00",
    tz="GMT",
    format="%Y-%m-%d %H:%M:%S"
)
end_time = as.POSIXct(
    "2014-12-31 23:00:00",
    tz="GMT",
    format="%Y-%m-%d %H:%M:%S"
)
ts = seq(start_time, end_time, by="1 hour")

topmodel_met_data = read.csv("data-raw/11_SWAT - Copy/05_Meteo/topmodel_hourly_met_data.csv")
topmodel_met_data_time = as.POSIXct(topmodel_met_data$time, tz="GMT")
time_ix = (
    (topmodel_met_data_time >= start_time) &
    (topmodel_met_data_time <= end_time)
)
rain = topmodel_met_data$prec[time_ix] / 1000
eto = topmodel_met_data$eto[time_ix] / 1000

## ================================= ## 
## ================================= ##
## 1. Only peatland restoration area ## 
## ================================= ##
## ================================= ##

peat_mask = raster(
    file.path(
        "data-raw",
        "11_SWAT - Copy",
        "01_Study_area",
        "Peatland combined",
        "pcomb_dem.tif"
    )
)
peat_mask[!is.na(peat_mask)] = 1

ncell = length(which(!is.na(getValues(peat_mask))))
catchment_area = ncell * res(peat_mask)[1] * res(peat_mask)[2]

maps = get_map_layers(
    dem=peatland_scenario_data$dem,
    mask=peat_mask,
    kc=peatland_scenario_data$kc
)
dem = maps[[1]]
topographic_wetness_index =
    maps$topographic_wetness_index %>%
    as.matrix %>%
    make.classes(32)

n = 5
delay = flowlength(as.matrix(dem)) * res(dem)[1]
delay = make.classes(delay, n)
delay = delay[n:1,]
delay[,2] = c(0, cumsum(delay[1:(n-1),2]))

data(huagrahuma)
parameters = huagrahuma$parameters
parameters["dt"] = 1

mean_kc = get_area_average_kc(maps[["kc"]])
pet = eto * mean_kc
Qsim_peatland = topmodel(
    parameters,
    topographic_wetness_index,
    delay,
    rain,
    pet
)
Qsim_peatland = Qsim_peatland * catchment_area

## some sanity checks:
mean_flow = mean(Qsim_peatland) # m3/h
max_flow = max(Qsim_peatland)  # m3/h
mean_rain = mean(rain)
max_rain = max(rain)
max_rain_vol = max_rain * catchment_area

