names(harv_irri)[sapply(seq_len(length(harv_irri)), FUN=function(index) isTRUE(cellStats(harv_irri[[index]], stat=sum) > cellStats(phys_irri[[index]], stat=sum)))]

## index of maps with irrigated area greater than zero
zero_ix = sapply(harv_irri, FUN=function(x) !isTRUE(all.equal(cellStats(x, stat=sum), 0.0)))

