#' Create a farm_parameters object.
#'
#' @param n_farm Integer scalar. The number of farms in the simulation.
#' @param area Numeric scalar. The area of each farm (m2)
#' @param initial_category Integer scalar. The initial category of each farm.
#' @param irrigation_efficiency Numeric scalar.
#' @param ... Additional arguments.
#'
#' @return farm_parameters
#' 
farm_parameters = function(n_farm,
                           area,
                           initial_category,
                           irrigation_efficiency,                           
                           ...) {
    x = list(
        area = _expand_parameter(n_farm, area),
        initial_category = _expand_parameter(n_farm, initial_category),
        irrigation_efficiency = _expand_parameter(n_farm, irrigation_efficiency)
    )
    structure(x, class="farm_parameters")
}
