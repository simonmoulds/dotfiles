## data = vector(mode="list", length=nrow(crops))
maps = vector(mode="list", length=nrow(crops))
for (i in 1:nrow(crops)) {
    crop_nm = crops$crop_nm[i]; print(crop_nm)
    suit_code = crops$gaez_suit_code[i]
    potyld_code = crops$gaez_potyld_code[i]
    suit =
        get_gaez_suit_data(suit_code,"data/gaez_data","_ll") %>%
        lapply(FUN=function(x) crop(x,extent(template)))

    potyld =
        get_gaez_potyld_data(potyld_code,"data/gaez_data","_ll") %>%
        lapply(FUN=function(x) crop(x,extent(template)))

    mixed_potyld = get_mixed_yield(suit, potyld)
    mixed_potyld %<>% setNames(paste0(crop_nm, "_", c("irri","rain")))
    maps[[i]] = mixed_potyld
}
maps = stack(unlist(maps))

## first, write maps to file -> these will be used in the
## coupled model
for (i in 1:nlayers(maps)) {
    map = maps[[i]]
    nm = names(map)
    outfn = file.path("data", paste0("potential_yield_", nm, "_mixed_input.tif"))
    writeRaster(map, filename=outfn, overwrite=TRUE)
}

## next, extract mean value for spatially aggregated
## system dynamics model
potyld = raster::extract(maps, adm2, weights=TRUE, fun=mean)

stop()

