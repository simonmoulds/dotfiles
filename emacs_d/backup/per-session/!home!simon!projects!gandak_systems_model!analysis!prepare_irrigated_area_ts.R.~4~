adm2_1960_raster = rasterize(adm2_1960, template, "ADM2_CODE")

adm2_2010 = readOGR(dsn="pkg/india_adm2_2001/data", layer="g2008_2_India", stringsAsFactors=FALSE)
adm2_2010$ADM2_CODE %<>% as.numeric
adm2_2010_raster = rasterize(adm2_2010, template, "ADM2_CODE")

ids = c(70272,17914,70274,17894,70097,17619,17595,17626,17632,17613,17628,17620,70103,17630,17631,17604,17618,70271,17904)

## Indiastat
data(indiastat)
indiastat_nia = indiastat[,c(1:3, grep("NIA", names(indiastat)))]
bh_dists = c("Pashchim Champaran","Purba Champaran","Sitamarhi","Sheohar","Gopalganj","Muzaffarpur","Siwan","Saran","Samastipur","Vaishali","Begusarai","Bhojpur","Patna")
up_dists = c("Maharajganj","Kushinagar","Gorakhpur","Deoria","Mau","Ballia")
years = 1980:2010
years = paste0("X", years, "_", substr(years + 1, 3, 4))
indiastat_nia %<>%
    filter(State %in% c("Uttar Pradesh","Bihar")) %>%
    filter(District %in% c(bh_dists, up_dists)) %>%
    filter(Year %in% years)

lut = adm2_2010@data[adm2_2010$ADM2_CODE %in% ids,c("ADM2_NAME","ADM2_CODE")] %>%
    setNames(c("District","GAUL_ID")) %>%
    arrange(District)

indiastat_nia %<>%
    left_join(lut, ., by="District") %>%
    select("State","District","Year","Canal-Total-NIA","Tanks-NIA","Tube Wells-NIA","Other Sources-NIA","Total-NIA") %>%
    setNames(c("State","District","date","canal_nia","tanks_nia","tubewells_nia","oth_source_nia","total_nia")) %>%
    mutate(State = toupper(State)) %>%
    mutate(District = toupper(District)) %>%
    arrange(State,District) %>%
    group_by(State,District)

write.csv(indiastat_nia, "data/indiastat_nia_districtwise.csv", row.names=FALSE)

