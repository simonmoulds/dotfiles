library(magrittr)
library(tidyr)
library(ggplot2)
library(cowplot)

## Time parameters
maxtime = 50
dt = 0.01
t = seq(0, maxtime, dt)
nt = length(t)

## Compute inter-arrival time of flood events, plus flood magnitude
t_mean = 1/dt
H_mult = 1
w = rep(0, nt)
index = 0
t0 = 0
t1 = 0
theta=0.28

set.seed(42)
while (index < nt) {
    x = runif(1)
    t1 = t0 + (t_mean * log(1/(1-x)))
    index = which.min(abs(t/dt - t1))
    y = runif(1)
    w[index] = H_mult * ((theta + 1) / theta) * (1 - (1 - y) ** theta)
    t0 = t1
}

compute_protection_increase = function(F, W, H, epsilon_T, xi_H) {
    ## Function to compute flood protection increase.
    ##
    ## Args:
    ## =====
    ## F : Flood damage
    ## W : Water level
    ## H : Current protection level    
    ## xi_H : TODO
    ##
    ## Return:
    ## =======
    ## Increase in flood protection
    ##
    if (F > 0) {
        R = epsilon_T * (W + xi_H * H - H)
    } else {
        R = 0
    }
    R
}

constrain_protection_increase = function(R0, F, G, gamma_E, check_incentive=TRUE, check_affordable=TRUE, allow_suboptimal=FALSE) {
    ## Function to balance the desired flood protection increase
    ## against the community socioeconomics.
    ##
    ## Args:
    ## =====
    ## R0 : Desired increase in flood protection
    ## F  : Flood damage experienced by the community
    ## G  : Community wealth
    ## gamma_E : Unit cost of flood protection increase
    ## allow_suboptimal : if TRUE, allow community to build flood
    ##   protection which would not protect against flood damage F
    ##
    ## Return:
    ## =======
    ## Increase in flood protection considering community
    ##   socioeconomics
    ##    
    R = R0

    ## 1. Is there an economic incentive to install the levee?
    if (check_incentive) {
        if (!((F * G) >= (gamma_E * R * sqrt(G)))) {
            R = 0                
        }
    }
    
    ## 2. Is there enough wealth to install the levee?
    if (check_affordable) {
        if (!((G - F * G) >= (gamma_E * R * sqrt(G)))) {
            R = 0            
            if (allow_suboptimal) {
                ## determine the maximum levee height that can be installed
                R_max = (G - F * G) / (gamma_E * sqrt(G))
                R = R_max
            }        
        }
    }    
    R
}

## Parameters
## ##########

## proportion of additional high water level due to levee heightening
xi_H = c(0.5,0.5)

## slope of floodplain, resilience of human settlement
alpha_H = c(10,7)

## maximum relative growth rate 
rho_E = c(1,1)

## cost for unit height R and width sqrt(G) of levee raising
gamma_E = c(0.005,0.005) # 0.005 -> inf

## distance at which people would accept to live, remembering past floods
lambda_P = c(1,1)        # 0 -> 5

## rate by which new properties can be built
sigma_P = c(0.1,0.1)

## safety factor for raising of levees
epsilon_T = c(1.1,1.1)

## rate of decay of levees
keta_T = c(0.1,0.1)

## proportion of shock after flooding if levees are raised
alpha_S = c(0.5,0.5)     # 0 -> 1

## memory loss rate 
mu_S = c(0.215,0.215)    # 0.01 -> 10

## State variables
F = data.frame(a=rep(0, nt), b=rep(0, nt))
R = data.frame(a=rep(0, nt), b=rep(0, nt))
R0 = data.frame(a=rep(0, nt), b=rep(0, nt))
S = data.frame(a=rep(0, nt), b=rep(0, nt))
G = data.frame(a=rep(0.01, nt), b=rep(0.01, nt))
D = data.frame(a=rep(1, nt), b=rep(1, nt))
H = data.frame(a=rep(0, nt), b=rep(0, nt))
M = data.frame(a=rep(0, nt), b=rep(0, nt))

nc = 2

for (i in 1:(nt-1)) {

    for (j in 1:nc) {
        
        ## proportion of settlement that is damaged
        if ((w[i] + xi_H[j] * H[i,j]) > H[i,j]) {
            F[i,j] = 1 - exp(-(w[i] + xi_H[j] * H[i,j]) / (alpha_H[j] * D[i,j]))
        } else {
            F[i,j] = 0
        }

        ## memory of flood events; memory of harm caused by inaction or
        ## the wrong type of action... when communities become more
        ## powerful their memory of past inaction creates a democratic
        ## pressure - possible to include this in the model?

        ## raising of levees: first calculate the theoretical
        ## amount by which the community would want to raise
        ## the levee
        R0[i,j] = compute_protection_increase(
            F[i,j], w[i], H[i,j], epsilon_T[j], xi_H[j]
        )
        R[i,j] = constrain_protection_increase(
            R0[i,j], F[i,j], G[i,j], gamma_E[j]
        )
    }
    
    ## wealth redistribution

    ## TODO: redistribution is not currently working
    
    raise_levee = as.numeric(R0[i,] - R[i,])
    wealth = as.numeric(G[i,])
    damage = as.numeric(F[i,])
    cost_of_levee = as.numeric(gamma_E * raise_levee * sqrt(wealth))
    wealth_after_flood = wealth - wealth * damage
    amount_needed = pmax(0, cost_of_levee - wealth_after_flood)
    amount_available = pmax(0, (wealth_after_flood - cost_of_levee) * tau)

    total_amount_needed = sum(amount_needed)
    total_amount_available = sum(amount_available)

    redistribution = rep(0, nc)
    if (total_amount_needed < total_amount_available) {
        redistribution = amount_available * (total_amount_needed / total_amount_available) * -1
        redistribution[raise_levee > 0] = amount_needed[raise_levee > 0]
    } else {
        redistribution = amount_needed * (total_amount_available / total_amount_needed)
        redistribution[!raise_levee > 0] = (amount_available * -1)[!raise_levee > 0]
    }

    ## perform wealth redistribution, and recalculate constrains
    ## on flood protection
    if (sum(abs(redistribution)) > 0) {
        print(redistribution)
        print(as.numeric(R[i,]))
        print(as.numeric(G[i,]))
    }
    
    G[i,] = G[i,] + redistribution

    if (sum(abs(redistribution)) > 0) {
        print(as.numeric(G[i,]))
    }
    
    for (j in 1:nc) {
        R[i,j] = constrain_protection_increase(
            R0[i,j], F[i,j], G[i,j], gamma_E[j],
            check_incentive=FALSE,
            check_affordable=TRUE
        )
    }

    if (sum(abs(redistribution)) > 0) {
        print(as.numeric(R[i,]))
    }
    
    for (j in 1:nc) {
        
        ## shock magnitude
        if (R[i,j] > 0) {
            S[i,j] = alpha_S[j] * F[i,j]
        } else {
            S[i,j] = 0
        }
        
        ## value of Dirac comb
        if (w[i] > 0) {
            Delta = 1 / dt
        } else {
            Delta = 0
        }

        ## compute system dynamics without redistribution
        dG_dt = rho_E[j] * (1 - D[i,j]) * G[i,j] - Delta * (F[i,j] * G[i,j] + gamma_E[j] * R[i,j] * sqrt(G[i,j]))
        dD_dt = (M[i,j] - D[i,j] / lambda_P[j]) * (sigma_P[j] / sqrt(G[i,j]))
        dH_dt = Delta * R[i,j] - keta_T[j] * H[i,j]
        dM_dt = Delta * S[i,j] - mu_S[j] * M[i,j]

        G[i+1,j] = G[i,j] + dG_dt * dt
        D[i+1,j] = D[i,j] + dD_dt * dt
        H[i+1,j] = H[i,j] + dH_dt * dt
        M[i+1,j] = M[i,j] + dM_dt * dt
    }
}    

## plots
## #####

Gd = G %>% cbind(data.frame(time=t), .) %>% gather("key","value",-time)
Hd = H %>% cbind(data.frame(time=t), .) %>% gather("key","value",-time)
Dd = D %>% cbind(data.frame(time=t), .) %>% gather("key","value",-time)
