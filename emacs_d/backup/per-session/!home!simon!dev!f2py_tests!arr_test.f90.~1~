
SUBROUTINE MULT(A,NROW,NCOL)

  INTEGER NROW
  INTEGER NCOL
  REAL*8 A(NROW,NCOL)
  DO I=1,NROW
     DO J=1,NCOL
        A(I,J) = A(I,J) * 3.14
     END DO
  END DO
END SUBROUTINE MULT


