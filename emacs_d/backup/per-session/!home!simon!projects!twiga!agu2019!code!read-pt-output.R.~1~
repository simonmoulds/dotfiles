library(zoo)
library(xts)
library(sp)
library(ncdf4)
library(magrittr)

outdir = '/home/simon/projects/twiga/agu2019/data'

dirs = list.files(outdir, full.names=TRUE)

## ################################
## load data for modelled locations
## ################################

yield = list()
rain = list()
stns = list()
for (i in 1:length(dirs)) {
    dir=dirs[i]
    stn=basename(dir)
    era5_nc = file.path(dir, 'output/prec_era5/netcdf/Y_cropland_yearMax_output.nc')
    tahmo_nc = file.path(dir, 'output/prec_tahmo/netcdf/Y_cropland_yearMax_output.nc')
    prec_fn = file.path("../data/pt_met_data", paste0("tahmo_era5_stn_", stn, "_met_2016-2019.csv"))
    if (file.exists(era5_nc) && file.exists(tahmo_nc)) {
        nc = nc_open(file.path(dir, 'output/prec_era5/netcdf/Y_cropland_yearMax_output.nc'))
        era5_yield = ncvar_get(nc, 'crop_yield')
        nc_close(nc)

        nc = nc_open(file.path(dir, 'output/prec_tahmo/netcdf/Y_cropland_yearMax_output.nc'))
        tahmo_yield = ncvar_get(nc, 'crop_yield')
        nc_close(nc)

        x = data.frame(year=2016:2018, id=stn, era5=era5_yield, tahmo=tahmo_yield)
        yield[[stn]] = x
        y = read.csv(prec_fn, header=TRUE)
        y[["id"]] = stn 
        rain[[stn]] = y
        
        stns[[stn]] = stn
    }    
}
stns = as.character(stns)

## #######################
## extract 2018 yield data
## #######################

era5_2018 = sapply(yield, FUN=function(x) x$era5[3])
tahmo_2018 = sapply(yield, FUN=function(x) x$tahmo[3])
max_yield = max(c(era5_yield, tahmo_yield))

plot(era5_2018, tahmo_2018, xlim=c(0,11), ylim=c(0,11))

