f.X <- function(x) dlnorm(x)
f.Y <- function(y) dlnorm(y)
f.Z <- function(z) integrate(function(x,z) f.Y(z-x)*f.X(x),-Inf,Inf,z)$value
f.Z <- Vectorize(f.Z)

set.seed(1)
X <- rlnorm(1000)
Y <- rlnorm(1000)
Z <- X + Y

# compare the methods
hist(Z,freq=F,breaks=50, xlim=c(0,30))
z <- seq(0,50,0.01)
lines(z,f.Z(z),lty=2,col="red")

