## ICRISAT - farmers land holding size (1970-2010)
library(readxl)
bihar_nia = read_excel("data/ICRISAT/Bihar/dt_nca_gca_nia_gia_a_web.xlsx", skip=9)
up_nia = read_excel("data/ICRISAT/UttarPradesh/dt_nca_gca_nia_gia_a_web.xlsx", skip=9)
nia = rbind(bihar_nia, up_nia)
icrisat_ids = c(901,902,903,904,906,907,911,220,221,222,224)
nia = nia[nia$DIST %in% icrisat_ids,]

lut = data.frame(DIST=icrisat_ids,
                 GAUL_ID=c(17618,17613,17598,730,17628,17619,644,17894,17914,72651,17892))

nia =
    left_join(lut, nia, by="DIST") %>%
    na_if(-1.00)

nia =
    nia %>%
    select(-DIST,-STCODE,-STNAME,-DISTNAME) %>%
    gather(key, value, -GAUL_ID, -YEAR) %>%
    spread(YEAR, value) %>%
    gather(YEAR, value, -GAUL_ID, -key) %>%
    unite(GAUL_ID, GAUL_ID, key, sep="-") %>%
    spread(GAUL_ID, value) %>%
    zoo::na.approx() %>%
    zoo::na.locf() %>%
    zoo::na.locf(fromLast=TRUE) %>%
    as.data.frame %>%
    gather(GAUL_ID, value, -YEAR) %>%
    separate(GAUL_ID, c("GAUL_ID","key"), "-") %>%
    mutate_at(vars(GAUL_ID), funs(as.numeric)) %>%
    spread(key, value) ## %>%
    ## select(-GAUL_ID) %>%
    ## group_by(YEAR) %>%
    ## summarise_all(funs(mean(., na.rm=TRUE))) %>%
    ## ungroup

