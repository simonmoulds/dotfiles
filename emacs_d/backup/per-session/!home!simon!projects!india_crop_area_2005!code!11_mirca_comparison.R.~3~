myfun1 = function(x, crop, yrs=1961:2016) {
    if (!crop %in% x$Item) stop()
    ix = which(x$Item %in% crop)
    cols = paste0("Y", yrs)
    y = x[ix,names(x) %in% cols] %>% as.numeric %>% unname
    y
}

myfun2 = function(crop, yrs=1970:2010) {
    out = rep(NA, length(yrs))
    for (i in 1:length(yrs)) {
        fs = list.files("data/output_1960/seasonal_maps", paste0("^INDIA_(IRR|RAIN)_", toupper(crop), "_(KHARIF|RABI|SUMMER|WHOLE_YEAR)_", yrs[i], ".tif$"), full.names=TRUE)
        if (length(fs) > 0) {
            st = stack(fs)
            r = stackApply(st, indices=rep(1, nlayers(st)), fun=sum, na.rm=TRUE)
            v = getValues(r)
            out[i] = sum(v, na.rm=TRUE)
        }
    }
    out
}

myfun3 = function(d, ...) {
    p = ggplot(d, aes(yr, value, colour=id)) +
