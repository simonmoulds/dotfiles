myfun = function(fs, pts) {
    tot = rep(NA, 12)
    for (i in 1:length(india_rain_fs)) {
        r = raster(fs[i])
        vals = r[pts]
        tot[i] = sum(vals, na.rm=TRUE)
    }
    tot
}

reshape_data = function(irri, rain) {
    data = data.frame(matrix(data=NA, nrow=2, ncol=12))
    data[1,] = irri
    data[2,] = rain
    rownames(data) = c("irrigated","rainfed")
    colnames(data) = toupper(month.abb)
    data = melt(cbind(data, ID=rownames(data)), id.vars=c('ID'))
    data
}

