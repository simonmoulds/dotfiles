library(Rcpp)
library(magrittr)

## ======================================
## climate data
## ======================================

climate_data = read.table(file.path("data","input","all_data_irr2.txt"), header=TRUE)
rainfall_data = read.table(file.path("data","input","sult_precip_1971_2013.txt"), header=TRUE)
prec = rainfall_data[["precip"]]
reference_ET = climate_data[["ETo_mm"]]

## ======================================
## time data
## ======================================

tm = as.POSIXlt(rainfall_data[["date"]])
day = tm[["yday"]] + 1
month = tm[["mon"]] + 1
year = tm[["year"]] + 1900

## ======================================
## Price data
## ======================================

price_data = read.table(file.path("data","input","all.variables_yield_interp_fert_cons.txt"), header = TRUE)
price_data_year = price_data[["year"]] %>% as.POSIXlt %>% `[[`("year") %>% `+`(1900)

index1 = match(sort(unique(year)), price_data_year) ## this index removes years outside the model period
index2 = match(year, price_data_year[index1])       ## this index maps annual values to daily

rice_price_per_t = price_data[["rice_p_per_t"]][index1][index2]
wheat_price_per_t = price_data[["wheat_p_per_t"]][index1][index2]

fert_n_t_ha = price_data[["fert_n_t_ha"]][index1][index2]
fert_p_t_ha = price_data[["fert_p_t_ha"]][index1][index2]
fert_k_t_ha = price_data[["fert_k_t_ha"]][index1][index2]

fert_n_price_per_kg = price_data[["fert_n_p_per_kg"]][index1][index2]
fert_p_price_per_kg = price_data[["fert_p_p_per_kg"]][index1][index2]
fert_k_price_per_kg = price_data[["fert_k_p_per_kg"]][index1][index2]

## make fertiliser price/application rate a daily time series
fertiliser_price = matrix(data=c(fert_n_price_per_kg, fert_p_price_per_kg, fert_k_price_per_kg), ncol=3)
fertiliser_app_rate = matrix(data=c(fert_n_t_ha, fert_p_t_ha, fert_k_t_ha), ncol=3)

## TODO: remove this
fertiliser_app_rate[,1] = 120
fertiliser_app_rate[,2] = 26
fertiliser_app_rate[,3] = 48

diesel_price_data = read.table(file.path("data","input","diesel_prices_long.txt"), header = TRUE)
diesel_price_data_year = diesel_price_data[["year"]] %>% as.POSIXlt
index = diesel_price_data_year %in% tm
diesel_price = diesel_price_data[["dp"]][index]

well_cost_data = read.table(file.path("data","input","well_cost_long.txt"), header = TRUE)
well_cost_data_year = well_cost_data[["year"]] %>% as.POSIXlt
index = well_cost_data_year %in% tm
well_cost = well_cost_data[["well_cost"]][index]

## ======================================
## yield data
## ======================================

yield_data = read.table(file.path("data","input","ln_crop_yield_sultanpur.txt"), h=T)
yield_data_year = yield_data[["Year"]]
index = yield_data_year %in% year
wheat_yield = yield_data[["wheat_th"]][index]
rice_yield = yield_data[["rice_th"]][index]

## ======================================
## crop data
## ======================================

## 1. crop coefficient

Kc = rep(0, length(day))

Kc1w = 0.80 ## crop factor wheat stage 1 (all taken from Choudhury et al 2013)
Kc2w = 1.12 ## crop factor wheat stage 2
Kc3w = 1.25 ## crop factor wheat stage 3
Kc4w = 0.46 ## crop factor wheat stage 4

Kc1r = 0.61 ## crop factor rice stage 1 (again, all taken from Choudhury et al 2013)
Kc2r = 0.8  ## crop factor rice stage 2
Kc3r = 1.23 ## crop factor rice stage 3
Kc4r = 0.74 ## crop factor rice stage 4

Kc[day >=1 & day <= 16] = Kc2w
Kc[day >=17 & day <= 47] = Kc3w
Kc[day >=48 & day <= 106] = Kc4w 
Kc[day >=320 & day <= 350] = Kc1w
Kc[day >=351 & day <= 366] = Kc2w
  
Kc[day >=148 & day <= 185] = Kc1r
Kc[day >=186 & day <= 223] = Kc2r
Kc[day >=224 & day <= 261] = Kc3r 
Kc[day >=262 & day <= 296] = Kc4r

## 2. ET depletion factor

et_depletion_factor = rep(0, length(day))

et_depletion_factor_wheat = 0.55 ## ET depletion factor wheat, from FAO56
et_depletion_factor_rice = 0.20  ## ET depletion factor rice, from FAO56

et_depletion_factor[day >= 1 & day <= 106] = et_depletion_factor_wheat
et_depletion_factor[day >= 320 & day <= 366] = et_depletion_factor_wheat
et_depletion_factor[day >= 148 & day <= 296] = et_depletion_factor_rice

## 3. rooting depth

rooting_depth_wheat = 1.25  ## rooting depth wheat, from FAO56
rooting_depth_rice = 0.65   ## rooting depth rice, from FAO56
rooting_depth_fallow = 0.01 ## rooting depth fallow

rooting_depth = rep(rooting_depth_fallow, length(day))

rooting_depth[day >= 1 & day <= 106] = rooting_depth_wheat
rooting_depth[day >= 320 & day <= 366] = rooting_depth_wheat
rooting_depth[day >= 148 & day <= 296] = rooting_depth_rice

