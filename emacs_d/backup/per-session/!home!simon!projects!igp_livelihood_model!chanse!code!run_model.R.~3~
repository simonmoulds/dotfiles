## ======================================
## Parameters
## ======================================

## region characteristics
farm_area = 10000  ##10000 m^2 in ha  
region_area = 20 * farm_area
surface_elev_masl = 103   ## Actual elevation above sea level

## farmer parameters
saving_lower = 50
saving_upper = 50
savings_reduction = 0.8 ## Amount savings are reduced per year when farmers income is zero 
saving_percentage = 0.1 ## Percentage of income retained as savings

## hydrological parameters
Sy = 0.3
surface_elev = (surface_elev_masl * region_area) * Sy
H_init = (surface_elev_masl - 7) * region_area * Sy 
evaporation_loss_coef = 0.8
root_zone_depletion_init = 0
field_capacity = 0.3
wilting_point = 0.12
runoff_coef = 0.95
return_flow_coef = 0.5
canal_volume = 1 * 5 * 4000
canal_leakage_coef = 0.4

## crop parameters
wheat_yield_coeff = 1.8 ## factor to change crop max yield by as values used are averages from Gov stats TODO - add to code
rice_yield_coeff = 1.7 ## factor to change crop max yield by as values used are averages from Gov stats TODO - add to code
Ks_max = 1
Ks_min = 0
Ky_wheat = 0.6
Ky_rice = 1.3

## irrigation parameters
harvest_day = 305
wheat_months = c(11,12,1,2,3,4)
rice_months = c(5,6,7,8,9,10)
irrigation_eff = 0.4
fuel_eff = 2.00  ## Pump efficiency multiplier 100=1.0 90=1.11 80=1.25 70=1.43 50=2.0 30=3.33 
wheat_min = 0.11
wheat_max = 0.15
rice_min = 0.15
rice_max = 0.20
well_depth1 = (surface_elev_masl - 20) * region_area * Sy
well_depth2 = (surface_elev_masl - 40) * region_area * Sy
well_depth3 = (surface_elev_masl - 80) * region_area * Sy
well_depth = c(well_depth1, well_depth2, well_depth3)
max_well_depth = min(well_depth)

## lengths
n_year   = length(unique(year)) ## TODO: change this
n_day    = length(day)
n_crop   = 2
n_farmer = 50

## ======================================
## irrigation scheduling
## ======================================

wheat_irr_schedule_mu = c(3,46,319)
wheat_irr_schedule_sd = c(3,3,3)

rice_irr_schedule_mu = c(148,168,208,218,268,288)
rice_irr_schedule_sd = c(3,3,3,3,3,3)

n_wheat_irr = length(wheat_irr_schedule_mu)
n_rice_irr = length(rice_irr_schedule_sd)

wheat_irr_schedule =
    rnorm(n = n_wheat_irr * n_farmer, mean=wheat_irr_schedule_mu, sd=wheat_irr_schedule_sd) %>%
    round %>%
    `[<-`(. < 1, 1) %>%
    ## `[<-`(. < 0, 0) %>%
    matrix(nrow=n_wheat_irr, ncol=n_farmer)

rice_irr_schedule =
    rnorm(n = n_rice_irr * n_farmer, mean=rice_irr_schedule_mu, sd=rice_irr_schedule_sd) %>%
    round %>%
    `[<-`(. < 1, 1) %>%
    ## `[<-`(. < 0, 0) %>%
    matrix(nrow=n_rice_irr, ncol=n_farmer)

wheat_can_irr_schedule_mu = c(3,46)
wheat_can_irr_schedule_sd = c(1,1)

rice_can_irr_schedule_mu = c(148,168,208,268,288)
rice_can_irr_schedule_sd = c(1,1,1,1,1)

n_wheat_can_irr = length(wheat_can_irr_schedule_mu)
n_rice_can_irr = length(rice_can_irr_schedule_mu)

wheat_can_irr_schedule =
    rnorm(n = n_wheat_can_irr * n_farmer, mean=wheat_can_irr_schedule_mu, sd=wheat_can_irr_schedule_sd) %>%
    round %>%
    `[<-`(. < 1, 1) %>%
    ## `[<-`(. < 0, 0) %>%
    matrix(nrow=n_wheat_can_irr, ncol=n_farmer)

rice_can_irr_schedule =
    rnorm(n = n_rice_can_irr * n_farmer, mean=rice_can_irr_schedule_mu, sd=rice_can_irr_schedule_sd) %>%
    round %>%
    `[<-`(. < 1, 1) %>%
    ## `[<-`(. < 0, 0) %>%
    matrix(nrow=n_rice_can_irr, ncol=n_farmer)

## this function changes the irrigation schedule if an irrigation is
## scheduled a short period (say 1 or 2 days) after canal water is
## available. This is based on the assumption that if a farmer is due
## to irrigation on Tuesday (for example), but in fact canal water is
## available on the Monday, he will irrigated a day early in order to
## make use of canal water (need to check what JoK thinks of this
## approach)
for (i in 1:nrow(wheat_irr_schedule)) {
    for (j in 1:ncol(wheat_irr_schedule)) {
        v = wheat_irr_schedule[i,j]
        diff = v - wheat_can_irr_schedule[,j]
        ix = diff > 0 & diff < 1
        if (any(ix)) {
            v = wheat_can_irr_schedule[ix,j]
        }
        wheat_irr_schedule[i,j] = v
    }
}

init_farmer_category = sample(1:1, size=n_farmer, replace=TRUE)
farmer_canal_access = sample(x=0:1, size=n_farmer, replace=TRUE, prob=c(0.9,0.1)) %>% as.logical

## run model
sourceCpp("code/model.cpp")

n_runs = 5

for (i in 1:length(n_runs)) {
    x = model(prec, reference_ET, day, year, month, Kc, et_depletion_factor, rooting_depth, diesel_price, rice_price_per_t, wheat_price_per_t, rice_yield, wheat_yield, rice_yield_coeff, wheat_yield_coeff, wheat_irr_schedule, wheat_can_irr_schedule, rice_irr_schedule, rice_can_irr_schedule, wheat_months, rice_months, wheat_min, wheat_max, rice_min, rice_max, Ky_wheat, Ky_rice, fertiliser_price, fertiliser_app_rate, farmer_canal_access, init_farmer_category, well_depth, max_well_depth, well_cost, H_init, Sy, root_zone_depletion_init, harvest_day, n_year, n_day, n_crop, n_farmer, region_area, farm_area, surface_elev, return_flow_coef, irrigation_eff, canal_volume, canal_leakage_coef, field_capacity, wilting_point, runoff_coef, Ks_max, Ks_min, evaporation_loss_coef, fuel_eff, saving_percentage, saving_lower, saving_upper)

    saveRDS(x, file.path("data","output",paste0("data_run_", i, ".rds")))
}

## Category
cat = x[["farmer_category"]]
ylim <- range(cat,na.rm=T)
plot(cat[,1],col=i,x=unique(year), ylim=ylim,type="l", main="Farmer Category", xlab="Year", ylab="Category");par(new=T)  
