library(rworldmap)
library(magrittr)

data(countriesCoarse)

meta = read.csv("../data/tahmo_stn_metadata.csv")
starttm =
    sprintf("%14.0f", meta$StartDate) %>%
    as.POSIXlt(., format="%Y%m%d%H%M%S")
yrs = starttm$year + 1900
meta[["StartYear"]] = as.integer(sprintf("%4.0f", yrs))
meta %<>% dplyr::select(X, Y, StartYear)

