    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:7, 8)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 11, 10)

    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:7, 8)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 11, 10)

    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:7, 8)
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 11, 10)
}

if (dist_nm %in% c("Bongaigaon")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:7, 8)
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 11, 10)

    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 1:7, 8)
    xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice-summer"]], 11, 10)

    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 1:8, 9)
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice-autumn"]], 10:11, 9)
}

if (dist_nm %in% c("Cachar")) {
    xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice-winter"]], 1:9, 10)
