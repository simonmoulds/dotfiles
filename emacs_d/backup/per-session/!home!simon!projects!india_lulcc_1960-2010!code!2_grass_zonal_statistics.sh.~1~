#!/bin/bash

wd=$HOME/projects/india_lulcc_1960-2010

echo '1:deciduous_broadleaf_forest
2:cropland
3:built_up_land
4:mixed_forest
5:shrubland
6:barren_land
7:fallow_land
8:wasteland
9:water_bodies
10:plantations
11:aquaculture
12:mangrove_forest
13:salt_pan
14:grassland
15:evergreen_broadleaf_forest
16:deciduous_needleleaf_forest
17:permanent_wetlands
18:snow_ice
19:evergreen_needleleaf_forest
' > category_names

echo 'export GRASS_MESSAGE_FORMAT=plain
r.mask -r
g.region rast=lulc_1985
g.region -p
r.category map=lulc_1985 separator=: rules=category_names
r.category map=lulc_1995 separator=: rules=category_names
r.category map=lulc_2005 separator=: rules=category_names
r.stats -al input=IND_adm2_1956_rast,lulc_1985 separator=tab output=data/lulc_1985_dist_area.txt --overwrite
r.stats -al input=IND_adm2_1956_rast,lulc_1995 separator=tab output=data/lulc_1995_dist_area.txt --overwrite
r.stats -al input=IND_adm2_1956_rast,lulc_2005 separator=tab output=data/lulc_2005_dist_area.txt --overwrite
' > mygrassjob.sh

chmod u+x mygrassjob.sh
export GRASS_BATCH_JOB=$wd/mygrassjob.sh
grass $HOME/grassdata/lcc/PERMANENT
unset GRASS_BATCH_JOB
rm mygrassjob.sh category_names
