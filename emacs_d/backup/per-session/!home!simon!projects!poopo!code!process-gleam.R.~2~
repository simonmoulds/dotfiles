## ################################### ##
## 2 - MOD16A2
## ################################### ##

years = 2001:2014
titicaca_rast = rasterize(
    basin_titicaca,
    raster("/data/earthengine/MODIS_NTSG_MOD16A2_105_A2001001.tif")
)
titicaca_rast[titicaca_rast != 1] = NA

poopo_rast = rasterize(
    basin_poopo,
    raster("/data/earthengine/MODIS_NTSG_MOD16A2_105_A2001001.tif"),
    field=1
)

basin_list = list(poopo=poopo_rast, titicaca=titicaca_rast)

annual_maps = vector(mode="list", length=length(years) * length(basin_list))
annual_total = as.data.frame(matrix(data=NA, nrow=length(years), ncol=length(basin_list)))
names(annual_total) = names(basin_list)
for (k in 1:length(basin_list)) {
    basin_rast = basin_list[[k]]
    for (i in 1:length(years)) {
        year = years[i]
        ptn = paste0("MODIS_NTSG_MOD16A2_105_A", year, "[0-9]{3}.tif")
        fs = list.files(
            '/data/earthengine',
            pattern=ptn,
            full.names=TRUE
        )
        maps = vector(mode="list", length=length(fs))
        for (j in 1:length(fs)) {        
            maps[[j]] = raster(fs[j]) * 0.1
        }
        ann_map = stackApply(stack(maps), indices=rep(1,length(fs)), fun=sum)
        ann_map[is.na(basin_rast)] = NA
        ann_map[ann_map == 0] = NA
        annual_maps[[i]] = ann_map
        annual_total[i,k] = mean(getValues(ann_map), na.rm=TRUE)
    }
}

