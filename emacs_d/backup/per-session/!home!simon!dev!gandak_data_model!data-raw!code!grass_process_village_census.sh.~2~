declare -a columns=(
    "a_LAND_FORES"
    "a_CANAL_GOVT"
    "a_WELL_WO_EL"
    "a_WELL_W_EL"
    "a_TW_WO_EL"
    "a_TW_W_EL"
    "a_TANK_IRR"
    "a_RIVER_IRR"
    "a_W_FALL"
    "a_OTH_IRR"
    "a_TOT_IRR"
    "a_UN_IRR"
    "a_CULT_WASTE"
    "a_AREA_NA_CU"
)

for state in "${suffixes[@]}"
do
    
    # import 30 arc-second grid from latlong, and
    # set the region to match its extent
    v.proj \
        location=latlong \
        mapset=PERMANENT \
        input="${state}"_grid_30s \
        --overwrite
    g.region vector="${state}"_grid_30s
    g.region -p
    
    # import the data
    infile=$datadir/india-village-census-2001-"${state}".gpkg
    v.in.ogr \
        input="${infile}" \
        output="${state}"_census_2001 \
        --overwrite

    # add a column to store the size of each
    # polygon in the vector map
    v.db.addcolumn \
        map="${state}"_census_2001 \
        columns="area_size double precision"

    v.to.db \
        map="${state}"_census_2001 \
        option=area \
        columns=area_size \
        units=meters

    # Intersect the census map with the grid map,
    # effectively dividing the areas in ainput
    # according to the area boundaries in binput
    # (see man page for more details)
    v.overlay \
        ainput="${state}"_census_2001 \
        binput="${state}"_grid_30s \
        operator=and \
        output="${state}"_census_2001_grid \
        snap=1e-8 \
        --overwrite

    # add a column to store the area of each
    # polygon in the resulting map
    v.db.addcolumn \
        map="${state}"_census_2001_grid \
        columns="new_area_size double precision"

    v.to.db \
        map="${state}"_census_2001_grid \
        option=area \
        columns=new_area_size \
        units=meters

    # compute the percentage area of a village in
    # the new polygons
    v.db.addcolumn \
        map="${state}"_census_2001_grid \
        columns="area_weight double precision"

    v.db.update \
        map="${state}"_census_2001_grid \
        column=area_weight \
        qcol="new_area_size/a_area_size"

