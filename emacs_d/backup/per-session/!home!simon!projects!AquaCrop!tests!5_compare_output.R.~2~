        paste0("Ch7_Tunis_Wheat_", suffix[i], "_1988_CropGrowth.txt"),
        "Bio") %>%
        max

    aqpy_yield =
        get_aqpy_output(
            aqpydir,
            paste0("Output_Ch7_Tunis_Wheat_", suffix[i], "_1988"),
            "Y_dailyTot_output.nc") %>%
        max %>% round(digits=2)

    aqpy_biomass =
