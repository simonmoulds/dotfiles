#!/bin/bash

# This script is run from
# 'run_grass_process_village_census.sh'

export GRASS_MESSAGE_FORMAT=plain

wd=/home/simon/dev/gandak_data_model/data-raw
datadir=/data/india_village_level_geospatial_socio_econ_data

# declare array of state suffixes...
declare -a suffixes=("BR" "UP")
    # "AP" "AR" "AS" "BR" "CG" "GA" "GJ" "HR" "HP"
    # "JK" "JH" "KA" "KL" "MP" "MH" "MN" "ML" "MZ"
    # "NL" "OR" "PB" "RJ" "SK" "TN" "TR" "UP" "UK"
    # "WB" "UTerr")

# ...and array of columns
declare -a columns=(
    "LAND_FORES"
    "CANAL_GOVT"
    "CANAL_PVT"
    "WELL_WO_EL"
    "WELL_W_EL"
    "TW_WO_EL"
    "TW_W_EL"
    "TANK_IRR"
    "RIVER_IRR"
    "W_FALL"
    "OTH_IRR"
    "TOT_IRR"
    "UN_IRR"
    "CULT_WASTE"
    "AREA_NA_CU"
)

declare -a land_use_columns=(
    "LAND_FORES"
    "TOT_IRR"
    "UN_IRR"
    "CULT_WASTE"
    "AREA_NA_CU"
)

declare -a irr_area_columns=(
    "CANAL_GOVT"
    "CANAL_PVT"
    "WELL_WO_EL"
    "WELL_W_EL"
    "TW_WO_EL"
    "TW_W_EL"
    "TANK_IRR"
    "RIVER_IRR"
    "W_FALL"
    "OTH_IRR"
)    

# reproject template map from latlong location
r.proj \
    location=latlong \
    mapset=PERMANENT \
    input=template \
    --overwrite

for state in "${suffixes[@]}"
do
    
    # import 30 arc-second grid from latlong, and
    # set the region to match its extent.
    v.proj \
        location=latlong \
        mapset=PERMANENT \
        input="${state}"_grid_30s \
        --overwrite

    g.region \
        vector="${state}"_grid_30s \
        align=template    
    g.region -p

    # for now, create a temporary cropland map
    # (ultimately replace with real cropland map)
    r.mapcalc "cropland = 1" --overwrite
    
    # import the village geospatial dataset for
    # the current state
    infile=$datadir/india-village-census-2001-"${state}".gpkg
    v.in.ogr \
        input="${infile}" \
        output="${state}"_census_2001 \
        --overwrite

    # compute the actual area of each polygon
    v.db.addcolumn \
        map="${state}"_census_2001 \
        columns="area_size double precision"
    v.to.db \
        map="${state}"_census_2001 \
        option=area \
        columns=area_size \
        units=meters

    # repair land use and irrigated areas
    v.db.addcolumn \
        map="${state}"_census_2001 \
        columns="calculated_area double precision,calculated_irr_area double precision,area_scale_factor double precision,irr_area_scale_factor double precision"
    
    # compute the area from the provided land use
    # statistics (hectares)
    v.db.update \
        map="${state}"_census_2001 \
        col=calculated_area \
        qcol="LAND_FORES+TOT_IRR+UN_IRR+CULT_WASTE+AREA_NA_CU"
    
    # compute a scale factor (divide by 10000 to
    # convert from hectares -> meters)
    v.db.update \
        map="${state}"_census_2001 \
        col=area_scale_factor \
        qcol="area_size / 10000 / calculated_area" \
        where="calculated_area > 0"

    # multiply land use columns by area_scale_factor
    # - this ensures that the sum of the area of
    # each land use equals the area of the polygon
    # (computed with v.to.db)
    for lu in "${land_use_columns[@]}"
    do        
        v.db.update \
            map="${state}"_census_2001 \
            col="${lu}" \
            qcol="${lu} * area_scale_factor"
    done

    # for irr in "${irr_area_columns[@]}"
    # do
    #     v.db.update \
    #         map="${state}"_census_2001 \
    #         col="${irr}" \
    #         qcol="${irr} * area_scale_factor"
    # done    

    # now scale irrigation columns to match TOT_IRR.
    # We do it this way (rather than just
    # multiplying the irrigation column by
    # area_scale_factor) because sometimes values
    # are provided for irrigation columns even when
    # TOT_IRR equals zero. We assume TOT_IRR is
    # correct, and scale the irrigation columns
    # accordingly.
    v.db.update \
        map="${state}"_census_2001 \
        col=calculated_irr_area \
        qcol="CANAL_GOVT+CANAL_PVT+WELL_WO_EL+WELL_W_EL+TW_WO_EL+TW_W_EL+TANK_IRR+RIVER_IRR+LAKE_IRR+W_FALL+OTH_IRR"
    v.db.update \
        map="${state}"_census_2001 \
        col=irr_area_scale_factor \
        qcol="TOT_IRR / calculated_irr_area"    
    for irr in "${irr_area_columns[@]}"
    do
        v.db.update \
            map="${state}"_census_2001 \
            col="${irr}" \
            qcol="${irr} * irr_area_scale_factor"
    done    
    
    # now, we intersect the census map with the
    # grid map, effectively dividing the areas in
    # ainput according to the area boundaries in
    # binput (see man page for more details)
    v.overlay \
        ainput="${state}"_census_2001 \
        binput="${state}"_grid_30s \
        operator=and \
        output="${state}"_census_2001_grid \
        snap=1e-8 \
        --overwrite

    # compute the area of each new polygon in the
    # resulting map
    v.db.addcolumn \
        map="${state}"_census_2001_grid \
        columns="new_area_size double precision"
    v.to.db \
        map="${state}"_census_2001_grid \
        option=area \
        columns=new_area_size \
        units=meters

    # convert overlay result to points
    v.extract \
        input="${state}"_census_2001_grid \
        output="${state}"_census_2001_grid_pts \
        type=centroid \
        --overwrite
    
    # find out whether each area contains
    # cropland; this works by querying the cropland
    # raster map with the centroids of each polygon
    # in the overlay result (e.g.
    # "${state}"_census_2001_grid_pts). Because
    # the cropland map is binary (1=cropland, 0=no
    # cropland), the result of the query may be
    # interpreted as a boolean.
    v.db.addcolumn \
        map="${state}"_census_2001_grid_pts \
        columns="has_cropland double precision"
    v.what.rast \
        map="${state}"_census_2001_grid_pts \
        type=centroid \
        raster=cropland \
        column=has_cropland

    # compute cropland area in village by
    # multiplying the polygon area with has_cropland
    v.db.addcolumn \
        map="${state}"_census_2001_grid_pts \
        columns="cropland_area double precision,total_cropland_area double precision"    
    v.db.update \
        map="${state}"_census_2001_grid_pts \
        col=cropland_area \
        qcol="has_cropland * new_area_size"

    # add up cropland area within a village
    v.vect.stats \
        points="${state}"_census_2001_grid_pts \
        type=centroid \
        areas="${state}"_census_2001 \
        points_column=cropland_area \
        count_column=num_points \
        method=sum \
        stats_column=total_cropland_area    

    # add village total_cropland_area to each
    # polygon in the overlay map by joining
    # database tables
    v.db.join \
        map="${state}"_census_2001_grid_pts \
        column=a_cat \
        other_table="${state}"_census_2001 \
        other_column=cat \
        subset_columns=total_cropland_area
    
    # compute the percentage of the total cropland
    # in a village in each of the new polygons
    v.db.addcolumn \
        map="${state}"_census_2001_grid_pts \
        columns="area_weight double precision"

    v.db.update \
        map="${state}"_census_2001_grid_pts \
        column=area_weight \
        qcol="cropland_area / total_cropland_area"

    # # CHECK
    # v.out.ogr \
    #     input="${state}"_census_2001_grid_pts \
    #     output="${state}"_census_2001_grid_pts.gpkg \
    #     type=centroid \
    #     format=GPKG \
    #     --overwrite
    
    for column in "${columns[@]}"
    do
        col=a_"${column}"
        newcol=a_"${column}"_wt        
        v.db.addcolumn \
            map="${state}"_census_2001_grid_pts \
            columns="${newcol} double precision"
        v.db.update \
            map="${state}"_census_2001_grid_pts \
            column="${newcol}" \
            qcol="${col}*area_weight"        
        v.vect.stats \
            points="${state}"_census_2001_grid_pts \
            type=centroid \
            areas="${state}"_grid_30s \
            points_column="${newcol}" \
            count_column=num_points \
            method=sum \
            stats_column="${col}"_sum
    done
done

