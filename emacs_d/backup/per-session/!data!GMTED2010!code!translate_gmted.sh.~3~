#!/bin/bash

for product in mi15 mn15 mx15 mi75 mn75 mx75
do
    subdir=/data/GMTED2010/data-raw/
    outdir=/data/GMTED2010/data/
    if [ ! -d ${outdir}/${product}_grd ];
    then
    	mkdir ${outdir}/${product}_grd
    fi    
    unzip -o ${subdir}/${product}_grd.zip -d ${outdir}/${product}_grd
    gdal_translate ${outdir}/${product}_grd/${product}_grd -of GTiff ${outdir}/${product}.tif
done
