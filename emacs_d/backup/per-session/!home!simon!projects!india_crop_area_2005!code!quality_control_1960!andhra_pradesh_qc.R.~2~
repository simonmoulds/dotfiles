## Rice
## ####

## http://drdpat.bih.nic.in/Status%20Paper%20-%2002.htm

xx[["irr_rice-summer"]][57:63] <- xx[["irr_rice-winter"]][57:63]
xx[["irr_rice-winter"]][50:63] <- NA
xx[["irr_rice-winter"]][is.na(xx[["irr_rice-winter"]])] <- xx[["irr_rice-autumn"]][is.na(xx[["irr_rice-winter"]])]
xx[["irr_rice-autumn"]] <- NA

xx[["irr_rice-summer"]] %<>% irr_frac_interp(xx[["apy_rice"]], 44:50, 43)
xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice"]], 44:50, 43)
xx[["irr_rice-winter"]] %<>% irr_frac_interp(xx[["apy_rice"]], 53, 52)

xx[["apy_rice"]] %<>% tot_frac_interp(rowSums(data.frame(xx[["irr_rice-summer"]], xx[["irr_rice-winter"]])), 61:63, 60)

## Sesamum
## #######

xx[["apy_sesamum"]] %<>% tot_frac_interp(xx[["irr_sesamum"]], 61:63, 60)

if (dist_nm %in% c("Chittoor")) {
    xx[["apy_sesamum"]] %<>% tot_frac_interp(xx[["irr_sesamum"]], 44, c(43,45))
    xx[["irr_sesamum"]] %<>% tot_frac_interp(xx[["apy_sesamum"]], 46, c(45,47))
}

if (dist_nm %in% c("Nalgonda")) {
    xx[["apy_sesamum"]] %<>% locf_interp(61:63)
    xx[["irr_sesamum"]] %<>% locf_interp(61:63)
}

if (dist_nm %in% c("Nizamabad")) {
    xx[["apy_sesamum"]] %<>% tot_frac_interp(xx[["irr_sesamum"]], 44:47, c(43))
}

if (dist_nm %in% c("Srikakulam.Vishakhapatnam")) {
    xx[["apy_sesamum"]] %<>% linear_interp(61)
    xx[["irr_sesamum"]] %<>% linear_interp(61)
}

if (dist_nm %in% c("West Godavari")) {
    xx[["apy_sesamum"]] %<>% tot_frac_interp(xx[["irr_sesamum"]], 46, 45)
}

