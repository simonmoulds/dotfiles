#!/bin/bash

# unzip raw files
for f in *.zip
do
    basen=$(echo $f | sed 's/\(.*\).zip/\1/')
    if [ ! -d $basen ]
    then
	mkdir $basen
    fi
    unzip -o $f -d $basen
done

# unzip conversion tool
unzip -o conversion_flt2asc/batch_conversion_mirca2000_flt_to_asc_execmd.zip -d conversion_flt2asc

cp conversion_flt2asc/flt_to_asc.exe monthly_growing_area_grids

cd monthly_growing_area_grids

ls | grep -E '^crop_[0-9]{2}_(rainfed|irrigated)_[0-9]{2}.flt.gz$' > tmp
while read line
do
    newn=$(echo $line | sed 's/crop\_\(.*\)\_\(.*\)\_\(.*\).flt.gz/crop\_\1\_\2\_\3.flt/g')
    pref=$(echo $line | sed 's/crop\_\(.*\)\_\(.*\)\_\(.*\).flt.gz/crop\_\1\_\2/g')
    # echo $pref
    # echo "${line}"
    gunzip -c $line > $newn
    wine flt_to_asc.exe $newn 4320 2160 12
    mv "${pref}"*.asc /data
done < tmp 

cd ..

