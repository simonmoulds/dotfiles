## Add Mau to Azamgarh, Maharajganj to Gorakhpur
adm2_2010_raster[adm2_2010_raster == 70274] = 17892
adm2_2010_raster[adm2_2010_raster == 70272] = 17914

## downscale to 5 arcminute grid
tubewell_frac = raster("../data/igp_tw_irr.tif")
tubewell_frac = crop(tubewell_frac, extent(template))
tubewell_frac = aggregate(tubewell_frac, fact=10, fun=sum)

v = getValues(adm2_2010_raster)

cats = c("MARG","SMALL","SEMIM","MEDIUM","LARGE")

tw_ownership = list(
    marg=raster(template),
    small=raster(template),
    semim=raster(template),
    medium=raster(template),
    large=raster(template))

for (i in 1:length(cats)) {
    farm_nos = raster(file.path("../data", paste0(tolower(cats[i]), "_no_1980.tif")))
    for (j in 1:nrow(mi1986)) {
        gaul_id = mi1986$gaul_id[j]
        cell_ix = which(v == gaul_id)
        total_farms = sum(farm_nos[cell_ix])
        if (is.na(total_farms)) stop()
        col_nm = paste0(cats[i], "_NO_TW")
        total_tubewells = mi1986[[col_nm]][j]
        area = tubewell_frac[cell_ix]
        weight = area / sum(area)
        tubewell_nos = total_tubewells * weight
        tw_ownership[[i]][cell_ix] = tubewell_nos / farm_nos[cell_ix]
    }
}

for (i in 1:length(tw_ownership)) {
    r = tw_ownership[[i]]
    r = crop(r, extent(model_mask))
    tw_ownership[[i]] = r
}

plot(tw_ownership[[1]])
plot(tw_ownership[[2]])
plot(tw_ownership[[3]])
plot(tw_ownership[[4]])
plot(tw_ownership[[5]])

for (i in 1:length(cats)) {
    r = tw_ownership[[i]]
    r = crop(r, extent(model_mask))
    tw_ownership[[i]] = r
    nm = file.path("../data", paste0(tolower(cats[i]), "_tw_ownership_rate.tif"))
    writeRaster(r, nm, format="GTiff", overwrite=TRUE)
}

