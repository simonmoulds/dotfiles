## District-wise number of tubewells
mi1986 = read_excel("../data/micensus/micensus_1986-87_shallowtubewell.xls") %>%
    setNames(paste0("X", seq(1, ncol(.)))) %>%
    filter(X1 %in% c("Bihar","Uttar Pradesh")) %>%
    setNames(c("state","id","dist", names(.)[4:38])) %>%
    dplyr::select(-(id)) %>%
    mutate(state = toupper(state)) %>%
    mutate(dist = toupper(dist)) %>%
    mutate(dist = replace(dist, dist == "EAST CHAMPARAN", "PURBA CHAMPARAN")) %>%
    mutate(dist = replace(dist, dist == "WEST CHAMPARAN", "PASHCHIM CHAMPARAN")) %>%
    mutate(dist = replace(dist, dist == "SAMISTIPUR", "SAMASTIPUR")) %>%
    filter(dist %in% toupper(x$dist)) %>% 
    left_join(x, by=c("state","dist"))

nms = names(mi1986)
nms[15:20] = c("MARG_NO_TW","SMALL_NO_TW","SEMIM_NO_TW","MEDIUM_NO_TW","LARGE_NO_TW","TOTAL_NO_TW")
names(mi1986) = nms
mi1986 %<>% dplyr::select(c("state","dist","gaul_id","MARG_NO_TW","SMALL_NO_TW","SEMIM_NO_TW","MEDIUM_NO_TW","LARGE_NO_TW","TOTAL_NO_TW"))

