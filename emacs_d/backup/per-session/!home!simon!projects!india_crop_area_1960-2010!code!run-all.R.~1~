rm(list=ls())

## Load required packages (all available on CRAN)
library(zoo)
library(maptools)    
library(rgdal)      
library(raster)
library(gdalUtils)

## Raw land use/land cover data from Indiastat and ICRISAT has been
## processed and added to the R package 'indagridat'. This package also
## contains the modified GADM district boundaries used in the analysis. 

## load data package and required datasets
devtools::load_all("pkg/indagridat")

data(indiastat1950)
data(icrisat1950)
district1950 <- readOGR(dsn=system.file("shapes",
                                        package="indagridat"),
                        layer="IND_adm2_1956_aea")

