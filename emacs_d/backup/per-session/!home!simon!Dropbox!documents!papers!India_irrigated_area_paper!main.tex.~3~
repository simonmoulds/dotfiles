\title{IndiaCropAtlas, a spatio-temporal dataset of irrigated and rainfed crop area in India (1970--2010)}

\author{Simon Moulds\textsuperscript{1{*}}, Wouter Buytaert\textsuperscript{2}, Slobodan Djordjevic\textsuperscript{1}, Dragan Savic\textsuperscript{1}}

\maketitle
