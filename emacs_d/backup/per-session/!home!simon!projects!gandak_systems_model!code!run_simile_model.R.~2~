## Script to run the Simile system dynamics model

library(Simile)
use.simile.at("/usr/lib/simile-6.9")

## load Simile model
model.handle = load.model("/home/simon/Simile/models/gandak_model_v2.so")
objs = list.objects(model.handle)
## for (obj in objs) {
##     print(c(obj, get.model.property(model.handle, obj, "Dims")))
## }

## create model instance, and load file parameters
instance.handle = create.model(model.handle)
set.model.step(instance.handle, 1, 1)
param.file = "/home/simon/Simile/models/gandak_model_v2.spf"
consult.parameter.metafile(instance.handle, param.file)
reset.model(instance.handle, -2)
get.model.time(instance.handle)
ts = 0:365

groundwater_depth = rep(0, length(ts))
recharge = rep(0, length(ts))
prec = rep(0, length(ts))
etref = rep(0, length(ts))
current_account = rep(0, length(ts))
tubewell_nos = rep(0, length(ts))
crop_income = rep(0, length(ts))
annual_income = rep(0, length(ts))
crop_yield = vector(mode="list", length(ts))
market_rate = vector(mode="list", length(ts))

for (count in ts) {
    execute.model(instance.handle, count+1, "Euler", count)
    groundwater_depth[count] = get.value.list(instance.handle, "/aquifer/groundwater_depth")
    recharge[count+1] = get.value.list(instance.handle, "/aquifer/recharge")
    prec[count+1] = get.value.list(instance.handle, "/Prec")
    etref[count+1] = get.value.list(instance.handle, "/ETref")
    current_account[count+1] = get.value.list(instance.handle, "/farm_income/current_account")
    tubewell_nos[count+1] = get.value.list(instance.handle, "/tubewell/tubewell_nos")
    crop_income[count+1] = get.value.list(instance.handle, "/farm_income/annual_income")
    annual_income[count+1] = get.value.list(instance.handle, "/farm_income/annual_income")
    market_rate[[count+1]] = get.value.list(instance.handle, "/crops/market_rate")
    ## crop_yield[[count+1]] = get.value.list(instance.handle, "/crops/crop_yield/Ya")
}
