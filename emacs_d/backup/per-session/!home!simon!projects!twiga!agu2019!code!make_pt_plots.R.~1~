library(zoo)
library(xts)
library(sp)
library(ncdf4)
library(magrittr)

rootdir = '/home/simon/projects/twiga/agu2019/data/aquacrop_pt'

## ################################
## load data for modelled locations
## ################################

read_yield = function(rootdir, subdir, crop) {
    yield_list = list()
    dirs = list.files(file.path(rootdir, subdir), full.names=TRUE)
    for (i in 1:length(dirs)) {
        dir=dirs[i]
        stn=basename(dir)
        era5_nc = file.path(dir, 'output', crop, 'prec_era5/netcdf/Y_cropland_yearMax_output.nc')
        tahmo_nc = file.path(dir, 'output', crop, 'prec_tahmo/netcdf/Y_cropland_yearMax_output.nc')        
        if (file.exists(era5_nc) && file.exists(tahmo_nc)) {
            nc = nc_open(era5_nc)
            era5_yield = ncvar_get(nc, 'crop_yield')
            nc_close(nc)

            nc = nc_open(tahmo_nc)
            tahmo_yield = ncvar_get(nc, 'crop_yield')
            nc_close(nc)

            x = data.frame(year=2016:2018, id=stn, era5=era5_yield, tahmo=tahmo_yield)
            yield_list[[stn]] = x
        }
    }    
    yield_list
}

## #######################
## extract 2018 yield data
## #######################

## Ghana
## #####

## Maize
ghana_maize_yield =
    read_yield(rootdir, "ghana", "maize") %>%
    do.call(rbind, .) %>%
    dplyr::filter(year %in% 2018)

plot(ghana_maize_yield$era5, ghana_maize_yield$tahmo, xlim=c(0,11), ylim=c(0,11))

## Sorghum
ghana_sorghum_yield =
    read_yield(rootdir, "ghana", "sorghum") %>%
    do.call(rbind, .) %>%
    dplyr::filter(year %in% 2018)

plot(ghana_sorghum_yield$era5, ghana_sorghum_yield$tahmo, xlim=c(0,13), ylim=c(0,13))

library(ggplot2)
p = ggplot(ghana_sorghum_yield, aes(x=era5, y=tahmo)) +
    geom_point(shape=1, size=3) +
    xlim(0,13) +
    ylim(0,13) +
    xlab("AquaCrop_ERA5") +
    ylab("AquaCrop_TAHMO")
p

