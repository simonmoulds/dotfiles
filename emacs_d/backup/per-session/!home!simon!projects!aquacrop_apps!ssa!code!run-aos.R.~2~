wd = getwd()
setwd(file_path_aos)
run_cmd = paste0("octave --eval AquaCropOS_RUN && break")
system(run_cmd)
setwd(wd)

## ######################
## read AquaCropOS output
## ######################

x = read.table("../data/aquacrop_os/Output/output_FinalOutput.txt", header=TRUE, sep="\t")
yield = x$Yield

## ###########################
## read AquaCrop-Python output
## ###########################

## point at which AquaCropOS was run
pts = SpatialPoints(
    coords=data.frame(x=-1.875, y=7.875),
    proj4string=CRS("+proj=longlat +ellps=WGS84 +datum=WGS84 +no_defs")
)

## for year 2000
nc = nc_open(file.path("../data", "netcdf", "Y_cropland_yearMax_output.nc"))
yield = ncvar_get(nc, "crop_yield") # nlon, nlat, time
lat = ncvar_get(nc, "lat")
lon = ncvar_get(nc, "lon")
lat_ix = which.min(abs(lat - pts$y))[1]
lon_ix = which.min(abs(lon - pts$x))[1]
yield_val = yield[lon_ix,lat_ix]
