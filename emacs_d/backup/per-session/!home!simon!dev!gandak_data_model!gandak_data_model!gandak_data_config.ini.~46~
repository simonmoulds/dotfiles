[globalOptions]

# Set the input directory map in an absolute path. The input
# forcing and parameter directories will be relative to this
# inputDir  = /home/simon/projects/gandak_systems_model_data/data
inputDir = /home/simon/dev/gandak_data_model/data

# output directory (absolute)
outputDir = /home/simon/projects/gandak_systems_model/land_surface/input

# Map of clone (must be provided in PCRaster maps)
cloneMap = Gandak05min.clone_sub.map

# The area/landmask of interest:
