## ======================================
## crop data
## ======================================

## 1. crop coefficient

Kc = rep(0, length(day))

Kc1w = 0.80 ## crop factor wheat stage 1 (all taken from Choudhury et al 2013)
Kc2w = 1.12 ## crop factor wheat stage 2
Kc3w = 1.25 ## crop factor wheat stage 3
Kc4w = 0.46 ## crop factor wheat stage 4

Kc1r = 0.61 ## crop factor rice stage 1 (again, all taken from Choudhury et al 2013)
Kc2r = 0.8  ## crop factor rice stage 2
Kc3r = 1.23 ## crop factor rice stage 3
Kc4r = 0.74 ## crop factor rice stage 4

Kc[day >=1 & day <= 16] = Kc2w
Kc[day >=17 & day <= 47] = Kc3w
Kc[day >=48 & day <= 106] = Kc4w 
Kc[day >=320 & day <= 350] = Kc1w
Kc[day >=351 & day <= 366] = Kc2w
  
Kc[day >=148 & day <= 185] = Kc1r
Kc[day >=186 & day <= 223] = Kc2r
Kc[day >=224 & day <= 261] = Kc3r 
Kc[day >=262 & day <= 296] = Kc4r

## 2. ET depletion factor

et_depletion_factor = rep(0, length(day))

et_depletion_factor_wheat = 0.55 ## ET depletion factor wheat, from FAO56
et_depletion_factor_rice = 0.20  ## ET depletion factor rice, from FAO56

et_depletion_factor[day >= 1 & day <= 106] = et_depletion_factor_wheat
et_depletion_factor[day >= 320 & day <= 366] = et_depletion_factor_wheat
et_depletion_factor[day >= 148 & day <= 296] = et_depletion_factor_rice

## 3. rooting depth

rooting_depth_wheat = 1.25  ## rooting depth wheat, from FAO56
rooting_depth_rice = 0.65   ## rooting depth rice, from FAO56
rooting_depth_fallow = 0.01 ## rooting depth fallow

rooting_depth = rep(rooting_depth_fallow, length(day))

rooting_depth[day >= 1 & day <= 106] = rooting_depth_wheat
rooting_depth[day >= 320 & day <= 366] = rooting_depth_wheat
rooting_depth[day >= 148 & day <= 296] = rooting_depth_rice

