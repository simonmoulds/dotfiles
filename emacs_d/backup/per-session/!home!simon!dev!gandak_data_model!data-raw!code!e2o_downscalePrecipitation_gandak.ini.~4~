[url]
# WRR1 (WFDEI)
serverroot = http://wci.earth2observe.eu/thredds/dodsC/
wrrsetroot = ecmwf/met_forcing_v0/

# WRR2 (EI with corrections)
# serverroot = http://wci.earth2observe.eu/thredds/dodsC/
# wrrsetroot = jrc/MSWEP/daily_e2o_netcdf_convention/


[selection]
latmin = 25
latmax = 28
lonmin = 83
lonmax = 86.5
startyear = 1979
endyear= 2014
startmonth = 1
endmonth = 12
startday = 1
endday = 31

resampling=True
# Set the variable to use here, see the table in the documentation for names
variable=Rainfall
filename=Rainf_daily_E2OBS_
standard_name=rainfall_flux

wrrversion = 1

# Optional conversions
[conversion]
# to celcius
#Temperature= Temperature - 273.15
# To mm
Rainfall= Rainfall * 86400

[downscaling]
highResDEM=/home/simon/dev/gandak_data_model/data-raw/data/hydrosheds_gandak_5m.map
downscaling=False

# linear, nearest
interpolmethod=nearest

[output]
# Gdal output format string
# See: http://www.gdal.org/formats_list.html
# examples: AAIGrid, PCRaster, GTiff
#format=PCRaster
format=GTiff
directory=/home/simon/dev/gandak_data_model/data/output_prec/
prefix=EX1
# Also downscale and save the intermediate variables (T, Pressure etc)
saveall=1

