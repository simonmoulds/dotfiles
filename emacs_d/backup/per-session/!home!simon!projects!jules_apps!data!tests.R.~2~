library(rgdal)
library(raster)

## ##################
## 1. JULES_LAND_FRAC
## ##################

## compare with WFDEI data; ensure compatability
wfdei = raster("/data/WFDEI/PSurf_daily_WFDEI/PSurf_daily_WFDEI_201612.nc")
wfdei = !is.na(wfdei)

gshhs = raster("jules_land_frac/gshhs_0.500000Deg.tif")

jules_frac = raster("jules_land_frac/jules_land_frac_0.500000Deg.tif")

v0 = getValues(wfdei)
v1 = getValues(jules_frac)

ix0 = which(v0 > v1)
ix1 = which(v1 > v0)

pts = as(wfdei, "SpatialPointsDataFrame")
pts = pts[ix0,]

plot(wfdei)
points(pts)

writeRaster(wfdei, "tmp/wfdei_grid.tif", overwrite=TRUE)
writeRaster(gshhs, "tmp/gshhs_grid.tif", overwrite=TRUE)
writeOGR(pts, "tmp", layer="missing_pts", driver="ESRI Shapefile")

