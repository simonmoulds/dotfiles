## Water balance model, based on the Global Crop Water Model
compute_eta = function(eto, ks) {
    eta = ks * eto
    eta
}

compute_ks = function(s, taw, p) {
    ks = max((s / ((1 - p) * taw)), 1)
    ks
}

compute_p = function(p_std, eto) {
    p = p_std + 0.04 * (5 - eto)
}

compute_runoff = function(prec, s0, taw, gamma) {
    runoff = prec * (s0 / taw) ** gamma
    return(runoff)
}

model = function(prec, eto, p_std, s0, taw, gamma) {
    p = compute_p(p_std, eto)
    ks = compute_ks(s0, taw, p)
    eta = compute_eta(eto, ks)
    runoff = compute_runoff(prec, s0, taw, gamma)
    s1 = max(s0 + prec - runoff - eta, 0)
    return(s1)
}

## import data for testing
meteo = read.csv("princeton_data.csv")
meteo$prcp = meteo$prcp * 24 * 60 * 60  # kg/m2/s -> mm/day
crop_params = read.csv("gcwm_crop_data.csv")

## set some parameters (assume maize, initially)
zr = 1.6 * 1000
fc = 0.33
wp = 0.10
taw = (fc - wp) * zr
s0 = 0
gamma = 2
p_std = 0.55

## run model
nt = nrow(meteo)
out = rep(NA, nt)
for (i in seq_len(nt)) {
    s1 = model(meteo$prcp[i], meteo$etref[i], p_std, s0, taw, gamma)
    if (is.nan(s1)) {
        break()
    }
    out[i] = s1
    s0 = s1
}

