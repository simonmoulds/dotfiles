## Quality control for Rajasthan

## Barley
## ######

xx[["apy_barley"]] %<>% irr_frac_interp(xx[["apy_barley"]], 61:63, 60)

if (dist_nm %in% c("Dhaulpur")) {
    xx[["irr_barley"]] = 0
}

## Chickpea
## ########

xx[["irr_chickpea"]] %<>% linear_interp(62)
xx[["apy_chickpea"]] %<>% irr_frac_interp(xx[["apy_chickpea"]], 61:63, 60)
xx[["irr_chickpea"]] %<>% tot_frac_interp(xx[["apy_chickpea"]], 44:50, 43)
xx[["irr_chickpea"]] %<>% locf_interp(60:63)
xx[["apy_chickpea"]] %<>% locf_interp(60:63)

if (dist_nm %in% c("Dhaulpur")) {
    xx[["irr_chickpea"]] = 0
}

if (dist_nm %in% c("Ganganagar")) {
    xx[["irr_chickpea"]] %<>% irr_frac_interp(xx[["apy_chickpea"]], 25:50, 51)
}

if (dist_nm %in% c("Udaipur")) {
    xx[["irr_chickpea"]] %<>% irr_frac_interp(xx[["apy_chickpea"]], 21, 20)
}

## Finger millet
## #############

xx[["irr_finger_millet"]] = 0
xx[["apy_finger_millet"]] = 0

## Groundnut
## #########

xx[["apy_groundnut"]] %<>% irr_frac_interp(xx[["irr_chickpea"]], 61:63, 60)

if (dist_nm %in% c("Banswara","Jhalawar")) {
    xx[["apy_groundnut"]] %<>% locf_interp(61:63)
    xx[["irr_groundnut"]] %<>% locf_interp(61:63)
}

## Maize
## #####

xx[["apy_maize"]] %<>% irr_frac_interp(xx[["irr_maize"]], 61:63, 60)

if (dist_nm %in% c("Bharatpur")) {
    xx[["irr_maize"]] %<>% linear_interp(62)
}

if (dist_nm %in% c("Ganganagar")) {
    xx[["apy_maize"]] %<>% locf_interp(42)
}

## Pearl millet
## ############

xx[["apy_pearl_millet"]] %<>% irr_frac_interp(xx[["irr_pearl_millet"]], 61:63, 60)
xx[["irr_pearl_millet"]] %<>% irr_frac_interp(xx[["apy_pearl_millet"]], 44:50, 43)

if (dist_nm %in% c("Ganganagar")) {
    xx[["irr_pearl_millet"]] %<>% tot_frac_interp(xx[["apy_pearl_millet"]], 25:50, 24)
}

## Pigeonpea
## #########

xx[["apy_pigeonpea"]] %<>% tot_frac_interp(xx[["irr_pigeonpea"]], 61:63, 60)
xx[["irr_pigeonpea"]] %<>% irr_frac_interp(xx[["apy_pigeonpea"]], 44:50, 43)

## Rapeseed
## ########

xx[["apy_rapeseed"]] %<>% tot_frac_interp(xx[["apy_rapeseed"]], 61:63, 60)

## Rice
## ####

xx[["apy_rice"]] %<>% tot_frac_interp(xx[["irr_rice-autumn"]], 61:63, 60)
xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice"]], 44:50, 43)

if (dist_nm %in% c("Alwar")) {
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice"]], 37, 36)
    xx[["apy_rice"]][37] = xx[["irr_rice-winter"]][37]
}

if (dist_nm %in% c("Bhilwara")) {
    xx[["irr_rice-autumn"]][21:22] = xx[["irr_rice-winter"]][21:22]
}

if (dist_nm %in% c("Bikaner")) {
    xx[["irr_rice-autumn"]][c(23:30,33:35)] = xx[["irr_rice-winter"]][c(23:30,33:35)]
}

if (dist_nm %in% c("Bundi")) {
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice"]], 30:31, 30)
    xx[["irr_rice-winter"]] = xx[["apy_rice"]]
}

if (dist_nm %in% c("Churu")) {
    xx[["apy_rice"]] = 0
}

if (dist_nm %in% c("Ganganagar")) {
    xx[["irr_rice-autumn"]] %<>% irr_frac_interp(xx[["apy_rice"]], 25:50, 51)
}

if (dist_nm %in% c("Jaisalmer")) {
    xx[["apy_rice"]] %<>% linear_interp(37)
}

if (dist_nm %in% c("Jhalawar")) {
    xx[["apy_rice"]] %<>% tot_frac_interp(xx[["irr_rice-autumn"]], 54, 53)
}

if (dist_nm %in% c("Jhunjhunun","Jodhpur","Nagaur","Pali")) {
    xx[["apy_rice"]] = 0
}

if (dist_nm %in% c("Kota")) {
    xx[["irr_rice-autumn"]][34:35] = xx[["irr_rice-winter"]][34:35]
}

xx[["irr_rice-winter"]] = xx[["irr_rice-autumn"]]

## Sesamum
## #######

xx[["apy_sesamum"]] %<>% tot_frac_interp(xx[["irr_sesamum"]], 61:63, 60)

if (dist_nm %in% c("Banswara","Bharatpur","Chittaurgaur","Dungarpur","Jhalawar","Jhunjhunun","Pali","Udaipur")) {
    xx[["apy_sesamum"]] %<>% locf_interp(61:63)
    xx[["irr_sesamum"]] %<>% locf_interp(61:63)
}

if (dist_nm %in% c("Barmer","Bhilwara","Jalor")) {
    xx[["irr_sesamum"]] %<>% linear_interp(62)
}

## Sorghum
## #######

if (is.na(xx[["irr_sorghum-kharif"]][61])) {
    xx[["irr_sorghum-kharif"]] %<>% locf_interp(61)
} else if (is.na(xx[["irr_sorghum-kharif"]][62])) {
    xx[["irr_sorghum-kharif"]] %<>% linear_interp(62)
}

xx[["apy_sorghum-kharif"]] %<>% irr_frac_interp(xx[["apy_sorghum-kharif"]], 61:63, 60)

## Soyabean
## ########

xx[["apy_soyabean"]] %<>% locf_interp(61:63)

## Sugarcane
## #########

if (is.na(xx[["irr_sugarcane-whole_year"]][61])) {
    xx[["irr_sugarcane-whole_year"]] %<>% locf_interp(61)
} else if (is.na(xx[["irr_sugarcane-whole_year"]][62])) {
    xx[["irr_sugarcane-whole_year"]] %<>% linear_interp(62)
}

xx[["apy_sugarcane-whole_year"]] %<>% irr_frac_interp(xx[["apy_sugarcane-whole_year"]], 61:63, 60)

xx[["apy_sugarcane-whole_year"]] = xx[["irr_sugarcane-whole_year"]]

## Wheat
## #####

if (is.na(xx[["irr_wheat"]][61])) {
    xx[["irr_wheat"]] %<>% locf_interp(61)
} else if (is.na(xx[["irr_wheat"]][62])) {
    xx[["irr_wheat"]] %<>% linear_interp(62)
}

xx[["apy_wheat"]] %<>% irr_frac_interp(xx[["irr_wheat"]], 61:63, 60)

if (dist_nm %in% c("Bharatpur")) {
    xx[["irr_wheat"]] %<>% irr_frac_interp(xx[["apy_wheat"]], 28, 27)
}

if (dist_nm %in% c("Churu")) {
    xx[["irr_wheat"]] %<>% irr_frac_interp(xx[["apy_wheat"]], 48:49, 47)
}

if (dist_nm %in% c("Dhaulpur")) {
    xx[["irr_wheat"]] %<>% locf_interp(44:50)
    xx[["irr_wheat"]][21:32] = xx[["irr_wheat"]][35]
}

if (dist_nm %in% c("Jhunjhunun")) {
    xx[["irr_wheat"]] %<>% irr_frac_interp(xx[["apy_wheat"]], 24, 23)
}

if (dist_nm %in% c("Sikar")) {
    xx[["apy_wheat"]] %<>% tot_frac_interp(xx[["irr_wheat"]], 30, 29)
}

