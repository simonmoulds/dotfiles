get_num_rows_to_skip = function(fn) {
    ## Identify the start of the data in MIDAS
    ## wind/prec/weather/radiation data files
    ##
    ## Args:
    ##   fn : filename (character)
    ##
    ## Returns:
    ##   integer representing the index of the last
    ##     row of metadata
    lines = readLines(fn)
    ix = grep("^data$", lines)
    if (length(ix) == 1) {
        skip = ix
    } else {
        stop()
    }
    skip
}

infill_with_mean_value = function(x, col) {
    ## Infill gaps by using the mean value for the same
    ## time point in other years
    ##
    ## Args:
    ##   x
    ##   col
    ##
    ## Returns:
    ##   x
    time_lt = as.POSIXlt(x$time)
    time_ix = time_lt$yday * 24 * 3600 + time_lt$hour * 3600
    x = cbind(x, time_ix=time_ix)
    x_mean = aggregate(x, by=list(time_ix=x$time_ix), data=x, FUN=mean, na.rm=TRUE)
    na_ix = which(is.na(x[[col]]))
    na_time_ix = x$time_ix[na_ix]
    x_mean_ix = match(na_time_ix, x_mean$time_ix)
    vals = x_mean[[col]][x_mean_ix]
    x[[col]][na_ix] = vals
    x
}

saturation_vapour_pressure_eq11 = function(temperature) {
    ## Compute saturation vapour pressure based
    ## on FAO56, equation 11
    ##
    ## Args:
    ##   temperature [degC]
    ##
    ## Returns:
    ##   eo [kPa]
    eo = 0.6108 * exp((17.27 * temperature) / (temperature + 237.3))
    eo
}

slope_saturation_vapour_pressure_curve_eq13 = function(temperature) {
    ## Compute slope of saturation vapour pressure curve
    ##
    ## Args:
    ##   temperature [degC]
    ##
    ## Returns:
    ##   Delta [kPa degC-1]
    Delta = (4098 * (0.6108 * exp((17.27 * temperature) / (temperature + 237.3)))) / ((temperature + 237.3) ** 2)
    Delta
}

actual_vapour_pressure_eq14 = function(dewpoint_temperature) {
    ea = saturation_vapour_pressure_eq11(dewpoint_temperature)
    ea
}

psychrometric_constant_eq8 = function(atmospheric_pressure) {
    ## Compute psychrometric constant
    ##
    ## Args:
    ##   atmospheric_pressure [kPa]
    ##
    ## Returns:
    ##   psychrometric_constant [kPa degC-1]
    cp = 1.013e-3                   # MJ kg-1 degC-1
    latent_heat_vaporization = 2.45 # MJ kg-1
    e = 0.622                       # -
    gamma = (
        (cp * atmospheric_pressure)
        / (e * latent_heat_vaporization)
    )    
    gamma
}

inverse_relative_distance_eq23 = function(julian_day) {
    dr = 1 + 0.033 * cos(2 * pi * julian_day / 365)
    dr
}

solar_declination_eq24 = function(julian_day) {
    delta = 0.409 * sin(((2 * pi * julian_day) / 365) - 1.39)
    delta
}

sunset_hour_angle_eq25 = function(latitude, solar_declination) {
    ws = acos(-tan(latitude) * tan(solar_declination))
    ws
}

solar_time_angle_start_eq29 = function(length_of_calculation_period, solar_time_angle_midpoint) {
    w1 = solar_time_angle_midpoint - (pi * length_of_calculation_period / 24)
    w1
}

solar_time_angle_end_eq30 = function(length_of_calculation_period, solar_time_angle_midpoint) {
    w2 = solar_time_angle_midpoint + (pi * length_of_calculation_period / 24)
    w2
}

solar_time_angle_midpoint_eq31 = function(longitude_of_tz, longitude_of_measurement_site, clock_time_at_midpoint, julian_day) {
    seasonal_correction = seasonal_correction_eq32(julian_day)
    w = pi / 12 * ((clock_time_at_midpoint + 0.06667 * (longitude_of_tz - longitude_of_measurement_site) + seasonal_correction) - 12)
    w
}

seasonal_correction_eq32 = function(julian_day) {
    b = b_eq33(julian_day)
    seasonal_correction = 0.1645 * sin(2 * b) - 0.1255 * cos(b) - 0.025 * sin(b)
    seasonal_correction
}

b_eq33 = function(julian_day) {
    b = 2 * pi * (julian_day - 81) / 364
    b
}
        
extraterrestrial_radiation_eq28 = function(latitude, julian_day, longitude_of_tz=0, longitude_of_measurement_site=0, clock_time_at_midpoint, length_of_calculation_period=1) {
    dr = inverse_relative_distance_eq23(julian_day)
    delta = solar_declination_eq24(julian_day)
    ws = sunset_hour_angle_eq25(latitude, delta)
    w = solar_time_angle_midpoint_eq31(longitude_of_tz, longitude_of_measurement_site, clock_time_at_midpoint, julian_day)
    w1 = solar_time_angle_start_eq29(length_of_calculation_period, w)
    w2 = solar_time_angle_end_eq30(length_of_calculation_period, w)
    ra = (12 * 60 / pi) * 0.0820 * dr * ((w2 - w1) * sin(latitude) * sin(delta) + cos(latitude) * cos(delta) * (sin(w2) - sin(w1)))
    ra[ra < 0] = 0
    ra
}

solar_radiation_eq35 = function(extraterrestrial_radiation, actual_duration_of_sunshine, maximum_duration_of_sunshine, a=0.25, b=0.5) {
    rs = (a + b * actual_duration_of_sunshine / maximum_duration_of_sunshine) * extraterrestrial_radiation
    rs
}

clear_sky_solar_radiation_eq36 = function(extraterrestrial_radiation, a=NA, b=NA, station_elevation=NA) {
    if (!is.na(a) & !is.na(b)) {
        rso = (a + b) * extraterrestrial_radiation
    } else if (!is.na(station_elevation)) {
        rso = (0.75 + 2e-5 * station_elevation) * extraterrestrial_radiation
    } else {
        stop()
    }
    rso
}

net_shortwave_radiation_eq38 = function(solar_radiation, albedo=0.23) {
    rns = (1 - albedo) * solar_radiation
    rns
}

get_hourly_period_2_to_3_hours_before_sunset = function(solar_time_angle_midpoint, sunset_hour_angle, solar_radiation_ratio, clear_sky_solar_radiation) {
    ## find the hourly period which is between
    ## 2-3 hours before sunset
    ## from: http://www.fao.org/3/X0490E/x0490e08.htm#eto%20calculated%20with%20different%20time%20steps
    ix = (
        (solar_time_angle_midpoint >= (sunset_hour_angle - 0.79)) &
        (solar_time_angle_midpoint <= (sunset_hour_angle - 0.52))
    )
    nighttime_ix = clear_sky_solar_radiation == 0
    nday = length(solar_radiation_ratio) / 24
    for (i in 1:(nday-1)) {
        start_ix = (i-1) * 24 + 1
        end_ix = i * 24
        night_end_ix = min(end_ix + 12, length(solar_radiation_ratio))
        sub_ix = ix[start_ix:end_ix]
        sub_nighttime_ix = nighttime_ix[(start_ix + 12):night_end_ix]
        sub_solar_radiation_ratio = solar_radiation_ratio[(start_ix + 12):night_end_ix]
        
        if (any(sub_ix)) {
            pre_sunset_ix = max(which(sub_ix))
            nighttime_ratio = sub_solar_radiation_ratio[pre_sunset_ix]
            sub_solar_radiation_ratio[sub_nighttime_ix] = nighttime_ratio
            solar_radiation_ratio[(start_ix + 12):night_end_ix] = sub_solar_radiation_ratio
        } else {
            solar_radiation_ratio[(start_ix + 12):night_end_ix] = default_nighttime_ratio
        }
    }
    solar_radiation_ratio
}

net_longwave_radiation_eq39_subdaily = function(temperature, solar_radiation, clear_sky_solar_radiation, solar_time_angle_midpoint, sunset_hour_angle, default_nighttime_ratio=0.5, actual_vapour_pressure, length_of_calculation_period=1) {
    ## Calculate net longwave radiation for subdaily period.
    ##
    ## Args:
    ##   temperature [degC]
    ##   solar_radiation [MJ m-2 T-1]
    ##   clear_sky_solar_radiation [MJ m-2 T-1]
    ##   actual_vapour_pressure [kPa]
    ##   length_of_calculation_period [hour]
    ##
    ## Returns:
    ##   net_longwave_radiation [MJ m-2 T-1]
    temperature_kelvin = temperature + 273.15
    solar_radiation_ratio = (
        solar_radiation /
        clear_sky_solar_radiation
    )

    solar_radiation_ratio[!is.finite(solar_radiation_ratio)] = NA
    solar_radiation_ratio = get_hourly_period_2_to_3_hours_before_sunset(solar_time_angle_midpoint, sunset_hour_angle, solar_radiation_ratio, clear_sky_solar_radiation)
    
    solar_radiation_ratio[is.na(solar_radiation_ratio)] = default_nighttime_ratio
    
    sigma = 4.903e-9 # MJ K-4 m-2 day-1
    sigma = sigma / (24 / length_of_calculation_period) # MJ K-4 m-2 T-1
    net_longwave_radiation = sigma * (temperature_kelvin ** 4) * (0.34 - 0.14 * actual_vapour_pressure ** 0.5) * (1.35 * solar_radiation_ratio - 0.35)
    net_longwave_radiation
}

net_radiation_eq40 = function(net_shortwave_radiation, net_longwave_radiation) {
    net_radiation = net_shortwave_radiation - net_longwave_radiation
    net_radiation
}


wind_speed_eq47 = function(wind_speed, z) {
    ## Calculate wind speed at 2m
    ##
    ## Args:
    ##   wind_speed [m s-1]
    ##   z [height at which wind speed was measured, m]
    ##
    ## Returns:
    ##   wind_speed_2m [m s-1]
    wind_speed_2m = wind_speed * (4.87 / (log(67.8 * z - 5.42)))
    wind_speed_2m
}

hourly_reference_et_eq53 = function(saturation_slope_vapour_pressure_curve, net_radiation, soil_heat_flux=0, psychrometric_constant, temperature, saturation_vapour_pressure, actual_vapour_pressure, wind_speed) {
    ## Calculate reference evapotranspiration at hourly
    ## time step
    ##
    ## Args:
    ## saturation_slope_vapour_pressure_curve [kPa degC-1]
    ## net_radiation [MJ m-2 hour-1]
    ## soil_heat_flux [MJ m-2 hour-1]
    ## psychrometric_constant [kPa degC-1]
    ## temperature [degC]
    ## saturation_vapour_pressure [kPa]
    ## actual_vapour_pressure [kPa]
    ## wind_speed [m s-1]
    ##
    ## Returns:
    ## eto [mm hour-1]
    eto = (0.408 * saturation_slope_vapour_pressure_curve * (net_radiation - soil_heat_flux) + psychrometric_constant * (37 / (temperature + 273)) * wind_speed * (saturation_vapour_pressure - actual_vapour_pressure)) / (saturation_slope_vapour_pressure_curve + psychrometric_constant * (1 + 0.34 * wind_speed))
    eto[eto < 0] = 0
    eto
}
