            fs = list.files("data/output_2005/seasonal_maps", pattern=paste0("INDIA_[A-Z]+_", toupper(crop), "_.*_", yr, ".tif$"), full.names=TRUE)
            st = stack(fs)
            out = data.frame(st[pts] * frac)
            out
        }

        myfun2 = function(crop, water, years, pts, dist_frac) {
            seasons = c("KHARIF","RABI","SUMMER","WHOLE_YEAR")
            frac = lapply(1:length(seasons), FUN=function(ix) rep(NA, length(years)))
            for (i in 1:length(years)) {
