        ## get district frac (data/district_frac)
        dist_frac_map = raster(file.path("data", "district_frac_1960", paste0("dist_", dists[j], "_frac1_ll.tif")))
        dist_frac_pts = as(dist_frac_map, "SpatialPoints")

        myfun7 = function(maps, pts) {
            st = stack(maps)
            vals = st[dist_frac_pts] %>% colSums(na.rm=TRUE) %>% unname
            vals
        }

        for (k in 1:length(maps)) {
            colnm = names(maps)[k]
            yy[[colnm]][21:61] = myfun7(maps[[colnm]], dist_frac_pts)
        }
        
        ## put back
        y[row_ix,] = yy
    }
