myfun4 = function(x, crop, yrs) {
    ## Function to calculate the total area allocated to a
    ## particular crop
    cols = grep(crop, names(x))
    xx = cbind(x[,1:5], data.frame(total=rowSums(x[,cols], na.rm=TRUE))) %>% group_by(Year) %>% summarize_at(vars(total), funs(sum(., na.rm=TRUE)))
    yrs = paste0(yrs, "-", substr(yrs + 1, 3, 4))
    res = xx[["total"]][xx$Year %in% yrs]
    res
}

