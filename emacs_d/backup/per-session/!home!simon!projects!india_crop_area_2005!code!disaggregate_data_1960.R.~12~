                    if (col %in% names(vals)) {
                        f = mean(vals[[col]] / total, na.rm=TRUE)
                        frac[[j]][i] = ifelse(is.nan(f),0,f)
                    } else {
                        frac[[j]][i] = 0
                    }
                }
            }    
            names(frac) = toupper(seasons)
            frac
        }
                    
