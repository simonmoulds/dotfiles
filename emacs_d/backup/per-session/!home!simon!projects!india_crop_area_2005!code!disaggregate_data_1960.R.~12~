get_faostat = function(x, crop, yrs=1961:2016) {
    if (!crop %in% x$Item) stop("Crop not found")
    ix = which(x$Item %in% crop)
    cols = paste0("Y", yrs)
    y = x[ix,names(x) %in% cols] %>% as.numeric %>% unname
    ## y = y / 100
    y
}

