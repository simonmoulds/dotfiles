myfun5 = function(crop, template, ts, alloc_ts, yrs, ...) {

    ## load files for specific crop
    ptn = paste0("^INDIA_(RAIN|IRR)_(", toupper(crop), ")_(KHARIF|RABI|SUMMER|WHOLE_YEAR)_2005.tif$")
    fs = list.files("data/output_2005/seasonal_maps", ptn, full.names=TRUE)
    if (length(fs) == 0) stop()
    st = stack(fs)
    nms = names(st)
    basenm = gsub(paste0("(INDIA)_(IRR|RAIN)_(", toupper(crop), ")_(KHARIF|RABI|SUMMER|WHOLE_YEAR)_([0-9]{4})"), "\\1_\\2_\\3_\\4", nms)
    water_src = gsub(paste0("(INDIA)_(IRR|RAIN)_(", toupper(crop), ")_(KHARIF|RABI|SUMMER|WHOLE_YEAR)_([0-9]{4})"), "\\2", nms)
    crop_nm = gsub(paste0("(INDIA)_(IRR|RAIN)_(", toupper(crop), ")_(KHARIF|RABI|SUMMER|WHOLE_YEAR)_([0-9]{4})"), "\\3", nms)
    season = gsub(paste0("(INDIA)_(IRR|RAIN)_(", toupper(crop), ")_(KHARIF|RABI|SUMMER|WHOLE_YEAR)_([0-9]{4})"), "\\4", nms)
    colnms = tolower(paste0(water_src, "_", crop_nm, "-", season))
        
    ## scale time series to 2005 total
    x_2005 = ts[yrs %in% 2005]
    sf = sum(cellStats(st, stat=sum)) / x_2005
    ts = (ts * sf) - alloc_ts
    ts[ts < 0] = 0

    ## generate maps
    st = st * template
    ## tot = stackApply(st, indices=rep(1, nlayers(st)), fun=sum)
    if (length(ts) != length(yrs)) stop()
    frac = st / sum(cellStats(st, stat=sum))
    if (nlayers(frac) > 1) {
        frac = unstack(frac)
    } else {
        frac = list(frac)
    }
    
    maps = vector(mode="list", length=length(frac))
    for (i in 1:length(frac)) {
        maps[[i]] = vector(mode="list", length=length(ts))
        for (j in 1:length(yrs)) {
            nm = paste0(basenm[i], "_", yrs[j], "_a")
            maps[[i]][[j]] = frac[[i]] * ts[j]
            names(maps[[i]][[j]]) = nm
        }
    }
    names(maps) = colnms
    maps
}

