#!/bin/bash

wd=/home/simon/dev/gandak_data_model/data-raw

# extract data
exd=$wd/data/india_village_level_geospatial_socio_econ
if [ ! -d $exd ]
then
    mkdir $exd
    unzip -o $wd/data/india-india-village-level-geospatial-socio-econ-1991-2001-br-2001-shp.zip -d $exd
    unzip -o $wd/data/india-india-village-level-geospatial-socio-econ-1991-2001-up-1991-shp.zip -d $exd
fi

# ogr2ogr -t_srs EPSG:4326 $exd/india-village-census-2001-BR_ll.shp $exd/india-village-census-2001-BR.shp -t_srs EPSG:4326

# create location from file
if [ ! -d /home/simon/grassdata/utm44n ]
then
    grass -c -e $exd/india-village-census-2001-BR.shp /home/simon/grassdata/utm44n
fi

chmod u+x $wd/mygrassjob.sh
export GRASS_BATCH_JOB=$wd/mygrassjob.sh
grass $HOME/grassdata/utm44n/PERMANENT
unset GRASS_BATCH_JOB
