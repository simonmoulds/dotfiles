import os
import time
import ee
import gdal
import re

# Initialize the Earth Engine module.
ee.Initialize()

# Define region:
# # Test region:
# region = ee.Geometry.Rectangle(78.5, 27.5, 78.75, 27.75);

# Poopo region, + buffer of 1/2 degree:
xmin, ymin, xmax, ymax = -70.9250, -20.1250, -66.3250, -14.0250
xmin -= 0.5
ymin -= 0.5
xmax += 0.5
ymax += 0.5
region = ee.Geometry.Rectangle(xmin, ymin, xmax, ymax)
res = 1./120
ncol = int((xmax-xmin) / res)
nrow = int((ymax-ymin) / res)

dataset = \
    ee.ImageCollection("MODIS/NTSG/MOD16A2/105") \
      .filter(ee.Filter.date('2001-01-01', '2020-01-01'))
et = dataset.select('ET');

count = dataset.size()
print(count.getInfo())
et_list = et.toList(count)

tasks = []
for i in range(count.getInfo()):
    img = ee.Image(et_list.get(i))
    id = re.sub('/','_',img.get('system:id').getInfo())    
    task = ee.batch.Export.image.toDrive(
        image = img,        
        description = id,
        scale = 1000,
        crs='EPSG:4326',
        region = region.getInfo()['coordinates'],
        maxPixels = 2e9,
        fileFormat='GeoTIFF',
        folder='earthengine'
    )
    task.start()
    tasks.append(task)

# ######################################################### #
# Download to local computer using rclone                   #
# ######################################################### #

def get_status(tasks):
    """Retrieve GEE task status."""
    return [task.status() for task in tasks]

def all_tasks_completed(tasks):
    """Check whether tasks are completed."""
    status = get_status(tasks)
    return all([((st['state'] == 'COMPLETED') | (st['state'] == 'FAILED')) for st in status])

# This polls Earth Engine to see if all tasks are complete,
# and prevents the script from advancing until they are
while not all_tasks_completed(tasks):
    status = get_status(tasks)
    completed = [1 for st in status if st == 'COMPLETED']
    print(str(sum(completed)) + ' / ' + str(len(status)) + ' completed')
    # print([st['state'] for st in status])
    time.sleep(10)

